  <script>
    lucide.createIcons();

    // Elements
    const form = document.getElementById('solver-form');
    const stateIdle = document.getElementById('ui-state-idle');
    const stateProcessing = document.getElementById('ui-state-processing');
    const stateOutput = document.getElementById('ui-state-output');
    
    const notebookCanvas = document.getElementById('notebook-canvas');
    const problemStatementTitle = document.getElementById('problem-statement-title');
    const mainHeader = document.getElementById('main-header');
    const rotationBanner = document.getElementById('rotation-banner');

    const selectionPopover = document.getElementById('selection-popover');
    const btnAskSelection = document.getElementById('btn-ask-selection');
    const doubtInput = document.getElementById('doubt-input');
    const doubtForm = document.getElementById('doubt-form');
    const doubtLoader = document.getElementById('doubt-loader');
    const doubtResponseCanvas = document.getElementById('doubt-response-canvas');

    const btnDownloadPdf = document.getElementById('btn-download-pdf');
    const btnShare = document.getElementById('btn-share');
    const btnReset = document.getElementById('btn-reset');
    const btnPrint = document.getElementById('btn-print');
    const btnExportImage = document.getElementById('btn-export-image');
    const btnStar = document.getElementById('btn-star');
    const btnCopyAll = document.getElementById('btn-copy-all');
    
    const btnFontInc = document.getElementById('btn-font-inc');
    const btnFontDec = document.getElementById('btn-font-dec');

    const btnNotesToggle = document.getElementById('btn-notes-toggle');
    const notesPanel = document.getElementById('notes-panel');
    const btnNotesClose = document.getElementById('btn-notes-close');
    const notesTextarea = document.getElementById('notes-textarea');
    const btnNotesSave = document.getElementById('btn-notes-save');
    const btnNotesClear = document.getElementById('btn-notes-clear');

    const historyToggle = document.getElementById('history-toggle');
    const historySection = document.getElementById('history-section');
    const historyList = document.getElementById('history-list');

    const shortcutsBtn = document.getElementById('shortcuts-btn');
    const shortcutsModal = document.getElementById('shortcuts-modal');
    const shortcutsModalClose = document.getElementById('shortcuts-modal-close');
    const shortcutsToast = document.getElementById('shortcuts-toast');

    let currentSolutionContext = null;
    let selectedTextTemp = '';
    let solutionHistory = JSON.parse(localStorage.getItem('boardalgo_history') || '[]');

    // Font Size
    let currentFontSize = 1;
    if (window.innerWidth >= 640) currentFontSize = 1.25;

    btnFontInc.addEventListener('click', () => {
        if(currentFontSize < 2.0) currentFontSize += 0.1;
        notebookCanvas.style.fontSize = `${currentFontSize}rem`;
        showToast('Font size increased');
    });
    btnFontDec.addEventListener('click', () => {
        if(currentFontSize > 0.7) currentFontSize -= 0.1;
        notebookCanvas.style.fontSize = `${currentFontSize}rem`;
        showToast('Font size decreased');
    });

    // Toast notification
    function showToast(message) {
      shortcutsToast.querySelector('#shortcut-text').textContent = message;
      shortcutsToast.classList.add('show');
      setTimeout(() => {
        shortcutsToast.classList.remove('show');
      }, 2000);
    }

    // Keyboard Shortcuts Modal
    shortcutsBtn.addEventListener('click', () => {
      shortcutsModal.classList.remove('hidden');
    });

    shortcutsModalClose.addEventListener('click', () => {
      shortcutsModal.classList.add('hidden');
    });

    shortcutsModal.addEventListener('click', (e) => {
      if (e.target === shortcutsModal) {
        shortcutsModal.classList.add('hidden');
      }
    });

    // Keyboard Shortcuts
    document.addEventListener('keydown', (e) => {
      // Ctrl+Enter - Submit form
      if (e.ctrlKey && e.key === 'Enter' && !stateIdle.classList.contains('hidden')) {
        e.preventDefault();
        form.dispatchEvent(new Event('submit'));
      }
      
      // Ctrl+N - New question
      if (e.ctrlKey && e.key === 'n') {
        e.preventDefault();
        btnReset.click();
      }
      
      // Ctrl+D - Download PDF
      if (e.ctrlKey && e.key === 'd' && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnDownloadPdf.click();
      }
      
      // Ctrl+P - Print
      if (e.ctrlKey && e.key === 'p' && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnPrint.click();
      }
      
      // Ctrl+C - Copy all (when not in input)
      if (e.ctrlKey && e.key === 'c' && !stateOutput.classList.contains('hidden') && 
          !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault();
        btnCopyAll.click();
      }
      
      // N - Notes
      if (e.key === 'n' && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName) && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnNotesToggle.click();
      }
      
      // S - Star
      if (e.key === 's' && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName) && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnStar.click();
      }
      
      // + - Increase font
      if ((e.key === '+' || e.key === '=') && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName) && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnFontInc.click();
      }
      
      // - - Decrease font
      if (e.key === '-' && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName) && !stateOutput.classList.contains('hidden')) {
        e.preventDefault();
        btnFontDec.click();
      }
      
      // T - Toggle theme
      if (e.key === 't' && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault();
        document.getElementById('theme-toggle').click();
      }
      
      // ? - Show shortcuts
      if (e.key === '?' && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault();
        shortcutsModal.classList.remove('hidden');
      }
      
      // Escape - Close modals
      if (e.key === 'Escape') {
        shortcutsModal.classList.add('hidden');
        notesPanel.classList.remove('open');
      }
    });

    // Rotation Check
    function checkRotation() {
        if (!stateOutput.classList.contains('hidden')) {
            if (window.innerWidth < 768 && window.innerHeight > window.innerWidth) {
                const hasTable = notebookCanvas.querySelector('table');
                if (hasTable) {
                    rotationBanner.classList.remove('hidden');
                } else {
                    rotationBanner.classList.add('hidden');
                }
            } else {
                rotationBanner.classList.add('hidden');
            }
        }
    }
    window.addEventListener('resize', checkRotation);

    function switchState(hideElem, showElem){
      hideElem.classList.replace('opacity-100','opacity-0');
      setTimeout(()=>{
        hideElem.classList.add('hidden'); hideElem.classList.remove('flex');
        showElem.classList.remove('hidden'); showElem.classList.add('flex');
        void showElem.offsetWidth;
        showElem.classList.replace('opacity-0','opacity-100');
        if(showElem === stateOutput) {
          checkRotation();
          historyToggle.classList.remove('hidden');
        }
      }, 300);
    }

    // Breathing Exercise
    let breatheInterval, factInterval;

    function startBreathingExercise() {
      const circle = document.getElementById('breathe-circle');
      const text = document.getElementById('breathe-text');
      const factText = document.getElementById('loading-fact');
      
      const facts = [
        "Analyzing CBSE patterns...",
        "Structuring solution logic...",
        "Calibrating equations...",
        "Formatting for boards...",
        "Finalizing answer..."
      ];
      let factIndex = 0;
      factText.textContent = facts[0];
      
      factInterval = setInterval(() => {
        factIndex = (factIndex + 1) % facts.length;
        factText.textContent = facts[factIndex];
      }, 4000);

      const phases = [
        { scale: 'scale-[1.5]', text: 'Breathe In', duration: 'duration-[4000ms]' },
        { scale: 'scale-[1.5]', text: 'Hold', duration: 'duration-[4000ms]' },
        { scale: 'scale-[0.5]', text: 'Exhale', duration: 'duration-[4000ms]' },
        { scale: 'scale-[0.5]', text: 'Rest', duration: 'duration-[4000ms]' }
      ];
      
      let phaseIndex = 0;
      
      function runPhase() {
        const phase = phases[phaseIndex];
        circle.className = `absolute inset-0 bg-brand-primary/20 rounded-full border-2 border-brand-primary transition-all ease-in-out ${phase.duration} ${phase.scale}`;
        text.textContent = phase.text;
        phaseIndex = (phaseIndex + 1) % phases.length;
      }
      
      runPhase();
      breatheInterval = setInterval(runPhase, 4000);
    }

    function stopBreathingExercise() {
      clearInterval(breatheInterval);
      clearInterval(factInterval);
    }

    // Render Steps
    function renderSteps(steps) {
      notebookCanvas.innerHTML = '';
      
      steps.forEach((step, idx) => {
        let inkClass = 'ink-black';
        if (step.ink === 'blue') inkClass = 'ink-blue';
        if (step.ink === 'red') inkClass = 'ink-red';
        if (step.ink === 'green') inkClass = 'ink-green';

        const stepDiv = document.createElement('div');
        stepDiv.className = `w-full step-wrapper ${inkClass}`;

        if (step.text) {
          const textSpan = document.createElement('span');
          textSpan.textContent = step.text + " ";
          stepDiv.appendChild(textSpan);
        }

        if (step.latex) {
          const mathSpan = document.createElement('div');
          try {
            let cleanLatex = step.latex.replace(/\$\$/g, '').trim();
            if(!cleanLatex.includes('\\') && !cleanLatex.includes('^') && cleanLatex.length > 10) {
              cleanLatex = cleanLatex.replace(/ /g, '\\ ');
            }

            katex.render(cleanLatex, mathSpan, {
              displayMode: true,
              throwOnError: false,
              strict: false
            });
            stepDiv.appendChild(mathSpan);
          } catch (e) {
            mathSpan.textContent = step.latex;
            mathSpan.className = "break-all font-mono text-sm mt-1";
            stepDiv.appendChild(mathSpan);
          }
        }
        notebookCanvas.appendChild(stepDiv);
      });
      
      checkRotation();
    }

    // NEW: Copy All Solution
    btnCopyAll.addEventListener('click', () => {
      const text = notebookCanvas.innerText;
      navigator.clipboard.writeText(text).then(() => {
        const tooltip = btnCopyAll.querySelector('.copy-tooltip');
        tooltip.classList.add('show');
        setTimeout(() => {
          tooltip.classList.remove('show');
        }, 2000);
        showToast('Solution copied to clipboard');
      });
    });

    // Star/Favorite
    btnStar.addEventListener('click', () => {
      const icon = btnStar.querySelector('i');
      btnStar.classList.toggle('active');
      
      if(icon.getAttribute('fill') === 'currentColor') {
        icon.setAttribute('fill', 'none');
        btnStar.classList.remove('text-amber-500');
        showToast('Removed from favorites');
      } else {
        icon.setAttribute('fill', 'currentColor');
        btnStar.classList.add('text-amber-500');
        showToast('Added to favorites');
      }
    });

    // Print Mode
    btnPrint.addEventListener('click', () => {
      window.print();
    });

    // Export as Image
    btnExportImage.addEventListener('click', async () => {
      const elementToExport = document.getElementById('pdf-export-container');
      const originalText = btnExportImage.innerHTML;
      btnExportImage.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Exporting...';
      lucide.createIcons();

      try {
        const canvas = await html2canvas(elementToExport, {
          scale: 2,
          useCORS: true,
          logging: false,
          backgroundColor: '#fdfcf0',
          windowWidth: 1200,
        });

        canvas.toBlob((blob) => {
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'BoardAlgo-Solution.png';
          a.click();
          URL.revokeObjectURL(url);
          showToast('Image exported successfully');
        }, 'image/png');

      } catch (error) {
        console.error('Export failed:', error);
        alert('Export failed. Please try again.');
      } finally {
        btnExportImage.innerHTML = originalText;
        lucide.createIcons();
      }
    });

    // Notes Panel
    btnNotesToggle.addEventListener('click', () => {
      notesPanel.classList.add('open');
    });

    btnNotesClose.addEventListener('click', () => {
      notesPanel.classList.remove('open');
    });

    // Save Notes (POST + localStorage)
    btnNotesSave.addEventListener('click', async () => {
      const notes = notesTextarea.value.trim();
      if (!notes) return;

      localStorage.setItem('boardalgo_notes', notes);

      try {
        const response = await fetch('/api/save-notes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            notes: notes,
            questionId: currentSolutionContext?.problem_statement || 'unknown',
            timestamp: new Date().toISOString()
          })
        });

        if (response.ok) {
          showToast('✓ Notes saved (local + server)');
        } else {
          showToast('✓ Notes saved locally');
        }
      } catch (error) {
        console.error('Server save failed:', error);
        showToast('✓ Notes saved locally');
      }
    });

    btnNotesClear.addEventListener('click', () => {
      if (confirm('Clear all notes?')) {
        notesTextarea.value = '';
      }
    });

    // Load saved notes
    const savedNotes = localStorage.getItem('boardalgo_notes');
    if (savedNotes) {
      notesTextarea.value = savedNotes;
    }

    // History Management
    function addToHistory(question, solution) {
      const historyItem = {
        id: Date.now(),
        question: question.substring(0, 80) + '...',
        timestamp: new Date().toISOString(),
        solution: solution
      };
      
      solutionHistory.unshift(historyItem);
      if (solutionHistory.length > 10) solutionHistory.pop();
      
      localStorage.setItem('boardalgo_history', JSON.stringify(solutionHistory));
      renderHistory();
    }

    function renderHistory() {
      historyList.innerHTML = '';
      
      if (solutionHistory.length === 0) {
        historySection.classList.add('hidden');
        return;
      }
      
      historySection.classList.remove('hidden');
      
      solutionHistory.forEach(item => {
        const div = document.createElement('div');
        div.className = 'history-card p-3 bg-slate-50 dark:bg-slate-800 rounded-lg cursor-pointer';
        div.innerHTML = `
          <div class="text-sm font-medium text-slate-900 dark:text-white mb-1 line-clamp-1">${item.question}</div>
          <div class="text-xs text-slate-500">${new Date(item.timestamp).toLocaleString()}</div>
        `;
        div.onclick = () => {
          currentSolutionContext = item.solution;
          if (item.solution.problem_statement) {
            problemStatementTitle.textContent = item.solution.problem_statement;
          }
          if (item.solution.steps) {
            renderSteps(item.solution.steps);
          }
          switchState(stateIdle, stateOutput);
          mainHeader.classList.add('hidden');
        };
        historyList.appendChild(div);
      });
    }

    historyToggle.addEventListener('click', () => {
      historySection.classList.toggle('hidden');
    });

    renderHistory();

    // Generate Solution
    form.addEventListener('submit', async (ev)=>{
      ev.preventDefault();
      switchState(stateIdle, stateProcessing);
      mainHeader.classList.add('hidden');
      startBreathingExercise();

      const payload = { question: document.getElementById('problem-input').value };

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const json = await res.json();
        
        currentSolutionContext = json;
        
        if(json.problem_statement) {
          problemStatementTitle.textContent = json.problem_statement;
        }

        if (json.steps && Array.isArray(json.steps)) {
          stopBreathingExercise();
          switchState(stateProcessing, stateOutput);
          renderSteps(json.steps);
          addToHistory(payload.question, json);
          
          // Set metadata
          const difficulty = json.difficulty || 'Medium';
          const difficultyBadge = document.querySelector('.difficulty-badge');
          difficultyBadge.textContent = difficulty;
          difficultyBadge.className = `difficulty-badge px-2 py-0.5 rounded text-white text-xs font-bold difficulty-${difficulty.toLowerCase()}`;
          
          document.getElementById('solve-time').innerHTML = `Est. Time: <strong class="text-brand-primary">${json.estimated_time || '12 min'}</strong>`;
          document.getElementById('subject-name').textContent = json.subject || 'Mathematics';
          
        } else {
          notebookCanvas.innerHTML = `<div class="ink-red font-bold p-4">Error: Invalid response.</div>`;
          stopBreathingExercise();
          switchState(stateProcessing, stateOutput);
        }

      } catch (err) {
        console.error(err);
        alert('Connection failed. Please check logs.');
        stopBreathingExercise();
        switchState(stateProcessing, stateIdle);
        mainHeader.classList.remove('hidden');
      }
    });

    // Reset
    btnReset.addEventListener('click', ()=>{
      form.reset();
      switchState(stateOutput, stateIdle);
      mainHeader.classList.remove('hidden');
      rotationBanner.classList.add('hidden');
      historyToggle.classList.add('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Selection to Doubt
    document.addEventListener('mouseup', handleSelection);
    document.addEventListener('touchend', handleSelection);

    function handleSelection(e) {
      setTimeout(() => { 
        const selection = window.getSelection();
        const text = selection.toString().trim();
        
        if(text.length > 0 && selection.rangeCount > 0 && notebookCanvas.contains(selection.anchorNode)) {
          selectedTextTemp = text;
          const range = selection.getRangeAt(0);
          const rect = range.getBoundingClientRect();
          
          const scrollY = window.scrollY || document.documentElement.scrollTop;
          const scrollX = window.scrollX || document.documentElement.scrollLeft;
          
          selectionPopover.style.display = 'block';
          selectionPopover.style.top = `${rect.top + scrollY - 5}px`;
          selectionPopover.style.left = `${rect.left + scrollX + (rect.width/2)}px`;
        } else if (!selectionPopover.contains(e.target)) {
          selectionPopover.style.display = 'none';
          selectedTextTemp = '';
        }
      }, 10);
    }

    btnAskSelection.addEventListener('click', (e) => {
      e.preventDefault();
      if(selectedTextTemp) {
        doubtInput.value = `Regarding: "${selectedTextTemp}"\nMy doubt is: `;
        selectionPopover.style.display = 'none';
        document.getElementById('doubt-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => {
          doubtInput.focus();
          const val = doubtInput.value;
          doubtInput.value = '';
          doubtInput.value = val;
        }, 500);
      }
    });

    // PERFECT Doubt Solver with HTML + LaTeX Support
    doubtForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const doubtVal = doubtInput.value.trim();
      if(!doubtVal) return;

      doubtForm.classList.add('hidden');
      doubtResponseCanvas.classList.add('hidden');
      doubtLoader.classList.remove('hidden');
      doubtLoader.classList.add('flex');

      try {
        const mainQuestionText = problemStatementTitle.textContent;
        const mainAnswerText = notebookCanvas.innerText;

        const payload = {
          doubt: doubtVal,
          highlightedText: selectedTextTemp || "",
          solutionContext: currentSolutionContext,
          mainQuestion: mainQuestionText,
          mainAnswer: mainAnswerText
        };

        const res = await fetch(doubtForm.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        
        const result = await res.json();
        const rawAnswer = result.answer || result.output || "Unexpected response.";
        
        // PERFECT: Render HTML + LaTeX
        doubtResponseCanvas.innerHTML = '';
        renderHTMLWithLatex(rawAnswer, doubtResponseCanvas);

      } catch (error) {
        doubtResponseCanvas.innerHTML = '<span class="text-red-600 font-bold">Failed to fetch doubt.</span>';
      } finally {
        doubtLoader.classList.add('hidden');
        doubtLoader.classList.remove('flex');
        doubtForm.classList.remove('hidden');
        doubtInput.value = '';
        doubtResponseCanvas.classList.remove('hidden');
      }
    });

    // PERFECT: Render HTML + LaTeX together
    function renderHTMLWithLatex(htmlText, container) {
      // First, create a temporary div to parse HTML
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = htmlText;
      
      // Process text nodes for LaTeX
      function processNode(node) {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent;
          const parts = text.split(/(\$\$[\s\S]+?\$\$|\$[^$]+?\$)/g);
          
          if (parts.length > 1) {
            const fragment = document.createDocumentFragment();
            
            parts.forEach(part => {
              if (part.startsWith('$$') && part.endsWith('$$')) {
                // Display math
                const latex = part.slice(2, -2);
                const mathSpan = document.createElement('div');
                try {
                  katex.render(latex, mathSpan, { displayMode: true, throwOnError: false });
                } catch (e) {
                  mathSpan.textContent = part;
                }
                fragment.appendChild(mathSpan);
              } else if (part.startsWith('$') && part.endsWith('$')) {
                // Inline math
                const latex = part.slice(1, -1);
                const mathSpan = document.createElement('span');
                try {
                  katex.render(latex, mathSpan, { displayMode: false, throwOnError: false });
                } catch (e) {
                  mathSpan.textContent = part;
                }
                fragment.appendChild(mathSpan);
              } else if (part) {
                // Regular text
                fragment.appendChild(document.createTextNode(part));
              }
            });
            
            node.parentNode.replaceChild(fragment, node);
          }
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          // Recursively process child nodes
          Array.from(node.childNodes).forEach(child => processNode(child));
        }
      }
      
      // Process all nodes in the temp div
      Array.from(tempDiv.childNodes).forEach(child => processNode(child));
      
      // Move processed content to container
      while (tempDiv.firstChild) {
        container.appendChild(tempDiv.firstChild);
      }
    }

    // PERFECT PDF with Clickable Watermark
    btnDownloadPdf.addEventListener('click', async () => {
      const elementToPrint = document.getElementById('pdf-export-container');
      const watermark = document.getElementById('pdf-watermark');
      
      watermark.classList.remove('hidden');
      watermark.classList.add('block');

      const originalFontSize = notebookCanvas.style.fontSize;
      notebookCanvas.style.fontSize = '1rem';

      const originalText = btnDownloadPdf.innerHTML;
      btnDownloadPdf.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Generating...';
      lucide.createIcons();

      try {
        const canvas = await html2canvas(elementToPrint, {
          scale: 2,
          useCORS: true,
          logging: false,
          backgroundColor: '#fdfcf0',
          windowWidth: 1200,
          windowHeight: elementToPrint.scrollHeight,
        });

        const imgData = canvas.toDataURL('image/jpeg', 1.0);
        const imgWidth = 210;
        const pageHeight = 297;
        const imgHeight = (canvas.height * imgWidth) / canvas.width;
        
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF('p', 'mm', 'a4');
        
        let heightLeft = imgHeight;
        let position = 0;

        pdf.addImage(imgData, 'JPEG', 0, position, imgWidth, imgHeight);
        heightLeft -= pageHeight;

        while (heightLeft > 0) {
          position = heightLeft - imgHeight;
          pdf.addPage();
          pdf.addImage(imgData, 'JPEG', 0, position, imgWidth, imgHeight);
          heightLeft -= pageHeight;
        }

        // Add clickable link
        const pageCount = pdf.internal.getNumberOfPages();
        pdf.setPage(pageCount);
        pdf.setFontSize(10);
        pdf.setTextColor(108, 43, 217);
        pdf.textWithLink('BoardAlgo.in', 85, pageHeight - 10, { url: 'https://boardalgo.in' });

        pdf.save('BoardAlgo-Solution.pdf');
        showToast('PDF downloaded successfully');

      } catch (error) {
        console.error('PDF generation failed:', error);
        alert('PDF generation failed. Please try again.');
      } finally {
        btnDownloadPdf.innerHTML = originalText;
        lucide.createIcons();
        watermark.classList.add('hidden');
        watermark.classList.remove('block');
        notebookCanvas.style.fontSize = originalFontSize;
      }
    });

    // Share
    btnShare.addEventListener('click', async () => {
      const title = problemStatementTitle.textContent;
      const url = window.location.href;
      if (navigator.share) {
        try { 
          await navigator.share({ 
            title: 'BoardAlgo Solution', 
            text: title, 
            url: url 
          }); 
          showToast('Shared successfully');
        } catch (err) {}
      } else {
        navigator.clipboard.writeText(`${title} - ${url}`);
        showToast('Link copied to clipboard');
      }
    });

    // Theme Toggle
    const themeToggleBtn = document.getElementById('theme-toggle');
    const htmlElement = document.documentElement;
    themeToggleBtn.addEventListener('click', ()=>{ 
      htmlElement.classList.toggle('dark'); 
      updateThreeJSColors(); 
    });

    // Three.js Background
    let scene, camera, renderer, grid;
    function initThreeJS(){
      const container = document.getElementById('canvas-container');
      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
      camera.position.set(0,3,10); 
      camera.rotation.x = -0.2;
      renderer = new THREE.WebGLRenderer({ alpha:true, antialias:true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      const gridGeo = new THREE.PlaneGeometry(200,200,60,60);
      const gridMat = new THREE.MeshBasicMaterial({ 
        color:0x6C2BD9, 
        wireframe:true, 
        transparent:true, 
        opacity:0.08 
      });
      grid = new THREE.Mesh(gridGeo, gridMat);
      grid.rotation.x = -Math.PI/2; 
      scene.add(grid);

      updateThreeJSColors();

      let time = 0;
      function animate(){
        requestAnimationFrame(animate);
        time += 0.002;
        grid.position.z = (time*10) % 5;
        const positions = gridGeo.attributes.position;
        for(let i=0;i<positions.count;i++) {
          positions.setZ(i, Math.sin(i/5 + time*5) * 0.2);
        }
        positions.needsUpdate = true;
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', ()=>{
        camera.aspect = window.innerWidth/window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      });
    }
    
    function updateThreeJSColors(){
      if(!scene) return;
      const isDark = htmlElement.classList.contains('dark');
      scene.fog = new THREE.FogExp2(isDark ? 0x020617 : 0xF9FAFB, 0.04);
    }
    initThreeJS();

    
    document.addEventListener("DOMContentLoaded", function(){

   if(savedSolution){

      currentSolutionContext = savedSolution;

      problemStatementTitle.textContent =
      savedSolution.initial_ai_response.problem_statement;

      renderSteps(
         savedSolution.initial_ai_response.steps
      );

      switchState(stateIdle, stateOutput);

      mainHeader.classList.add("hidden");

   }

});


  </script>
  
  <script src="/js/tracking.js" defer></script>
</body>
