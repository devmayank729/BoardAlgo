<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>BoardAlgo | Elite Step-by-Step Solver</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&family=Kalam:wght@400;700&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: {
              primary: '#6C2BD9',
              accent: '#16A34A',
              dark: '#020617',
              surface: '#0f172a',
              paper: '#fdfcf0',
              stickynote: '#fff7d1'
            }
          },
          fontFamily: {
            sans: ['Inter','sans-serif'],
            display: ['Poppins','sans-serif'],
            handwriting: ['Kalam', 'cursive']
          },
          boxShadow: {
            'glow-primary': '0 0 20px rgba(108, 43, 217, 0.5)',
            'paper': '0 10px 40px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05)',
          }
        }
      }
    }
  </script>

  <style>
    body { overflow-x: hidden; transition: background-color .3s ease, color .3s ease; }
    #canvas-container { position: fixed; top:0; left:0; width:100vw; height:100vh; z-index:0; pointer-events:none; }
    
    .hud-panel { background: rgba(15,23,42,.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border:1px solid rgba(255,255,255,.1); box-shadow:0 8px 32px 0 rgba(0,0,0,.3); }
    html:not(.dark) .hud-panel { background: rgba(255,255,255,.95); border:1px solid rgba(0,0,0,.1); box-shadow: 0 8px 32px 0 rgba(0,0,0,.05); }

    /* =========================================
       TRUE 100% WIDTH NOTEBOOK CSS
       ========================================= */
    .notebook-paper {
      background-color: #fdfcf0;
      background-image: 
        linear-gradient(90deg, transparent 40px, #ff8a8a 40px, #ff8a8a 42px, transparent 42px),
        linear-gradient(#cbd5e1 1px, transparent 1px);
      background-size: 100% 2.5rem;
      line-height: 2.5rem;
      padding: 2.4rem 1rem 2.5rem 55px;
      font-family: 'Kalam', cursive;
      color: #1c1c1e;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1), inset 0 0 20px rgba(0,0,0,0.02);
      border-radius: 4px;
      width: 100%; 
      box-sizing: border-box;
      overflow-wrap: break-word;
      word-break: break-word;
      hyphens: auto;
    }

    @media (min-width: 768px) {
      .notebook-paper {
        background-image: 
          linear-gradient(90deg, transparent 79px, #ff8a8a 79px, #ff8a8a 81px, transparent 81px),
          linear-gradient(#cbd5e1 1px, transparent 1px);
        padding: 2.4rem 2rem 2.5rem 100px;
      }
    }

    /* Ink Colors */
    .ink-blue, .ink-blue .katex { color: #1e3aa5 !important; }
    .ink-black, .ink-black .katex { color: #1c1c1e !important; }
    .ink-red, .ink-red .katex { color: #d32f2f !important; }
    .ink-green, .ink-green .katex { color: #1b5e20 !important; }

    /* KaTeX Table Overflow Fix */
    .katex-display { 
      margin: 0 !important; 
      padding: 5px 0 !important; 
      overflow-x: auto; 
      overflow-y: hidden;
      max-width: 100%;
      display: block;
    }
    .katex-display::-webkit-scrollbar { height: 6px; }
    .katex-display::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.2); border-radius: 4px; }
    
    .step-wrapper { width: 100%; overflow-x: auto; overflow-y: hidden; }
    .notebook-paper table { width: 100%; border-collapse: collapse; margin-top: 1rem; background: rgba(255,255,255,0.5); }
    .notebook-paper th, .notebook-paper td { border: 1px solid #94a3b8; padding: 0.5rem; line-height: 1.5rem; }

    /* Floating Popover */
    #selection-popover { position: absolute; z-index: 9999; display: none; transform: translateX(-50%) translateY(-100%); margin-top: -10px; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar{ width:8px; height: 8px; } 
    ::-webkit-scrollbar-track{ background:transparent } 
    ::-webkit-scrollbar-thumb{ background:#6C2BD9; border-radius:4px }

    /* PDF Specific Overrides applied during export */
    .pdf-exporting .katex-display { overflow: visible !important; white-space: normal !important; }
    .pdf-exporting .step-wrapper { overflow: visible !important; }
  </style>
</head>

<body class="bg-[#F9FAFB] dark:bg-[#020617] text-slate-800 dark:text-slate-200 min-h-screen flex flex-col relative w-full overflow-x-hidden">

  <div id="selection-popover">
    <button id="btn-ask-selection" class="bg-slate-900 text-white text-xs font-bold px-4 py-2 rounded-lg shadow-xl flex items-center gap-2 hover:bg-brand-primary transition-colors border border-slate-700">
      <i data-lucide="help-circle" class="w-4 h-4 text-brand-accent"></i> Ask AI about this
    </button>
    <div class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-t-[8px] border-t-slate-900 absolute left-1/2 -translate-x-1/2 bottom-[-8px]"></div>
  </div>

  <div id="canvas-container" aria-hidden="true"></div>

  <div id="rotation-banner" class="hidden fixed top-0 left-0 w-full bg-brand-primary text-white text-center py-2 z-[100] font-bold text-sm shadow-lg flex items-center justify-center gap-2">
    <i data-lucide="rotate-ccw" class="w-4 h-4 animate-spin-slow"></i>
    Please rotate your phone to Landscape mode for the best view of tables.
  </div>

  <nav class="fixed top-0 w-full z-50 border-b border-white/10 bg-white/70 dark:bg-[#0f172a]/70 backdrop-blur-md">
    <div class="w-full px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <i data-lucide="cpu" class="w-6 h-6 text-brand-primary"></i>
        <span class="text-xl font-display font-bold tracking-tight text-slate-900 dark:text-white">
          BOARD <span class="text-brand-primary">Algo</span>
        </span>
      </a>
      <button id="theme-toggle" class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors">
        <i data-lucide="sun" class="w-5 h-5 hidden dark:block text-amber-400"></i>
        <i data-lucide="moon" class="w-5 h-5 block dark:hidden text-brand-primary"></i>
      </button>
    </div>
  </nav>

  <main class="relative z-10 w-full px-2 sm:px-6 pt-24 pb-20 flex-grow flex flex-col gap-6">

    <header class="text-center mb-4" id="main-header">
      <h1 class="text-3xl md:text-5xl font-display font-extrabold text-slate-900 dark:text-white mb-2 tracking-tight">Elite Solver</h1>
      <p class="text-slate-500 text-sm md:text-base max-w-2xl mx-auto">Generate 100vw, flawless, board-ready solutions.</p>
    </header>

    <section id="ui-state-idle" class="w-full max-w-4xl mx-auto flex flex-col gap-6 transition-opacity duration-300">
      <form id="solver-form" action="/api/generate-solution" method="POST" class="w-full">
        <div class="hud-panel rounded-2xl p-0 overflow-hidden shadow-xl">
          <textarea name="question" id="problem-input" 
            class="w-full min-h-[160px] bg-transparent text-slate-900 dark:text-white p-6 resize-none font-medium placeholder-slate-400 text-lg md:text-xl border-none focus:ring-0"
            placeholder="Paste your board exam question here..." required></textarea>
          <div class="flex items-center justify-between px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-black/20">
            <span class="text-xs text-brand-primary font-bold tracking-widest uppercase flex items-center gap-1"><i data-lucide="zap" class="w-4 h-4"></i> Synapse Ready</span>
            <button type="submit" class="px-8 py-3 rounded-xl bg-brand-primary text-white font-display font-bold hover:scale-[1.02] active:scale-95 shadow-glow-primary flex items-center gap-2">
              <i data-lucide="pen-tool" class="w-5 h-5"></i> Generate 5-Mark Answer
            </button>
          </div>
        </div>
      </form>
    </section>

    <section id="ui-state-processing" class="hidden flex-col items-center justify-center w-full max-w-2xl mx-auto min-h-[300px] hud-panel rounded-2xl p-8 opacity-0">
      <i data-lucide="pen-tool" class="w-12 h-12 text-brand-primary animate-bounce mb-4"></i>
      <h2 class="text-2xl font-display font-bold text-slate-900 dark:text-white mb-2">Analyzing Board Parameters...</h2>
      <div class="w-full max-w-xs bg-slate-200 dark:bg-slate-800 rounded-full h-2 mb-2 overflow-hidden">
        <div class="bg-brand-primary h-2 rounded-full animate-pulse" style="width:100%"></div>
      </div>
    </section>

    <section id="ui-state-output" class="hidden w-full flex-col gap-4 opacity-0">
      
      <div class="w-full hud-panel rounded-xl p-3 flex flex-wrap items-center justify-between gap-4 mb-2 sticky top-16 z-40">
        
        <div class="flex items-center gap-2 bg-slate-100 dark:bg-slate-800 p-1 rounded-lg">
          <span class="text-xs font-bold text-slate-500 px-2 uppercase tracking-wide">Size</span>
          <button id="btn-font-dec" class="p-1.5 rounded bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-slate-200 transition shadow-sm"><i data-lucide="minus" class="w-4 h-4"></i></button>
          <button id="btn-font-inc" class="p-1.5 rounded bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-slate-200 transition shadow-sm"><i data-lucide="plus" class="w-4 h-4"></i></button>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <button id="btn-share" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm font-bold hover:text-brand-primary transition flex items-center gap-2"><i data-lucide="share-2" class="w-4 h-4"></i> Share</button>
          <button id="btn-bookmark" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm font-bold hover:text-brand-primary transition flex items-center gap-2"><i data-lucide="bookmark" class="w-4 h-4"></i> Save</button>
          <button id="btn-download-pdf" class="px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-bold hover:bg-opacity-90 transition flex items-center gap-2 shadow-glow-primary"><i data-lucide="download" class="w-4 h-4"></i> Download PDF</button>
          <button id="btn-reset" class="px-4 py-2 border border-brand-primary text-brand-primary rounded-lg text-sm font-bold hover:bg-brand-primary/10 transition flex items-center gap-2"><i data-lucide="rotate-ccw" class="w-4 h-4"></i> Ask Another</button>
        </div>
      </div>

      <div id="pdf-export-container" class="w-full flex flex-col">
        
        <div class="w-full bg-slate-900 dark:bg-black text-white p-6 rounded-t-xl border-b-4 border-brand-primary">
          <span class="text-brand-accent font-bold uppercase tracking-widest text-xs mb-2 block">Board Question</span>
          <h2 id="problem-statement-title" class="text-xl md:text-2xl font-bold leading-relaxed"></h2>
        </div>

        <div class="relative w-full">
          <div id="notebook-canvas" class="notebook-paper" style="font-size: 1.25rem;">
            </div>
        </div>

        <div id="pdf-watermark" class="hidden text-center pt-8 pb-4">
          <p style="font-family: sans-serif; font-size: 14px; color: #64748b;">
            Authentic Solution generated by <a href="https://boardalgo.in" style="color: #6C2BD9; text-decoration: none; font-weight: bold;">BoardAlgo.in</a>
          </p>
        </div>
      </div>

      <div class="w-full flex flex-col gap-6 mt-6">
        
        <div id="doubt-section" class="w-full hud-panel rounded-2xl border-2 border-brand-primary/30 p-6 shadow-[0_0_30px_rgba(108,43,217,0.15)] relative overflow-hidden">
          <div class="absolute top-0 left-0 w-2 h-full bg-brand-primary"></div>
          <h3 class="text-xl font-display font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <i data-lucide="sparkles" class="w-6 h-6 text-brand-primary"></i> AI Doubt Solver
          </h3>
          
          <form id="doubt-form" method="POST" action="/tool/subdoubt"  class="flex flex-col gap-4">
            <textarea name="subquestion" id="doubt-input"  rows="2" 
              class="w-full bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/50 transition-all text-slate-900 dark:text-white placeholder-slate-400 resize-none" 
              placeholder="Highlight any text on the notebook above, or type your specific doubt here..."></textarea>
            <div class="flex justify-end">
              <button type="submit" class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-8 py-3 rounded-xl text-sm font-bold hover:scale-[1.02] transition-transform flex items-center gap-2 shadow-lg">
                <i data-lucide="send" class="w-4 h-4"></i> Clarify Doubt
              </button>
            </div>
          </form>

          <div id="doubt-loader" class="hidden flex-col items-center justify-center py-8 gap-3">
            <i data-lucide="loader-2" class="w-8 h-8 text-brand-primary animate-spin"></i>
            <span class="text-sm font-mono text-slate-500">BoardAlgo Tutor is typing...</span>
          </div>
          <div id="doubt-response-canvas" class="hidden mt-6 bg-brand-stickynote text-slate-900 p-6 rounded-lg shadow-md font-handwriting text-xl leading-relaxed border-l-8 border-amber-400"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
          <div class="hud-panel rounded-2xl p-6 text-center border border-slate-200 dark:border-slate-800">
            <i data-lucide="drafting-compass" class="w-12 h-12 mx-auto text-brand-primary/40 mb-3"></i>
            <h4 class="font-bold text-lg mb-1">Board-Level Diagram</h4>
            <p class="text-sm text-slate-500">Auto-generated diagrams for this question are coming soon.</p>
          </div>
          <div class="hud-panel rounded-2xl p-6 text-center border border-slate-200 dark:border-slate-800">
            <i data-lucide="award" class="w-12 h-12 mx-auto text-amber-500/50 mb-3"></i>
            <h4 class="font-bold text-lg mb-1">CBSE Topper's Sheet</h4>
            <p class="text-sm text-slate-500">Fetching original handwritten answer sheets from CBSE database is coming soon.</p>
          </div>
        </div>

      </div>

    </section>

  </main>

  <script>
    lucide.createIcons();

    const form = document.getElementById('solver-form');
    const stateIdle = document.getElementById('ui-state-idle');
    const stateProcessing = document.getElementById('ui-state-processing');
    const stateOutput = document.getElementById('ui-state-output');
    
    const notebookCanvas = document.getElementById('notebook-canvas');
    const problemStatementTitle = document.getElementById('problem-statement-title');
    const mainHeader = document.getElementById('main-header');
    const rotationBanner = document.getElementById('rotation-banner');

    const selectionPopover = document.getElementById('selection-popover');
    const btnAskSelection = document.getElementById('btn-ask-selection');
    const doubtInput = document.getElementById('doubt-input');
    const doubtForm = document.getElementById('doubt-form');
    const doubtLoader = document.getElementById('doubt-loader');
    const doubtResponseCanvas = document.getElementById('doubt-response-canvas');

    const btnDownloadPdf = document.getElementById('btn-download-pdf');
    const btnShare = document.getElementById('btn-share');
    const btnBookmark = document.getElementById('btn-bookmark');
    const btnReset = document.getElementById('btn-reset');
    
    const btnFontInc = document.getElementById('btn-font-inc');
    const btnFontDec = document.getElementById('btn-font-dec');

    // FIX 4: Context Variable to hold the entire generated solution
    let currentSolutionContext = null;
    
    // Dynamic Font Sizing Logic
    let currentFontSize = 1.25; // Default rem
    btnFontInc.addEventListener('click', () => {
        if(currentFontSize < 2.0) currentFontSize += 0.1;
        notebookCanvas.style.fontSize = `${currentFontSize}rem`;
    });
    btnFontDec.addEventListener('click', () => {
        if(currentFontSize > 0.8) currentFontSize -= 0.1;
        notebookCanvas.style.fontSize = `${currentFontSize}rem`;
    });

    // Device Rotation Check
    function checkRotation() {
        if (window.innerWidth < 768 && window.innerHeight > window.innerWidth) {
            rotationBanner.classList.remove('hidden');
        } else {
            rotationBanner.classList.add('hidden');
        }
    }
    window.addEventListener('resize', checkRotation);

    function switchState(hideElem, showElem){
      hideElem.classList.replace('opacity-100','opacity-0');
      setTimeout(()=>{
        hideElem.classList.add('hidden'); hideElem.classList.remove('flex');
        showElem.classList.remove('hidden'); showElem.classList.add('flex');
        void showElem.offsetWidth;
        showElem.classList.replace('opacity-0','opacity-100');
      }, 300);
    }

    // Generate Solution
    form.addEventListener('submit', async (ev)=>{
      ev.preventDefault();
      switchState(stateIdle, stateProcessing);
      mainHeader.classList.add('hidden');

      const payload = { question: document.getElementById('problem-input').value };

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const json = await res.json();
        
        // Save Context for Doubt Fetching
        currentSolutionContext = json;

        notebookCanvas.innerHTML = ''; 
        
        if(json.problem_statement) {
            problemStatementTitle.textContent = json.problem_statement;
        }

        if (json.steps && Array.isArray(json.steps)) {
            json.steps.forEach(step => {
                let inkClass = 'ink-black';
                if (step.ink === 'blue') inkClass = 'ink-blue';
                if (step.ink === 'red') inkClass = 'ink-red';
                if (step.ink === 'green') inkClass = 'ink-green';

                const stepDiv = document.createElement('div');
                stepDiv.className = `w-full mb-3 step-wrapper ${inkClass}`;

                if (step.text) {
                    const textSpan = document.createElement('span');
                    textSpan.textContent = step.text + " "; 
                    stepDiv.appendChild(textSpan);
                }

                if (step.latex) {
                    const mathSpan = document.createElement('div');
                    try {
                        let cleanLatex = step.latex.replace(/\$\$/g, '').trim();
                        if(!cleanLatex.includes('\\') && !cleanLatex.includes('^') && cleanLatex.length > 10) {
                             cleanLatex = cleanLatex.replace(/ /g, '\\ ');
                        }

                        katex.render(cleanLatex, mathSpan, {
                            displayMode: true, 
                            throwOnError: false,
                            strict: false 
                        });
                        stepDiv.appendChild(mathSpan);
                    } catch (e) {
                        mathSpan.textContent = step.latex;
                        mathSpan.className = "break-all font-mono text-sm mt-1";
                        stepDiv.appendChild(mathSpan);
                    }
                }
                notebookCanvas.appendChild(stepDiv);
            });
            checkRotation();

        } else {
            notebookCanvas.innerHTML = `<div class="ink-red font-bold p-4">Error: AI did not generate valid steps.</div>`;
        }

        switchState(stateProcessing, stateOutput);

      } catch (err) {
        console.error(err);
        alert('Connection failed. Please check logs.');
        switchState(stateProcessing, stateIdle);
        mainHeader.classList.remove('hidden');
      }
    });

    // Reset Flow
    btnReset.addEventListener('click', ()=>{
      form.reset();
      switchState(stateOutput, stateIdle);
      mainHeader.classList.remove('hidden');
      rotationBanner.classList.add('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ==========================================
    // HIGHLIGHT TO ASK DOUBT (Fix 3: Absolute Body Positioning)
    // ==========================================
    let selectedTextTemp = '';

    document.addEventListener('mouseup', handleSelection);
    document.addEventListener('touchend', handleSelection);

    function handleSelection(e) {
        setTimeout(() => { 
            const selection = window.getSelection();
            const text = selection.toString().trim();
            
            // Only trigger if selection is inside notebook
            if(text.length > 0 && selection.rangeCount > 0 && notebookCanvas.contains(selection.anchorNode)) {
                selectedTextTemp = text;
                const range = selection.getRangeAt(0);
                const rect = range.getBoundingClientRect();
                
                const scrollY = window.scrollY || document.documentElement.scrollTop;
                const scrollX = window.scrollX || document.documentElement.scrollLeft;
                
                selectionPopover.style.display = 'block';
                selectionPopover.style.top = `${rect.top + scrollY - 5}px`;
                selectionPopover.style.left = `${rect.left + scrollX + (rect.width/2)}px`;
            } else if (!selectionPopover.contains(e.target)) {
                selectionPopover.style.display = 'none';
                selectedTextTemp = '';
            }
        }, 10);
    }

    btnAskSelection.addEventListener('click', (e) => {
        e.preventDefault();
        if(selectedTextTemp) {
            doubtInput.value = `Regarding: "${selectedTextTemp}"\nMy doubt is: `;
            selectionPopover.style.display = 'none';
            document.getElementById('doubt-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => {
                doubtInput.focus();
                const val = doubtInput.value;
                doubtInput.value = '';
                doubtInput.value = val;
            }, 500);
        }
    });

    // ==========================================
    // DOUBT SOLVER FETCH (Fix 4: Full Context POST)
    // ==========================================
    doubtForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const doubtVal = doubtInput.value.trim();
        if(!doubtVal) return;

        doubtForm.classList.add('hidden');
        doubtResponseCanvas.classList.add('hidden');
        doubtLoader.classList.remove('hidden');
        doubtLoader.classList.add('flex');

        try {
            // Sending entire Context + User Doubt
            const payload = {
                doubt: doubtVal,
                highlightedText: selectedTextTemp || "",
                solutionContext: currentSolutionContext
            };

            const res = await fetch(doubtForm.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            // Awaiting backend response format { answer: "html string" }
            const result = await res.json();
            
            // Display Result
            doubtResponseCanvas.innerHTML = result.answer || result.output || "Tutor responded, but answer format was unexpected."; 

        } catch (error) {
            doubtResponseCanvas.innerHTML = '<span class="text-red-600 font-bold">Failed to fetch doubt.</span>';
        } finally {
            doubtLoader.classList.add('hidden');
            doubtLoader.classList.remove('flex');
            doubtForm.classList.remove('hidden');
            doubtInput.value = ''; 
            doubtResponseCanvas.classList.remove('hidden');
        }
    });

    // ==========================================
    // PERFECT PDF EXPORT (Fix 2: Landscape & Page Breaks)
    // ==========================================
    btnDownloadPdf.addEventListener('click', () => {
        const elementToPrint = document.getElementById('pdf-export-container');
        const watermark = document.getElementById('pdf-watermark');
        
        watermark.classList.remove('hidden');
        watermark.classList.add('block');

        const originalFontSize = notebookCanvas.style.fontSize;
        notebookCanvas.style.fontSize = '1.1rem'; 
        notebookCanvas.style.boxShadow = 'none';
        elementToPrint.classList.add('pdf-exporting'); 

        const opt = {
            margin:       [0.5, 0.5, 0.5, 0.5],
            filename:     'BoardAlgo-Solution.pdf',
            image:        { type: 'jpeg', quality: 1 },
            html2canvas:  { scale: 2, useCORS: true },
            jsPDF:        { unit: 'in', format: 'a4', orientation: 'landscape' }, // Landscape for tables
            pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }, // Prevents cutting lines
            enableLinks:  true 
        };

        const originalText = btnDownloadPdf.innerHTML;
        btnDownloadPdf.innerHTML = `<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Generating...`;
        
        html2pdf().set(opt).from(elementToPrint).save().then(() => {
            btnDownloadPdf.innerHTML = originalText;
            lucide.createIcons();
            watermark.classList.add('hidden');
            watermark.classList.remove('block');
            notebookCanvas.style.fontSize = originalFontSize;
            notebookCanvas.style.boxShadow = '';
            elementToPrint.classList.remove('pdf-exporting');
        });
    });

    // ==========================================
    // SHARE & BOOKMARK
    // ==========================================
    btnShare.addEventListener('click', async () => {
        const title = problemStatementTitle.textContent;
        const url = window.location.href;
        if (navigator.share) {
            try { await navigator.share({ title: 'BoardAlgo Solution', text: title, url: url }); } 
            catch (err) {}
        } else {
            navigator.clipboard.writeText(`${title} - ${url}`);
            alert('Link copied to clipboard!');
        }
    });

    btnBookmark.addEventListener('click', function() {
        const icon = this.querySelector('i');
        if(icon.getAttribute('fill') === 'currentColor') {
            icon.setAttribute('fill', 'none');
            icon.classList.remove('text-brand-primary');
        } else {
            icon.setAttribute('fill', 'currentColor');
            icon.classList.add('text-brand-primary');
        }
    });

    // Theme & Background
    const themeToggleBtn = document.getElementById('theme-toggle');
    const htmlElement = document.documentElement;
    themeToggleBtn.addEventListener('click', ()=>{ 
        htmlElement.classList.toggle('dark'); 
        updateThreeJSColors(); 
    });

    let scene, camera, renderer, grid;
    function initThreeJS(){
      const container = document.getElementById('canvas-container');
      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
      camera.position.set(0,3,10); camera.rotation.x = -0.2;
      renderer = new THREE.WebGLRenderer({ alpha:true, antialias:true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(window.devicePixelRatio);
      container.appendChild(renderer.domElement);

      const gridGeo = new THREE.PlaneGeometry(200,200,60,60);
      const gridMat = new THREE.MeshBasicMaterial({ color:0x6C2BD9, wireframe:true, transparent:true, opacity:0.08 });
      grid = new THREE.Mesh(gridGeo, gridMat);
      grid.rotation.x = -Math.PI/2; scene.add(grid);

      updateThreeJSColors();

      let time = 0;
      function animate(){
        requestAnimationFrame(animate);
        time += 0.002;
        grid.position.z = (time*10) % 5;
        const positions = gridGeo.attributes.position;
        for(let i=0;i<positions.count;i++) positions.setZ(i, Math.sin(i/5 + time*5) * 0.2);
        positions.needsUpdate = true;
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', ()=>{
        camera.aspect = window.innerWidth/window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
    
    function updateThreeJSColors(){
      if(!scene) return;
      const isDark = htmlElement.classList.contains('dark');
      scene.fog = new THREE.FogExp2(isDark ? 0x020617 : 0xF9FAFB, 0.04);
    }
    initThreeJS();

  </script>
  
  <script src="/js/tracking.js" defer></script>
</body>
</html>