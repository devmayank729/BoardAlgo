<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BoardAlgo | Student Command Center</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>

window.addEventListener('DOMContentLoaded', () => {
    <% if(typeof error !== 'undefined' && error) { %>
        openModal();
        switchTab('info');
    <% } %>
});

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            black:   '#020617',
                            surface: '#0f172a',
                            border:  '#1e293b',
                            primary: '#6C2BD9',
                            accent:  '#16A34A',
                        }
                    },
                    fontFamily: {
                        sans:    ['Inter', 'sans-serif'],
                        display: ['Poppins', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        /* ─── Base ─────────────────────────────────────── */
        body { background-color: #f8fafc; color: #0f172a; transition: background-color 0.3s, color 0.3s; }
        .dark body { background-color: #020617; color: #f8fafc; }

        /* ─── Glass ────────────────────────────────────── */
        .glass {
            background: rgba(255,255,255,0.72);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(0,0,0,0.06);
            transition: all 0.3s ease;
        }
        .dark .glass {
            background: rgba(15,23,42,0.65);
            border: 1px solid rgba(255,255,255,0.08);
        }

        /* ─── Glow cards ───────────────────────────────── */
        .glow-card {
            position: relative; overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .glow-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(108,43,217,0.18);
            border-color: rgba(108,43,217,0.3) !important;
        }
        .glow-card .card-arrow {
            opacity: 0; transform: translateX(-4px);
            transition: opacity 0.2s, transform 0.2s;
        }
        .glow-card:hover .card-arrow { opacity: 1; transform: translateX(0); }

        /* ─── Inputs ───────────────────────────────────── */
        .glass-input {
            width: 100%;
            background: rgba(255,255,255,0.6);
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 10px;
            padding: 9px 14px;
            font-family: 'Inter', sans-serif;
            font-size: 0.875rem;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .dark .glass-input {
            background: rgba(0,0,0,0.25);
            border-color: rgba(255,255,255,0.1);
            color: #f1f5f9;
        }
        .glass-input:focus {
            border-color: #6C2BD9;
            box-shadow: 0 0 0 3px rgba(108,43,217,0.15);
        }
        .glass-input option { background: #0f172a; color: #f1f5f9; }

        /* ─── Stat tiles ───────────────────────────────── */
        .stat-tile {
            position: relative; overflow: hidden;
            transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        }
        .stat-tile::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at top left, rgba(108,43,217,0.07), transparent 60%);
            pointer-events: none;
        }
        .stat-tile:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(108,43,217,0.12);
            border-color: rgba(108,43,217,0.25) !important;
        }

        /* ─── Upgrade banner ───────────────────────────── */
        .upgrade-banner {
            background: linear-gradient(135deg, rgba(108,43,217,0.14) 0%, rgba(99,102,241,0.08) 50%, rgba(22,163,74,0.07) 100%);
            border: 1px solid rgba(108,43,217,0.3);
            position: relative; overflow: hidden;
        }
        .dark .upgrade-banner { background: linear-gradient(135deg, rgba(108,43,217,0.18), rgba(99,102,241,0.1), rgba(22,163,74,0.08)); }
        .upgrade-banner::before {
            content: ''; position: absolute; top: -50px; right: -50px;
            width: 220px; height: 220px;
            background: radial-gradient(circle, rgba(108,43,217,0.2) 0%, transparent 70%);
            pointer-events: none;
        }

        /* ─── Activity item ────────────────────────────── */
        .activity-item {
            transition: background-color 0.2s, border-color 0.2s, transform 0.2s;
        }
        .activity-item:hover {
            transform: translateX(3px);
            border-color: rgba(108,43,217,0.25) !important;
        }
        .dark .activity-item:hover { background: rgba(255,255,255,0.03) !important; }
        .activity-item:hover { background: rgba(108,43,217,0.03) !important; }

        /* ─── Modal ────────────────────────────────────── */
        #profile-modal {
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        .modal-scroll::-webkit-scrollbar { width: 4px; }
        .modal-scroll::-webkit-scrollbar-track { background: transparent; }
        .modal-scroll::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.3); border-radius: 2px; }

        /* ─── Tab buttons ──────────────────────────────── */
        .modal-tab {
            flex: 1; padding: 7px 4px; border-radius: 8px; border: none;
            font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600;
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
        }
        .modal-tab.active { background: #6C2BD9; color: white; box-shadow: 0 3px 10px rgba(108,43,217,0.35); }
        .modal-tab:not(.active) { background: transparent; color: #64748b; }
        .dark .modal-tab:not(.active) { color: #94a3b8; }
        .modal-tab:not(.active):hover { background: rgba(108,43,217,0.08); color: #6C2BD9; }

        /* ─── Badge ────────────────────────────────────── */
        .badge {
            display: inline-flex; align-items: center; gap: 3px;
            padding: 2px 8px; border-radius: 99px;
            font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
        }
        .badge-pro   { background: rgba(108,43,217,0.15); color: #a78bfa; border: 1px solid rgba(108,43,217,0.3); }
        .badge-trial { background: rgba(22,163,74,0.12);  color: #4ade80; border: 1px solid rgba(22,163,74,0.25); }
        .badge-free  { background: rgba(245,158,11,0.12); color: #fbbf24; border: 1px solid rgba(245,158,11,0.25); }
        .badge-exp   { background: rgba(239,68,68,0.12);  color: #f87171; border: 1px solid rgba(239,68,68,0.25); }

        /* ─── Scrollbar ────────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.25); border-radius: 3px; }

        /* ─── Avatar ring ──────────────────────────────── */
        .avatar-ring {
            background: conic-gradient(#6C2BD9 0%, #a78bfa 45%, #16A34A 70%, #6C2BD9 100%);
            border-radius: 50%; padding: 2px; display: inline-flex;
        }
        .avatar-inner {
            border-radius: 50%; overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Poppins', sans-serif; font-weight: 700;
        }

        /* ─── Glow dot ─────────────────────────────────── */
        .glow-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: #16A34A; box-shadow: 0 0 6px #16A34A;
            display: inline-block; animation: dotpulse 2s ease-in-out infinite;
        }
        @keyframes dotpulse {
            0%,100% { opacity:1; transform:scale(1); }
            50% { opacity:0.55; transform:scale(0.82); }
        }

        /* ─── Danger zone btn ──────────────────────────── */
        .btn-danger {
            padding: 7px 16px; border-radius: 9px;
            border: 1px solid rgba(239,68,68,0.35);
            background: rgba(239,68,68,0.07);
            color: #f87171; font-size: 0.8rem; font-weight: 600;
            cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s;
        }
        .btn-danger:hover { background: rgba(239,68,68,0.15); border-color: rgba(239,68,68,0.5); }

        /* ─── Footer link ──────────────────────────────── */
        .footer-link { color: #94a3b8; font-size: 0.875rem; text-decoration: none; transition: color 0.2s; }
        .footer-link:hover { color: #6C2BD9; }

        /* ─── Feature table row ────────────────────────── */
        .feat-row:nth-child(odd)  { background: rgba(108,43,217,0.03); }
        .dark .feat-row:nth-child(odd) { background: rgba(108,43,217,0.06); }

        /* ─── Logout btn ───────────────────────────────── */
        .logout-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 7px 13px; border-radius: 9px;
            border: 1px solid rgba(239,68,68,0.28);
            background: rgba(239,68,68,0.07);
            color: #f87171; font-size: 0.8rem; font-weight: 500;
            text-decoration: none; font-family: 'Inter', sans-serif;
            transition: all 0.2s;
        }
        .logout-btn:hover { background: rgba(239,68,68,0.15); border-color: rgba(239,68,68,0.45); }
    </style>
</head>

<body class="antialiased min-h-screen flex flex-col relative overflow-x-hidden">

<!-- Particle background -->
<canvas id="bg-canvas" class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none" style="opacity:0.35;"></canvas>
<div class="fixed inset-0 -z-10 pointer-events-none dark:opacity-100 opacity-0 transition-opacity duration-500" style="background:radial-gradient(ellipse 80% 50% at 50% -20%, rgba(108,43,217,0.12), transparent);"></div>

<!-- ══════════════════════ NAV ══════════════════════ -->
<nav class="fixed top-0 w-full z-50 glass" style="border-bottom:1px solid rgba(0,0,0,0.05);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 gap-2 sm:gap-4">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 min-w-0 flex-shrink-0">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center text-white font-bold font-display text-base" style="background:linear-gradient(135deg,#6C2BD9,#a855f7);box-shadow:0 3px 10px rgba(108,43,217,0.4);">B</div>
                <span class="text-xl font-bold font-display tracking-tight text-slate-900 dark:text-white truncate">BOARD <span class="text-brand-primary">Algo</span></span>
            </a>

            <!-- Right cluster -->
            <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">

                <!-- Theme toggle -->
                <button id="theme-toggle" class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-slate-500 dark:text-gray-400 transition-colors">
                    <i data-lucide="sun"  class="hidden dark:block w-4 h-4 sm:w-5 sm:h-5"></i>
                    <i data-lucide="moon" class="block dark:hidden w-4 h-4 sm:w-5 sm:h-5"></i>
                </button>

                <!-- Settings -->
                <button id="open-profile-btn" class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-slate-500 dark:text-gray-400 transition-colors" title="Profile & Settings">
                    <i data-lucide="settings" class="w-4 h-4 sm:w-5 sm:h-5"></i>
                </button>

                <!-- Logout (desktop) -->
                <a href="/auth/logout" class="logout-btn hidden sm:flex">
                    <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
                    <span>Logout</span>
                </a>

                <!-- Divider + avatar chip -->
                <div class="flex items-center gap-2 sm:gap-3 pl-2 sm:pl-3 border-l border-gray-200 dark:border-gray-800 cursor-pointer hover:opacity-80 transition-opacity" onclick="document.getElementById('open-profile-btn').click()">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-semibold text-slate-900 dark:text-white leading-tight"><%= user.username %></p>
                        <%
                        let navBadgeLabel = 'Free Trial';
                        if(user.subscription_status === 'ACTIVE') navBadgeLabel = 'Pro Member';
                        else if(user.subscription_status === 'EXPIRED' || user.subscription_status === 'CHURNED') navBadgeLabel = 'Plan Expired';
                        %>
                        <p class="text-xs font-medium mt-0.5" style="color:#6C2BD9;"><%= navBadgeLabel %></p>
                    </div>
                    <% if(user.photoURL) { %>
                    <div class="avatar-ring flex-shrink-0" style="width:36px;height:36px;">
                        <div class="avatar-inner" style="width:100%;height:100%;">
                            <img src="<%= user.photoURL %>" style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    </div>
                    <% } else { %>
                    <div class="h-9 w-9 rounded-full flex-shrink-0 flex items-center justify-center text-white font-bold font-display text-base" style="background:linear-gradient(135deg,rgba(108,43,217,0.8),rgba(168,85,247,0.7));border:2px solid rgba(108,43,217,0.4);">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- ══════════════════ PROFILE MODAL ══════════════════ -->
<div id="profile-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 opacity-0 transition-opacity duration-300 px-4 py-6" style="backdrop-filter:blur(6px);">
    <div id="profile-modal-content" class="glass w-full rounded-2xl transform scale-95 transition-transform duration-300 modal-scroll" style="max-width:520px;max-height:92vh;overflow-y:auto;">
        <div class="p-6 sm:p-7">

            <!-- Header -->
            <div class="flex justify-between items-start mb-5">
                <div>
                    <h2 class="text-xl font-bold font-display text-slate-900 dark:text-white">Profile Settings</h2>
                    <p class="text-xs text-slate-500 dark:text-gray-400 mt-1">Manage your account information</p>
                </div>
                <button id="close-profile-btn" class="p-1.5 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors flex-shrink-0 ml-4">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>

            <!-- Tab bar -->
            <div class="flex gap-1 p-1 rounded-xl mb-6" style="background:rgba(0,0,0,0.05);">
                <button class="modal-tab active" data-tab="info"     onclick="switchTab('info')">Personal Info</button>
                <button class="modal-tab"        data-tab="security" onclick="switchTab('security')">Security</button>
                <button class="modal-tab"        data-tab="plan"     onclick="switchTab('plan')">Plan & Billing</button>
            </div>

            <!-- ── TAB: Personal Info ── -->
            <div id="tab-info" class="tab-panel">
                <!-- Avatar + quick info -->
                <div class="flex items-center gap-4 p-4 rounded-xl mb-5 border border-gray-200 dark:border-white/8" style="background:rgba(108,43,217,0.04);">
                    <div class="flex-shrink-0">
                        <% if(user.photoURL) { %>
                        <div class="avatar-ring" style="width:60px;height:60px;">
                            <div class="avatar-inner" style="width:100%;height:100%;">
                                <img src="<%= user.photoURL %>" style="width:100%;height:100%;object-fit:cover;">
                            </div>
                        </div>
                        <% } else { %>
                        <div class="avatar-ring" style="width:60px;height:60px;">
                            <div class="avatar-inner w-full h-full text-white text-2xl font-display font-bold" style="background:linear-gradient(135deg,#6C2BD9,#a855f7);">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </div>
                        </div>
                        <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-slate-900 dark:text-white text-base truncate"><%= user.username %></p>
                        <p class="text-xs text-slate-500 dark:text-gray-400 truncate mt-0.5"><%= user.email %></p>
                        <div class="flex items-center gap-2 mt-2 flex-wrap">
                            <span class="glow-dot"></span>
                            <%
                            let statusLabel2 = 'Free Trial';
                            let badgeClass2 = 'badge-trial';
                            if(user.subscription_status === 'ACTIVE') { statusLabel2='Pro Member'; badgeClass2='badge-pro'; }
                            else if(user.subscription_status === 'EXPIRED' || user.subscription_status === 'CHURNED') { statusLabel2='Expired'; badgeClass2='badge-exp'; }
                            %>
                            <span class="badge <%= badgeClass2 %>"><%= statusLabel2 %></span>
                            <% if(user.Class) { %>
                            <span class="text-xs text-slate-500 dark:text-gray-400">Class <%= user.Class %></span>
                            <% } %>
                            <% if(user.provider === 'google') { %>
                            <span class="text-xs font-medium" style="color:#4285F4;">Google Account</span>
                            <% } %>
                        </div>
                    </div>
                    <!-- Mobile logout inside modal -->
                    <a href="/auth/logout" class="sm:hidden p-2 rounded-lg text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Logout">
                        <i data-lucide="log-out" class="w-4 h-4"></i>
                    </a>
                </div>

                <!-- Edit Form -->
                <form method="POST" action="/user/update-profile" id="profile-edit-form">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Username</label>
                            <input type="text" name="username" value="<%= user.username %>" class="glass-input" required placeholder="Your display name">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Class / Grade</label>
                            <select name="current_class" class="glass-input">
                                <option value="">Select class</option>
                                <% ['9','10','11','12'].forEach(function(c){ %>
                                <option value="<%= c %>" <%= user.Class === c ? 'selected' : '' %>>Class <%= c %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Email</label>
                            <input type="email" name="email" value="<%= user.email %>" class="glass-input"
                                   <%= user.provider === 'google' ? 'readonly' : '' %>
                                   style="<%= user.provider === 'google' ? 'opacity:0.6;cursor:not-allowed;' : '' %>">
                            <% if(user.provider === 'google') { %><p class="text-xs text-slate-400 mt-1">Managed by Google</p><% } %>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Phone</label>
                            <input type="tel" name="phone_number" value="<%= user.phone_number || '' %>" class="glass-input" placeholder="+91 XXXXXXXXXX">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Parent's Phone</label>
                            <input type="tel" name="parent_phone_number" value="<%= user.parent_phone_number || '' %>" class="glass-input" placeholder="+91 XXXXXXXXXX">
                        </div>

                    </div>
                    <div class="flex gap-3 pt-2">
                        <button type="button" id="cancel-profile-btn" class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 text-slate-700 dark:text-gray-300 text-sm font-semibold hover:bg-gray-100 dark:hover:bg-white/5 transition-colors">Cancel</button>
                        <button type="submit" id="save-profile-btn" class="flex-2 flex-1 px-4 py-2.5 rounded-xl text-white text-sm font-semibold transition-all" style="background:linear-gradient(135deg,#6C2BD9,#7c3aed);box-shadow:0 4px 14px rgba(108,43,217,0.35);">Save Changes</button>
                    </div>
                </form>
            </div>



                <!-- Danger zone -->
                <div class="mt-5 p-4 rounded-xl border border-dashed border-red-300/50 dark:border-red-500/25" style="background:rgba(239,68,68,0.04);">
                    <p class="text-xs font-bold text-red-400 uppercase tracking-widest mb-2">Danger Zone</p>
                    <p class="text-sm text-slate-500 dark:text-gray-400 mb-3">Permanently delete your account. This cannot be undone.</p>
                    <button class="btn-danger">Delete Account</button>
                </div>
            </div>

            <!-- ── TAB: Plan & Billing ── -->
            <div id="tab-plan" class="tab-panel hidden">
                <%
                let planLabel = 'Free Trial';
                let planBadge = 'badge-trial';
                if(user.subscription_status === 'ACTIVE') { planLabel = 'Pro'; planBadge = 'badge-pro'; }
                else if(user.subscription_status === 'EXPIRED' || user.subscription_status === 'CHURNED') { planLabel = 'Expired'; planBadge = 'badge-exp'; }
                %>
                <!-- Current plan card -->
                <div class="p-4 rounded-xl border border-gray-200 dark:border-white/8 mb-4" style="background:rgba(108,43,217,0.04);">
                    <div class="flex items-center justify-between mb-3">
                        <p class="font-bold text-slate-900 dark:text-white text-sm">Current Plan</p>
                        <span class="badge <%= planBadge %>"><%= planLabel %></span>
                    </div>
                    <% if(user.subscription_status === 'ACTIVE' && user.plan_expiry_date) { %>
                    <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-gray-400 mb-3">
                        <i data-lucide="calendar" class="w-3.5 h-3.5 flex-shrink-0"></i>
                        <span>Expires <strong class="text-slate-700 dark:text-gray-200"><%= new Date(user.plan_expiry_date).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></strong></span>
                    </div>
                    <% } %>
                    <% if(user.subscription_status !== 'ACTIVE') { %>
                    <p class="text-sm text-slate-500 dark:text-gray-400 mb-3 leading-relaxed">Upgrade to unlock unlimited AI solutions, board analytics, priority support, and more.</p>
                    <a href="/pricing" onclick="closeModal()">
                        <button class="w-full py-2.5 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90" style="background:linear-gradient(135deg,#6C2BD9,#16A34A);box-shadow:0 4px 16px rgba(108,43,217,0.35);">
                            🚀 Upgrade to Pro
                        </button>
                    </a>
                    <% } else { %>
                    <a href="/pricing" onclick="closeModal()">
                        <button class="w-full py-2 rounded-xl text-sm font-semibold border border-gray-300 dark:border-gray-600 text-slate-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors">Manage Subscription</button>
                    </a>
                    <% } %>
                </div>

                <!-- Feature comparison -->
                <div class="rounded-xl overflow-hidden border border-gray-200 dark:border-white/8">
                    <div class="px-4 py-2.5 border-b border-gray-200 dark:border-white/8" style="background:rgba(0,0,0,0.03);">
