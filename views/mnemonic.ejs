                <button id="btn-reset" class="flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-brand-primary transition-colors focus:outline-none">
                  <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> New Hook
                </button>
              </div>
            </div>

            <div id="ai-items-container" class="glass rounded-b-2xl border border-gray-200 dark:border-white/8 border-t-0 p-5 md:p-7 space-y-5"></div>

            <div class="flex items-center justify-center gap-3 mt-4 flex-wrap">
              <button id="btn-copy-output"
                class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 dark:border-white/8 bg-white/60 dark:bg-white/5 text-slate-600 dark:text-slate-400 hover:border-brand-primary/40 hover:text-brand-primary text-sm font-medium transition-all">
                <i data-lucide="copy" class="w-3.5 h-3.5"></i> Copy
              </button>
              <button id="btn-save-txt"
                class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 dark:border-white/8 bg-white/60 dark:bg-white/5 text-slate-600 dark:text-slate-400 hover:border-brand-primary/40 hover:text-brand-primary text-sm font-medium transition-all">
                <i data-lucide="download" class="w-3.5 h-3.5"></i> Save
              </button>
              <button id="btn-bookmark"
                class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 dark:border-white/8 bg-white/60 dark:bg-white/5 text-slate-600 dark:text-slate-400 hover:border-amber-400/40 hover:text-amber-400 text-sm font-medium transition-all">
                <i data-lucide="bookmark" class="w-3.5 h-3.5"></i> Save to History
              </button>
            </div>
          </div>

        </div>
      </section>

    </div>
  </main>

  <!-- ══════════════ SCRIPTS ══════════════ -->
  <script>
  lucide.createIcons();

  // ── Theme ─────────────────────────────────────────────
  const html = document.documentElement;
  (function(){
    const s = localStorage.theme;
    if(s==='dark'||(!s&&window.matchMedia('(prefers-color-scheme: dark)').matches)) html.classList.add('dark');
    else html.classList.remove('dark');
  })();
  document.getElementById('theme-toggle').addEventListener('click',()=>{
    html.classList.toggle('dark');
    localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
    if(typeof updateThreeColors === 'function') updateThreeColors();
  });

  // ── DOM refs ──────────────────────────────────────────
  const form            = document.getElementById('mnemonic-form');
  const textarea        = document.getElementById('brain-dump');
  const fileInput       = document.getElementById('file-input');
  const imgStrip        = document.getElementById('img-preview-strip');
  const previewThumb    = document.getElementById('preview-thumb');
  const previewFilename = document.getElementById('preview-filename');
  const previewFilesize = document.getElementById('preview-filesize');
  const btnRemoveImg    = document.getElementById('btn-remove-img');
  const btnUpload       = document.getElementById('btn-upload');
  const btnCamera       = document.getElementById('btn-camera');
  const btnLore         = document.getElementById('btn-lore');
  const btnHack         = document.getElementById('btn-hack');
  const modeInput       = document.getElementById('mode-input');
  const btnDeepScan     = document.getElementById('btn-deepscan');
  const deepScanInput   = document.getElementById('deepscan-input');
  const deepscanTrack   = document.getElementById('deepscan-track');
  const deepscanKnob    = document.getElementById('deepscan-knob');
  const deepscanIcon    = document.getElementById('deepscan-icon');
  const languageInput   = document.getElementById('language-input');
  const langDescText    = document.getElementById('lang-desc-text');
  const outputLangBadge = document.getElementById('output-lang-badge');
  const btnGenerate     = document.getElementById('btn-generate');
  const stateIdle       = document.getElementById('ui-state-idle');
  const stateProc       = document.getElementById('ui-state-processing');
  const stateOutput     = document.getElementById('ui-state-output');
  const progressBar     = document.getElementById('progress-bar');
  const terminalLog     = document.getElementById('terminal-log');
  const procTitle       = document.getElementById('proc-title');
  const procSubtitle    = document.getElementById('proc-subtitle');
  const aiItems         = document.getElementById('ai-items-container');
  const sourceMatrix    = document.getElementById('source-matrix-container');
  const outputModeBadge = document.getElementById('output-mode-badge');
  const btnCancel       = document.getElementById('btn-cancel');
  const btnReset        = document.getElementById('btn-reset');
  const btnCopy         = document.getElementById('btn-copy-output');
  const btnSave         = document.getElementById('btn-save-txt');
  const btnReconfig     = document.getElementById('btn-reconfig');
  const confirmModal    = document.getElementById('confirm-modal');
  const modalCancelBtn  = document.getElementById('modal-cancel-btn');
  const modalConfirmBtn = document.getElementById('modal-confirm-btn');

  // ── App state ─────────────────────────────────────────
  let currentMode     = 'lore';
  let isDeepScan      = false;
  let currentLanguage = 'english';
  let ctrl            = null;
  let progTimer       = null;
  let imageBase64     = null;

  // ── Helpers ───────────────────────────────────────────
  function showToast(msg, ms=1800){
    const t = document.createElement('div'); t.className='toast'; t.textContent=msg;
    document.body.appendChild(t);
    setTimeout(()=>{ if(t.parentNode) t.parentNode.removeChild(t); }, ms);
  }

  function switchState(hide, show){
    hide.style.opacity='0';
    setTimeout(()=>{
      hide.classList.add('hidden'); hide.classList.remove('flex');
      show.classList.remove('hidden');
      void show.offsetWidth;
      show.style.opacity='1';
    }, 280);
  }

  function formatBytes(b){
    if(b<1024) return b+' B';
    if(b<1048576) return (b/1024).toFixed(1)+' KB';
    return (b/1048576).toFixed(1)+' MB';
  }

  // ── Mode selection ────────────────────────────────────
  function setMode(mode){
    currentMode = mode;
    modeInput.value = mode;
    btnLore.style.borderColor = mode==='lore' ? '#6C2BD9' : 'rgba(0,0,0,0.08)';
    btnLore.style.background  = mode==='lore' ? 'rgba(108,43,217,0.07)' : '';
    btnHack.style.borderColor = mode==='hack' ? '#16A34A'  : 'rgba(0,0,0,0.08)';
    btnHack.style.background  = mode==='hack' ? 'rgba(22,163,74,0.06)'  : '';
    const loreDot = btnLore.querySelector('.mode-radio div');
    const hackDot = btnHack.querySelector('.mode-radio div');
    btnLore.querySelector('.mode-radio').style.borderColor = mode==='lore' ? '#6C2BD9' : 'rgba(0,0,0,0.2)';
    btnHack.querySelector('.mode-radio').style.borderColor = mode==='hack' ? '#16A34A' : 'rgba(0,0,0,0.2)';
    if(loreDot) loreDot.classList.toggle('hidden', mode!=='lore');
    if(hackDot) hackDot.classList.toggle('hidden', mode!=='hack');
    btnLore.setAttribute('aria-checked', mode==='lore');
    btnHack.setAttribute('aria-checked', mode==='hack');
    if(mode==='hack'){
      btnGenerate.style.background = 'linear-gradient(135deg,#16A34A,#15803d)';
      btnGenerate.style.boxShadow  = '0 4px 20px rgba(22,163,74,0.4)';
    } else {
      btnGenerate.style.background = 'linear-gradient(135deg,#6C2BD9,#7c3aed)';
      btnGenerate.style.boxShadow  = '0 4px 20px rgba(108,43,217,0.4)';
    }
  }
  btnLore.addEventListener('click', ()=> setMode('lore'));
  btnHack.addEventListener('click', ()=> setMode('hack'));
  setMode('lore');

  // ── Deep Scan ─────────────────────────────────────────
  btnDeepScan.addEventListener('click', ()=>{
    isDeepScan = !isDeepScan;
    deepScanInput.value = isDeepScan ? 'true' : 'false';
    btnDeepScan.setAttribute('aria-pressed', isDeepScan);
    if(isDeepScan){
      btnDeepScan.classList.add('active');
      deepscanTrack.style.background  = '#16A34A';
      deepscanTrack.style.borderColor = '#16A34A';
      deepscanKnob.style.left         = '20px';
      deepscanKnob.style.background   = '#fff';
      deepscanIcon.style.color        = '#4ade80';
    } else {
      btnDeepScan.classList.remove('active');
      deepscanTrack.style.background  = 'rgba(0,0,0,0.08)';
      deepscanTrack.style.borderColor = 'rgba(0,0,0,0.1)';
      deepscanKnob.style.left         = '2px';
      deepscanKnob.style.background   = '#94a3b8';
      deepscanIcon.style.color        = '';
    }
  });

  // ── Language selector ─────────────────────────────────
  const LANG_META = {
    english:  { badge:'🇬🇧 EN', desc:'Full English output — precise, clean, board-exam ready.' },
    hinglish: { badge:'🔀 HE',  desc:'Hindi + English mix — the way toppers actually talk. Natural and fast to remember.' },
    hindi:    { badge:'🇮🇳 HI', desc:'Pure Hindi output — best if you think and memorize in Hindi.' }
  };
  document.querySelectorAll('.lang-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.lang-btn').forEach(b=> b.classList.remove('active'));
      btn.classList.add('active');
      currentLanguage = btn.dataset.lang;
      languageInput.value = currentLanguage;
      langDescText.textContent = LANG_META[currentLanguage].desc;
    });
  });

  // ── Image upload — FULLY WIRED ────────────────────────
  btnUpload.addEventListener('click', ()=> fileInput.click());
  btnCamera.addEventListener('click', ()=> showToast('📷 Camera capture coming soon'));

  function loadImageFile(file){
    if(!file) return;
    if(file.size > 5 * 1024 * 1024){ showToast('❌ Image too large — max 5MB'); fileInput.value=''; return; }
    const reader = new FileReader();
    reader.onload = (e)=>{
      imageBase64 = e.target.result;
      previewThumb.src = imageBase64;
      previewFilename.textContent = file.name;
      previewFilesize.textContent = formatBytes(file.size);
      imgStrip.classList.add('visible');
      btnUpload.style.borderColor = '#6C2BD9';
      btnUpload.style.color       = '#6C2BD9';
    };
    reader.readAsDataURL(file);
  }

  fileInput.addEventListener('change', ()=> loadImageFile(fileInput.files && fileInput.files[0]));

  function clearImage(){
    imageBase64 = null; fileInput.value = '';
    previewThumb.src = ''; previewFilename.textContent = ''; previewFilesize.textContent = '';
    imgStrip.classList.remove('visible');
    btnUpload.style.borderColor = ''; btnUpload.style.color = '';
  }
  btnRemoveImg.addEventListener('click', clearImage);

  // Paste image from clipboard
  window.addEventListener('paste', (e)=>{
    if(!e.clipboardData) return;
    for(const it of e.clipboardData.items){
      if(it.type && it.type.startsWith('image/')){
        const blob = it.getAsFile();
        if(blob.size > 5*1024*1024){ showToast('❌ Pasted image too large — max 5MB'); return; }
        const dt = new DataTransfer(); dt.items.add(blob);
        fileInput.files = dt.files;
        loadImageFile(blob);
        return;
      }
    }
  });

  // ── Textarea auto-expand ──────────────────────────────
  textarea.addEventListener('input', function(){
    this.style.height='auto';
    this.style.height = Math.max(140, this.scrollHeight)+'px';
  });

  // ── Processing terminal ───────────────────────────────
  const TERMINAL = {
    lore: [
      { t:'> Reading your concept...',                    c:'#94a3b8', d:0 },
      { t:'> Mapping to your learning profile...',        c:'#a78bfa', d:700 },
      { t:'> Constructing narrative arc...',              c:'#94a3b8', d:1500 },
      { t:'> Planting memory anchors in the story...',    c:'#a78bfa', d:2600 },
      { t:'> Finalizing lore sequence...',                c:'#94a3b8', d:4000 },
    ],
    hack: [
      { t:'> Extracting concept signal...',               c:'#94a3b8', d:0 },
      { t:'> Compressing to minimum viable mnemonic...',  c:'#4ade80', d:500 },
      { t:'> Applying persona filter...',                 c:'#94a3b8', d:1200 },
      { t:'> Neural hack ready. Encoding...',             c:'#4ade80', d:2000 },
    ],
    deep: [
      { t:'> Deep Scan activated...',                     c:'#60a5fa', d:0 },
      { t:'> Cross-referencing NCERT chapter index...',   c:'#94a3b8', d:700 },
      { t:'> Pulling chapter references...',              c:'#60a5fa', d:1600 },
      { t:'> Validating academic accuracy...',            c:'#94a3b8', d:2800 },
      { t:'> Building citation-backed hook...',           c:'#60a5fa', d:4200 },
    ]
  };

  let termTimers = [];
  function runTerminal(lines){
    terminalLog.innerHTML = ''; termTimers.forEach(clearTimeout); termTimers = [];
    lines.forEach(({t,c,d})=>{
      const tid = setTimeout(()=>{
        const el = document.createElement('div');
        el.className='terminal-line'; el.style.color=c; el.textContent=t;
        terminalLog.appendChild(el); terminalLog.scrollTop=terminalLog.scrollHeight;
      }, d);
      termTimers.push(tid);
    });
  }

  function startProgress(fast){
    clearInterval(progTimer); let p=15;
    progTimer=setInterval(()=>{
      if(p<78){ p+=Math.random()*(fast?10:5); if(p>78)p=78; progressBar.style.width=Math.floor(p)+'%'; }
    }, fast?280:480);
  }
  function stopProgress(){ clearInterval(progTimer); progTimer=null; }

  // ── Render output ─────────────────────────────────────
  function renderOutput(rawData, mode, deepScan, language){
    const items = Array.isArray(rawData) ? rawData : [rawData];
    if(!items.length) return;

    // Badges
    if(deepScan){ outputModeBadge.textContent='Deep Scan'; outputModeBadge.className='badge badge-deep'; }
    else if(mode==='hack'){ outputModeBadge.textContent='Neural Hack'; outputModeBadge.className='badge badge-hack'; }
    else { outputModeBadge.textContent='Lore Engine'; outputModeBadge.className='badge badge-lore'; }
    outputLangBadge.textContent = (LANG_META[language]||LANG_META.english).badge;

    // Build cards
    aiItems.innerHTML='';
    items.forEach((json,idx)=>{
      const card = document.createElement('div');
      card.className='result-card p-5 md:p-6';
      card.style.cssText=`opacity:0;transform:translateY(12px);transition:opacity .4s ease ${idx*0.12}s,transform .4s ease ${idx*0.12}s;`;

      if(items.length>1){
        const pl=document.createElement('div');
        pl.className='text-[10px] font-bold uppercase tracking-widest mb-3 flex items-center gap-2';
        pl.style.color='#a78bfa';
        pl.innerHTML=`<i data-lucide="layers" class="w-3 h-3"></i> Part ${idx+1} of ${items.length}`;
        card.appendChild(pl);
      }

      const titleEl=document.createElement('div');
      titleEl.className='text-lg md:text-xl font-display font-bold text-brand-primary mb-3';
      titleEl.textContent=json.title||'Result';
      card.appendChild(titleEl);

      if(json.definition){
        const def=document.createElement('p');
        def.className='text-sm text-slate-600 dark:text-gray-300 leading-relaxed mb-4 pb-4 border-b border-gray-100 dark:border-white/5';
        def.textContent=json.definition;
        card.appendChild(def);
      }

      if(json.latex_formula && json.latex_formula!=='null' && json.latex_formula!==null){
        const fBox=document.createElement('div');
        fBox.className='formula-box p-4 mb-4 text-slate-800 dark:text-slate-200';
        const clean=json.latex_formula.replace(/\$\$/g,'').trim();
        try{ if(window.katex) katex.render(clean,fBox,{displayMode:true,throwOnError:false}); else fBox.textContent=json.latex_formula; }
        catch(e){ fBox.textContent=json.latex_formula; }
        card.appendChild(fBox);
      }

      if(json.hook_text){
        const hero=document.createElement('div');
        hero.className='mnemonic-hero p-5 md:p-6';
        const hl=document.createElement('div');
        hl.className='text-[10px] font-bold uppercase tracking-widest mb-3 flex items-center gap-2';
        hl.style.color='#a78bfa';
        hl.innerHTML=`<i data-lucide="${mode==='hack'?'zap':'book-open'}" class="w-3 h-3"></i> ${json.hook_label||(mode==='lore'?'Lore Engine Narrative:':'Neural Hack Mnemonic:')}`;
        hero.appendChild(hl);
        const ht=document.createElement('p');
        ht.className='text-xl md:text-2xl font-display font-bold text-slate-900 dark:text-white leading-snug mb-3';
        ht.textContent=json.hook_text;
        hero.appendChild(ht);
        if(json.hook_subtext){
          const sub=document.createElement('div');
          sub.className='pt-3 border-t border-brand-primary/10';
          const sl=document.createElement('p');
          sl.className='text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1.5';
          sl.textContent='How it maps →';
          sub.appendChild(sl);
          const st=document.createElement('p');
          st.className='text-xs text-slate-500 dark:text-gray-400 leading-relaxed font-mono';
          st.textContent=json.hook_subtext;
          sub.appendChild(st);
          hero.appendChild(sub);
        }
        card.appendChild(hero);
      }

      aiItems.appendChild(card);
      requestAnimationFrame(()=> requestAnimationFrame(()=>{
        card.style.opacity='1'; card.style.transform='translateY(0)';
      }));
    });

    lucide.createIcons();

    // Source matrix
    const allSources = items.flatMap(j=> j.source_matrix||[]);
    if(allSources.length){
      let h=`<div class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-gray-500 flex items-center gap-2 mb-3 px-1"><i data-lucide="database" class="w-3 h-3"></i> NCERT References</div>`;
      allSources.forEach((s,i)=>{
        const ac=i%2===0?'#6C2BD9':'#16A34A';
        const icon=s.icon_type==='file'?'file-text':'book-open';
        h+=`<div class="source-card glass p-3 mb-3" style="border-left-color:${ac};">
          <div class="flex items-start justify-between gap-2 mb-2">
            <p class="text-xs font-semibold text-slate-800 dark:text-slate-200 leading-tight">${s.title||'Source'}</p>
            <span class="text-[10px] font-bold whitespace-nowrap px-1.5 py-0.5 rounded flex-shrink-0" style="color:${ac};background:rgba(108,43,217,0.08);border:1px solid rgba(108,43,217,0.15);">${s.match_percentage||''}</span>
          </div>
          <div class="flex items-center gap-1.5 text-slate-400">
            <i data-lucide="${icon}" class="w-3.5 h-3.5"></i>
            <span class="text-[11px]">${icon==='file-text'?'Board Paper':'NCERT Chapter'}</span>
          </div>
        </div>`;
      });
      sourceMatrix.innerHTML=h; lucide.createIcons();
    } else {
      sourceMatrix.innerHTML='';
    }
  }

  // ── Form submit ───────────────────────────────────────
  form.addEventListener('submit', async (ev)=>{
    ev.preventDefault();
    const q = textarea.value.trim();
    if(!q){ showToast('Please type what you want to memorize'); return; }

    const isFast  = currentMode==='hack' && !isDeepScan;
    const lines   = isDeepScan ? TERMINAL.deep : (currentMode==='hack' ? TERMINAL.hack : TERMINAL.lore);

    procTitle.textContent    = isDeepScan ? 'Running Deep Scan...' : (currentMode==='hack' ? 'Hacking your concept...' : 'Crafting your lore...');
    procSubtitle.textContent = isDeepScan ? 'Deep Scan · NCERT Cross-Reference' : (currentMode==='hack' ? 'Neural Hack · Compression Mode' : 'Lore Engine · Narrative Mode');

    runTerminal(lines);
    progressBar.style.width='15%';
    startProgress(isFast);
    stateProc.setAttribute('aria-busy','true');
    switchState(stateIdle, stateProc);

    const payload = { question:q, mode:currentMode, deepScan:isDeepScan, language:currentLanguage, image:imageBase64 };
    ctrl = new AbortController();

    try{
      const res = await fetch(form.action, {
        method:'POST', headers:{'Content-Type':'application/json'},
        credentials:'include', body:JSON.stringify(payload), signal:ctrl.signal
      });
      progressBar.style.width='88%';
      if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.error||`Server error ${res.status}`); }
      const json = await res.json();
      stopProgress(); progressBar.style.width='100%';

      renderOutput(json.initial_ai_response||json, currentMode, isDeepScan, currentLanguage);
      stateProc.setAttribute('aria-busy','false');
      switchState(stateProc, stateOutput);

    } catch(err){
      stopProgress(); progressBar.style.width='0%';
      stateProc.setAttribute('aria-busy','false');
      switchState(stateProc, stateIdle);
      if(err.name==='AbortError') showToast('Cancelled.');
      else { showToast('❌ '+(err.message||'Something went wrong.')); console.error(err); }
    } finally {
      ctrl=null; termTimers.forEach(clearTimeout); termTimers=[];
    }
  });

  // ── Cancel ────────────────────────────────────────────
  btnCancel.addEventListener('click',()=>{
    if(ctrl) ctrl.abort();
    stateProc.setAttribute('aria-busy','false');
    switchState(stateProc,stateIdle);
    stopProgress(); progressBar.style.width='0%';
  });

  // ── Reset ─────────────────────────────────────────────
  btnReset.addEventListener('click',()=>{
    form.reset(); clearImage();
    aiItems.innerHTML=''; sourceMatrix.innerHTML='';
    progressBar.style.width='0%';
    switchState(stateOutput,stateIdle);
    setMode('lore'); textarea.focus();
  });

  // ── Copy / Save ───────────────────────────────────────
  btnCopy.addEventListener('click',()=>{
    const txt=aiItems.innerText||'';
    if(!txt) return showToast('Nothing to copy yet');
    navigator.clipboard.writeText(txt).then(()=>showToast('✓ Copied to clipboard'));
  });
  btnSave.addEventListener('click',()=>{
    const txt=aiItems.innerText||'';
    if(!txt) return showToast('Nothing to save yet');
    const blob=new Blob([txt],{type:'text/plain'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='boardalgo-mnemonic.txt'; a.click();
  });
  document.getElementById('btn-bookmark').addEventListener('click',()=>showToast('📌 Bookmark feature coming soon'));

  // ── Keyboard shortcut ─────────────────────────────────
  textarea.addEventListener('keydown',(e)=>{ if((e.ctrlKey||e.metaKey)&&e.key==='Enter') btnGenerate.click(); });

  // ── Reconfigure Profile modal ─────────────────────────
  btnReconfig.addEventListener('click',()=>{
    confirmModal.classList.add('open');
    document.body.style.overflow='hidden';
  });
  function closeConfirmModal(){
    confirmModal.classList.remove('open');
    document.body.style.overflow='';
  }
  modalCancelBtn.addEventListener('click', closeConfirmModal);
  confirmModal.addEventListener('click',(e)=>{ if(e.target===confirmModal) closeConfirmModal(); });

  modalConfirmBtn.addEventListener('click', async ()=>{
    modalConfirmBtn.textContent='Resetting...';
    modalConfirmBtn.disabled=true;
    try{
      // ← Change this URL to match your reset-behaviour route
      await fetch('/api/user/reset-behaviour', { method:'POST', credentials:'include' });
      // ← Change this to your onboarding/persona-setup page URL
      window.location.href='/onboarding';
    } catch(e){
      showToast('❌ Reset failed. Try again.');
      modalConfirmBtn.textContent='Yes, Reset It';
      modalConfirmBtn.disabled=false;
      closeConfirmModal();
    }
  });

  // ── GSAP entrance ─────────────────────────────────────
  gsap.to('.gsap-entry',{ y:0, opacity:1, stagger:.1, duration:.55, ease:'power2.out', delay:.05 });

  // ── Three.js background ───────────────────────────────
  let threeParticles, threeRenderer, threeScene;
  function updateThreeColors(){
    if(!threeParticles) return;
    threeParticles.material.opacity = html.classList.contains('dark') ? 0.6 : 0.2;
  }
  (function(){
    const canvas = document.getElementById('bg-canvas');
    threeRenderer = new THREE.WebGLRenderer({canvas,alpha:true});
    threeScene    = new THREE.Scene();
    const camera  = new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,1000);
    threeRenderer.setSize(innerWidth,innerHeight);
    threeRenderer.setPixelRatio(Math.min(devicePixelRatio,2));
    const count=1500, pos=new Float32Array(count*3);
    for(let i=0;i<count*3;i++) pos[i]=(Math.random()-.5)*20;
    const geo=new THREE.BufferGeometry();
    geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
    const mat=new THREE.PointsMaterial({size:.02,color:0x6C2BD9,transparent:true,opacity:.6});
    threeParticles=new THREE.Points(geo,mat);
    threeScene.add(threeParticles); camera.position.z=4;
    let mx=0,my=0;
    document.addEventListener('mousemove',e=>{ mx=e.clientX/innerWidth-.5; my=e.clientY/innerHeight-.5; });
    (function animate(){
      requestAnimationFrame(animate);
      threeParticles.rotation.y+=.0005+mx*.002;
      threeParticles.rotation.x+=.0002+my*.001;
      threeRenderer.render(threeScene,camera);
    })();
    window.addEventListener('resize',()=>{
      camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix();
      threeRenderer.setSize(innerWidth,innerHeight);
    });
    updateThreeColors();
  })();

  // ── Injected result loader ────────────────────────────
  (function(){
    if(!window.__INJECTED_RESULT__) return;
    const saved = window.__INJECTED_RESULT__;
    const raw   = saved.initial_ai_response || saved;
    const mode  = saved.generation_mode  || 'lore';
    const deep  = saved.deep_scan_enabled || false;
    const lang  = saved.language          || 'english';

    currentMode=mode; isDeepScan=deep; currentLanguage=lang;
    setMode(mode);
    if(deep) btnDeepScan.click();

    // Sync language pills
    document.querySelectorAll('.lang-btn').forEach(b=>{
      b.classList.toggle('active', b.dataset.lang===lang);
    });
    languageInput.value=lang;
    langDescText.textContent=(LANG_META[lang]||LANG_META.english).desc;

    renderOutput(raw, mode, deep, lang);
    switchState(stateIdle, stateOutput);
  })();

  </script>

  <script src="/js/tracking.js" defer></script>
</body>
</html>
