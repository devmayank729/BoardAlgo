                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 bg-white/50 dark:bg-white/5">
                  <i data-lucide="radar" class="w-4 h-4 text-slate-500 dark:text-slate-400" id="deepscan-icon"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-slate-700 dark:text-slate-200 flex items-center gap-2">
                    Deep Scan
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wider"
                      style="background:rgba(22,163,74,0.1);color:#4ade80;border:1px solid rgba(22,163,74,0.2);">Pro</span>
