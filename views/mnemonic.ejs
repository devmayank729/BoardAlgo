          </div>

          <!-- Hint row + Reconfigure -->
          <div class="gsap-entry flex flex-wrap items-center justify-between gap-3 px-1">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-slate-400 dark:text-slate-600">
              <span class="flex items-center gap-1"><i data-lucide="book-open" class="w-3 h-3"></i> Lore → long chapters</span>
              <span class="hidden sm:inline text-slate-300 dark:text-slate-700">·</span>
              <span class="flex items-center gap-1"><i data-lucide="zap" class="w-3 h-3"></i> Hack → lists &amp; formulas</span>
              <span class="hidden sm:inline text-slate-300 dark:text-slate-700">·</span>
              <span class="flex items-center gap-1"><i data-lucide="radar" class="w-3 h-3"></i> Deep Scan → before exams</span>
