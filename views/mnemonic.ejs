<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BoardAlgo | Memory Synthesizer</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

  <script>
    window.__INJECTED_RESULT__ = <%- typeof savedSolution !== "undefined" ? JSON.stringify(savedSolution) : "null" %>;
  </script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: { black:'#020617', surface:'#0f172a', border:'#1e293b', primary:'#6C2BD9', accent:'#16A34A' }
          },
          fontFamily: {
            sans:    ['Inter','sans-serif'],
            display: ['Poppins','sans-serif'],
            mono:    ['Space Mono','monospace'],
          }
        }
      }
    }
  </script>

  <style>
  .mnemonic-section-wrap {
  display: flex;
  flex-direction: column;
  gap: 0;
}


.decode-toggle-btn {
  border-radius: 10px !important;
  margin-top: 8px !important;
}
 

    /* ── Base ────────────────────────────────────────────────────── */
    body { background-color:#f8fafc; color:#0f172a; transition:background-color .3s,color .3s; overflow-x:hidden; }
    .dark body { background-color:#020617; color:#f8fafc; }

    /* ── Glass ───────────────────────────────────────────────────── */
    .glass { background:rgba(255,255,255,0.72); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); border:1px solid rgba(0,0,0,0.06); transition:all .3s ease; }
    .dark .glass { background:rgba(15,23,42,0.65); border:1px solid rgba(255,255,255,0.08); }

    /* ── Scrollbar ───────────────────────────────────────────────── */
    ::-webkit-scrollbar { width:6px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:rgba(108,43,217,0.25); border-radius:3px; }

    /* ── Glow dot ────────────────────────────────────────────────── */
    .glow-dot { width:7px; height:7px; border-radius:50%; background:#16A34A; box-shadow:0 0 6px #16A34A; display:inline-block; animation:dotpulse 2s ease-in-out infinite; }
    @keyframes dotpulse { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:.55;transform:scale(.82);} }

    /* ── Avatar ring ─────────────────────────────────────────────── */
    .avatar-ring { background:conic-gradient(#6C2BD9 0%,#a78bfa 45%,#16A34A 70%,#6C2BD9 100%); border-radius:50%; padding:2px; display:inline-flex; }
    .avatar-inner { border-radius:50%; overflow:hidden; display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:700; }

    /* ── Input ───────────────────────────────────────────────────── */
    #brain-dump { outline:none; resize:none; caret-color:#6C2BD9; }
    .input-shell:focus-within { border-color:rgba(108,43,217,0.5)!important; box-shadow:0 0 0 3px rgba(108,43,217,0.1),0 0 30px rgba(108,43,217,0.08); }

    /* ── Deep scan btn ───────────────────────────────────────────── */
    .deepscan-btn { border:2px solid rgba(0,0,0,0.08); transition:all .3s ease; }
    .dark .deepscan-btn { border-color:rgba(255,255,255,0.1); }
    .deepscan-btn.active { border-color:#16A34A!important; background:rgba(22,163,74,0.08)!important; box-shadow:0 0 20px rgba(22,163,74,0.2); }

    /* ── Lang pill ───────────────────────────────────────────────── */
    .lang-track { display:flex; background:rgba(0,0,0,0.06); border:1px solid rgba(0,0,0,0.08); border-radius:10px; padding:3px; gap:2px; }
    .dark .lang-track { background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.08); }
    .lang-btn { flex:1; padding:6px 10px; border-radius:7px; border:none; cursor:pointer; font-family:'Inter',sans-serif; font-size:.75rem; font-weight:600; transition:all .25s; white-space:nowrap; background:transparent; color:#64748b; }
    .dark .lang-btn { color:#94a3b8; }
    .lang-btn.active { background:#6C2BD9; color:#fff; box-shadow:0 2px 10px rgba(108,43,217,0.4); }
    .lang-btn:not(.active):hover { background:rgba(108,43,217,0.08); color:#6C2BD9; }

    /* ── Generate button ─────────────────────────────────────────── */
    .gen-btn { background:linear-gradient(135deg,#6C2BD9,#7c3aed); box-shadow:0 4px 20px rgba(108,43,217,0.4); transition:all .3s cubic-bezier(.34,1.56,.64,1); position:relative; overflow:hidden; }
    .gen-btn::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,0.15),transparent); border-radius:inherit; }
    .gen-btn:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(108,43,217,0.55); }
    .gen-btn:active { transform:scale(.97); }

    /* ── Spinners ────────────────────────────────────────────────── */
    #ui-state-processing { background:rgba(255,255,255,0.85); backdrop-filter:blur(20px); }
    .dark #ui-state-processing { background:rgba(2,6,23,0.92); }
    .ring-outer { border:2px solid rgba(108,43,217,0.15); animation:spin 8s linear infinite; }
    .ring-mid   { border:2px solid transparent; border-top-color:#6C2BD9; animation:spin 1.1s linear infinite; }
    .ring-inner { border:1px solid rgba(108,43,217,0.3); border-top-color:rgba(108,43,217,0.6); animation:spin .7s linear infinite reverse; }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* ── Terminal ────────────────────────────────────────────────── */
    .terminal-line { opacity:0; transform:translateY(6px); animation:termReveal .35s ease forwards; }
    @keyframes termReveal { to { opacity:1; transform:translateY(0); } }

    /* ── Progress bar ────────────────────────────────────────────── */
    #progress-bar { transition:width .5s ease; background:linear-gradient(90deg,#6C2BD9,#a855f7,#16A34A); background-size:200% 100%; animation:barShift 2s linear infinite; }
    @keyframes barShift { 0%{background-position:0 0;}100%{background-position:-200% 0;} }

    /* ── XP Bar (nav) ────────────────────────────────────────────── */
    .xp-bar-wrap {
      display:flex; align-items:center; gap:7px;
      padding:4px 10px; border-radius:8px;
      background:rgba(108,43,217,0.06); border:1px solid rgba(108,43,217,0.14);
    }
    .xp-bar-track {
      width:60px; height:4px; border-radius:2px;
      background:rgba(108,43,217,0.15); overflow:hidden;
    }
    .xp-bar-fill {
      height:100%; border-radius:2px;
      background:linear-gradient(90deg,#6C2BD9,#a855f7);
      transition:width .6s cubic-bezier(.34,1.3,.64,1);
    }
    .xp-label {
      font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
      color:#a78bfa; letter-spacing:.06em; white-space:nowrap;
    }
    .level-badge {
      font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
      padding:2px 6px; border-radius:4px; letter-spacing:.04em;
      background:rgba(108,43,217,0.14); color:#a78bfa;
      border:1px solid rgba(108,43,217,0.25);
    }

    /* ── Stats strip (under output header) ──────────────────────── */
    .stats-strip {
      display:flex; align-items:center; gap:12px; flex-wrap:wrap;
      padding:8px 20px; border-bottom:1px solid rgba(0,0,0,0.05);
      background:rgba(0,0,0,0.02);
    }
    .dark .stats-strip { background:rgba(0,0,0,0.2); border-bottom-color:rgba(255,255,255,0.04); }
    .stat-item {
      display:flex; align-items:center; gap:5px;
      font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
      color:#64748b; letter-spacing:.04em;
    }
    .dark .stat-item { color:#475569; }
    .stat-item .stat-val { color:#6C2BD9; }
    .dark .stat-item .stat-val { color:#a78bfa; }
    .stat-divider { width:1px; height:12px; background:rgba(0,0,0,0.08); }
    .dark .stat-divider { background:rgba(255,255,255,0.07); }

    /* ── XP gain toast ───────────────────────────────────────────── */
    .xp-gain-pop {
      position:fixed; right:20px; bottom:24px; z-index:600;
      display:flex; align-items:center; gap:8px;
      padding:10px 16px; border-radius:12px;
      background:rgba(108,43,217,0.92); color:#fff;
      font-family:'Space Mono',monospace; font-size:12px; font-weight:700;
      box-shadow:0 8px 30px rgba(108,43,217,0.45);
      border:1px solid rgba(255,255,255,0.15);
      animation:xpPopIn .4s cubic-bezier(.34,1.56,.64,1) forwards;
      backdrop-filter:blur(10px);
    }
    @keyframes xpPopIn {
      from { opacity:0; transform:translateY(16px) scale(.9); }
      to   { opacity:1; transform:translateY(0) scale(1); }
    }

    /* ── Achievement banner ──────────────────────────────────────── */
    .achievement-banner {
      position:fixed; top:72px; right:16px; z-index:600;
      display:flex; align-items:center; gap:10px;
      padding:12px 16px; border-radius:14px; max-width:280px;
      background:rgba(15,23,42,0.96); border:1px solid rgba(108,43,217,0.3);
      box-shadow:0 12px 40px rgba(0,0,0,0.4);
      animation:achieveIn .45s cubic-bezier(.34,1.3,.64,1) forwards;
      backdrop-filter:blur(14px);
    }
    @keyframes achieveIn {
      from { opacity:0; transform:translateX(30px); }
      to   { opacity:1; transform:translateX(0); }
    }
    .achieve-icon {
      width:36px; height:36px; border-radius:10px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center; font-size:18px;
      background:rgba(108,43,217,0.15); border:1px solid rgba(108,43,217,0.25);
    }
    .achieve-title { font-family:'Poppins',sans-serif; font-size:.78rem; font-weight:700; color:#e2e8f0; margin-bottom:2px; }
    .achieve-sub   { font-family:'Space Mono',monospace; font-size:9px; color:#64748b; letter-spacing:.04em; }

    /* ── Memory strength meter ───────────────────────────────────── */
    .memory-strength-wrap {
      display:flex; align-items:center; gap:10px;
      padding:10px 14px; border-radius:10px; margin-top:12px;
      background:rgba(22,163,74,0.05); border:1px solid rgba(22,163,74,0.12);
    }
    .dark .memory-strength-wrap { background:rgba(22,163,74,0.07); }
    .ms-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#16A34A; white-space:nowrap; }
    .ms-track { flex:1; height:5px; border-radius:3px; background:rgba(22,163,74,0.15); overflow:hidden; }
    .ms-fill   { height:100%; border-radius:3px; background:linear-gradient(90deg,#16A34A,#4ade80); width:0%; transition:width 1.2s cubic-bezier(.34,1.3,.64,1); }
    .ms-pct { font-family:'Space Mono',monospace; font-size:10px; font-weight:700; color:#16A34A; white-space:nowrap; }

    /* ── Result card ─────────────────────────────────────────────── */
    .result-card {
      border:1px solid rgba(108,43,217,0.12); border-radius:20px;
      transition:border-color .3s, box-shadow .3s;
      position:relative; overflow:hidden; background:rgba(255,255,255,0.6);
    }
    .dark .result-card { background:rgba(15,23,42,0.7); }
    .result-card::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(108,43,217,0.5),rgba(22,163,74,0.3),transparent); }
    .result-card:hover { border-color:rgba(108,43,217,0.3); box-shadow:0 12px 40px rgba(108,43,217,0.1); }

    /* ── Part header ─────────────────────────────────────────────── */
    .part-header {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:14px;
    }
    .part-label {
      font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
      text-transform:uppercase; letter-spacing:.1em; color:#a78bfa;
      display:flex; align-items:center; gap:6px;
    }
    .part-lock-badge {
      font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
      padding:2px 7px; border-radius:5px; letter-spacing:.04em;
      display:none; align-items:center; gap:4px;
    }
    .part-lock-badge.visible { display:flex; }
    .part-lock-badge.locked { background:rgba(22,163,74,0.1); color:#4ade80; border:1px solid rgba(22,163,74,0.2); }

    /* ── Formula box ─────────────────────────────────────────────── */
    .formula-box { background:linear-gradient(135deg,#08081a,#0d0a28); border:1px solid rgba(108,43,217,0.35); border-radius:14px; overflow-x:auto; position:relative; margin-bottom:20px; }
    .formula-box::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(108,43,217,0.7),rgba(168,85,247,0.4),transparent); }
    .formula-header { display:flex; align-items:center; gap:6px; padding:10px 18px 6px; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:rgba(167,139,250,0.55); border-bottom:1px solid rgba(108,43,217,0.12); }
    .formula-line { padding:10px 20px; border-bottom:1px solid rgba(255,255,255,0.04); }
    .formula-line:last-child { border-bottom:none; }
    .formula-box .katex, .formula-box .katex * { color:#e8e0ff!important; }
    .formula-box .katex .frac-line { background:#e8e0ff!important; }
    .formula-box .katex svg, .formula-box .katex svg path { color:#e8e0ff; stroke:#e8e0ff; fill:#e8e0ff; }
    .formula-box .katex-display { margin:.2em 0!important; }

    /* ── Mnemonic hero ───────────────────────────────────────────── */
    .mnemonic-hero { border-radius:14px; position:relative; overflow:hidden; padding:20px 22px; }
    .mnemonic-hero[data-mode="lore"] { background:linear-gradient(135deg,rgba(108,43,217,0.07),rgba(15,23,42,0.03)); border:1px solid rgba(108,43,217,0.18); }
    .dark .mnemonic-hero[data-mode="lore"] { background:linear-gradient(135deg,rgba(108,43,217,0.12),rgba(5,8,20,0.5)); }
    .mnemonic-hero[data-mode="hack"] { background:linear-gradient(135deg,rgba(22,163,74,0.06),rgba(5,20,8,0.03)); border:1px solid rgba(22,163,74,0.18); }
    .dark .mnemonic-hero[data-mode="hack"] { background:linear-gradient(135deg,rgba(22,163,74,0.10),rgba(3,12,6,0.5)); }
    .mnemonic-hero[data-mode="deep"] { background:linear-gradient(135deg,rgba(59,130,246,0.06),rgba(3,8,20,0.03)); border:1px solid rgba(59,130,246,0.18); }
    .dark .mnemonic-hero[data-mode="deep"] { background:linear-gradient(135deg,rgba(59,130,246,0.10),rgba(3,6,20,0.5)); }
    .mnemonic-hero::before { content:''; position:absolute; top:0; left:0; bottom:0; width:4px; border-radius:4px 0 0 4px; }
    .mnemonic-hero[data-mode="lore"]::before  { background:linear-gradient(180deg,#6C2BD9,#a855f7); }
    .mnemonic-hero[data-mode="hack"]::before  { background:linear-gradient(180deg,#16A34A,#4ade80); }
    .mnemonic-hero[data-mode="deep"]::before  { background:linear-gradient(180deg,#3b82f6,#60a5fa); }
    .mnemonic-hero::after { content:''; position:absolute; top:-50px; right:-50px; width:180px; height:180px; border-radius:50%; pointer-events:none; opacity:.5; }
    .mnemonic-hero[data-mode="lore"]::after  { background:radial-gradient(circle,rgba(108,43,217,0.15),transparent 70%); }
    .mnemonic-hero[data-mode="hack"]::after  { background:radial-gradient(circle,rgba(22,163,74,0.12),transparent 70%); }
    .mnemonic-hero[data-mode="deep"]::after  { background:radial-gradient(circle,rgba(59,130,246,0.12),transparent 70%); }
    .hook-text { line-height:1.35; position:relative; z-index:1; }
    .hook-text strong { font-weight:900; display:inline; }
    .mnemonic-hero[data-mode="lore"]  .hook-text strong { color:#6C2BD9; }
    .mnemonic-hero[data-mode="hack"]  .hook-text strong { color:#16A34A; }
    .mnemonic-hero[data-mode="deep"]  .hook-text strong { color:#3b82f6; }
    .dark .mnemonic-hero[data-mode="lore"]  .hook-text strong { color:#a78bfa; text-shadow:0 0 18px rgba(167,139,250,0.35); }
    .dark .mnemonic-hero[data-mode="hack"]  .hook-text strong { color:#4ade80; text-shadow:0 0 18px rgba(74,222,128,0.3); }
    .dark .mnemonic-hero[data-mode="deep"]  .hook-text strong { color:#60a5fa; text-shadow:0 0 18px rgba(96,165,250,0.3); }

    /* ── Mnemonic label row ──────────────────────────────────────── */
    .mnemonic-label-row { font-family:'Space Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; display:flex; align-items:center; gap:6px; margin-bottom:10px; position:relative; z-index:1; }

    /* ── Hook context teaser ─────────────────────────────────────── */
    .hook-context-text { font-size:.78rem; font-family:'Inter',sans-serif; color:#64748b; font-style:italic; line-height:1.5; margin-bottom:14px; position:relative; z-index:1; }
    .dark .hook-context-text { color:#94a3b8; }

    /* ── Acronym badge row ───────────────────────────────────────── */
    .acronym-badge-row { display:flex; align-items:center; gap:5px; flex-wrap:wrap; margin-bottom:14px; position:relative; z-index:1; }
    .acronym-row-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.6; margin-right:2px; }
    .acronym-letter-pill { width:32px; height:32px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-family:'Space Mono',monospace; font-size:.85rem; font-weight:700; flex-shrink:0; transition:all .2s; }
    .mnemonic-hero[data-mode="hack"] .acronym-letter-pill { background:rgba(22,163,74,0.12); color:#4ade80; border:1.5px solid rgba(22,163,74,0.2); }
    .mnemonic-hero[data-mode="lore"] .acronym-letter-pill { background:rgba(108,43,217,0.12); color:#a78bfa; border:1.5px solid rgba(108,43,217,0.2); }
    .mnemonic-hero[data-mode="deep"] .acronym-letter-pill { background:rgba(59,130,246,0.12); color:#60a5fa; border:1.5px solid rgba(59,130,246,0.2); }

    /* ── Word chips ──────────────────────────────────────────────── */
    .word-chips-container { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:12px; position:relative; z-index:1; }
    .word-chip {
      display:inline-flex; align-items:baseline; gap:1px;
      padding:8px 13px 8px 9px; border-radius:11px;
      cursor:pointer; font-family:'Poppins',sans-serif; font-size:1rem; font-weight:600;
      transition:transform .18s ease, box-shadow .18s ease, background .18s ease, border-color .18s ease;
      position:relative; user-select:none; -webkit-tap-highlight-color:transparent;
    }
    .mnemonic-hero[data-mode="hack"] .word-chip { background:rgba(22,163,74,0.07); border:1.5px solid rgba(22,163,74,0.15); color:#f1f5f9; }
    .mnemonic-hero[data-mode="lore"] .word-chip { background:rgba(108,43,217,0.07); border:1.5px solid rgba(108,43,217,0.15); color:#f1f5f9; }
    .mnemonic-hero[data-mode="deep"] .word-chip { background:rgba(59,130,246,0.07); border:1.5px solid rgba(59,130,246,0.15); color:#f1f5f9; }
    .mnemonic-hero[data-mode="hack"] .word-chip:hover,.mnemonic-hero[data-mode="hack"] .word-chip.chip-active { background:rgba(22,163,74,0.18); border-color:rgba(22,163,74,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(22,163,74,0.2); }
    .mnemonic-hero[data-mode="lore"] .word-chip:hover,.mnemonic-hero[data-mode="lore"] .word-chip.chip-active { background:rgba(108,43,217,0.18); border-color:rgba(108,43,217,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(108,43,217,0.2); }
    .mnemonic-hero[data-mode="deep"] .word-chip:hover,.mnemonic-hero[data-mode="deep"] .word-chip.chip-active { background:rgba(59,130,246,0.18); border-color:rgba(59,130,246,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(59,130,246,0.2); }
    .chip-key-letter { font-size:1.1em; font-weight:800; }
    .mnemonic-hero[data-mode="hack"] .chip-key-letter { color:#4ade80; }
    .mnemonic-hero[data-mode="lore"] .chip-key-letter { color:#a78bfa; }
    .mnemonic-hero[data-mode="deep"] .chip-key-letter { color:#60a5fa; }
    .chip-rest-word { font-weight:600; color:#e2e8f0; transition:opacity .25s; }
    /* locked chip state */
    .word-chip.chip-locked { border-color:rgba(22,163,74,0.5)!important; background:rgba(22,163,74,0.1)!important; }

    /* ── Test mode ───────────────────────────────────────────────── */
    .word-chips-container.test-mode .chip-rest-word { opacity:0; }
    .word-chips-container.test-mode .word-chip.chip-revealed .chip-rest-word { opacity:1!important; }
    .mnemonic-hero[data-mode="hack"] .word-chips-container.test-mode .word-chip.chip-revealed { background:rgba(22,163,74,0.22)!important; border-color:rgba(22,163,74,0.5)!important; }
    .mnemonic-hero[data-mode="lore"] .word-chips-container.test-mode .word-chip.chip-revealed { background:rgba(108,43,217,0.22)!important; border-color:rgba(108,43,217,0.5)!important; }
    .mnemonic-hero[data-mode="deep"] .word-chips-container.test-mode .word-chip.chip-revealed { background:rgba(59,130,246,0.22)!important; border-color:rgba(59,130,246,0.5)!important; }

    /* ── Test mode score bar ─────────────────────────────────────── */
    .test-score-bar {
      height:3px; border-radius:2px; background:rgba(0,0,0,0.08); overflow:hidden;
      margin-top:8px; position:relative; z-index:1;
    }
    .dark .test-score-bar { background:rgba(255,255,255,0.06); }
    .test-score-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,#16A34A,#4ade80); width:0%; transition:width .4s ease; }
    .test-score-label {
      font-family:'Space Mono',monospace; font-size:9px; color:#64748b;
      margin-top:4px; position:relative; z-index:1;
      display:flex; align-items:center; justify-content:space-between;
    }

    /* ── Chip tooltip ────────────────────────────────────────────── */
    .chip-tooltip {
      position:absolute; bottom:calc(100% + 10px); left:50%; transform:translateX(-50%);
      background:#1e293b; color:#f1f5f9; font-size:11px; font-family:'Space Mono',monospace;
      padding:7px 11px; border-radius:9px; white-space:nowrap;
      border:1px solid rgba(255,255,255,0.1); z-index:30; pointer-events:none;
      box-shadow:0 8px 24px rgba(0,0,0,0.45);
    }
    .chip-tooltip::after { content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%); border:6px solid transparent; border-top-color:#1e293b; }
    @keyframes chipTooltipIn { from{opacity:0;transform:translateX(-50%) translateY(6px);}to{opacity:1;transform:translateX(-50%) translateY(0);} }

    /* ── Mnemonic full sentence ──────────────────────────────────── */
    .mnemonic-full-sentence { font-size:.82rem; color:rgba(148,163,184,0.55); font-family:'Inter',sans-serif; font-style:italic; margin-bottom:12px; line-height:1.5; position:relative; z-index:1; }

    /* ── Test mode btn ───────────────────────────────────────────── */
    .test-mode-btn {
      padding:5px 11px; border-radius:8px; border:1px solid rgba(108,43,217,0.22);
      background:rgba(108,43,217,0.05); color:#a78bfa;
      font-size:.68rem; font-weight:700; font-family:'Space Mono',monospace;
      text-transform:uppercase; letter-spacing:.06em;
      cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:5px;
    }
    .test-mode-btn:hover { background:rgba(108,43,217,0.14); border-color:rgba(108,43,217,0.45); }
    .test-mode-btn.active { background:rgba(108,43,217,0.18); border-color:#6C2BD9; color:#c4b5fd; }

    /* ── Decode toggle ───────────────────────────────────────────── */
    .decode-toggle-btn {
      width:100%; padding:11px 14px; border-radius:10px;
      border:1px dashed rgba(0,0,0,0.15); background:rgba(0,0,0,0.04);
      color:#64748b; font-size:.7rem; font-weight:700;
      font-family:'Space Mono',monospace; text-transform:uppercase; letter-spacing:.09em;
      display:flex; align-items:center; gap:8px;
      cursor:pointer; transition:all .25s; margin-top:10px;
      position:relative; z-index:1; text-align:left;
    }
    .dark .decode-toggle-btn { border-color:rgba(255,255,255,0.1); background:rgba(0,0,0,0.18); }
    .decode-toggle-btn:hover { border-color:rgba(108,43,217,0.35); color:#a78bfa; background:rgba(108,43,217,0.06); border-style:solid; }
    .decode-toggle-btn[data-open="true"] { border-style:solid; border-color:rgba(108,43,217,0.25); color:#a78bfa; background:rgba(108,43,217,0.04); }
    .decode-toggle-hint { margin-left:auto; font-size:9px; opacity:.45; }

    /* ── Decode content ──────────────────────────────────────────── */
    .decode-content-wrapper {
      overflow:hidden; position:relative; z-index:1;
      transition:max-height .45s cubic-bezier(0.4,0,0.2,1), opacity .3s ease, margin-top .3s ease;
      max-height:900px; opacity:1; margin-top:10px;
    }
    .collapsed-decode { max-height:0!important; opacity:0!important; margin-top:0!important; }

    /* ── Decode map grid — FIXED light mode colors ───────────────── */
    .decode-map-grid {
      display:flex; flex-direction:column; gap:3px;
      padding:8px; border-radius:12px; margin-bottom:10px;
      background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.08);
    }
    .dark .decode-map-grid { background:rgba(0,0,0,0.35); border-color:rgba(255,255,255,0.06); }
    .decode-map-row {
      display:flex; align-items:center; gap:10px;
      padding:7px 10px; border-radius:8px; transition:background .15s;
    }
    .decode-map-row:hover { background:rgba(108,43,217,0.04); }
    .dark .decode-map-row:hover { background:rgba(108,43,217,0.1); }
    .decode-letter-badge {
      width:28px; height:28px; border-radius:7px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-family:'Space Mono',monospace; font-size:.75rem; font-weight:700;
    }
    .decode-letter-badge[data-mode="hack"] { background:rgba(22,163,74,0.1); color:#16A34A; border:1px solid rgba(22,163,74,0.2); }
    .decode-letter-badge[data-mode="lore"] { background:rgba(108,43,217,0.1); color:#6C2BD9; border:1px solid rgba(108,43,217,0.2); }
    .decode-letter-badge[data-mode="deep"] { background:rgba(59,130,246,0.1); color:#2563eb; border:1px solid rgba(59,130,246,0.2); }
    .dark .decode-letter-badge[data-mode="hack"] { color:#4ade80; }
    .dark .decode-letter-badge[data-mode="lore"] { color:#a78bfa; }
    .dark .decode-letter-badge[data-mode="deep"] { color:#60a5fa; }
    .decode-row-text { flex:1; display:flex; align-items:baseline; flex-wrap:wrap; gap:3px; min-width:0; }
    /* FIXED: was #e2e8f0 — invisible in light mode */
    .decode-word-label { font-family:'Poppins',sans-serif; font-weight:700; font-size:.82rem; color:#1e293b; }
    .dark .decode-word-label { color:#e2e8f0; }
    .decode-arrow { font-family:'Space Mono',monospace; font-size:.7rem; color:#94a3b8; flex-shrink:0; }
    .decode-meaning { font-family:'Space Mono',monospace; font-size:.7rem; color:#475569; line-height:1.4; flex:1; }
    .dark .decode-meaning { color:#94a3b8; }
    .decode-full-text {
      font-family:'Space Mono',monospace; font-size:.7rem; line-height:1.7;
      padding-top:10px; margin-top:4px; border-top:1px solid rgba(0,0,0,0.06);
      color:#475569;
    }
    .dark .decode-full-text { color:#94a3b8; border-top-color:rgba(255,255,255,0.06); }

    /* ── Mapping strip (lore fallback) ───────────────────────────── */
    .mapping-strip { background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.06); border-radius:10px; padding:10px 14px; position:relative; z-index:1; }
    .dark .mapping-strip { background:rgba(0,0,0,0.3); border-color:rgba(255,255,255,0.06); }

    /* ── Source card ─────────────────────────────────────────────── */
    .source-card { border-left:3px solid #6C2BD9; border-radius:12px; transition:transform .25s,box-shadow .25s; }
    .source-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(108,43,217,0.12); }

    /* ── Toast ───────────────────────────────────────────────────── */
    .toast { position:fixed; left:50%; transform:translateX(-50%); bottom:24px; background:rgba(15,23,42,0.95); color:#f1f5f9; padding:10px 18px; border-radius:10px; font-size:13px; z-index:500; border:1px solid rgba(255,255,255,0.1); backdrop-filter:blur(10px); animation:termReveal .3s ease forwards; font-family:'Inter',sans-serif; white-space:nowrap; }

    /* ── State sections ──────────────────────────────────────────── */
    .state-section { transition:opacity .3s ease; }

    /* ── Badges ──────────────────────────────────────────────────── */
    .badge { display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:99px;font-size:.68rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase; }
    .badge-lore { background:rgba(108,43,217,0.12);color:#a78bfa;border:1px solid rgba(108,43,217,0.25); }
    .badge-hack { background:rgba(22,163,74,0.1);color:#4ade80;border:1px solid rgba(22,163,74,0.2); }
    .badge-deep { background:rgba(59,130,246,0.1);color:#60a5fa;border:1px solid rgba(59,130,246,0.2); }

    /* ── Logout / reconfig ───────────────────────────────────────── */
    .logout-btn { display:flex;align-items:center;gap:6px;padding:7px 13px;border-radius:9px;border:1px solid rgba(239,68,68,0.28);background:rgba(239,68,68,0.07);color:#f87171;font-size:.8rem;font-weight:500;text-decoration:none;font-family:'Inter',sans-serif;transition:all .2s; }
    .logout-btn:hover { background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.45); }
    .reconfig-btn { display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:8px;font-size:.75rem;font-weight:600;border:1px solid rgba(239,68,68,0.22);background:rgba(239,68,68,0.05);color:#f87171;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s; }
    .reconfig-btn:hover { background:rgba(239,68,68,0.12);border-color:rgba(239,68,68,0.4); }

    /* ── Confirm modal ───────────────────────────────────────────── */
    #confirm-modal { position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.55);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:1rem; }
    #confirm-modal.open { display:flex; }
    #confirm-modal-box { background:#fff;border-radius:20px;padding:2rem;max-width:380px;width:100%;box-shadow:0 24px 60px rgba(0,0,0,0.2);border:1px solid rgba(0,0,0,0.06);animation:termReveal .3s ease; }
    .dark #confirm-modal-box { background:#0f172a;border-color:rgba(255,255,255,0.08); }

    /* ── Image preview ───────────────────────────────────────────── */
    #img-preview-strip { display:none;align-items:center;gap:10px;padding:8px 16px;border-top:1px solid rgba(0,0,0,0.05);background:rgba(108,43,217,0.03); }
    .dark #img-preview-strip { border-top-color:rgba(255,255,255,0.05);background:rgba(108,43,217,0.05); }
    #img-preview-strip.visible { display:flex; }
    #preview-thumb { width:52px;height:52px;object-fit:cover;border-radius:8px;border:2px solid rgba(108,43,217,0.3);flex-shrink:0; }

    /* ── GSAP entry ──────────────────────────────────────────────── */
    .gsap-entry { opacity:0; transform:translateY(16px); }

    /* ── Action bar ──────────────────────────────────────────────── */
    .action-bar-btn { display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:10px;border:1px solid rgba(0,0,0,0.08);background:rgba(255,255,255,0.7);color:#64748b;font-size:.8rem;font-weight:600;font-family:'Inter',sans-serif;transition:all .25s;cursor:pointer; }
    .dark .action-bar-btn { background:rgba(15,23,42,0.7);border-color:rgba(255,255,255,0.08);color:#94a3b8; }
    .action-bar-btn:hover { border-color:rgba(108,43,217,0.4);color:#6C2BD9;transform:translateY(-1px);box-shadow:0 4px 12px rgba(108,43,217,0.1); }

    /* ── Def text ────────────────────────────────────────────────── */
    .def-text { font-size:.9rem;color:#475569;line-height:1.7;border-bottom:1px solid rgba(0,0,0,0.06);padding-bottom:16px;margin-bottom:18px; }
    .dark .def-text { color:#94a3b8;border-bottom-color:rgba(255,255,255,0.06); }

    /* ── Tip banner ──────────────────────────────────────────────── */
    .tip-banner { display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:10px;margin-top:14px;background:rgba(108,43,217,0.05);border:1px solid rgba(108,43,217,0.1);font-size:.72rem;color:#94a3b8;font-family:'Inter',sans-serif; }

    /* ── Chip pop ────────────────────────────────────────────────── */
    @keyframes chipPop { 0%{transform:scale(1.18) translateY(-3px);}60%{transform:scale(.96) translateY(0);}100%{transform:scale(1) translateY(0);} }
    .chip-pop { animation:chipPop .3s ease; }

    /* ── Streak badge ────────────────────────────────────────────── */
    .streak-pill {
      display:inline-flex; align-items:center; gap:4px;
      padding:2px 8px; border-radius:99px;
      font-family:'Space Mono',monospace; font-size:9px; font-weight:700; letter-spacing:.04em;
      background:rgba(251,191,36,0.1); color:#f59e0b; border:1px solid rgba(251,191,36,0.2);
    }
  </style>
</head>

<body class="antialiased min-h-screen flex flex-col relative">

  <canvas id="bg-canvas" class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none" style="opacity:0.35;"></canvas>
  <div class="fixed inset-0 -z-10 pointer-events-none dark:opacity-100 opacity-0 transition-opacity duration-500" style="background:radial-gradient(ellipse 80% 50% at 50% -20%,rgba(108,43,217,0.12),transparent);"></div>

  <!-- ══════ CONFIRM MODAL ══════ -->
  <div id="confirm-modal" role="dialog" aria-modal="true">
    <div id="confirm-modal-box">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(239,68,68,0.1);">
          <i data-lucide="refresh-cw" class="w-5 h-5 text-red-400"></i>
        </div>
        <div>
          <h3 class="font-display font-bold text-slate-900 dark:text-white text-base">Reconfigure Profile?</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">This will reset your learning persona</p>
        </div>
      </div>
      <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed mb-5">Your current psychographic profile will be deleted and you'll answer the setup questions again. Your history and saved hooks <strong>won't</strong> be affected.</p>
      <div class="flex gap-3">
        <button id="modal-cancel-btn" class="flex-1 py-2.5 rounded-xl border border-gray-200 dark:border-white/10 text-slate-600 dark:text-slate-300 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">Keep Profile</button>
        <button id="modal-confirm-btn" class="flex-1 py-2.5 rounded-xl text-white text-sm font-bold transition-all" style="background:linear-gradient(135deg,#dc2626,#b91c1c);box-shadow:0 4px 14px rgba(220,38,38,0.35);">Yes, Reset It</button>
      </div>
    </div>
  </div>

  <!-- ══════ NAV ══════ -->
  <nav class="fixed top-0 w-full z-50 glass" style="border-bottom:1px solid rgba(0,0,0,0.05);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 gap-2 sm:gap-4">
        <div class="flex items-center gap-3 min-w-0 flex-shrink-0">
          <a href="/dashboard" class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400 hover:text-brand-primary transition-colors text-sm font-medium">
            <i data-lucide="arrow-left" class="w-4 h-4"></i><span class="hidden sm:inline">Dashboard</span>
          </a>
          <span class="text-slate-300 dark:text-slate-700">|</span>
          <a href="/" class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center text-white font-bold font-display text-base" style="background:linear-gradient(135deg,#6C2BD9,#a855f7);box-shadow:0 3px 10px rgba(108,43,217,0.4);">B</div>
            <span class="text-xl font-bold font-display tracking-tight text-slate-900 dark:text-white">BOARD <span class="text-brand-primary">Algo</span></span>
          </a>
        </div>
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <!-- XP Bar -->
          <div class="xp-bar-wrap hidden sm:flex" id="nav-xp-wrap">
            <span class="level-badge" id="nav-level">LVL 1</span>
            <div class="xp-bar-track"><div class="xp-bar-fill" id="nav-xp-fill" style="width:0%"></div></div>
            <span class="xp-label" id="nav-xp-label">0 XP</span>
          </div>
          <button id="theme-toggle" class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-slate-500 dark:text-gray-400 transition-colors">
            <i data-lucide="sun"  class="hidden dark:block w-4 h-4 sm:w-5 sm:h-5"></i>
            <i data-lucide="moon" class="block dark:hidden w-4 h-4 sm:w-5 sm:h-5"></i>
          </button>
          <a href="/auth/logout" class="logout-btn hidden sm:flex">
            <i data-lucide="log-out" class="w-3.5 h-3.5"></i><span>Logout</span>
          </a>
          <div class="flex items-center gap-2 sm:gap-3 pl-2 sm:pl-3 border-l border-gray-200 dark:border-gray-800">
            <div class="text-right hidden sm:block">
              <p class="text-sm font-semibold text-slate-900 dark:text-white leading-tight"><%= user.username %></p>
              <p class="text-xs font-medium mt-0.5" style="color:#6C2BD9;"><% if(user.subscription_status==='ACTIVE'){%>Pro Member<%}else{%>Free Trial<%}%></p>
            </div>
            <%if(user.photoURL){%>
            <div class="avatar-ring flex-shrink-0" style="width:36px;height:36px;"><div class="avatar-inner" style="width:100%;height:100%;"><img src="<%=user.photoURL%>" style="width:100%;height:100%;object-fit:cover;"></div></div>
            <%}else{%>
            <div class="h-9 w-9 rounded-full flex-shrink-0 flex items-center justify-center text-white font-bold font-display text-base" style="background:linear-gradient(135deg,rgba(108,43,217,0.8),rgba(168,85,247,0.7));border:2px solid rgba(108,43,217,0.4);"><%=user.username.charAt(0).toUpperCase()%></div>
            <%}%>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══════ MAIN ══════ -->
  <main class="flex-grow pt-20 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">

      <div class="gsap-entry text-center pt-8 pb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-4 text-xs font-semibold" style="background:rgba(108,43,217,0.08);border:1px solid rgba(108,43,217,0.2);color:#a78bfa;">
          <span class="glow-dot"></span> BoardAlgo AI · Memory Synthesizer
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white tracking-tight mb-3">
          Never forget a concept.<br class="hidden sm:block">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Ever again.</span>
        </h1>
        <p class="text-slate-500 dark:text-gray-400 text-sm sm:text-base max-w-lg mx-auto leading-relaxed">
          Type what you want to memorize. BoardAlgo AI turns it into a trick your brain cannot unsee.
        </p>
      </div>

      <!-- ══════ STATE: IDLE ══════ -->
      <section id="ui-state-idle" class="state-section gsap-entry">
        <form id="mnemonic-form" action="/api/generate-mnemonic" method="POST" autocomplete="off" novalidate>

          <div class="glass input-shell rounded-2xl overflow-hidden mb-4">
            <textarea id="brain-dump" name="question"
              class="w-full min-h-[140px] bg-transparent text-slate-900 dark:text-white p-5 pb-3 font-sans text-base placeholder-slate-400 dark:placeholder-slate-500 leading-relaxed"
              placeholder="e.g. I want to memorize s-block elements of the periodic table..."
              required></textarea>
            <div id="img-preview-strip">
              <img id="preview-thumb" src="" alt="Preview" />
              <div class="flex-1 min-w-0">
                <p id="preview-filename" class="text-xs font-semibold text-slate-700 dark:text-slate-200 truncate"></p>
                <p id="preview-filesize" class="text-[11px] text-slate-400 mt-0.5"></p>
              </div>
              <button id="btn-remove-img" type="button" class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-slate-400 hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all">
                <i data-lucide="x" class="w-3.5 h-3.5"></i>
              </button>
            </div>
            <div class="flex flex-wrap items-center justify-between px-4 py-3 border-t border-gray-100 dark:border-white/5 bg-black/2 dark:bg-black/20 gap-2">
              <div class="flex items-center gap-2">
                <button id="btn-camera" type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 dark:border-white/8 bg-white/60 dark:bg-white/5 text-slate-500 hover:text-brand-primary hover:border-brand-primary/40 transition-all text-xs font-medium">
                  <i data-lucide="camera" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">Scan Photo</span>
                </button>
                <button id="btn-upload" type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 dark:border-white/8 bg-white/60 dark:bg-white/5 text-slate-500 hover:text-brand-primary hover:border-brand-primary/40 transition-all text-xs font-medium">
                  <i data-lucide="image" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">Upload Image</span>
                </button>
                <input id="file-input" name="image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" class="hidden" />
              </div>
              <span class="text-xs text-slate-400 dark:text-slate-600 font-medium flex items-center gap-1">
                <i data-lucide="command" class="w-3 h-3"></i>+Enter to generate
              </span>
            </div>
          </div>

          <div class="glass rounded-2xl p-5 mb-4">
            <p class="text-xs font-semibold text-slate-500 dark:text-gray-400 uppercase tracking-widest mb-3">Choose your weapon</p>
            <div class="flex gap-3 mb-5">
              <button id="btn-lore" type="button" role="radio" aria-checked="true"
                class="mode-btn flex-1 flex flex-col items-start p-4 rounded-xl border-2 transition-all duration-300 text-left focus:outline-none"
