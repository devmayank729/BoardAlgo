  </main>

  <!-- ══════════════ SCRIPTS ══════════════ -->
  <script>
  lucide.createIcons();

  // ── Theme ──────────────────────────────────────────────────────────────────
  const html = document.documentElement;
  (function(){
    const s = localStorage.theme;
    if(s==='dark'||(!s&&window.matchMedia('(prefers-color-scheme: dark)').matches)) html.classList.add('dark');
    else html.classList.remove('dark');
  })();
  document.getElementById('theme-toggle').addEventListener('click',()=>{
    html.classList.toggle('dark');
    localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
    if(typeof updateThreeColors==='function') updateThreeColors();
  });

  // ── DOM refs ───────────────────────────────────────────────────────────────
  const form            = document.getElementById('mnemonic-form');
  const textarea        = document.getElementById('brain-dump');
  const fileInput       = document.getElementById('file-input');
  const imgStrip        = document.getElementById('img-preview-strip');
  const previewThumb    = document.getElementById('preview-thumb');
  const previewFilename = document.getElementById('preview-filename');
  const previewFilesize = document.getElementById('preview-filesize');
  const btnRemoveImg    = document.getElementById('btn-remove-img');
  const btnUpload       = document.getElementById('btn-upload');
  const btnCamera       = document.getElementById('btn-camera');
  const btnLore         = document.getElementById('btn-lore');
  const btnHack         = document.getElementById('btn-hack');
  const modeInput       = document.getElementById('mode-input');
  const btnDeepScan     = document.getElementById('btn-deepscan');
  const deepScanInput   = document.getElementById('deepscan-input');
  const deepscanTrack   = document.getElementById('deepscan-track');
  const deepscanKnob    = document.getElementById('deepscan-knob');
  const deepscanIcon    = document.getElementById('deepscan-icon');
  const languageInput   = document.getElementById('language-input');
  const langDescText    = document.getElementById('lang-desc-text');
  const outputLangBadge = document.getElementById('output-lang-badge');
  const btnGenerate     = document.getElementById('btn-generate');
  const stateIdle       = document.getElementById('ui-state-idle');
  const stateProc       = document.getElementById('ui-state-processing');
  const stateOutput     = document.getElementById('ui-state-output');
  const progressBar     = document.getElementById('progress-bar');
  const terminalLog     = document.getElementById('terminal-log');
  const procTitle       = document.getElementById('proc-title');
  const procSubtitle    = document.getElementById('proc-subtitle');
  const aiItems         = document.getElementById('ai-items-container');
  const sourceMatrix    = document.getElementById('source-matrix-container');
  const outputModeBadge = document.getElementById('output-mode-badge');
  const streakBadge     = document.getElementById('streak-badge');
  const btnCancel       = document.getElementById('btn-cancel');
  const btnReset        = document.getElementById('btn-reset');
  const btnCopy         = document.getElementById('btn-copy-output');
  const btnSave         = document.getElementById('btn-save-txt');
  const btnReconfig     = document.getElementById('btn-reconfig');
  const confirmModal    = document.getElementById('confirm-modal');
  const modalCancelBtn  = document.getElementById('modal-cancel-btn');
  const modalConfirmBtn = document.getElementById('modal-confirm-btn');

  // ── App state ──────────────────────────────────────────────────────────────
  let currentMode     = 'lore';
  let isDeepScan      = false;
  let currentLanguage = 'english';
  let ctrl            = null;
  let progTimer       = null;
  let imageBase64     = null;

  // ── XP / Gamification state (session-persistent) ───────────────────────────
  const G = {
    xp:          parseInt(sessionStorage.getItem('ba_xp')       || '0'),
    locked:      parseInt(sessionStorage.getItem('ba_locked')    || '0'),
    tests:       parseInt(sessionStorage.getItem('ba_tests')     || '0'),
    streak:      parseInt(localStorage.getItem('ba_streak')      || '1'),
    lastDay:     localStorage.getItem('ba_lastday')              || '',
    achievements: JSON.parse(sessionStorage.getItem('ba_ach')    || '[]'),
  };

  // XP thresholds per level
  const XP_LEVELS = [0,50,130,250,420,650,950,1350,1900,2600,3500];
  function getLevel(xp){ let l=1; for(let i=1;i<XP_LEVELS.length;i++){ if(xp>=XP_LEVELS[i]) l=i+1; else break; } return Math.min(l,XP_LEVELS.length); }
  function getLevelXP(xp){ const l=getLevel(xp); const base=XP_LEVELS[l-1]; const next=XP_LEVELS[l]||XP_LEVELS[XP_LEVELS.length-1]+1000; return {base,next,pct:Math.round((xp-base)/(next-base)*100)}; }

  function saveG(){
    sessionStorage.setItem('ba_xp',G.xp);
    sessionStorage.setItem('ba_locked',G.locked);
    sessionStorage.setItem('ba_tests',G.tests);
    sessionStorage.setItem('ba_ach',JSON.stringify(G.achievements));
    localStorage.setItem('ba_streak',G.streak);
    localStorage.setItem('ba_lastday',G.lastDay);
  }

  function updateNavXP(){
    const l = getLevel(G.xp);
    const {pct} = getLevelXP(G.xp);
    document.getElementById('nav-level').textContent = `LVL ${l}`;
    document.getElementById('nav-xp-fill').style.width = pct + '%';
    document.getElementById('nav-xp-label').textContent = G.xp + ' XP';
  }

  function updateStatStrip(){
    document.getElementById('stat-locked').textContent   = G.locked;
    document.getElementById('stat-xp-earned').textContent = G.xp;
    document.getElementById('stat-tests').textContent    = G.tests;
  }

  function gainXP(amount, reason){
    const oldLevel = getLevel(G.xp);
    G.xp += amount;
    const newLevel = getLevel(G.xp);
    saveG();
    updateNavXP();
    updateStatStrip();
    showXPGain('+' + amount + ' XP  ·  ' + reason);
    if(newLevel > oldLevel) showAchievement('⚡', 'Level Up!', 'You reached Level ' + newLevel);
  }

  function showXPGain(msg){
    const el = document.createElement('div');
    el.className = 'xp-gain-pop';
    el.innerHTML = `<i data-lucide="star" style="width:14px;height:14px;"></i> ${msg}`;
    document.body.appendChild(el);
    lucide.createIcons();
    setTimeout(()=>{ el.style.transition='opacity .4s ease'; el.style.opacity='0'; setTimeout(()=>el.remove(),400); }, 2200);
  }

  // Achievement definitions
  const ACHIEVEMENTS = {
    first_hook:    { icon:'🎯', title:'First Hook!',       sub:'Welcome to BoardAlgo AI' },
    five_hooks:    { icon:'🔥', title:'On Fire!',          sub:'5 hooks generated today'  },
    first_test:    { icon:'🧠', title:'Memory Tested!',    sub:'Completed your first test' },
    perfect_test:  { icon:'⭐', title:'Perfect Recall!',   sub:'100% in test mode'         },
    five_tests:    { icon:'🏆', title:'Test Champion!',    sub:'5 tests passed'            },
    deep_scan:     { icon:'🔬', title:'Deep Researcher!',  sub:'First Deep Scan used'      },
  };

  function triggerAchievement(key){
    if(G.achievements.includes(key)) return;
    G.achievements.push(key);
    saveG();
    const a = ACHIEVEMENTS[key];
    if(a) showAchievement(a.icon, a.title, a.sub);
  }

  function showAchievement(icon, title, sub){
    const el = document.createElement('div');
    el.className = 'achievement-banner';
    el.innerHTML = `<div class="achieve-icon">${icon}</div><div><div class="achieve-title">${title}</div><div class="achieve-sub">ACHIEVEMENT UNLOCKED · ${sub.toUpperCase()}</div></div>`;
    document.body.appendChild(el);
    setTimeout(()=>{ el.style.transition='opacity .5s ease,transform .5s ease'; el.style.opacity='0'; el.style.transform='translateX(30px)'; setTimeout(()=>el.remove(),500); }, 3500);
  }

  // Streak check
  (function(){
    const today = new Date().toDateString();
    if(G.lastDay !== today){
      const yesterday = new Date(Date.now()-86400000).toDateString();
      if(G.lastDay === yesterday) G.streak++;
      else if(G.lastDay !== '') G.streak = 1;
      G.lastDay = today;
      saveG();
    }
    if(G.streak > 1){
      streakBadge.textContent = `🔥 ${G.streak} day streak`;
      streakBadge.classList.remove('hidden');
    }
    updateNavXP();
    updateStatStrip();
  })();

  // ── Helpers ────────────────────────────────────────────────────────────────
  function showToast(msg, ms=1800){
    const t = document.createElement('div'); t.className='toast'; t.textContent=msg;
    document.body.appendChild(t);
    setTimeout(()=>{ if(t.parentNode) t.parentNode.removeChild(t); }, ms);
  }

  function switchState(hide, show){
    hide.style.opacity='0';
    setTimeout(()=>{
      hide.classList.add('hidden'); hide.classList.remove('flex');
      show.classList.remove('hidden'); void show.offsetWidth; show.style.opacity='1';
    }, 280);
  }

  function formatBytes(b){ if(b<1024) return b+' B'; if(b<1048576) return (b/1024).toFixed(1)+' KB'; return (b/1048576).toFixed(1)+' MB'; }

  function mdBold(raw){
    if(!raw) return '';
    const safe = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    return safe.replace(/\*\*([^*\n]+?)\*\*/g,'<strong>$1</strong>');
  }

  function renderLatexBlock(rawFormula, containerEl){
    if(!window.katex){ const pre=document.createElement('pre'); pre.style.cssText='font-size:.8rem;color:#e8e0ff;padding:8px 16px;white-space:pre-wrap;'; pre.textContent=rawFormula; containerEl.appendChild(pre); return; }
    const lines = rawFormula.split(/\n+/).map(l=>l.replace(/\$\$/g,'').trim()).filter(Boolean);
    lines.forEach(line=>{ const row=document.createElement('div'); row.className='formula-line'; try{ katex.render(line,row,{displayMode:true,throwOnError:false,strict:false}); }catch(e){ row.style.cssText='font-family:Space Mono,monospace;font-size:.85rem;color:#e8e0ff;opacity:.8;'; row.textContent=line; } containerEl.appendChild(row); });
  }

  // ── Confetti ───────────────────────────────────────────────────────────────
  function fireConfetti(x, y){
    const canvas = document.createElement('canvas');
    canvas.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:200;';
    document.body.appendChild(canvas);
    const ctx=canvas.getContext('2d'); canvas.width=innerWidth; canvas.height=innerHeight;
    const colors=['#6C2BD9','#a78bfa','#16A34A','#4ade80','#f472b6','#fbbf24','#38bdf8'];
    const cx = x || canvas.width/2, cy = y || canvas.height/3;
    const pieces=Array.from({length:60},()=>({ x:cx, y:cy, r:3+Math.random()*5, color:colors[Math.floor(Math.random()*colors.length)], vx:(Math.random()-.5)*8, vy:-4-Math.random()*6, rot:Math.random()*360, vr:(Math.random()-.5)*14 }));
    let frame; const start=Date.now();
    function draw(){ ctx.clearRect(0,0,canvas.width,canvas.height); const elapsed=Date.now()-start; pieces.forEach(p=>{ p.x+=p.vx; p.y+=p.vy; p.rot+=p.vr; p.vy+=0.1; ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot*Math.PI/180); ctx.fillStyle=p.color; ctx.globalAlpha=Math.max(0,1-elapsed/2000); ctx.fillRect(-p.r,-p.r/2,p.r*2,p.r); ctx.restore(); }); if(elapsed<2000) frame=requestAnimationFrame(draw); else{ cancelAnimationFrame(frame); if(canvas.parentNode) document.body.removeChild(canvas); } }
    draw();
  }

  // ── Build mnemonic section ─────────────────────────────────────────────────
  function buildMnemonicSection(json, heroMode, labelColor, labelIcon, defaultLabel, cardEl) {
 
    // Outer wrapper — no overflow restriction
    const wrap = document.createElement('div');
    wrap.className = 'mnemonic-section-wrap';
 
    // Hero — keeps overflow:hidden for gradient/glow effects
    const hero = document.createElement('div');
    hero.className = 'mnemonic-hero';
    hero.dataset.mode = heroMode;
    wrap.appendChild(hero);
 
    // Label row
    const hl = document.createElement('div');
    hl.className = 'mnemonic-label-row';
    hl.style.color = labelColor;
    hl.innerHTML = `<i data-lucide="${labelIcon}" class="w-3 h-3"></i> ${json.hook_label || defaultLabel}`;
    hero.appendChild(hl);
 
    // Context teaser
    if (json.hook_context) {
      const ctx = document.createElement('p');
      ctx.className = 'hook-context-text';
      ctx.textContent = json.hook_context;
      hero.appendChild(ctx);
    }
 
    const hasChips = Array.isArray(json.word_chips) && json.word_chips.length > 0;
 
    if (hasChips) {
 
      // Acronym key row
      if (json.acronym_key) {
        const akRow = document.createElement('div');
        akRow.className = 'acronym-badge-row';
        const akLabel = document.createElement('span');
        akLabel.className = 'acronym-row-label';
        akLabel.style.color = labelColor;
        akLabel.textContent = 'Key →';
        akRow.appendChild(akLabel);
        [...json.acronym_key].forEach(l => {
          const p = document.createElement('span');
          p.className = 'acronym-letter-pill';
          p.textContent = l;
          akRow.appendChild(p);
        });
        hero.appendChild(akRow);
      }
 
      // Word chips
      const chipsContainer = document.createElement('div');
      chipsContainer.className = 'word-chips-container';
      let revealedCount = 0;
      const totalChips = json.word_chips.length;
 
      // Score bar (below chips, inside hero)
      const scoreBarWrap = document.createElement('div');
      scoreBarWrap.innerHTML = `
        <div class="test-score-bar"><div class="test-score-fill"></div></div>
        <div class="test-score-label" style="display:none;">
          <span>Tap each word to reveal</span>
          <span class="test-score-pct">0 / ${totalChips}</span>
        </div>`;
 
      json.word_chips.forEach((chipData, idx) => {
        const chip = document.createElement('div');
        chip.className = 'word-chip';
        chip.innerHTML = `<span class="chip-key-letter">${chipData.letter || '?'}</span><span class="chip-rest-word">${chipData.rest || ''}</span>`;
        chip.style.opacity = '0';
        chip.style.transform = 'translateY(10px)';
        setTimeout(() => {
          chip.style.transition = 'opacity .3s ease, transform .3s ease';
          chip.style.opacity = '1';
          chip.style.transform = 'translateY(0)';
        }, 60 + idx * 45);
 
        chip.addEventListener('click', () => {
          const isTestMode = chipsContainer.classList.contains('test-mode');
          if (isTestMode) {
            if (!chip.classList.contains('chip-revealed')) {
              chip.classList.add('chip-revealed', 'chip-pop');
              setTimeout(() => chip.classList.remove('chip-pop'), 300);
              revealedCount++;
              const pct = Math.round(revealedCount / totalChips * 100);
              const fill = scoreBarWrap.querySelector('.test-score-fill');
              const pctLabel = scoreBarWrap.querySelector('.test-score-pct');
              if (fill) fill.style.width = pct + '%';
              if (pctLabel) pctLabel.textContent = `${revealedCount} / ${totalChips}`;
              if (revealedCount === totalChips) {
                G.tests++;
                saveG();
                updateStatStrip();
                gainXP(25, 'Test passed');
                triggerAchievement('first_test');
                if (G.tests >= 5) triggerAchievement('five_tests');
                triggerAchievement('perfect_test');
                setTimeout(() => {
                  const rect = chip.getBoundingClientRect();
                  fireConfetti(rect.left, rect.top);
                  showToast('Memory locked! +25 XP', 2800);
                  showMemoryStrength(cardEl, 100);
                  chipsContainer.querySelectorAll('.word-chip').forEach(c => c.classList.add('chip-locked'));
                }, 200);
              }
            }
          } else {
            // Tooltip mode
            chipsContainer.querySelectorAll('.chip-tooltip').forEach(t => t.remove());
            chipsContainer.querySelectorAll('.word-chip.chip-active').forEach(c => c.classList.remove('chip-active'));
            if (!chip.classList.contains('chip-active')) {
              const mapsTo = (chipData.maps_to && chipData.maps_to.trim())
                ? chipData.maps_to
                : `${chipData.letter} — see decode below`;
              const tooltip = document.createElement('div');
              tooltip.className = 'chip-tooltip';
              tooltip.style.animation = 'chipTooltipIn .2s ease forwards';
              tooltip.innerHTML = `<span style="font-weight:700;color:${labelColor};">${chipData.letter}</span>&nbsp;→&nbsp;${mapsTo}`;
              chip.appendChild(tooltip);
              chip.classList.add('chip-active');
              setTimeout(() => { tooltip.remove(); chip.classList.remove('chip-active'); }, 3500);
            }
          }
        });
        chipsContainer.appendChild(chip);
      });
 
      hero.appendChild(chipsContainer);
 
      // Full mnemonic sentence (small italic)
      if (json.hook_text) {
        const s = document.createElement('p');
        s.className = 'mnemonic-full-sentence';
        s.textContent = json.hook_text;
        hero.appendChild(s);
      }
 
      // Test mode row
      const testRow = document.createElement('div');
      testRow.style.cssText = 'display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:4px;position:relative;z-index:1;';
      const testBtn = document.createElement('button');
      testBtn.className = 'test-mode-btn';
      testBtn.type = 'button';
      testBtn.innerHTML = `<i data-lucide="brain-circuit" class="w-3 h-3"></i> Test Me`;
      testBtn.addEventListener('click', () => {
        const isTest = chipsContainer.classList.toggle('test-mode');
        testBtn.classList.toggle('active', isTest);
        testBtn.innerHTML = isTest
          ? `<i data-lucide="eye" class="w-3 h-3"></i> Show All`
          : `<i data-lucide="brain-circuit" class="w-3 h-3"></i> Test Me`;
        lucide.createIcons();
        const scoreLabel = scoreBarWrap.querySelector('.test-score-label');
        if (scoreLabel) scoreLabel.style.display = isTest ? 'flex' : 'none';
        if (isTest) {
          revealedCount = 0;
          const fill = scoreBarWrap.querySelector('.test-score-fill');
          const pctLabel = scoreBarWrap.querySelector('.test-score-pct');
          if (fill) fill.style.width = '0%';
          if (pctLabel) pctLabel.textContent = `0 / ${totalChips}`;
          chipsContainer.querySelectorAll('.word-chip').forEach(c => {
            c.classList.remove('chip-revealed', 'chip-active', 'chip-locked');
            c.querySelectorAll('.chip-tooltip').forEach(t => t.remove());
          });
          showToast('Tap each word to recall the mapping', 2000);
        }
      });
      const tiphint = document.createElement('span');
      tiphint.style.cssText = `font-family:'Space Mono',monospace;font-size:9px;color:#94a3b8;letter-spacing:.04em;`;
      tiphint.textContent = 'tap any word · reveal mapping';
      testRow.appendChild(testBtn);
      testRow.appendChild(tiphint);
      hero.appendChild(testRow);
      hero.appendChild(scoreBarWrap);
 
    } else {
      // Lore / non-acronym
      const ht = document.createElement('p');
      ht.className = 'hook-text text-xl md:text-2xl font-display font-bold text-slate-900 dark:text-white leading-snug mb-4';
      ht.innerHTML = mdBold(json.hook_text || '');
      hero.appendChild(ht);
    }
 
    // ── Decode section — OUTSIDE the hero (fixes overflow:hidden clipping) ──
 
    const subtext = (json.hook_subtext || '').trim();
    const hasDecodeContent = hasChips || subtext.length > 0;
 
    if (hasDecodeContent) {
 
      // Build decode content div FIRST
      const decodeContent = document.createElement('div');
      decodeContent.className = 'decode-content-wrapper collapsed-decode';
      // Explicit background so it's never transparent-on-transparent
      decodeContent.style.cssText = `
        background: var(--decode-bg, transparent);
        border-radius: 12px;
        margin-top: 0;
      `;
 
      if (hasChips) {
        const mapGrid = document.createElement('div');
        mapGrid.className = 'decode-map-grid';
 
        json.word_chips.forEach(chipData => {
          const row = document.createElement('div');
          row.className = 'decode-map-row';
 
          const badge = document.createElement('div');
          badge.className = 'decode-letter-badge';
          badge.dataset.mode = heroMode;
          badge.textContent = chipData.letter || '?';
 
          const textPart = document.createElement('div');
          textPart.className = 'decode-row-text';
 
          const wordLabel = document.createElement('span');
          wordLabel.className = 'decode-word-label';
          wordLabel.textContent = (chipData.letter || '') + (chipData.rest || '');
 
          const arrow = document.createElement('span');
          arrow.className = 'decode-arrow';
          arrow.textContent = ' → ';
 
          const meaning = document.createElement('span');
          meaning.className = 'decode-meaning';
          meaning.textContent = (chipData.maps_to && chipData.maps_to.trim())
            ? chipData.maps_to
            : `${chipData.letter} — tap chip above for details`;
 
          textPart.appendChild(wordLabel);
          textPart.appendChild(arrow);
          textPart.appendChild(meaning);
          row.appendChild(badge);
          row.appendChild(textPart);
          mapGrid.appendChild(row);
        });
 
        decodeContent.appendChild(mapGrid);
 
        // Full subtext note
        const fullNote = document.createElement('p');
        fullNote.className = 'decode-full-text';
        fullNote.innerHTML = subtext
          ? mdBold(subtext)
          : json.word_chips.map(c => `[${c.letter}]${c.rest} = ${c.maps_to || c.letter}`).join('  ·  ');
        decodeContent.appendChild(fullNote);
 
      } else {
        // Plain subtext (Lore or non-acronym)
        const mapWrap = document.createElement('div');
        mapWrap.className = 'mapping-strip';
 
        const ml = document.createElement('p');
        ml.style.cssText = `font-family:'Space Mono',monospace;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:${labelColor};display:flex;align-items:center;gap:5px;margin-bottom:8px;`;
        ml.innerHTML = `<i data-lucide="arrow-right" class="w-3 h-3"></i> How it maps`;
 
        const st = document.createElement('p');
        // Explicit colors — no inheritance surprises
        st.style.cssText = `font-family:'Space Mono',monospace;font-size:.75rem;line-height:1.7;color:#475569;`;
        st.innerHTML = mdBold(subtext);
 
        mapWrap.appendChild(ml);
        mapWrap.appendChild(st);
        decodeContent.appendChild(mapWrap);
      }
 
      // Toggle button — appended to WRAP, not hero
      const decodeToggle = document.createElement('button');
      decodeToggle.className = 'decode-toggle-btn';
      decodeToggle.type = 'button';
      decodeToggle.dataset.open = 'false';
      decodeToggle.innerHTML = `<i data-lucide="lock" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Unlock the Decode</span><span class="decode-toggle-hint">tap to reveal →</span>`;
 
      // Append toggle and content to WRAP (not hero)
      wrap.appendChild(decodeToggle);
      wrap.appendChild(decodeContent);
 
      // Wire toggle — NO GSAP (eliminated the opacity conflict)
      decodeToggle.addEventListener('click', () => {
        const isOpen = decodeToggle.dataset.open === 'true';
        if (!isOpen) {
          decodeContent.classList.remove('collapsed-decode');
          decodeToggle.dataset.open = 'true';
          decodeToggle.innerHTML = `<i data-lucide="lock-open" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Hide Decode</span>`;
        } else {
          decodeContent.classList.add('collapsed-decode');
          decodeToggle.dataset.open = 'false';
          decodeToggle.innerHTML = `<i data-lucide="lock" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Unlock the Decode</span><span class="decode-toggle-hint">tap to reveal →</span>`;
        }
        lucide.createIcons();
      });
    }
 
    return wrap; // return wrap, not hero
  }

  // Show memory strength meter on a card
  function showMemoryStrength(cardEl, pct){
    const existing = cardEl.querySelector('.memory-strength-wrap');
    if(existing){ existing.remove(); }
    const wrap = document.createElement('div'); wrap.className = 'memory-strength-wrap';
    wrap.innerHTML = `<span class="ms-label">Memory Strength</span><div class="ms-track"><div class="ms-fill"></div></div><span class="ms-pct">${pct}%</span>`;
    cardEl.appendChild(wrap);
    setTimeout(()=>{ const fill=wrap.querySelector('.ms-fill'); if(fill) fill.style.width=pct+'%'; }, 80);
  }

  // ── Mode selection ─────────────────────────────────────────────────────────
  function setMode(mode){
    currentMode=mode; modeInput.value=mode;
    btnLore.style.borderColor=mode==='lore'?'#6C2BD9':'rgba(0,0,0,0.08)'; btnLore.style.background=mode==='lore'?'rgba(108,43,217,0.07)':'';
    btnHack.style.borderColor=mode==='hack'?'#16A34A':'rgba(0,0,0,0.08)'; btnHack.style.background=mode==='hack'?'rgba(22,163,74,0.06)':'';
    const ld=btnLore.querySelector('.mode-radio div'), hd=btnHack.querySelector('.mode-radio div');
    btnLore.querySelector('.mode-radio').style.borderColor=mode==='lore'?'#6C2BD9':'rgba(0,0,0,0.2)';
    btnHack.querySelector('.mode-radio').style.borderColor=mode==='hack'?'#16A34A':'rgba(0,0,0,0.2)';
    if(ld) ld.classList.toggle('hidden',mode!=='lore'); if(hd) hd.classList.toggle('hidden',mode!=='hack');
    btnLore.setAttribute('aria-checked',mode==='lore'); btnHack.setAttribute('aria-checked',mode==='hack');
    btnGenerate.style.background=mode==='hack'?'linear-gradient(135deg,#16A34A,#15803d)':'linear-gradient(135deg,#6C2BD9,#7c3aed)';
    btnGenerate.style.boxShadow=mode==='hack'?'0 4px 20px rgba(22,163,74,0.4)':'0 4px 20px rgba(108,43,217,0.4)';
  }
  btnLore.addEventListener('click',()=>setMode('lore')); btnHack.addEventListener('click',()=>setMode('hack')); setMode('lore');

  // ── Deep Scan ──────────────────────────────────────────────────────────────
  btnDeepScan.addEventListener('click',()=>{
    isDeepScan=!isDeepScan; deepScanInput.value=isDeepScan?'true':'false'; btnDeepScan.setAttribute('aria-pressed',isDeepScan);
    if(isDeepScan){ btnDeepScan.classList.add('active'); deepscanTrack.style.background='#16A34A'; deepscanTrack.style.borderColor='#16A34A'; deepscanKnob.style.left='20px'; deepscanKnob.style.background='#fff'; deepscanIcon.style.color='#4ade80'; }
    else { btnDeepScan.classList.remove('active'); deepscanTrack.style.background='rgba(0,0,0,0.08)'; deepscanTrack.style.borderColor='rgba(0,0,0,0.1)'; deepscanKnob.style.left='2px'; deepscanKnob.style.background='#94a3b8'; deepscanIcon.style.color=''; }
  });

  // ── Language ───────────────────────────────────────────────────────────────
  const LANG_META = { english:{badge:'🇬🇧 EN',desc:'Full English output — precise, clean, board-exam ready.'}, hinglish:{badge:'🔀 HE',desc:'Hindi + English mix — the way toppers actually talk.'}, hindi:{badge:'🇮🇳 HI',desc:'Pure Hindi output — best if you think and memorize in Hindi.'} };
  document.querySelectorAll('.lang-btn').forEach(btn=>{ btn.addEventListener('click',()=>{ document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); currentLanguage=btn.dataset.lang; languageInput.value=currentLanguage; langDescText.textContent=LANG_META[currentLanguage].desc; }); });

  // ── Image upload ───────────────────────────────────────────────────────────
  btnUpload.addEventListener('click',()=>fileInput.click()); btnCamera.addEventListener('click',()=>showToast('📷 Camera capture coming soon'));
  function loadImageFile(file){ if(!file) return; if(file.size>5*1024*1024){ showToast('❌ Image too large — max 5MB'); fileInput.value=''; return; } const r=new FileReader(); r.onload=(e)=>{ imageBase64=e.target.result; previewThumb.src=imageBase64; previewFilename.textContent=file.name; previewFilesize.textContent=formatBytes(file.size); imgStrip.classList.add('visible'); btnUpload.style.borderColor='#6C2BD9'; btnUpload.style.color='#6C2BD9'; }; r.readAsDataURL(file); }
  fileInput.addEventListener('change',()=>loadImageFile(fileInput.files&&fileInput.files[0]));
  function clearImage(){ imageBase64=null; fileInput.value=''; previewThumb.src=''; previewFilename.textContent=''; previewFilesize.textContent=''; imgStrip.classList.remove('visible'); btnUpload.style.borderColor=''; btnUpload.style.color=''; }
  btnRemoveImg.addEventListener('click',clearImage);
  window.addEventListener('paste',(e)=>{ if(!e.clipboardData) return; for(const it of e.clipboardData.items){ if(it.type&&it.type.startsWith('image/')){ const blob=it.getAsFile(); if(blob.size>5*1024*1024){ showToast('❌ Pasted image too large — max 5MB'); return; } const dt=new DataTransfer(); dt.items.add(blob); fileInput.files=dt.files; loadImageFile(blob); return; } } });
  textarea.addEventListener('input',function(){ this.style.height='auto'; this.style.height=Math.max(140,this.scrollHeight)+'px'; });

  // ── Processing terminal ────────────────────────────────────────────────────
  const TERMINAL = {
    lore:[{t:'> Reading your concept...',c:'#94a3b8',d:0},{t:'> Mapping to your learning profile...',c:'#a78bfa',d:700},{t:'> Constructing narrative arc...',c:'#94a3b8',d:1500},{t:'> Planting memory anchors in the story...',c:'#a78bfa',d:2600},{t:'> Finalizing lore sequence...',c:'#94a3b8',d:4000}],
    hack:[{t:'> Extracting concept signal...',c:'#94a3b8',d:0},{t:'> Compressing to minimum viable mnemonic...',c:'#4ade80',d:500},{t:'> Building letter chips...',c:'#94a3b8',d:1200},{t:'> Neural hack ready. Encoding...',c:'#4ade80',d:2000}],
    deep:[{t:'> Deep Scan activated...',c:'#60a5fa',d:0},{t:'> Cross-referencing NCERT chapter index...',c:'#94a3b8',d:700},{t:'> Pulling verified chapter references...',c:'#60a5fa',d:1600},{t:'> Validating academic accuracy...',c:'#94a3b8',d:2800},{t:'> Building citation-backed hook...',c:'#60a5fa',d:4200}],
  };
  let termTimers=[];
  function runTerminal(lines){ terminalLog.innerHTML=''; termTimers.forEach(clearTimeout); termTimers=[]; lines.forEach(({t,c,d})=>{ const tid=setTimeout(()=>{ const el=document.createElement('div'); el.className='terminal-line'; el.style.color=c; el.textContent=t; terminalLog.appendChild(el); terminalLog.scrollTop=terminalLog.scrollHeight; },d); termTimers.push(tid); }); }
  function startProgress(fast){ clearInterval(progTimer); let p=15; progTimer=setInterval(()=>{ if(p<78){ p+=Math.random()*(fast?10:5); if(p>78)p=78; progressBar.style.width=Math.floor(p)+'%'; } },fast?280:480); }
  function stopProgress(){ clearInterval(progTimer); progTimer=null; }

  // ── Render output ──────────────────────────────────────────────────────────
  function renderOutput(rawData, mode, deepScan, language){
    const items = Array.isArray(rawData)?rawData:[rawData];
    if(!items.length) return;

    if(deepScan){ outputModeBadge.textContent='Deep Scan'; outputModeBadge.className='badge badge-deep'; }
    else if(mode==='hack'){ outputModeBadge.textContent='Neural Hack'; outputModeBadge.className='badge badge-hack'; }
    else { outputModeBadge.textContent='Lore Engine'; outputModeBadge.className='badge badge-lore'; }
    outputLangBadge.textContent=(LANG_META[language]||LANG_META.english).badge;

    const heroMode   = deepScan?'deep':mode;
    const titleColor = deepScan?'#3b82f6':(mode==='hack'?'#16A34A':'#6C2BD9');
    const labelColor = deepScan?'#60a5fa':(mode==='hack'?'#4ade80':'#a78bfa');
    const labelIcon  = deepScan?'scan-search':(mode==='hack'?'zap':'book-open');
    const defaultLabel = deepScan?'Deep Scan Result:':(mode==='lore'?'Lore Engine Narrative:':'Neural Hack Mnemonic:');

    aiItems.innerHTML='';

    items.forEach((json, idx)=>{
      const card = document.createElement('div');
      card.className = 'result-card p-5 md:p-6';
      card.style.cssText = `opacity:0;transform:translateY(14px);transition:opacity .45s ease ${idx*0.12}s,transform .45s cubic-bezier(0.34,1.3,0.64,1) ${idx*0.12}s;`;

      // Part header
      if(items.length > 1){
        const ph = document.createElement('div'); ph.className = 'part-header';
        const pl = document.createElement('div'); pl.className = 'part-label';
        pl.innerHTML = `<i data-lucide="layers" class="w-3 h-3"></i> Part ${idx+1} of ${items.length}`;
        const lb = document.createElement('div'); lb.className = 'part-lock-badge locked'; lb.id = `lock-badge-${idx}`;
        lb.innerHTML = `<i data-lucide="check-circle" class="w-3 h-3"></i> Locked`;
        lb.style.display = 'none';
        ph.appendChild(pl); ph.appendChild(lb); card.appendChild(ph);
      }

      // Title
      const titleEl = document.createElement('div'); titleEl.className='text-lg md:text-xl font-display font-bold mb-3'; titleEl.style.color=titleColor; titleEl.textContent=json.title||'Result';
      card.appendChild(titleEl);

      // Definition
      if(json.definition){ const def=document.createElement('p'); def.className='def-text'; def.textContent=json.definition; card.appendChild(def); }

      // Formula
      if(json.latex_formula&&json.latex_formula!=='null'&&json.latex_formula!==null){
        const fBox=document.createElement('div'); fBox.className='formula-box';
        const fHeader=document.createElement('div'); fHeader.className='formula-header'; fHeader.innerHTML=`<i data-lucide="sigma" class="w-3 h-3" style="color:rgba(167,139,250,0.6)"></i> Formulae`;
        fBox.appendChild(fHeader); renderLatexBlock(json.latex_formula,fBox); card.appendChild(fBox);
      }

      // Mnemonic
      if(json.hook_text){
        card.appendChild(buildMnemonicSection(json, heroMode, labelColor, labelIcon, defaultLabel, card));
      }

      // Tip (first card only)
      if(idx===0 && Array.isArray(json.word_chips) && json.word_chips.length>0){
        const tip=document.createElement('div'); tip.className='tip-banner';
        tip.innerHTML=`<i data-lucide="lightbulb" class="w-3.5 h-3.5 flex-shrink-0" style="color:#a78bfa;"></i> Tap any word chip to reveal its mapping. Hit <strong style="color:#a78bfa;">Test Me</strong> to earn +25 XP.`;
        card.appendChild(tip);
      }

      aiItems.appendChild(card);
      requestAnimationFrame(()=>requestAnimationFrame(()=>{ card.style.opacity='1'; card.style.transform='translateY(0)'; }));
    });

    lucide.createIcons();

    // XP for generation
    G.locked++; saveG(); updateStatStrip();
    gainXP(15, 'Hook generated');
    if(G.locked === 1) triggerAchievement('first_hook');
    if(G.locked === 5) triggerAchievement('five_hooks');
    if(deepScan) triggerAchievement('deep_scan');

    // Light confetti on generation
    setTimeout(()=>fireConfetti(), 350);

    // Source matrix
    const allSources = items.flatMap(j=>j.source_matrix||[]);
    if(allSources.length){
      let h=`<div style="font-family:'Space Mono',monospace;" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-gray-500 flex items-center gap-2 mb-3 px-1"><i data-lucide="database" class="w-3 h-3"></i> NCERT References</div>`;
      allSources.forEach((s,i)=>{
        const ac=i%2===0?'#6C2BD9':'#16A34A', icon=s.icon_type==='file'?'file-text':'book-open';
        h+=`<div class="source-card glass p-3 mb-3" style="border-left-color:${ac};">
          <div class="flex items-start justify-between gap-2 mb-2">
            <p class="text-xs font-semibold text-slate-800 dark:text-slate-200 leading-tight">${s.title||'Source'}</p>
            <span class="text-[10px] font-bold whitespace-nowrap px-1.5 py-0.5 rounded flex-shrink-0" style="color:${ac};background:rgba(108,43,217,0.08);border:1px solid rgba(108,43,217,0.15);">${s.match_percentage||''}</span>
          </div>
          <div class="flex items-center gap-1.5 text-slate-400"><i data-lucide="${icon}" class="w-3.5 h-3.5"></i><span class="text-[11px]">${icon==='file-text'?'Board Paper':'NCERT Chapter'}</span></div>
        </div>`;
      });
      sourceMatrix.innerHTML=h; lucide.createIcons();
    } else { sourceMatrix.innerHTML=''; }
  }

  // ── Form submit ────────────────────────────────────────────────────────────
  form.addEventListener('submit', async(ev)=>{
    ev.preventDefault();
    const q=textarea.value.trim();
    if(!q){ showToast('Please type what you want to memorize'); return; }
    const isFast=currentMode==='hack'&&!isDeepScan;
    const lines=isDeepScan?TERMINAL.deep:(currentMode==='hack'?TERMINAL.hack:TERMINAL.lore);
    procTitle.textContent=isDeepScan?'Running Deep Scan...':(currentMode==='hack'?'Hacking your concept...':'Crafting your lore...');
    procSubtitle.textContent=isDeepScan?'Deep Scan · NCERT Cross-Reference':(currentMode==='hack'?'Neural Hack · Compression Mode':'Lore Engine · Narrative Mode');
    runTerminal(lines); progressBar.style.width='15%'; startProgress(isFast);
    stateProc.setAttribute('aria-busy','true'); switchState(stateIdle,stateProc);
    const payload={question:q,mode:currentMode,deepScan:isDeepScan,language:currentLanguage,image:imageBase64};
    ctrl=new AbortController();
    try{
      const res=await fetch(form.action,{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(payload),signal:ctrl.signal});
      progressBar.style.width='88%';
      if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.error||`Server error ${res.status}`); }
      const json=await res.json();
      stopProgress(); progressBar.style.width='100%';
      renderOutput(json.initial_ai_response||json,currentMode,isDeepScan,currentLanguage);
      stateProc.setAttribute('aria-busy','false'); switchState(stateProc,stateOutput);
    } catch(err){
      stopProgress(); progressBar.style.width='0%'; stateProc.setAttribute('aria-busy','false');
      switchState(stateProc,stateIdle);
      if(err.name==='AbortError') showToast('Cancelled.');
      else { showToast('❌ '+(err.message||'Something went wrong.')); console.error(err); }
    } finally { ctrl=null; termTimers.forEach(clearTimeout); termTimers=[]; }
  });

  btnCancel.addEventListener('click',()=>{ if(ctrl) ctrl.abort(); stateProc.setAttribute('aria-busy','false'); switchState(stateProc,stateIdle); stopProgress(); progressBar.style.width='0%'; });
  btnReset.addEventListener('click',()=>{ form.reset(); clearImage(); aiItems.innerHTML=''; sourceMatrix.innerHTML=''; progressBar.style.width='0%'; switchState(stateOutput,stateIdle); setMode('lore'); textarea.focus(); });
  btnCopy.addEventListener('click',()=>{ const txt=aiItems.innerText||''; if(!txt) return showToast('Nothing to copy yet'); navigator.clipboard.writeText(txt).then(()=>showToast('✓ Copied to clipboard')); });
  btnSave.addEventListener('click',()=>{ const txt=aiItems.innerText||''; if(!txt) return showToast('Nothing to save yet'); const blob=new Blob([txt],{type:'text/plain'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='boardalgo-mnemonic.txt'; a.click(); });
  document.getElementById('btn-bookmark').addEventListener('click',()=>showToast('📌 Bookmark feature coming soon'));
  textarea.addEventListener('keydown',(e)=>{ if((e.ctrlKey||e.metaKey)&&e.key==='Enter') btnGenerate.click(); });

  // ── Reconfig modal ─────────────────────────────────────────────────────────
  btnReconfig.addEventListener('click',()=>{ confirmModal.classList.add('open'); document.body.style.overflow='hidden'; });
  function closeConfirmModal(){ confirmModal.classList.remove('open'); document.body.style.overflow=''; }
  modalCancelBtn.addEventListener('click',closeConfirmModal);
  confirmModal.addEventListener('click',(e)=>{ if(e.target===confirmModal) closeConfirmModal(); });
  modalConfirmBtn.addEventListener('click',async()=>{ modalConfirmBtn.textContent='Resetting...'; modalConfirmBtn.disabled=true; try{ await fetch('/api/user/reset-behaviour',{method:'POST',credentials:'include'}); window.location.href='/mne/onboarding'; }catch(e){ showToast('❌ Reset failed. Try again.'); modalConfirmBtn.textContent='Yes, Reset It'; modalConfirmBtn.disabled=false; closeConfirmModal(); } });

  gsap.to('.gsap-entry',{y:0,opacity:1,stagger:.1,duration:.55,ease:'power2.out',delay:.05});

  // ── Three.js background ────────────────────────────────────────────────────
  let threeParticles, threeRenderer;
  function updateThreeColors(){ if(!threeParticles) return; threeParticles.material.opacity=html.classList.contains('dark')?.6:.2; }
  (function(){
    const canvas=document.getElementById('bg-canvas');
    threeRenderer=new THREE.WebGLRenderer({canvas,alpha:true});
    const scene=new THREE.Scene(), camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,1000);
    threeRenderer.setSize(innerWidth,innerHeight); threeRenderer.setPixelRatio(Math.min(devicePixelRatio,2));
    const count=1500,pos=new Float32Array(count*3); for(let i=0;i<count*3;i++) pos[i]=(Math.random()-.5)*20;
    const geo=new THREE.BufferGeometry(); geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
    const mat=new THREE.PointsMaterial({size:.02,color:0x6C2BD9,transparent:true,opacity:.6});
    threeParticles=new THREE.Points(geo,mat); scene.add(threeParticles); camera.position.z=4;
    let mx=0,my=0; document.addEventListener('mousemove',e=>{ mx=e.clientX/innerWidth-.5; my=e.clientY/innerHeight-.5; });
    (function animate(){ requestAnimationFrame(animate); threeParticles.rotation.y+=.0005+mx*.002; threeParticles.rotation.x+=.0002+my*.001; threeRenderer.render(scene,camera); })();
    window.addEventListener('resize',()=>{ camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix(); threeRenderer.setSize(innerWidth,innerHeight); });
    updateThreeColors();
  })();

  // ── Injected result loader ─────────────────────────────────────────────────
  (function(){
    if(!window.__INJECTED_RESULT__) return;
    const saved=window.__INJECTED_RESULT__;
    const raw=saved.initial_ai_response||saved;
    const mode=saved.generation_mode||'lore';
    const deep=saved.deep_scan_enabled||false;
    const lang=saved.language||'english';
    currentMode=mode; isDeepScan=deep; currentLanguage=lang;
    setMode(mode); if(deep) btnDeepScan.click();
    document.querySelectorAll('.lang-btn').forEach(b=>{ b.classList.toggle('active',b.dataset.lang===lang); });
    languageInput.value=lang; langDescText.textContent=(LANG_META[lang]||LANG_META.english).desc;
    renderOutput(raw,mode,deep,lang); switchState(stateIdle,stateOutput);
  })();

  </script>
  <script src="/js/tracking.js" defer></script>
</body>
</html>