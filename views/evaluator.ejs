function formatBytes(b) {
  if (b < 1024) return b + ' B';
  if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
  return (b / (1024 * 1024)).toFixed(2) + ' MB';
}

function buildImageMeta() {
  const arr = Array.from(fileDT.files).map(f => ({
    name: f.name, size: f.size, sizeHuman: formatBytes(f.size),
    type: f.type, lastModified: f.lastModified
  }));
  document.getElementById('f-imgmeta').value = JSON.stringify(arr);
}

function addFiles(files) {
  Array.from(files).forEach(f => {
    if (fileDT.files.length >= 10) return;
    if (f.size > 20 * 1024 * 1024) { alert(`"${f.name}" exceeds 20 MB limit.`); return; }
    const dup = Array.from(fileDT.files).some(x => x.name === f.name && x.size === f.size);
    if (dup) return;
    fileDT.items.add(f);
    renderChip(f);
  });
  fileInput.files = fileDT.files;
  buildImageMeta();
  refreshSubmit();
}

function renderChip(file) {
  const chip = document.createElement('div');
  chip.className = 'file-chip';
  const isPdf = file.type === 'application/pdf';
  chip.innerHTML = `
    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      ${isPdf
        ? '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>'
        : '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>'}
    </svg>
    <span class="file-chip-name">${file.name}</span>
    <span class="text-[10px] text-purple-300/70">${formatBytes(file.size)}</span>
    <span class="chip-remove" title="Remove">✕</span>`;
  chip.querySelector('.chip-remove').addEventListener('click', e => {
    e.stopPropagation();
    const newDT = new DataTransfer();
    Array.from(fileDT.files).forEach(x => {
      if (!(x.name === file.name && x.size === file.size)) newDT.items.add(x);
    });
    fileDT = newDT;
    fileInput.files = fileDT.files;
    buildImageMeta();
    chip.remove();
    refreshSubmit();
  });
  previewList.appendChild(chip);
}

// Click → open picker
dropZone.addEventListener('click', e => {
  if (e.target.closest('.chip-remove') || e.target.closest('.file-chip')) return;
