/* ══════════════════════════════════════════════════════════════════════
   5. RESULT RENDERER
   ══════════════════════════════════════════════════════════════════════ */
function renderResult(data) {
  clearInterval(loadingInterval);
  document.getElementById('loading-section').classList.add('hidden');
  document.getElementById('upload-section').style.display = 'none';

  const rs = document.getElementById('result-section');
  rs.style.display = 'block';

  const { meta, rubric, visual_annotations, perfect_marker_answer } = data;

  /* ── Scorecard ── */
  const scored = meta.total_marks_awarded;
  const maxMk  = meta.max_marks;
  document.getElementById('score-main').textContent = `${scored}/${maxMk}`;

  const dashArray = 351.9;
  requestAnimationFrame(() => {
    document.getElementById('ring-fill-el').style.strokeDashoffset =
      dashArray * (1 - scored / maxMk);
  });

  // Difficulty badge
  const diffEl = document.getElementById('diff-badge');
  const d = (meta.difficulty || 'Medium').toLowerCase();
  diffEl.textContent = meta.difficulty || 'Medium';
  diffEl.className = 'diff-pill ' + (d === 'easy' ? 'diff-easy' : d === 'hard' ? 'diff-hard' : 'diff-medium');

  // Meta chips — subject, score, screen info, confidence (if provided)
  const chips = document.getElementById('meta-chips');
  const confScore = (data.meta && typeof data.meta.confidence === 'number')
    ? data.meta.confidence : null;

  const chipDefs = [
    [`<i data-lucide="book" class="w-3 h-3"></i>`, meta.subject],
    [`<i data-lucide="target" class="w-3 h-3"></i>`, `${scored}/${maxMk} marks`],

  ];
  if (confScore !== null) {
    const confPct  = Math.round(confScore * 100);
    const confColor = confPct >= 80 ? '#4ade80' : confPct >= 55 ? '#fbbf24' : '#f87171';
    chipDefs.push([
      `<i data-lucide="activity" class="w-3 h-3" style="color:${confColor};"></i>`,
      `AI Confidence: ${confPct}%`
    ]);
  }
  chipDefs.forEach(([ic, txt]) => {
    const c = document.createElement('span');
    c.className = 'meta-chip';
    c.innerHTML = `${ic} ${txt}`;
    chips.appendChild(c);
  });
  lucide.createIcons();

  // Problem statement banner
  if (meta.problem_statement) {
    const psWrap = document.getElementById('ps-wrapper');
    const psEl   = document.getElementById('problem-statement-banner');
    if (psWrap && psEl) { psEl.textContent = meta.problem_statement; psWrap.style.display = ''; }
  }

  // Summary
  document.getElementById('eval-summary').textContent = meta.evaluation_summary;

  // Rubric bars
  const rubricData = rubric || [
    { label: 'Conceptual Accuracy', scored: scored * 0.6, total: maxMk * 0.6, color: '#a78bfa' },
    { label: 'Step Completeness',   scored: scored * 0.4, total: maxMk * 0.4, color: '#fbbf24' },
  ];
  const rbContainer = document.getElementById('rubric-bars');
  rbContainer.innerHTML = '';
  rubricData.forEach(r => {
    const pct = Math.round((r.scored / r.total) * 100);
    const row = document.createElement('div');
    row.innerHTML = `
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-medium text-slate-600 dark:text-gray-300">${r.label}</span>
        <span class="text-xs font-bold" style="color:${r.color};">${r.scored}/${r.total}</span>
      </div>
      <div class="rbar-track">
        <div class="rbar-fill" data-w="${pct}%" style="width:0%;background:${r.color};"></div>
      </div>`;
    rbContainer.appendChild(row);
  });
  setTimeout(() => {
    rbContainer.querySelectorAll('.rbar-fill').forEach(b => { b.style.width = b.dataset.w; });
  }, 120);

  /* ── Image + Konva ── */
  setupAugmentedCanvas(data.imageUrls, visual_annotations);

  /* ── Topper's Notebook ── */
  renderSteps(perfect_marker_answer);

  /* ── GSAP entrance ── */
  gsap.from('.gsap-r', { y: 28, opacity: 0, stagger: 0.12, duration: 0.7, ease: 'power2.out' });
  lucide.createIcons();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ══════════════════════════════════════════════════════════════════════
   6. SCHEMA VALIDATION + NORMALISATION LAYER
   ══════════════════════════════════════════════════════════════════════ */

const SCHEMA_CURRENT_VERSION = '1.0';
const VALID_ANNOTATION_TYPES = new Set(['tick','cross','circle','text','step_mark']);
const CONFIDENCE_THRESHOLD   = 0.40; // drop annotations below 40% confidence

/**
 * normalisePayload — handles two shapes from Gemini:
 *   Shape A (versioned):  { "version": "1.0", "annotations": [...] }
 *   Shape B (legacy flat): the raw visual_annotations array directly
 * Always returns: { version, annotations[] }
 */
function normalisePayload(raw) {
  if (!raw) return { version: SCHEMA_CURRENT_VERSION, annotations: [] };
  // Already the new versioned envelope
  if (!Array.isArray(raw) && Array.isArray(raw.annotations))
    return { version: raw.version || SCHEMA_CURRENT_VERSION, annotations: raw.annotations };
  // Legacy: flat array
  if (Array.isArray(raw))
    return { version: SCHEMA_CURRENT_VERSION, annotations: raw };
  // Fallback for data object with visual_annotations key (our own schema)
  if (Array.isArray(raw.visual_annotations))
    return { version: raw.version || SCHEMA_CURRENT_VERSION, annotations: raw.visual_annotations };
  return { version: SCHEMA_CURRENT_VERSION, annotations: [] };
}

/**
 * validateAnnotations — enforces the contract BEFORE drawing anything.
 * • Rejects malformed entries (missing box_2d, unknown type)
 * • Clamps all coords to [0, 1000]
 * • Fixes inverted bounding boxes (ymin > ymax etc.)
 * • Filters low-confidence annotations (< CONFIDENCE_THRESHOLD)
 */
function validateAnnotations(annotations) {
  const valid = [];
  const skipped = [];

  (annotations || []).forEach((a, idx) => {
    // ① Must have a known annotation_type
    if (!VALID_ANNOTATION_TYPES.has(a.annotation_type)) {
      skipped.push({ idx, reason: `unknown type "${a.annotation_type}"` });
      return;
    }
    // ② Must have a box_2d with exactly 4 numeric elements
    if (!Array.isArray(a.box_2d) || a.box_2d.length !== 4 ||
        a.box_2d.some(v => typeof v !== 'number' && isNaN(Number(v)))) {
      skipped.push({ idx, reason: 'invalid box_2d' });
      return;
    }
    // ③ Confidence filter — only if the field is present
    if (typeof a.confidence === 'number' && a.confidence < CONFIDENCE_THRESHOLD) {
      skipped.push({ idx, reason: `confidence ${a.confidence} below threshold` });
      return;
    }

    // Clamp each coord to [0, 1000] and cast to Number
    let [y0, x0, y1, x1] = a.box_2d.map(v => Math.max(0, Math.min(1000, Number(v))));

    // Fix inverted boxes (Gemini sometimes returns them swapped)
    if (y0 > y1) [y0, y1] = [y1, y0];
    if (x0 > x1) [x0, x1] = [x1, x0];

    // Enforce minimum 10px region to avoid zero-size shapes
    if ((y1 - y0) < 10) y1 = y0 + 10;
    if ((x1 - x0) < 10) x1 = x0 + 10;

    a.box_2d = [y0, x0, y1, x1];
    valid.push(a);
  });

  if (skipped.length > 0)
    console.warn(`[BoardAlgo Validator] Skipped ${skipped.length} annotation(s):`, skipped);

  return valid;
}

/* ══════════════════════════════════════════════════════════════════════
   7. KONVA ANNOTATION ENGINE
   ══════════════════════════════════════════════════════════════════════ */
let konvaStage = null;
let konvaLayer = null;
let errorGroup  = null;   // layer group: red/error annotations
let markGroup   = null;   // layer group: green/mark annotations
let errorsVisible = true;
let marksVisible  = true;
let annotationsVisible = true;
let currentZoom = 1;
let currentAnnotations = [];

// Use a placeholder image for the demo when no real image is available
const DEMO_IMAGE_URL = 'https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/PNG_transparency_demonstration_1.png/280px-PNG_transparency_demonstration_1.png';


function setupAugmentedCanvas(imageUrls, rawAnnotations) {
  // 1. Save data globally
  globalImageUrls = imageUrls || [];
  const payload = normalisePayload(rawAnnotations);
  globalAnnotations = validateAnnotations(payload.annotations);
  
  currentImageIndex = 0;

  // 2. Show/Hide Pagination UI
  const pageNav = document.getElementById('page-nav');
  if (globalImageUrls.length > 1) {
    pageNav.classList.remove('hidden');
    pageNav.classList.add('flex');
  } else {
    pageNav.classList.add('hidden');
    pageNav.classList.remove('flex');
  }

  // 3. Render the first page
  renderCurrentPage();
}

function renderCurrentPage() {
  const img = document.getElementById('student-img');
  const wrapper = document.getElementById('canvas-wrapper');

  // Update page text (e.g., "Page 1 / 3")
  document.getElementById('page-indicator').textContent = `Page ${currentImageIndex + 1} / ${globalImageUrls.length}`;

  // Filter annotations for ONLY this page. 
  // (Assuming Gemini uses 1-based indexing for page_number)
  currentAnnotations = globalAnnotations.filter(a => a.page_number === (currentImageIndex + 1));

  // Load the specific image
  img.crossOrigin = 'anonymous';
  img.src = globalImageUrls[currentImageIndex] || DEMO_IMAGE_URL;

  img.onload = () => {
    // Rebuild the Konva canvas specifically for this newly loaded image
    buildKonva(); 
  };
}

// 4. Navigation Functions
function prevPage() {
  if (currentImageIndex > 0) {
    currentImageIndex--;
    renderCurrentPage();
  }
}

function nextPage() {
  if (currentImageIndex < globalImageUrls.length - 1) {
    currentImageIndex++;
    renderCurrentPage();
  }
}

function buildKonva() {
  const img      = document.getElementById('student-img');
  const wrapper  = document.getElementById('canvas-wrapper');
  const konvaDiv = document.getElementById('konva-container');

  const rw = img.offsetWidth  || wrapper.offsetWidth  || 600;
  const rh = img.offsetHeight || Math.round(rw * 1.4);

  // Destroy old stage cleanly
  if (konvaStage) { konvaStage.destroy(); konvaStage = null; }
  errorGroup = null;
  markGroup  = null;

  konvaDiv.style.width  = rw + 'px';
  konvaDiv.style.height = rh + 'px';

  konvaStage = new Konva.Stage({ container: 'konva-container', width: rw, height: rh });
  konvaLayer = new Konva.Layer();

  // Two groups — independent visibility, better perf than one flat list
  errorGroup = new Konva.Group({ name: 'errors' });  // red: cross, circle, text, red step_mark
  markGroup  = new Konva.Group({ name: 'marks'  });  // green: tick, green step_mark

  konvaLayer.add(errorGroup, markGroup);
  konvaStage.add(konvaLayer);

  if (annotationsVisible) drawAnnotations(rw, rh);
}

function drawAnnotations(rw, rh) {
  // Clear both groups — not the layer (keeps groups alive)
  if (errorGroup) errorGroup.destroyChildren();
  if (markGroup)  markGroup.destroyChildren();

  /* ── Scale helpers ───────────────────────────────────────────────────── */
  const sw = (n) => Math.max(1.5, rw * n);
  const fs = (n) => Math.max(10, Math.min(20, rw * n));

  currentAnnotations.forEach(anno => {
    // Coordinate contract: [ymin, xmin, ymax, xmax] on 0-1000 grid
    const [yn, xn, ym, xm] = anno.box_2d;
    const px = (xn / 1000) * rw;
    const py = (yn / 1000) * rh;
    const pw = ((xm - xn) / 1000) * rw;
    const ph = ((ym - yn) / 1000) * rh;
    const cx = px + pw / 2;
    const cy = py + ph / 2;

    const isRed   = anno.color === 'red';
    const isGreen = anno.color === 'green';
    const strokeC = isRed   ? 'rgba(239,68,68,0.88)'  :
                    isGreen ? 'rgba(22,163,74,0.92)'   : 'rgba(108,43,217,0.88)';
    const fillC   = isRed   ? 'rgba(239,68,68,0.09)'  :
                    isGreen ? 'rgba(22,163,74,0.10)'   : 'rgba(108,43,217,0.09)';
    const glowC   = isRed   ? '#EF4444'  :
                    isGreen ? '#16A34A'  : '#6C2BD9';

    // ── Route: errors (red) → errorGroup, marks (green) → markGroup ──
    const target = isGreen ? markGroup : errorGroup;

    /* ── TICK  ✓ ────────────────────────────────────────────────────── */
    if (anno.annotation_type === 'tick') {
      const r    = Math.max(14, Math.min(28, Math.min(pw, ph) / 2));
      const halo = new Konva.Circle({ x: cx, y: cy, radius: r + 4,
        fill: 'rgba(22,163,74,0.12)', stroke: 'rgba(22,163,74,0.35)', strokeWidth: 1 });
      const bg   = new Konva.Circle({ x: cx, y: cy, radius: r,
        fill: 'rgba(22,163,74,0.82)',
        shadowColor: '#16A34A', shadowBlur: 10, shadowOpacity: 0.5 });
      const ts   = r * 0.55;
      const tick = new Konva.Line({
        points: [cx - ts * 0.6, cy, cx - ts * 0.1, cy + ts * 0.6, cx + ts * 0.7, cy - ts * 0.55],
        stroke: '#ffffff', strokeWidth: sw(0.008) + 1.5,
        lineCap: 'round', lineJoin: 'round',
      });
      target.add(halo, bg, tick);
      if (anno.comment) addTooltipBehaviour(bg, anno.comment, cx, py);

    /* ── CROSS  ✗ ───────────────────────────────────────────────────── */
    } else if (anno.annotation_type === 'cross') {
      const r    = Math.max(14, Math.min(28, Math.min(pw, ph) / 2));
      const halo = new Konva.Circle({ x: cx, y: cy, radius: r + 4,
        fill: 'rgba(239,68,68,0.1)', stroke: 'rgba(239,68,68,0.3)', strokeWidth: 1 });
      const bg   = new Konva.Circle({ x: cx, y: cy, radius: r,
        fill: 'rgba(239,68,68,0.8)',
        shadowColor: '#EF4444', shadowBlur: 10, shadowOpacity: 0.5 });
      const arm  = r * 0.52;
      const l1   = new Konva.Line({ points: [cx - arm, cy - arm, cx + arm, cy + arm],
        stroke: '#ffffff', strokeWidth: sw(0.007) + 1.5, lineCap: 'round' });
      const l2   = new Konva.Line({ points: [cx + arm, cy - arm, cx - arm, cy + arm],
        stroke: '#ffffff', strokeWidth: sw(0.007) + 1.5, lineCap: 'round' });
      target.add(halo, bg, l1, l2);
      if (anno.comment) addTooltipBehaviour(bg, anno.comment, cx, py);

    /* ── CIRCLE  (dashed ellipse) ───────────────────────────────────── */
    } else if (anno.annotation_type === 'circle') {
      const ellipse = new Konva.Ellipse({
        x: cx, y: cy,
        radiusX: Math.max(8, pw / 2), radiusY: Math.max(8, ph / 2),
        stroke: strokeC, strokeWidth: sw(0.005), dash: [7, 4],
        fill: fillC,
        shadowColor: glowC, shadowBlur: 10, shadowOpacity: 0.3,
      });
      target.add(ellipse);
      addTooltipBehaviour(ellipse, anno.comment, cx, py);

    /* ── TEXT  (bubble + arrow) ─────────────────────────────────────── */
    } else if (anno.annotation_type === 'text' && anno.comment) {
      const label = new Konva.Label({ x: px, y: py });
      label.add(new Konva.Tag({
        fill: isRed ? 'rgba(239,68,68,0.92)' : 'rgba(22,163,74,0.92)',
        cornerRadius: 7,
        shadowColor: glowC, shadowBlur: 9, shadowOpacity: 0.45,
      }));
      label.add(new Konva.Text({
        text: anno.comment, fontSize: fs(0.022),
        fontFamily: 'Poppins, sans-serif', fontStyle: 'bold',
        fill: '#ffffff', padding: 6,
      }));
      target.add(label);
      if (ph > 4) {
        const ay1 = py + fs(0.022) + 18, ay2 = py + ph * 0.85;
        if (ay2 > ay1) {
          target.add(new Konva.Arrow({
            points: [px + 10, ay1, px + 10, ay2],
            stroke: strokeC, fill: strokeC,
            strokeWidth: 1.5, pointerLength: 7, pointerWidth: 6, dash: [4, 3],
          }));
        }
      }

    /* ── STEP_MARK  (margin score circle) ──────────────────────────── */
    } else if (anno.annotation_type === 'step_mark' && anno.comment) {
      const isDed = isRed || String(anno.comment).startsWith('-');
      const bgF   = isDed ? 'rgba(239,68,68,0.88)' : 'rgba(22,163,74,0.88)';
      const shd   = isDed ? '#EF4444' : '#16A34A';
      const fontSize = fs(0.030);
      const radius   = Math.max(18, Math.min(36, Math.min(pw, ph) / 2));

      const circle = new Konva.Circle({
        x: cx, y: cy, radius: radius, fill: bgF,
        shadowColor: shd, shadowBlur: 14, shadowOpacity: 0.55,
        stroke: isDed ? 'rgba(239,68,68,0.4)' : 'rgba(22,163,74,0.4)', strokeWidth: 1.5,
      });
      const label = new Konva.Text({
        text: anno.comment, fontSize: fontSize,
        fontFamily: 'Poppins, sans-serif', fontStyle: 'bold', fill: '#ffffff',
        align: 'center', verticalAlign: 'middle',
        width: radius * 2, height: radius * 2, x: cx - radius, y: cy - radius,
      });
      const rule = new Konva.Line({
        points: [cx - radius - 6, cy, cx - radius - 30, cy],
        stroke: isDed ? 'rgba(239,68,68,0.35)' : 'rgba(22,163,74,0.35)',
        strokeWidth: 1.2, dash: [3, 3],
      });
      target.add(rule, circle, label);
    }
  });

  // Apply group visibility state (persists across redraws)
  if (errorGroup) errorGroup.visible(errorsVisible);
  if (markGroup)  markGroup.visible(marksVisible);
  konvaLayer.draw();
}

// Tooltip behaviour on Konva shapes
function addTooltipBehaviour(shape, comment, x, y) {
  if (!comment) return;
  const tooltip = document.getElementById('anno-tooltip');
  shape.on('mouseenter touchstart', () => {
    tooltip.textContent = comment;
    tooltip.style.left  = x + 'px';
    tooltip.style.top   = (y - 32) + 'px';
    tooltip.classList.add('show');
  });
  shape.on('mouseleave touchend', () => {
    tooltip.classList.remove('show');
  });
}

// Toggle ALL annotations
function toggleAnnotations() {
  annotationsVisible = !annotationsVisible;
  const btn = document.getElementById('btn-toggle-annot');
  if (annotationsVisible) {
    drawAnnotations(konvaStage.width(), konvaStage.height());
    btn.innerHTML = '<i data-lucide="eye" class="w-3.5 h-3.5"></i> All: ON';
  } else {
    if (errorGroup) errorGroup.visible(false);
    if (markGroup)  markGroup.visible(false);
    konvaLayer.draw();
    btn.innerHTML = '<i data-lucide="eye-off" class="w-3.5 h-3.5"></i> All: OFF';
  }
  lucide.createIcons();
}

// Toggle only error (red) group
function toggleErrors() {
  if (!errorGroup || !konvaStage) return;
  errorsVisible = !errorsVisible;
  errorGroup.visible(errorsVisible);
  konvaLayer.draw();
  const btn = document.getElementById('btn-toggle-errors');
  btn.innerHTML = `<i data-lucide="${errorsVisible ? 'x-circle' : 'x-circle'}" class="w-3.5 h-3.5" style="color:#f87171;"></i> Errors: ${errorsVisible ? 'ON' : 'OFF'}`;
  btn.style.opacity = errorsVisible ? '1' : '0.5';
  lucide.createIcons();
}

// Toggle only marks (green) group
function toggleMarks() {
  if (!markGroup || !konvaStage) return;
  marksVisible = !marksVisible;
  markGroup.visible(marksVisible);
  konvaLayer.draw();
  const btn = document.getElementById('btn-toggle-marks');
  btn.innerHTML = `<i data-lucide="check-circle" class="w-3.5 h-3.5" style="color:#4ade80;"></i> Marks: ${marksVisible ? 'ON' : 'OFF'}`;
  btn.style.opacity = marksVisible ? '1' : '0.5';
  lucide.createIcons();
}

// Zoom
function zoomImage(factor) {
  currentZoom = Math.min(4, Math.max(0.5, currentZoom * factor));
  const img = document.getElementById('student-img');
  img.style.transformOrigin = 'top left';
  img.style.transform = `scale(${currentZoom})`;
  document.getElementById('canvas-wrapper').style.overflow = currentZoom > 1 ? 'auto' : 'hidden';
}
function resetZoom() {
  currentZoom = 1;
  document.getElementById('student-img').style.transform = '';
  document.getElementById('canvas-wrapper').style.overflow = 'hidden';
}

// Responsive resize: rebuild Konva when wrapper size changes
const resizeObserver = new ResizeObserver(() => {
  if (konvaStage && document.getElementById('result-section').style.display !== 'none') {
    requestAnimationFrame(buildKonva);
  }
});
resizeObserver.observe(document.getElementById('canvas-wrapper'));

// Also listen to orientation change
window.addEventListener('orientationchange', () => {
  setTimeout(() => {
    if (konvaStage) buildKonva();
  }, 350);
});

/* ══════════════════════════════════════════════════════════════════════
   7. KATEX STEP RENDERER — Topper's Notebook
   ══════════════════════════════════════════════════════════════════════ */
function renderSteps(steps) {
  const container = document.getElementById('steps-container');
  container.innerHTML = '';

  (steps || []).forEach((s, i) => {
    const card = document.createElement('div');
    card.className = 'step-card py-5 px-1';

    const header = document.createElement('div');
    header.className = 'flex items-start gap-3 sm:gap-4';

    const numEl = document.createElement('div');
    numEl.className = 'step-num mt-0.5 flex-shrink-0';
    numEl.textContent = s.step || (i + 1);

    const body = document.createElement('div');
    body.className = 'flex-1 min-w-0';

    const textEl = document.createElement('p');
    textEl.className = 'text-sm sm:text-base text-slate-700 dark:text-gray-200 leading-relaxed font-medium';
    textEl.textContent = s.text;
    body.appendChild(textEl);

    if (s.latex) {
      const mathBlock = document.createElement('div');
      mathBlock.className = 'katex-block';
      try {
        katex.render(s.latex, mathBlock, {
          displayMode: true,
          throwOnError: false,
          trust: true,
        });
      } catch(err) {
        mathBlock.textContent = s.latex;
        mathBlock.style.fontFamily = 'monospace';
        mathBlock.style.color = '#6C2BD9';
      }
      body.appendChild(mathBlock);
    }

    header.appendChild(numEl);
    header.appendChild(body);
    card.appendChild(header);
    container.appendChild(card);
  });
}

/* ══════════════════════════════════════════════════════════════════════
   8. RESET
   ══════════════════════════════════════════════════════════════════════ */
function resetEvaluator() {
  clearInterval(loadingInterval);

  // Cancel any in-flight fetch
  if (submitAbortCtrl) { try { submitAbortCtrl.abort('cancelled'); } catch(_){} submitAbortCtrl = null; }
  lastFormData = null;

  // Reset file state
  fileDT = new DataTransfer();
  fileInput.files = fileDT.files;
  document.getElementById('file-preview-list').innerHTML = '';

  // Reset Konva
  if (konvaStage) { konvaStage.destroy(); konvaStage = null; }
  errorGroup = null; markGroup = null;
  errorsVisible = true; marksVisible = true; annotationsVisible = true;

  // Reset img + DOM
  document.getElementById('student-img').src = '';
  document.getElementById('img-info-bar').innerHTML = '';
  document.getElementById('meta-chips').innerHTML = '';
  document.getElementById('rubric-bars').innerHTML = '';
  document.getElementById('steps-container').innerHTML = '';
  document.getElementById('ring-fill-el').style.strokeDashoffset = '351.9';
  document.getElementById('score-main').textContent = '—';
  const psWrap = document.getElementById('ps-wrapper');
  if (psWrap) psWrap.style.display = 'none';

  // Show upload, hide result + loading
  const up = document.getElementById('upload-section');
  up.style.display = ''; up.style.opacity = '1'; up.style.pointerEvents = '';
  document.getElementById('loading-section').classList.add('hidden');
  document.getElementById('result-section').style.display = 'none';

  submitBtn.disabled = true;
  document.getElementById('submit-label').innerHTML =
    `<i data-lucide="gavel" class="w-5 h-5"></i> Submit to Strict Examiner`;

  currentZoom = 1; currentAnnotations = [];
  lucide.createIcons();
  gsap.from('.gsap-entry', { y: 20, opacity: 0, stagger: 0.07, duration: 0.55, ease: 'power2.out' });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

