            class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border transition-all hover:opacity-80"
            style="border-color:rgba(108,43,217,0.3);background:rgba(108,43,217,0.08);color:#a78bfa;">
            <i data-lucide="upload-cloud" class="w-4 h-4"></i> Upload Again
          </button>
        </div>
      </div>
    </div>`;
  lucide.createIcons();
}

async function submitWithRetry(formData, attempt = 1) {
  submitAbortCtrl = new AbortController();
  const timeoutId = setTimeout(() => submitAbortCtrl.abort('timeout'), SUBMIT_TIMEOUT_MS);

  try {
    const response = await fetch('/examiner/evaluate', {
      method: 'POST', body: formData, signal: submitAbortCtrl.signal,
    });
    clearTimeout(timeoutId);

    if (!response.ok) {
      if (response.status === 429) {
        showErrorState('Rate limit reached', 'You\'ve used too many evaluations recently. Please wait a minute and try again.', true);
        return;
      }
      if (response.status >= 500) throw new Error(`Server error ${response.status}`);
      showErrorState(`Request failed (${response.status})`, 'The server rejected the request. Please check your inputs and try again.', false);
      return;
    }

    let json;
    try { json = await response.json(); } catch (_) { throw new Error('Invalid JSON from server'); }

    if (json && json.meta) {
      animateProgress(100);
      setTimeout(() => renderResult(json, json.imageUrls || ''), 400);
    } else {
      showErrorState('Unexpected response format', 'The server returned data in an unrecognised format. Please try again.', true);
    }
  } catch (err) {
    clearTimeout(timeoutId);
    if (err.name !== 'AbortError' && err.message !== 'cancelled' && attempt <= SUBMIT_MAX_RETRIES) {
      const statusEl = document.getElementById('loading-status');
      if (statusEl) statusEl.textContent = `Network hiccup — retrying (attempt ${attempt + 1} of ${SUBMIT_MAX_RETRIES + 1})…`;
      await new Promise(r => setTimeout(r, RETRY_DELAY_MS));
      return submitWithRetry(formData, attempt + 1);
    }
    if (err.name === 'AbortError' || String(err.message).includes('timeout')) {
      showErrorState('Request timed out', `Gemini took longer than ${SUBMIT_TIMEOUT_MS / 1000}s. Please try again.`, true);
    } else {
      showErrorState('Network error', `Could not reach the server: ${err.message}.`, true);
    }
  }
}

function retrySubmit() {
  if (!lastFormData) { resetEvaluator(); return; }
  // Restore the loading HTML
  document.getElementById('loading-section').innerHTML = buildLoaderHTML();
  lucide.createIcons();
