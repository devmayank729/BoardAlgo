  DEVICE METADATA
════════════════════════════════════════════════════════════════════ */
function captureDeviceMetadata() {
  const ua = navigator.userAgent;
  let dtype = 'desktop';
  if (/Mobi|Android|iPhone|iPad|iPod/i.test(ua)) dtype = 'mobile';
  else if (/Tablet|iPad/i.test(ua)) dtype = 'tablet';
  document.getElementById('f-sw').value    = screen.width;
  document.getElementById('f-sh').value    = screen.height;
  document.getElementById('f-dpr').value   = window.devicePixelRatio || 1;
  document.getElementById('f-dtype').value = dtype;
  document.getElementById('f-vw').value    = window.innerWidth;
  document.getElementById('f-vh').value    = window.innerHeight;
  document.getElementById('f-ua').value    = ua;
  document.getElementById('f-ts').value    = new Date().toISOString();
}

/* ════════════════════════════════════════════════════════════════════
  FILE MANAGEMENT
════════════════════════════════════════════════════════════════════ */
const dropZone    = document.getElementById('drop-zone');
const fileInput   = document.getElementById('file-input');
const previewList = document.getElementById('file-preview-list');
const submitBtn   = document.getElementById('submit-btn');
let   fileDT      = new DataTransfer();

const BLOCKED_TYPES = ['application/pdf', 'application/x-pdf'];
const MAX_FILE_SIZE = 20 * 1024 * 1024; // 20 MB
const MAX_FILES     = 20;

function refreshSubmit() {
  submitBtn.disabled = fileDT.files.length === 0;
  const cd = document.getElementById('file-count-display');
  if (fileDT.files.length > 0) {
    cd.textContent = `${fileDT.files.length} image${fileDT.files.length > 1 ? 's' : ''} selected`;
    cd.classList.remove('hidden');
  } else {
    cd.classList.add('hidden');
  }
}

function formatBytes(b) {
  if (b < 1024) return b + ' B';
  if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
  return (b / (1024 * 1024)).toFixed(2) + ' MB';
}

function buildImageMeta() {
  const arr = Array.from(fileDT.files).map(f => ({
    name: f.name, size: f.size, sizeHuman: formatBytes(f.size),
    type: f.type, lastModified: f.lastModified
  }));
  document.getElementById('f-imgmeta').value = JSON.stringify(arr);
}

function addFiles(files) {
  Array.from(files).forEach(f => {
    // ★ Block PDFs
    if (BLOCKED_TYPES.includes(f.type) || f.name.toLowerCase().endsWith('.pdf')) {
      showToast(`"${f.name}" — PDFs are not accepted. Please upload an image.`, 'error');
      return;
    }
    // Max files
    if (fileDT.files.length >= MAX_FILES) {
      showToast(`Maximum ${MAX_FILES} images allowed.`, 'error');
      return;
    }
    // Max size
    if (f.size > MAX_FILE_SIZE) {
      showToast(`"${f.name}" exceeds the 20 MB limit.`, 'error');
      return;
    }
    // Deduplicate
    const dup = Array.from(fileDT.files).some(x => x.name === f.name && x.size === f.size);
    if (dup) return;

    fileDT.items.add(f);
    renderChip(f);
  });
  fileInput.files = fileDT.files;
  buildImageMeta();
  refreshSubmit();
}

/* ★ THUMBNAIL CHIP — shows actual image preview */
function renderChip(file) {
  const chip = document.createElement('div');
  chip.className = 'file-chip';
  chip.dataset.name = file.name;
  chip.dataset.size = file.size;

  // Create thumbnail
  const thumb = document.createElement('img');
  thumb.className = 'chip-thumb';
  thumb.alt = file.name;
  const objUrl = URL.createObjectURL(file);
  thumb.src = objUrl;
  thumb.onload = () => {}; // blob URL, fast

  const nameEl  = document.createElement('span');
  nameEl.className = 'file-chip-name';
  nameEl.textContent = file.name;

  const sizeEl  = document.createElement('span');
  sizeEl.className = 'text-[10px] text-purple-300/70 flex-shrink-0';
  sizeEl.textContent = formatBytes(file.size);

  const removeEl = document.createElement('span');
  removeEl.className = 'chip-remove';
  removeEl.title = 'Remove';
  removeEl.textContent = '✕';
  removeEl.addEventListener('click', e => {
    e.stopPropagation();
    URL.revokeObjectURL(objUrl);
    const newDT = new DataTransfer();
    Array.from(fileDT.files).forEach(x => {
      if (!(x.name === file.name && x.size === file.size)) newDT.items.add(x);
    });
    fileDT = newDT;
    fileInput.files = fileDT.files;
    buildImageMeta();
    chip.remove();
    refreshSubmit();
  });

  chip.appendChild(thumb);
  chip.appendChild(nameEl);
  chip.appendChild(sizeEl);
  chip.appendChild(removeEl);
  previewList.appendChild(chip);
}

/* ★ PASTE HANDLER — Ctrl+V anywhere on the page */
document.addEventListener('paste', (e) => {
  const items = e.clipboardData && e.clipboardData.items;
  if (!items) return;
  const imageFiles = [];
  for (const item of items) {
    if (item.kind === 'file' && item.type.startsWith('image/')) {
      const file = item.getAsFile();
      if (file) {
        // Give it a useful name with timestamp
        const ext = file.type.split('/')[1] || 'png';
        const named = new File([file], `paste-${Date.now()}.${ext}`, { type: file.type });
        imageFiles.push(named);
      }
    }
  }
  if (imageFiles.length > 0) {
    // Flash the drop zone green
    dropZone.classList.add('paste-flash');
    setTimeout(() => dropZone.classList.remove('paste-flash'), 500);
    addFiles(imageFiles);
    showToast(`${imageFiles.length} image${imageFiles.length > 1 ? 's' : ''} pasted from clipboard ✓`, 'success');
  }
});

// Click and drag-drop
dropZone.addEventListener('click', e => {
  if (e.target.closest('.chip-remove') || e.target.closest('.file-chip')) return;
  fileInput.click();
});
dropZone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
fileInput.addEventListener('change', () => addFiles(fileInput.files));

['dragenter','dragover'].forEach(ev =>
  dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.add('drag-over'); }));
['dragleave','dragend','drop'].forEach(ev =>
  dropZone.addEventListener(ev, () => dropZone.classList.remove('drag-over')));
dropZone.addEventListener('drop', e => { e.preventDefault(); addFiles(e.dataTransfer.files); });

/* ════════════════════════════════════════════════════════════════════
  TOAST NOTIFICATIONS
════════════════════════════════════════════════════════════════════ */
function showToast(message, type = 'info') {
  const toast = document.createElement('div');
  const colors = {
    success: 'rgba(22,163,74,0.95)', error: 'rgba(239,68,68,0.95)', info: 'rgba(108,43,217,0.95)'
  };
  toast.style.cssText = `
    position: fixed; bottom: 20px; right: 20px; z-index: 99999;
    padding: 10px 16px; border-radius: 10px;
    background: ${colors[type] || colors.info};
    color: white; font-size: 0.8rem; font-weight: 600;
    font-family: 'Inter', sans-serif;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    animation: toastIn 0.3s ease; max-width: 320px; line-height: 1.4;
  `;
  toast.textContent = message;
  if (!document.getElementById('toast-style')) {
    const s = document.createElement('style');
    s.id = 'toast-style';
    s.textContent = `@keyframes toastIn { from { opacity:0; transform: translateY(12px) scale(0.95); } to { opacity:1; transform: none; } }
    @keyframes toastOut { from { opacity:1; } to { opacity:0; transform: translateY(6px); } }`;
    document.head.appendChild(s);
  }
  document.body.appendChild(toast);
  setTimeout(() => {
    toast.style.animation = 'toastOut 0.3s ease forwards';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

