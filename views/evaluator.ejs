<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>BoardAlgo | Strict Board Evaluator</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@500;600;700;800&family=Kalam:wght@400;700&display=swap" rel="stylesheet">

  <!-- CDN: Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- CDN: Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <!-- CDN: GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

  <!-- CDN: Three.js (particle bg) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <!-- CDN: Konva.js (image annotation canvas) -->
  <script src="https://unpkg.com/konva@9.3.6/konva.min.js"></script>

  <!-- CDN: KaTeX (math rendering) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: {
              black:   '#020617',
              surface: '#0f172a',
              border:  '#1e293b',
              primary: '#6C2BD9',
              accent:  '#16A34A',
              red:     '#EF4444',
            }
          },
          fontFamily: {
            sans:    ['Inter', 'sans-serif'],
            display: ['Poppins', 'sans-serif'],
            hand:    ['Kalam', 'cursive'],
          }
        }
      }
    }
  </script>

  <style>
    /* ─── CSS Variables ─────────────────────────────── */
    :root {
      --c-primary: #6C2BD9;
      --c-accent:  #16A34A;
      --c-red:     #EF4444;
      --c-surface: #0f172a;
      --c-bg:      #020617;
    }

    /* ─── Base ──────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background-color: #f8fafc;
      color: #0f172a;
      transition: background-color 0.3s, color 0.3s;
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    .dark body { background-color: #020617; color: #f8fafc; }

    /* ─── Scrollbar ─────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.3); border-radius: 3px; }

    /* ─── Glass ─────────────────────────────────────── */
    .glass {
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(0,0,0,0.07);
    }
    .dark .glass {
      background: rgba(15,23,42,0.65);
      border: 1px solid rgba(255,255,255,0.08);
    }

    /* ─── Logout btn (match dashboard) ─────────────── */
    .logout-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 13px; border-radius: 9px;
      border: 1px solid rgba(239,68,68,0.28);
      background: rgba(239,68,68,0.07);
      color: #f87171; font-size: 0.8rem; font-weight: 500;
      text-decoration: none; transition: all 0.2s;
    }
    .logout-btn:hover { background: rgba(239,68,68,0.16); border-color: rgba(239,68,68,0.5); }

    /* ─── Avatar ring ───────────────────────────────── */
    .avatar-ring {
      background: conic-gradient(#6C2BD9 0%, #a78bfa 45%, #16A34A 70%, #6C2BD9 100%);
      border-radius: 50%; padding: 2px; display: inline-flex;
    }
    .avatar-inner {
      border-radius: 50%; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Poppins', sans-serif; font-weight: 700;
    }

    /* ─── Footer link ───────────────────────────────── */
    .footer-link { color: #94a3b8; font-size: 0.875rem; text-decoration: none; transition: color 0.2s; }
    .footer-link:hover { color: var(--c-primary); }

    /* ═══════════════════════════════════════════════════
       STATE A — UPLOAD
    ══════════════════════════════════════════════════════ */

    /* Drop zone */
    #drop-zone {
      border: 2px dashed rgba(108,43,217,0.35);
      border-radius: 22px;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      cursor: pointer; position: relative; overflow: hidden;
    }
    #drop-zone::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% -10%, rgba(108,43,217,0.07), transparent 65%);
      pointer-events: none; transition: opacity 0.3s;
    }
    #drop-zone.drag-over {
      border-color: var(--c-primary);
      box-shadow: 0 0 0 4px rgba(108,43,217,0.18), 0 24px 48px rgba(108,43,217,0.15);
      transform: scale(1.012);
    }
    #drop-zone.drag-over::before { opacity: 2; }
    #drop-zone:hover:not(.drag-over) {
      border-color: rgba(108,43,217,0.6);
      box-shadow: 0 8px 32px rgba(108,43,217,0.1);
    }

    /* Upload icon bounce */
    .upload-icon-wrap {
      width: 84px; height: 84px; border-radius: 24px;
      margin: 0 auto 22px;
      background: linear-gradient(135deg, rgba(108,43,217,0.13), rgba(99,102,241,0.1));
      border: 1px solid rgba(108,43,217,0.22);
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }
    #drop-zone:hover .upload-icon-wrap { transform: translateY(-6px) scale(1.07); }

    /* File chip */
    .file-chip {
      display: flex; align-items: center; gap: 7px;
      padding: 5px 10px 5px 8px; border-radius: 10px;
      background: rgba(108,43,217,0.1); border: 1px solid rgba(108,43,217,0.22);
      font-size: 0.75rem; font-weight: 500; color: #a78bfa;
      animation: chipIn 0.22s cubic-bezier(0.34,1.56,0.64,1);
      max-width: 190px;
    }
    .dark .file-chip { background: rgba(108,43,217,0.16); }
    @keyframes chipIn {
      from { opacity:0; transform: scale(0.85) translateY(6px); }
      to   { opacity:1; transform: none; }
    }
    .file-chip-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex:1; }
    .chip-remove { cursor: pointer; opacity: 0.6; flex-shrink:0; transition: opacity 0.15s, transform 0.15s; }
    .chip-remove:hover { opacity:1; transform: scale(1.2); }

    /* Format badge */
    .fmt-badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 12px; border-radius: 10px;
      font-size: 0.75rem; font-weight: 600;
      border: 1px solid rgba(0,0,0,0.07);
      background: rgba(0,0,0,0.03);
      color: #475569; transition: all 0.2s;
    }
    .dark .fmt-badge {
      border-color: rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.04);
      color: #94a3b8;
    }
    .fmt-badge:hover { border-color: rgba(108,43,217,0.3); background: rgba(108,43,217,0.06); color: #a78bfa; }

    /* Submit btn */
    .btn-submit {
      width: 100%; padding: 15px 24px; border-radius: 15px;
      background: linear-gradient(135deg, #6C2BD9 0%, #7c3aed 45%, #b91c1c 100%);
      color: #fff; font-family: 'Poppins', sans-serif; font-weight: 700;
      font-size: 1.0rem; letter-spacing: 0.01em; border: none; cursor: pointer;
      box-shadow: 0 6px 28px rgba(108,43,217,0.45), inset 0 1px 0 rgba(255,255,255,0.15);
      transition: all 0.25s ease; position: relative; overflow: hidden;
    }
    .btn-submit::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.14), transparent 60%);
      pointer-events: none;
    }
    .btn-submit:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 36px rgba(108,43,217,0.55), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .btn-submit:active:not(:disabled) { transform: translateY(0); }
    .btn-submit:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ═══════════════════════════════════════════════════
       LOADING STATE
    ══════════════════════════════════════════════════════ */
    .scanner-line {
      position: absolute; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, #6C2BD9, #EF4444, transparent);
      animation: scan 2s linear infinite;
    }
    @keyframes scan {
      0%  { top: 0; opacity: 1; }
      95% { top: 100%; opacity: 0.6; }
      100%{ top: 0; opacity: 0; }
    }
    @keyframes thinking-pulse {
      0%,100% { opacity:1; transform: scale(1); }
      50% { opacity:0.3; transform: scale(0.75); }
    }
    .t-dot { animation: thinking-pulse 1.5s ease-in-out infinite; }
    .t-dot:nth-child(2) { animation-delay: 0.25s; }
    .t-dot:nth-child(3) { animation-delay: 0.5s; }

    /* ═══════════════════════════════════════════════════
       STATE B — RESULT
    ══════════════════════════════════════════════════════ */

    /* Scorecard */
    .scorecard {
      background: linear-gradient(135deg, rgba(239,68,68,0.07) 0%, rgba(108,43,217,0.06) 50%, rgba(22,163,74,0.04) 100%);
      border: 1px solid rgba(239,68,68,0.22);
    }
    .dark .scorecard { background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(108,43,217,0.08), rgba(22,163,74,0.05)); }

    /* Score ring */
    .score-ring-wrap { position: relative; display: inline-flex; align-items: center; justify-content: center; }
    .score-ring-wrap svg { transform: rotate(-90deg); }
    .ring-track { fill: none; stroke: rgba(108,43,217,0.13); }
    .ring-fill  { fill: none; stroke: url(#rGrad); stroke-linecap: round;
                  transition: stroke-dashoffset 1.4s cubic-bezier(0.34,1.56,0.64,1); }
    .ring-text  { position: absolute; text-align: center; font-family: 'Poppins', sans-serif; }

    /* Strict badge */
    .strict-badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px; border-radius: 99px;
      background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);
      color: #f87171; font-size: 0.68rem; font-weight: 800;
      letter-spacing: 0.06em; text-transform: uppercase;
    }

    /* Difficulty pill */
    .diff-pill {
      padding: 2px 9px; border-radius: 99px;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .diff-easy   { background:rgba(22,163,74,0.12);  color:#4ade80; border:1px solid rgba(22,163,74,0.25); }
    .diff-medium { background:rgba(245,158,11,0.12); color:#fbbf24; border:1px solid rgba(245,158,11,0.25); }
    .diff-hard   { background:rgba(239,68,68,0.12);  color:#f87171; border:1px solid rgba(239,68,68,0.3); }

    /* ─── AR Canvas wrapper ─────────────────────────── */
    #canvas-wrapper {
      position: relative;
      display: inline-block;
      width: 100%;
      line-height: 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    #student-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 12px;
    }
    #konva-container {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      border-radius: 12px;
      overflow: hidden;
    }

    /* annotation tooltip */
    .anno-tooltip {
      position: absolute;
      background: rgba(15,23,42,0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(239,68,68,0.35);
      color: #fca5a5;
      padding: 5px 10px; border-radius: 8px;
      font-size: 0.75rem; font-weight: 600;
      pointer-events: none; z-index: 20;
      transform: translateX(-50%);
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      opacity: 0; transition: opacity 0.15s;
    }
    .anno-tooltip.show { opacity: 1; }

    /* ─── Topper's Notebook ─────────────────────────── */
    .toppers-notebook {
      background: #ffffff;
      border-left: 4px solid var(--c-primary);
      border-radius: 0 14px 14px 0;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 8px rgba(108,43,217,0.1);
    }
    .dark .toppers-notebook {
      background: rgba(15,23,42,0.85);
      border-left-color: #a78bfa;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .step-card {
      border-bottom: 1px solid rgba(108,43,217,0.08);
      transition: background 0.2s;
    }
    .dark .step-card { border-bottom-color: rgba(255,255,255,0.05); }
    .step-card:last-child { border-bottom: none; }
    .step-card:hover { background: rgba(108,43,217,0.03); }
    .dark .step-card:hover { background: rgba(108,43,217,0.07); }
    .step-num {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, #6C2BD9, #a855f7);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.75rem; font-weight: 700;
      font-family: 'Poppins', sans-serif;
      box-shadow: 0 3px 10px rgba(108,43,217,0.4);
    }
    .katex-block {
      overflow-x: auto; padding: 10px 16px; border-radius: 10px;
      background: rgba(108,43,217,0.05); border: 1px solid rgba(108,43,217,0.1);
      margin-top: 10px;
    }
    .dark .katex-block { background: rgba(108,43,217,0.09); border-color: rgba(108,43,217,0.18); }
    .katex-block .katex { font-size: 1.1em; }

    /* ─── Rubric bar ────────────────────────────────── */
    .rbar-track { background: rgba(0,0,0,0.06); height: 7px; border-radius: 99px; overflow: hidden; }
    .dark .rbar-track { background: rgba(255,255,255,0.07); }
    .rbar-fill { height: 100%; border-radius: 99px; transition: width 1.1s cubic-bezier(0.34,1.56,0.64,1); }

    /* ─── Glow card ─────────────────────────────────── */
    .glow-card { transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; }
    .glow-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(108,43,217,0.14);
      border-color: rgba(108,43,217,0.25) !important;
    }

    /* ─── Metadata chip ─────────────────────────────── */
    .meta-chip {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 8px;
      font-size: 0.72rem; font-weight: 600;
      background: rgba(108,43,217,0.08); border: 1px solid rgba(108,43,217,0.18);
      color: #a78bfa;
    }
    .dark .meta-chip { background: rgba(108,43,217,0.13); }

    /* ─── Glow dot ──────────────────────────────────── */
    .glow-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #16A34A; box-shadow: 0 0 6px #16A34A;
      display: inline-block; animation: dotpulse 2s ease-in-out infinite;
    }
    @keyframes dotpulse {
      0%,100% { opacity:1; transform:scale(1); }
      50% { opacity:0.5; transform:scale(0.8); }
    }

    /* ─── Diagram placeholder ───────────────────────── */
    .diagram-ph {
      border: 2px dashed rgba(108,43,217,0.22);
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(108,43,217,0.04), rgba(99,102,241,0.03));
      transition: border-color 0.3s, background 0.3s;
    }
    .diagram-ph:hover { border-color: rgba(108,43,217,0.42); }

    /* ─── Section header rule ───────────────────────── */
    .section-rule {
      display: flex; align-items: center; gap: 12px; margin-bottom: 18px;
    }
    .section-rule h3 { font-family: 'Poppins', sans-serif; font-weight: 700; }
    .section-rule::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(90deg, rgba(108,43,217,0.2), transparent);
    }

    /* ─── Glass input ───────────────────────────────── */
    .gl-input {
      width: 100%;
      background: rgba(255,255,255,0.55);
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 11px; padding: 9px 13px;
      font-family: 'Inter', sans-serif; font-size: 0.875rem;
      color: #0f172a; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .dark .gl-input {
      background: rgba(0,0,0,0.28);
      border-color: rgba(255,255,255,0.09);
      color: #f1f5f9;
    }
    .gl-input:focus {
      border-color: #6C2BD9;
      box-shadow: 0 0 0 3px rgba(108,43,217,0.16);
    }
    .gl-input option { background: #0f172a; color: #f1f5f9; }
    select.gl-input { cursor: pointer; }

    /* ─── Responsive ────────────────────────────────── */
    @media (max-width: 640px) {
      .notebook-paper { padding: 28px 14px 36px 60px !important; }
    }

    /* ─── Print / PDF ───────────────────────────────── */
    @media print {
      #bg-canvas, nav, footer, #upload-section, #loading-section { display: none !important; }
      body { background: white !important; }
      .glass { background: white !important; box-shadow: none !important; }
    }
  </style>
</head>

<body class="antialiased min-h-screen flex flex-col relative overflow-x-hidden">

<!-- EJS: Backend injects evaluation data and image URL -->

<script>
  window.injectedEvaluationData = <%- JSON.stringify(evaluationData || null) %>;
</script>

<!-- Particle canvas -->
<canvas id="bg-canvas" class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none" style="opacity:0.3;"></canvas>
<div class="fixed inset-0 -z-10 pointer-events-none"
     style="background:radial-gradient(ellipse 70% 45% at 50% -10%, rgba(239,68,68,0.07), transparent);"></div>

<!-- ═══════════════════════════════ NAV ═══════════════════════════════ -->
<nav class="fixed top-0 w-full z-50 glass" style="border-bottom:1px solid rgba(0,0,0,0.05);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 gap-2">

      <!-- Logo + breadcrumb -->
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-base"
               style="background:linear-gradient(135deg,#6C2BD9,#a855f7);box-shadow:0 3px 10px rgba(108,43,217,0.4);">B</div>
          <span class="text-xl font-bold font-display tracking-tight text-slate-900 dark:text-white hidden sm:block">
            BOARD <span style="color:#6C2BD9;">Algo</span>
          </span>
        </a>
        <span class="hidden sm:flex items-center gap-1.5 text-sm text-slate-400 dark:text-gray-500">
          <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
          <span class="font-bold" style="color:#EF4444;">Strict Examiner</span>
        </span>
      </div>

      <!-- Right cluster -->
      <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">

        <!-- Theme toggle -->
        <button id="theme-toggle"
                class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-slate-500 dark:text-gray-400 transition-colors"
                aria-label="Toggle theme">
          <i data-lucide="sun"  class="hidden dark:block w-4 h-4 sm:w-5 sm:h-5"></i>
          <i data-lucide="moon" class="block dark:hidden w-4 h-4 sm:w-5 sm:h-5"></i>
        </button>

        <!-- Back to dashboard -->
        <a href="/dashboard"
           class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium
                  text-slate-600 dark:text-gray-300 hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
          <i data-lucide="layout-dashboard" class="w-3.5 h-3.5"></i> Dashboard
        </a>

        <a href="/auth/logout" class="logout-btn hidden sm:flex">
          <i data-lucide="log-out" class="w-3.5 h-3.5"></i><span>Logout</span>
        </a>

        <!-- Avatar chip -->
        <div class="flex items-center gap-2 pl-2 sm:pl-3 border-l border-gray-200 dark:border-gray-800">
          <div class="text-right hidden sm:block">
            <p class="text-sm font-semibold text-slate-900 dark:text-white leading-tight"><%= user.username %></p>
            <%
              let navLabel = 'Free Trial';
              if(user.subscription_status === 'ACTIVE') navLabel = 'Pro Member';
              else if(user.subscription_status === 'EXPIRED' || user.subscription_status === 'CHURNED') navLabel = 'Expired';
            %>
            <p class="text-xs font-medium mt-0.5" style="color:#6C2BD9;"><%= navLabel %></p>
          </div>
          <% if(user.photoURL) { %>
          <div class="avatar-ring flex-shrink-0" style="width:36px;height:36px;">
            <div class="avatar-inner w-full h-full">
              <img src="<%= user.photoURL %>" style="width:100%;height:100%;object-fit:cover;" alt="avatar">
            </div>
          </div>
          <% } else { %>
          <div class="h-9 w-9 rounded-full flex-shrink-0 flex items-center justify-center
                       text-white font-bold text-base font-display"
               style="background:linear-gradient(135deg,rgba(108,43,217,0.8),rgba(168,85,247,0.7));
                      border:2px solid rgba(108,43,217,0.4);">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════ MAIN ═══════════════════════════════ -->
<main class="flex-grow pt-20 sm:pt-24 pb-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-7 sm:space-y-10">

    <!-- ── Page Hero ── -->
    <div class="gsap-entry text-center space-y-3 pt-2">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full"
           style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);">
        <i data-lucide="gavel" class="w-3.5 h-3.5" style="color:#f87171;"></i>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#f87171;">AI-Powered · CBSE Grading</span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white tracking-tight leading-tight">
        Strict Board
        <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#EF4444 10%,#6C2BD9 90%);">
          Evaluator
        </span>
      </h1>
      <p class="text-base sm:text-lg text-slate-500 dark:text-gray-400 max-w-2xl mx-auto">
        Upload your handwritten answer. AI grades it with surgical precision — visual annotations, marks breakdown, and a topper-quality model answer.
      </p>
    </div>

    <!-- ── Feature tiles ── -->
    <div class="gsap-entry grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style="background:rgba(239,68,68,0.1);">
          <i data-lucide="shield-check" class="w-4 h-4" style="color:#f87171;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">CBSE Marking</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Official scheme</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style="background:rgba(108,43,217,0.1);">
          <i data-lucide="scan" class="w-4 h-4" style="color:#a78bfa;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">AR Annotations</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Visual marks</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style="background:rgba(22,163,74,0.1);">
          <i data-lucide="sigma" class="w-4 h-4" style="color:#4ade80;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">KaTeX Math</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Perfect rendering</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style="background:rgba(245,158,11,0.1);">
          <i data-lucide="zap" class="w-4 h-4" style="color:#fbbf24;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">Instant Results</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Under 30 sec</p>
      </div>
    </div>

    <!-- ════════════ STATE A: UPLOAD FORM ════════════ -->
    <div id="upload-section" class="gsap-entry">
      <form id="evaluator-form" method="POST" action="/examiner/evaluate" enctype="multipart/form-data"
            novalidate>

        <!-- Hidden metadata fields (populated by JS before submit) -->
        <input type="hidden" name="screen_width"        id="f-sw">
        <input type="hidden" name="screen_height"       id="f-sh">
        <input type="hidden" name="device_pixel_ratio"  id="f-dpr">
        <input type="hidden" name="device_type"         id="f-dtype">
        <input type="hidden" name="viewport_width"      id="f-vw">
        <input type="hidden" name="viewport_height"     id="f-vh">
        <input type="hidden" name="user_agent"          id="f-ua">
        <input type="hidden" name="image_metadata_json" id="f-imgmeta">
        <input type="hidden" name="timestamp_submit"    id="f-ts">

        <!-- Subject / Marks / Class / Exam Year row -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Subject *</label>
            <select name="subject" class="gl-input" required>
              <option value="">Select…</option>
              <option>Physics</option>
              <option>Chemistry</option>
              <option>Mathematics</option>
              <option>Biology</option>
              <option>English</option>
              <option>History</option>
              <option>Geography</option>
              <option>Economics</option>
              <option>Computer Science</option>
              <option>Accountancy</option>
              <option>Business Studies</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Max Marks *</label>
            <input type="number" name="total_marks" min="1" max="100" placeholder="e.g. 5"
                   class="gl-input" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Class *</label>
            <select name="class" class="gl-input" required>
              <option value="">Select…</option>
              <% ['9','10','11','12'].forEach(function(c){ %>
              <option value="<%= c %>" <%= (user.Class === c) ? 'selected' : '' %>>Class <%= c %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Exam Year</label>
            <select name="exam_year" class="gl-input">
              <option value="">Any</option>
              <% for(let y=2025;y>=2015;y--){ %>
              <option value="<%= y %>"><%= y %></option>
              <% } %>
            </select>
          </div>
        </div>

        <!-- Question text -->
        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">
            Question / Topic
            <span class="normal-case font-normal text-slate-400 ml-1">(improves accuracy significantly)</span>
          </label>
          <textarea name="question_text" rows="2"
                    placeholder="e.g. Find the derivative of f(x) = x² · sin(x) using the product rule…"
                    class="gl-input" style="resize:vertical;"></textarea>
        </div>

        <!-- ── Drag & Drop zone ── -->
        <div id="drop-zone"
             class="glass rounded-2xl p-8 sm:p-14 text-center mb-5"
             role="button" tabindex="0" aria-label="Upload answer sheets">
          <div class="upload-icon-wrap">
            <i data-lucide="upload-cloud" class="w-10 h-10" style="color:#6C2BD9;"></i>
          </div>
          <h3 class="text-lg sm:text-xl font-bold font-display text-slate-900 dark:text-white mb-2">
            Drop your answer sheets here
          </h3>
          <p class="text-sm text-slate-400 dark:text-gray-500 mb-7">
            or <span class="font-semibold" style="color:#6C2BD9;">browse to upload</span>
          </p>
          <!-- Format badges -->
          <div class="flex flex-wrap justify-center gap-2 mb-7">
            <span class="fmt-badge"><i data-lucide="camera" class="w-3 h-3" style="color:#6C2BD9;"></i> Camera</span>
            <span class="fmt-badge"><i data-lucide="image"  class="w-3 h-3" style="color:#818cf8;"></i> JPG / PNG / WEBP</span>
            <span class="fmt-badge"><i data-lucide="file-text" class="w-3 h-3" style="color:#f472b6;"></i> PDF</span>
            <span class="fmt-badge"><i data-lucide="layers" class="w-3 h-3" style="color:#fbbf24;"></i> Multiple Pages</span>
          </div>
          <!-- File chip list -->
          <div id="file-preview-list" class="flex flex-wrap justify-center gap-2"></div>
          <p id="drop-hint" class="text-xs text-slate-400 dark:text-gray-600 mt-5">Max 10 files · 20 MB each</p>
        </div>
        <input type="file" id="file-input" name="answer_images"
               multiple accept="image/*" capture="environment" class="hidden">

        <!-- Submit -->
        <button type="submit" id="submit-btn" class="btn-submit" disabled>
          <span id="submit-label" class="flex items-center justify-center gap-2.5">
            <i data-lucide="gavel" class="w-5 h-5"></i>
            Submit to Strict Examiner
          </span>
        </button>
        <p class="text-center text-xs text-slate-400 dark:text-gray-600 mt-3">
          Your screen & image metadata are sent alongside your answer to improve evaluation accuracy.
        </p>
      </form>
    </div><!-- /upload-section -->

    <!-- ════════════ LOADING STATE ════════════ -->
    <div id="loading-section" class="hidden">
      <div class="glass rounded-2xl border border-gray-200 dark:border-white/6 overflow-hidden" style="position:relative;">
        <!-- Scanner animation bar -->
        <div class="scanner-line"></div>
        <div class="p-10 sm:p-16 text-center">
          <div class="w-20 h-20 rounded-2xl mx-auto mb-6 flex items-center justify-center"
               style="background:linear-gradient(135deg,#EF4444,#6C2BD9);box-shadow:0 8px 30px rgba(239,68,68,0.45);">
            <i data-lucide="scan-line" class="w-9 h-9 text-white"></i>
          </div>
          <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Examiner Analysing…</h3>
          <p id="loading-status" class="text-sm text-slate-400 dark:text-gray-500 mb-8 transition-all duration-500">
            Reading your handwriting…
          </p>
          <div class="flex justify-center gap-2.5">
            <span class="t-dot w-3 h-3 rounded-full inline-block" style="background:#EF4444;"></span>
            <span class="t-dot w-3 h-3 rounded-full inline-block" style="background:#6C2BD9;"></span>
            <span class="t-dot w-3 h-3 rounded-full inline-block" style="background:#16A34A;"></span>
          </div>
          <!-- Progress steps -->
          <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-lg mx-auto text-left">
            <div id="step-read"  class="flex items-center gap-2 text-xs text-slate-400 dark:text-gray-500">
              <div class="w-5 h-5 rounded-full border-2 border-purple-500 flex items-center justify-center animate-spin" id="spin-read">
                <i data-lucide="loader-2" class="w-3 h-3 text-purple-500"></i>
              </div> Reading answer
            </div>
            <div id="step-eval"  class="flex items-center gap-2 text-xs text-slate-400 dark:text-gray-500 opacity-40">
              <div class="w-5 h-5 rounded-full border-2 border-gray-400 flex items-center justify-center" id="spin-eval">
                <i data-lucide="loader-2" class="w-3 h-3 text-gray-400"></i>
              </div> Applying marking
            </div>
            <div id="step-done"  class="flex items-center gap-2 text-xs text-slate-400 dark:text-gray-500 opacity-40">
              <div class="w-5 h-5 rounded-full border-2 border-gray-400 flex items-center justify-center" id="spin-done">
                <i data-lucide="loader-2" class="w-3 h-3 text-gray-400"></i>
              </div> Generating answer
            </div>
          </div>
        </div>
      </div>
    </div><!-- /loading -->

    <!-- ════════════ STATE B: RESULT ════════════ -->
    <div id="result-section" style="display:none;">
    <div id="page-nav" class="hidden flex items-center gap-2 bg-slate-100 dark:bg-slate-800 rounded-lg p-1">
            <button onclick="prevPage()" class="p-1 rounded hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-600 dark:text-gray-300">
              <i data-lucide="chevron-left" class="w-4 h-4"></i>
            </button>
            <span id="page-indicator" class="text-xs font-bold px-2">Page 1 / 1</span>
            <button onclick="nextPage()" class="p-1 rounded hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-600 dark:text-gray-300">
              <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </button>
          </div>

      <!-- ─── 1. Scorecard ─── -->
      <div class="gsap-r scorecard glass rounded-2xl p-5 sm:p-7 mb-6 border">
        <div class="flex flex-col lg:flex-row items-start lg:items-center gap-6">

          <!-- Score ring -->
          <div class="score-ring-wrap flex-shrink-0 mx-auto lg:mx-0">
            <svg width="130" height="130" viewBox="0 0 130 130">
              <defs>
                <linearGradient id="rGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="#EF4444"/>
                  <stop offset="100%" stop-color="#6C2BD9"/>
                </linearGradient>
              </defs>
              <circle class="ring-track" cx="65" cy="65" r="56" stroke-width="9"/>
              <circle id="ring-fill-el" class="ring-fill" cx="65" cy="65" r="56"
                      stroke-width="9" stroke-dasharray="351.9" stroke-dashoffset="351.9"/>
            </svg>
            <div class="ring-text">
              <p id="score-main" class="text-2xl font-bold dark:text-white text-slate-900 leading-none">—</p>
              <p class="text-xs text-slate-400 mt-0.5">marks</p>
            </div>
          </div>

          <!-- Details -->
          <div class="flex-1 w-full">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <h2 class="text-xl font-bold font-display text-slate-900 dark:text-white">Evaluation Complete</h2>
              <span class="strict-badge"><i data-lucide="shield-alert" class="w-3 h-3"></i> Strict Mode</span>
              <span id="diff-badge" class="diff-pill">—</span>
            </div>

            <!-- Meta chips -->
            <div class="flex flex-wrap gap-2 mb-4" id="meta-chips"></div>

            <!-- Problem statement -->
            <div id="ps-wrapper" style="display:none;" class="mb-3">
              <div class="flex items-start gap-2 p-3 rounded-xl"
                   style="background:rgba(108,43,217,0.06);border:1px solid rgba(108,43,217,0.16);">
                <i data-lucide="help-circle" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:#a78bfa;"></i>
                <div>
                  <p class="text-xs font-bold text-slate-500 dark:text-gray-400 uppercase tracking-wide mb-0.5">Question</p>
                  <p id="problem-statement-banner" class="text-sm font-medium text-slate-800 dark:text-gray-100 leading-snug"></p>
                </div>
              </div>
            </div>

            <!-- Summary -->
            <div class="p-3 sm:p-4 rounded-xl mb-4"
                 style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);">
              <p class="text-sm font-semibold text-red-500 dark:text-red-400 mb-1 flex items-center gap-1.5">
                <i data-lucide="message-square-warning" class="w-3.5 h-3.5"></i>
                Examiner's Summary
              </p>
              <p id="eval-summary" class="text-sm text-slate-600 dark:text-gray-300 leading-relaxed"></p>
            </div>

            <!-- Rubric bars -->
            <div id="rubric-bars" class="space-y-2.5 mb-4"></div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-2">
              <button onclick="resetEvaluator()"
                      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold
                             border transition-all hover:opacity-80"
                      style="border-color:rgba(108,43,217,0.3);background:rgba(108,43,217,0.08);color:#a78bfa;">
                <i data-lucide="refresh-ccw" class="w-3.5 h-3.5"></i> New Evaluation
              </button>
              <button id="btn-download"
                      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold
                             border transition-all hover:opacity-80"
                      style="border-color:rgba(22,163,74,0.3);background:rgba(22,163,74,0.08);color:#4ade80;">
                <i data-lucide="download" class="w-3.5 h-3.5"></i> Download PDF
              </button>
              <button id="btn-share"
                      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold
                             border transition-all hover:opacity-80"
                      style="border-color:rgba(108,43,217,0.3);background:rgba(108,43,217,0.08);color:#a78bfa;">
                <i data-lucide="share-2" class="w-3.5 h-3.5"></i> Share
              </button>
            </div>
          </div>
        </div>
      </div><!-- /scorecard -->

      <!-- ─── 2. AR Canvas ─── -->
      <div class="gsap-r mb-8">
        <div class="section-rule">
          <h3 class="text-base text-slate-900 dark:text-white flex items-center gap-2">
            <i data-lucide="scan" class="w-4 h-4" style="color:#6C2BD9;"></i>
            Augmented Annotation View
          </h3>
        </div>

        <!-- Toolbar -->
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <button id="btn-toggle-annot" onclick="toggleAnnotations()"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border transition-all"
                  style="border-color:rgba(108,43,217,0.3);background:rgba(108,43,217,0.08);color:#a78bfa;">
            <i data-lucide="eye" class="w-3.5 h-3.5"></i> All: ON
          </button>
          <button id="btn-toggle-errors" onclick="toggleErrors()"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border transition-all"
                  style="border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.07);color:#f87171;">
            <i data-lucide="x-circle" class="w-3.5 h-3.5" style="color:#f87171;"></i> Errors: ON
          </button>
          <button id="btn-toggle-marks" onclick="toggleMarks()"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border transition-all"
                  style="border-color:rgba(22,163,74,0.3);background:rgba(22,163,74,0.07);color:#4ade80;">
            <i data-lucide="check-circle" class="w-3.5 h-3.5" style="color:#4ade80;"></i> Marks: ON
          </button>
          <button onclick="zoomImage(1.2)"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border border-gray-200 dark:border-white/8 text-slate-600 dark:text-gray-300 transition-all hover:border-purple-400">
            <i data-lucide="zoom-in" class="w-3.5 h-3.5"></i>
          </button>
          <button onclick="zoomImage(0.83)"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border border-gray-200 dark:border-white/8 text-slate-600 dark:text-gray-300 transition-all hover:border-purple-400">
            <i data-lucide="zoom-out" class="w-3.5 h-3.5"></i>
          </button>
          <button onclick="resetZoom()"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         border border-gray-200 dark:border-white/8 text-slate-600 dark:text-gray-300 transition-all hover:border-purple-400">
            <i data-lucide="maximize-2" class="w-3.5 h-3.5"></i> Reset
          </button>
          <!-- Legend -->
          <div class="flex items-center gap-3 ml-auto text-xs">
            <span class="flex items-center gap-1.5 text-slate-500 dark:text-gray-400">
              <span class="inline-block w-3 h-3 rounded-full" style="background:rgba(239,68,68,0.7);"></span> Error
            </span>
            <span class="flex items-center gap-1.5 text-slate-500 dark:text-gray-400">
              <span class="inline-block w-3 h-3 rounded-full" style="background:rgba(22,163,74,0.8);"></span> Mark
            </span>
          </div>
        </div>

        <!-- Image + Konva wrapper -->
        <div id="canvas-wrapper">
          <img id="student-img" src="" alt="Student answer sheet" loading="lazy">
          <div id="konva-container"></div>
          <!-- Tooltip div -->
          <div id="anno-tooltip" class="anno-tooltip"></div>
        </div>

        <!-- Image info bar -->
        <div id="img-info-bar"
             class="mt-2 flex flex-wrap items-center gap-3 text-xs text-slate-400 dark:text-gray-500">
        </div>
      </div><!-- /AR canvas -->

      <!-- ─── 3. Topper's Notebook ─── -->
      <div class="gsap-r mb-8">
        <div class="section-rule">
          <h3 class="text-base text-slate-900 dark:text-white flex items-center gap-2">
            <i data-lucide="book-open-check" class="w-4 h-4" style="color:#16A34A;"></i>
            Topper's Perfect Answer
          </h3>
        </div>

        <div class="toppers-notebook rounded-r-2xl overflow-hidden">
          <!-- Header strip -->
          <div class="px-5 sm:px-7 py-4 border-b border-gray-100 dark:border-white/5 flex items-center justify-between"
               style="background:linear-gradient(90deg,rgba(108,43,217,0.06),transparent);">
            <div class="flex items-center gap-2">
              <i data-lucide="award" class="w-4 h-4" style="color:#16A34A;"></i>
              <span class="text-sm font-bold text-slate-900 dark:text-white">Board-Standard Model Answer</span>
            </div>
            <span class="flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full"
                  style="background:rgba(22,163,74,0.1);color:#4ade80;border:1px solid rgba(22,163,74,0.25);">
              <span class="glow-dot" style="width:5px;height:5px;"></span> 100% correct
            </span>
          </div>
          <!-- Steps container -->
          <div id="steps-container" class="p-5 sm:p-7"></div>
        </div>
      </div>

      <!-- ─── 4. Diagram Placeholder ─── -->
      <div class="gsap-r diagram-ph p-8 sm:p-10 text-center mb-6">
        <div class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center"
             style="background:rgba(108,43,217,0.1);border:1px solid rgba(108,43,217,0.15);">
          <i data-lucide="pen-tool" class="w-5 h-5" style="color:#a78bfa;"></i>
        </div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-3"
              style="background:rgba(108,43,217,0.12);border:1px solid rgba(108,43,217,0.22);color:#a78bfa;">
          Coming Soon
        </span>
        <h4 class="text-base font-bold font-display text-slate-800 dark:text-gray-100 mb-2">
          Diagramming Engine <span style="color:#6C2BD9;">v2.0</span>
        </h4>
        <p class="text-sm text-slate-500 dark:text-gray-400 max-w-sm mx-auto leading-relaxed">
          CBSE-standard auto-generated diagrams — ray optics, circuit layouts, force vectors — rendered pixel-perfect for board exams.
        </p>
        <div class="flex flex-wrap justify-center gap-2 mt-4">
          <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-white/10 text-slate-400">Ray Diagrams</span>
