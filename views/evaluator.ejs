      { step:1, text:"Identify the structure: f(x) = x² · sin(x) is a product of two functions u(x) = x² and v(x) = sin(x). Apply the Product Rule.", latex:"(uv)' = u'v + uv'" },
      { step:2, text:"Differentiate each part individually:", latex:"\\frac{d}{dx}(x^2) = 2x \\qquad \\text{and} \\qquad \\frac{d}{dx}(\\sin x) = \\cos x" },
      { step:3, text:"Substitute back into the product rule formula:", latex:"f'(x) = (2x)(\\sin x) + (x^2)(\\cos x)" },
      { step:4, text:"Simplify to the final answer:", latex:"\\boxed{f'(x) = 2x\\sin(x) + x^2\\cos(x)}" }
    ]
  };
}

