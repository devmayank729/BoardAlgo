/** submitWithRetry — wraps fetch in retry logic with timeout */
async function submitWithRetry(formData, attempt = 1) {
  submitAbortCtrl = new AbortController();
  const timeoutId = setTimeout(() => submitAbortCtrl.abort('timeout'), SUBMIT_TIMEOUT_MS);

  try {
    const response = await fetch('/examiner/evaluate', {
      method: 'POST',
      body:   formData,
      signal: submitAbortCtrl.signal,
    });
    clearTimeout(timeoutId);

    // ── HTTP-level errors ──────────────────────────────────────────────
    if (!response.ok) {
      if (response.status === 429) {
        showErrorState(
          'Rate limit reached',
          'You\'ve used too many evaluations recently. Please wait a minute and try again.',
          true
        );
        return;
      }
      if (response.status >= 500) {
        throw new Error(`Server error ${response.status}`);
      }
      showErrorState(
        `Request failed (${response.status})`,
        'The server rejected the request. Please check your inputs and try again.',
        false
      );
      return;
    }

    // ── Parse JSON ─────────────────────────────────────────────────────
    let json;
    try {
      json = await response.json();
    } catch (_) {
      throw new Error('Invalid JSON from server');
    }

    // ── Success path ───────────────────────────────────────────────────
    if (json && json.meta) {
      renderResult(json, json.imageUrls || '');
    } else {
      showErrorState(
        'Unexpected response format',
        'The server returned data in an unrecognised format. Please try again.',
        true
      );
    }

  } catch (err) {
    clearTimeout(timeoutId);

    // Retry on network/timeout (not on explicit abort by user)
    if (err.name !== 'AbortError' && err.message !== 'cancelled' && attempt <= SUBMIT_MAX_RETRIES) {
      document.getElementById('loading-status').textContent =
        `Network hiccup — retrying (attempt ${attempt + 1} of ${SUBMIT_MAX_RETRIES + 1})…`;
      await new Promise(r => setTimeout(r, RETRY_DELAY_MS));
      return submitWithRetry(formData, attempt + 1);
    }

    // Final failure
    if (err.name === 'AbortError' || String(err.message).includes('timeout')) {
      showErrorState(
        'Request timed out',
        `Gemini took longer than ${SUBMIT_TIMEOUT_MS / 1000}s. This sometimes happens with complex answers. Please try again.`,
        true
      );
    } else {
      showErrorState(
        'Network error',
        `Could not reach the server: ${err.message}. Check your connection and try again.`,
        true
      );
    }
  }
}

