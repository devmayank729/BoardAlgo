<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>BoardAlgo | Strict Board Evaluator</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@500;600;700;800&family=Kalam:wght@400;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://unpkg.com/konva@9.3.6/konva.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: {
              black: '#020617', surface: '#0f172a', border: '#1e293b',
              primary: '#6C2BD9', accent: '#16A34A', red: '#EF4444',
            }
          },
          fontFamily: {
            sans: ['Inter','sans-serif'], display: ['Poppins','sans-serif'], hand: ['Kalam','cursive'],
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --c-primary: #6C2BD9; --c-accent: #16A34A; --c-red: #EF4444;
      --c-surface: #0f172a; --c-bg: #020617;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background-color: #f8fafc; color: #0f172a;
      transition: background-color 0.3s, color 0.3s;
      font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased;
    }
    .dark body { background-color: #020617; color: #f8fafc; }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.3); border-radius: 3px; }

    .glass {
      background: rgba(255,255,255,0.75); backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(0,0,0,0.07);
    }
    .dark .glass { background: rgba(15,23,42,0.65); border: 1px solid rgba(255,255,255,0.08); }

    .logout-btn {
      display: flex; align-items: center; gap: 6px; padding: 7px 13px; border-radius: 9px;
      border: 1px solid rgba(239,68,68,0.28); background: rgba(239,68,68,0.07);
      color: #f87171; font-size: 0.8rem; font-weight: 500; text-decoration: none; transition: all 0.2s;
    }
    .logout-btn:hover { background: rgba(239,68,68,0.16); border-color: rgba(239,68,68,0.5); }

    .avatar-ring {
      background: conic-gradient(#6C2BD9 0%, #a78bfa 45%, #16A34A 70%, #6C2BD9 100%);
      border-radius: 50%; padding: 2px; display: inline-flex;
    }
    .avatar-inner {
      border-radius: 50%; overflow: hidden; display: flex;
      align-items: center; justify-content: center;
      font-family: 'Poppins', sans-serif; font-weight: 700;
    }
    .footer-link { color: #94a3b8; font-size: 0.875rem; text-decoration: none; transition: color 0.2s; }
    .footer-link:hover { color: var(--c-primary); }

    /* ══ UPLOAD ZONE ══ */
    #drop-zone {
      border: 2px dashed rgba(108,43,217,0.35); border-radius: 22px;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      cursor: pointer; position: relative; overflow: hidden;
    }
    #drop-zone::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% -10%, rgba(108,43,217,0.07), transparent 65%);
      pointer-events: none; transition: opacity 0.3s;
    }
    #drop-zone.drag-over {
      border-color: var(--c-primary);
      box-shadow: 0 0 0 4px rgba(108,43,217,0.18), 0 24px 48px rgba(108,43,217,0.15);
      transform: scale(1.012);
    }
    #drop-zone.paste-flash {
      border-color: #16A34A;
      box-shadow: 0 0 0 5px rgba(22,163,74,0.2), 0 12px 32px rgba(22,163,74,0.15);
      animation: pasteFlash 0.4s ease;
    }
    @keyframes pasteFlash {
      0% { background: rgba(22,163,74,0.12); }
      100% { background: transparent; }
    }
    #drop-zone:hover:not(.drag-over) {
      border-color: rgba(108,43,217,0.6); box-shadow: 0 8px 32px rgba(108,43,217,0.1);
    }
    .upload-icon-wrap {
      width: 84px; height: 84px; border-radius: 24px; margin: 0 auto 22px;
      background: linear-gradient(135deg, rgba(108,43,217,0.13), rgba(99,102,241,0.1));
      border: 1px solid rgba(108,43,217,0.22);
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }
    #drop-zone:hover .upload-icon-wrap { transform: translateY(-6px) scale(1.07); }

    /* ══ FILE CHIP WITH THUMBNAIL ══ */
    .file-chip {
      display: flex; align-items: center; gap: 7px;
      padding: 4px 10px 4px 5px; border-radius: 10px;
      background: rgba(108,43,217,0.1); border: 1px solid rgba(108,43,217,0.22);
      font-size: 0.75rem; font-weight: 500; color: #a78bfa;
      animation: chipIn 0.22s cubic-bezier(0.34,1.56,0.64,1);
      max-width: 210px; position: relative; overflow: hidden;
    }
    .dark .file-chip { background: rgba(108,43,217,0.16); }
    @keyframes chipIn {
      from { opacity:0; transform: scale(0.85) translateY(6px); }
      to   { opacity:1; transform: none; }
    }
    .chip-thumb {
      width: 32px; height: 32px; border-radius: 6px; object-fit: cover; flex-shrink: 0;
      border: 1px solid rgba(108,43,217,0.3); background: rgba(108,43,217,0.1);
    }
    .chip-thumb-placeholder {
      width: 32px; height: 32px; border-radius: 6px; flex-shrink: 0;
      background: rgba(108,43,217,0.15); border: 1px solid rgba(108,43,217,0.2);
      display: flex; align-items: center; justify-content: center;
    }
    .file-chip-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex:1; }
    .chip-remove { cursor: pointer; opacity: 0.6; flex-shrink:0; transition: opacity 0.15s, transform 0.15s; }
    .chip-remove:hover { opacity:1; transform: scale(1.2); }

    .fmt-badge {
      display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px;
      border-radius: 10px; font-size: 0.75rem; font-weight: 600;
      border: 1px solid rgba(0,0,0,0.07); background: rgba(0,0,0,0.03);
      color: #475569; transition: all 0.2s;
    }
    .dark .fmt-badge { border-color: rgba(255,255,255,0.07); background: rgba(255,255,255,0.04); color: #94a3b8; }
    .fmt-badge:hover { border-color: rgba(108,43,217,0.3); background: rgba(108,43,217,0.06); color: #a78bfa; }

    .btn-submit {
      width: 100%; padding: 15px 24px; border-radius: 15px;
      background: linear-gradient(135deg, #6C2BD9 0%, #7c3aed 45%, #b91c1c 100%);
      color: #fff; font-family: 'Poppins', sans-serif; font-weight: 700;
      font-size: 1.0rem; letter-spacing: 0.01em; border: none; cursor: pointer;
      box-shadow: 0 6px 28px rgba(108,43,217,0.45), inset 0 1px 0 rgba(255,255,255,0.15);
      transition: all 0.25s ease; position: relative; overflow: hidden;
    }
    .btn-submit::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.14), transparent 60%);
      pointer-events: none;
    }
    .btn-submit:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 36px rgba(108,43,217,0.55), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .btn-submit:active:not(:disabled) { transform: translateY(0); }
    .btn-submit:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ══ ENHANCED LOADER ══ */
    #loading-section { display: none; }
    .loader-card {
      border-radius: 24px; overflow: hidden; position: relative;
      background: linear-gradient(135deg, rgba(15,23,42,0.98), rgba(5,10,25,0.98));
      border: 1px solid rgba(108,43,217,0.2);
      box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(108,43,217,0.1);
    }

    /* Scanner beam */
    .scan-beam {
      position: absolute; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, transparent 0%, rgba(108,43,217,0.4) 20%, rgba(239,68,68,0.9) 50%, rgba(108,43,217,0.4) 80%, transparent 100%);
      animation: scanBeam 2.4s ease-in-out infinite;
      filter: blur(1px);
    }
    @keyframes scanBeam {
      0% { top: 0%; opacity: 1; }
      90% { top: 100%; opacity: 0.5; }
      100% { top: 0%; opacity: 0; }
    }
    /* Ambient glow strips */
    .glow-strip-top {
      position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, #6C2BD9, #EF4444, #6C2BD9, transparent);
      animation: glowPulse 2.4s ease-in-out infinite;
    }
    .glow-strip-bottom {
      position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, #6C2BD9, #EF4444, #6C2BD9, transparent);
      animation: glowPulse 2.4s ease-in-out infinite 1.2s;
    }
    @keyframes glowPulse {
      0%, 100% { opacity: 0.4; } 50% { opacity: 1; }
    }

    /* Central orb */
    .loader-orb-container {
      position: relative; width: 140px; height: 140px; margin: 0 auto;
    }
    .orb-ring {
      position: absolute; border-radius: 50%;
      border: 2px solid transparent; animation: orbSpin linear infinite;
    }
    .orb-ring-1 {
      inset: 0;
      border-top-color: rgba(108,43,217,0.8);
      border-right-color: rgba(108,43,217,0.2);
      animation-duration: 1.8s;
    }
    .orb-ring-2 {
      inset: 12px;
      border-top-color: rgba(239,68,68,0.7);
      border-left-color: rgba(239,68,68,0.2);
      animation-duration: 2.4s;
      animation-direction: reverse;
    }
    .orb-ring-3 {
      inset: 24px;
      border-top-color: rgba(22,163,74,0.8);
      border-right-color: rgba(22,163,74,0.15);
      animation-duration: 3s;
    }
    @keyframes orbSpin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .orb-core {
      position: absolute; inset: 36px; border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, rgba(108,43,217,0.8), rgba(239,68,68,0.5), rgba(15,23,42,0.9));
      display: flex; align-items: center; justify-content: center;
      animation: coreBreath 2.4s ease-in-out infinite;
      box-shadow: 0 0 30px rgba(108,43,217,0.5), inset 0 0 20px rgba(239,68,68,0.3);
    }
    @keyframes coreBreath {
      0%, 100% { transform: scale(1); box-shadow: 0 0 30px rgba(108,43,217,0.5); }
      50% { transform: scale(1.06); box-shadow: 0 0 50px rgba(108,43,217,0.7), 0 0 20px rgba(239,68,68,0.4); }
    }

    /* Progress bar */
    .loader-progress-track {
      height: 4px; border-radius: 99px; background: rgba(255,255,255,0.06); overflow: hidden;
    }
    .loader-progress-fill {
      height: 100%; border-radius: 99px; width: 0%;
      background: linear-gradient(90deg, #6C2BD9, #EF4444);
      transition: width 0.8s cubic-bezier(0.34,1.56,0.64,1);
      box-shadow: 0 0 8px rgba(108,43,217,0.5);
    }

    /* Stage steps */
    .loader-stage {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 10px;
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
      transition: all 0.4s ease;
    }
    .loader-stage.active {
      background: rgba(108,43,217,0.1); border-color: rgba(108,43,217,0.3);
    }
    .loader-stage.done {
      background: rgba(22,163,74,0.08); border-color: rgba(22,163,74,0.2);
    }
    .stage-icon {
      width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 11px; flex-shrink: 0; transition: all 0.4s;
      background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .loader-stage.active .stage-icon {
      background: rgba(108,43,217,0.3); color: #a78bfa;
      border-color: rgba(108,43,217,0.5); animation: stageSpin 1s linear infinite;
    }
    .loader-stage.done .stage-icon {
      background: rgba(22,163,74,0.3); color: #4ade80;
      border-color: rgba(22,163,74,0.5); animation: none;
    }
    @keyframes stageSpin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Fun facts ticker */
    .fact-ticker {
      overflow: hidden; height: 20px; position: relative;
    }
    .fact-item {
      position: absolute; top: 0; left: 0; right: 0;
      font-size: 0.72rem; color: rgba(148,163,184,0.7);
      transition: transform 0.4s ease, opacity 0.4s ease;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* ══ PAGE TURN ANIMATION ══ */
    .page-flip-perspective {
      perspective: 1400px; perspective-origin: 50% 50%;
    }
    .page-content-wrap {
      transform-style: preserve-3d; backface-visibility: hidden;
      will-change: transform, opacity;
    }
    .page-content-wrap.flip-exit-left {
      animation: flipExitLeft 0.38s cubic-bezier(0.55, 0.055, 0.675, 0.19) forwards;
    }
    .page-content-wrap.flip-exit-right {
      animation: flipExitRight 0.38s cubic-bezier(0.55, 0.055, 0.675, 0.19) forwards;
    }
    .page-content-wrap.flip-enter-right {
      animation: flipEnterRight 0.42s cubic-bezier(0.215, 0.61, 0.355, 1.0) forwards;
    }
    .page-content-wrap.flip-enter-left {
      animation: flipEnterLeft 0.42s cubic-bezier(0.215, 0.61, 0.355, 1.0) forwards;
    }
    @keyframes flipExitLeft {
      0%   { transform: perspective(1400px) rotateY(0deg); opacity: 1; }
      100% { transform: perspective(1400px) rotateY(-80deg); opacity: 0; }
    }
    @keyframes flipExitRight {
      0%   { transform: perspective(1400px) rotateY(0deg); opacity: 1; }
      100% { transform: perspective(1400px) rotateY(80deg); opacity: 0; }
    }
    @keyframes flipEnterRight {
      0%   { transform: perspective(1400px) rotateY(80deg); opacity: 0; }
      100% { transform: perspective(1400px) rotateY(0deg); opacity: 1; }
    }
    @keyframes flipEnterLeft {
      0%   { transform: perspective(1400px) rotateY(-80deg); opacity: 0; }
      100% { transform: perspective(1400px) rotateY(0deg); opacity: 1; }
    }

    /* Page shadow overlay during flip */
    .page-flip-shadow {
      position: absolute; inset: 0; border-radius: 12px; pointer-events: none; z-index: 5;
      background: linear-gradient(90deg, rgba(0,0,0,0.7), transparent);
      opacity: 0; transition: opacity 0.2s;
    }

    /* ══ AR CANVAS ══ */
    #canvas-wrapper {
      position: relative; display: inline-block; width: 100%;
      line-height: 0; border-radius: 12px; overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    #student-img {
      width: 100%; height: auto; display: block; border-radius: 12px;
    }
    #konva-container {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; border-radius: 12px; overflow: hidden;
    }
    /* Safe zone overlay — annotations won't bleed past this */
    #canvas-safezone {
      position: absolute; inset: 0; pointer-events: none; border-radius: 12px;
      /* Subtle inset shadow to show the safe zone visually */
    }
    .anno-tooltip {
      position: absolute; background: rgba(15,23,42,0.92); backdrop-filter: blur(8px);
      border: 1px solid rgba(239,68,68,0.35); color: #fca5a5;
      padding: 5px 10px; border-radius: 8px; font-size: 0.75rem; font-weight: 600;
      pointer-events: none; z-index: 20; transform: translateX(-50%); white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4); opacity: 0; transition: opacity 0.15s;
    }
    .anno-tooltip.show { opacity: 1; }

    /* ══ FULLSCREEN MODE ══ */
    #fullscreen-overlay {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(2,6,23,0.97); backdrop-filter: blur(12px);
      flex-direction: column;
    }
    #fullscreen-overlay.active { display: flex; }

    .fs-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px; flex-shrink: 0;
      background: rgba(15,23,42,0.8); border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .fs-image-area {
      flex: 1; overflow: hidden; display: flex; align-items: center; justify-content: center;
      position: relative; cursor: grab;
    }
    .fs-image-area:active { cursor: grabbing; }
    .fs-zoom-container {
      position: relative; transform-origin: center center;
      transition: transform 0.2s ease;
    }
    .fs-zoom-container img {
      display: block; max-width: 90vw; max-height: 82vh;
      border-radius: 10px; user-select: none;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    }
    #fs-konva-container {
      position: absolute; top: 0; left: 0; pointer-events: none; border-radius: 10px;
    }
    .fs-bottombar {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      padding: 10px 20px; flex-shrink: 0;
      background: rgba(15,23,42,0.8); border-top: 1px solid rgba(255,255,255,0.06);
      overflow-x: auto;
    }
    .fs-thumb {
      width: 52px; height: 52px; border-radius: 7px; object-fit: cover;
      border: 2px solid rgba(255,255,255,0.1); cursor: pointer;
      transition: all 0.2s; flex-shrink: 0;
    }
    .fs-thumb.active { border-color: #6C2BD9; box-shadow: 0 0 12px rgba(108,43,217,0.5); }
    .fs-thumb:hover:not(.active) { border-color: rgba(255,255,255,0.3); }
    .fs-btn {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 10px;
      background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.8); cursor: pointer; transition: all 0.2s; flex-shrink: 0;
    }
    .fs-btn:hover { background: rgba(108,43,217,0.3); border-color: rgba(108,43,217,0.5); color: #a78bfa; }
    .fs-zoom-display {
      font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.5);
      min-width: 44px; text-align: center; font-family: 'Poppins', sans-serif;
    }

    /* ══ RESULT COMPONENTS ══ */
    .scorecard {
      background: linear-gradient(135deg, rgba(239,68,68,0.07) 0%, rgba(108,43,217,0.06) 50%, rgba(22,163,74,0.04) 100%);
      border: 1px solid rgba(239,68,68,0.22);
    }
    .dark .scorecard { background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(108,43,217,0.08), rgba(22,163,74,0.05)); }
    .score-ring-wrap { position: relative; display: inline-flex; align-items: center; justify-content: center; }
    .score-ring-wrap svg { transform: rotate(-90deg); }
    .ring-track { fill: none; stroke: rgba(108,43,217,0.13); }
    .ring-fill  { fill: none; stroke: url(#rGrad); stroke-linecap: round;
                  transition: stroke-dashoffset 1.4s cubic-bezier(0.34,1.56,0.64,1); }
    .ring-text  { position: absolute; text-align: center; font-family: 'Poppins', sans-serif; }
    .strict-badge {
      display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 99px;
      background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);
      color: #f87171; font-size: 0.68rem; font-weight: 800;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .diff-pill { padding: 2px 9px; border-radius: 99px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
    .diff-easy   { background:rgba(22,163,74,0.12);  color:#4ade80; border:1px solid rgba(22,163,74,0.25); }
    .diff-medium { background:rgba(245,158,11,0.12); color:#fbbf24; border:1px solid rgba(245,158,11,0.25); }
    .diff-hard   { background:rgba(239,68,68,0.12);  color:#f87171; border:1px solid rgba(239,68,68,0.3); }
    .toppers-notebook {
      background: #ffffff; border-left: 4px solid var(--c-primary);
      border-radius: 0 14px 14px 0;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 8px rgba(108,43,217,0.1);
    }
    .dark .toppers-notebook {
      background: rgba(15,23,42,0.85); border-left-color: #a78bfa;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .step-card { border-bottom: 1px solid rgba(108,43,217,0.08); transition: background 0.2s; }
    .dark .step-card { border-bottom-color: rgba(255,255,255,0.05); }
    .step-card:last-child { border-bottom: none; }
    .step-card:hover { background: rgba(108,43,217,0.03); }
    .dark .step-card:hover { background: rgba(108,43,217,0.07); }
    .step-num {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, #6C2BD9, #a855f7);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.75rem; font-weight: 700; font-family: 'Poppins', sans-serif;
      box-shadow: 0 3px 10px rgba(108,43,217,0.4);
    }
    .katex-block {
      overflow-x: auto; padding: 10px 16px; border-radius: 10px;
      background: rgba(108,43,217,0.05); border: 1px solid rgba(108,43,217,0.1); margin-top: 10px;
    }
    .dark .katex-block { background: rgba(108,43,217,0.09); border-color: rgba(108,43,217,0.18); }
    .katex-block .katex { font-size: 1.1em; }
    .rbar-track { background: rgba(0,0,0,0.06); height: 7px; border-radius: 99px; overflow: hidden; }
    .dark .rbar-track { background: rgba(255,255,255,0.07); }
    .rbar-fill { height: 100%; border-radius: 99px; transition: width 1.1s cubic-bezier(0.34,1.56,0.64,1); }
    .glow-card { transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; }
    .glow-card:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(108,43,217,0.14); border-color: rgba(108,43,217,0.25) !important; }
    .meta-chip {
      display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 8px;
      font-size: 0.72rem; font-weight: 600;
      background: rgba(108,43,217,0.08); border: 1px solid rgba(108,43,217,0.18); color: #a78bfa;
    }
    .dark .meta-chip { background: rgba(108,43,217,0.13); }
    .glow-dot {
      width: 7px; height: 7px; border-radius: 50%; background: #16A34A;
      box-shadow: 0 0 6px #16A34A; display: inline-block; animation: dotpulse 2s ease-in-out infinite;
    }
    @keyframes dotpulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.5; transform:scale(0.8); } }
    .diagram-ph {
      border: 2px dashed rgba(108,43,217,0.22); border-radius: 16px;
      background: linear-gradient(135deg, rgba(108,43,217,0.04), rgba(99,102,241,0.03));
      transition: border-color 0.3s, background 0.3s;
    }
    .diagram-ph:hover { border-color: rgba(108,43,217,0.42); }
    .section-rule { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .section-rule h3 { font-family: 'Poppins', sans-serif; font-weight: 700; }
    .section-rule::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, rgba(108,43,217,0.2), transparent); }
    .gl-input {
      width: 100%; background: rgba(255,255,255,0.55); border: 1px solid rgba(0,0,0,0.08);
      border-radius: 11px; padding: 9px 13px; font-family: 'Inter', sans-serif; font-size: 0.875rem;
      color: #0f172a; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .dark .gl-input { background: rgba(0,0,0,0.28); border-color: rgba(255,255,255,0.09); color: #f1f5f9; }
    .gl-input:focus { border-color: #6C2BD9; box-shadow: 0 0 0 3px rgba(108,43,217,0.16); }
    .gl-input option { background: #0f172a; color: #f1f5f9; }
    select.gl-input { cursor: pointer; }

    /* ══ PAGE NAV ══ */
    .page-nav-btn {
      display: flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; border-radius: 10px;
      background: rgba(108,43,217,0.1); border: 1px solid rgba(108,43,217,0.25);
      color: #a78bfa; cursor: pointer; transition: all 0.2s;
    }
    .page-nav-btn:hover:not(:disabled) { background: rgba(108,43,217,0.25); border-color: rgba(108,43,217,0.5); }
    .page-nav-btn:disabled { opacity: 0.35; cursor: not-allowed; }

    /* ══ TIP BANNER ══ */
    .tip-banner {
      border-radius: 14px; padding: 14px 16px;
      background: linear-gradient(135deg, rgba(22,163,74,0.08), rgba(22,163,74,0.04));
      border: 1px solid rgba(22,163,74,0.2);
    }
    .tip-badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 2px 8px; border-radius: 6px; font-size: 0.65rem; font-weight: 800;
      background: rgba(22,163,74,0.2); border: 1px solid rgba(22,163,74,0.3);
      color: #4ade80; text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ══ PASTE HINT ══ */
    .paste-hint {
      display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px;
      border-radius: 8px; font-size: 0.72rem; font-weight: 600;
      background: rgba(22,163,74,0.08); border: 1px solid rgba(22,163,74,0.2);
      color: #4ade80;
    }
    kbd {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 1px 5px; border-radius: 4px; font-size: 0.65rem; font-weight: 700;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
      color: rgba(255,255,255,0.7); font-family: 'Poppins', monospace;
    }

    /* ══ ANNOTATION COUNT BADGES ══ */
    .anno-stat {
      display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px;
      border-radius: 8px; font-size: 0.7rem; font-weight: 700;
    }
    .anno-stat-errors { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #f87171; }
    .anno-stat-marks  { background: rgba(22,163,74,0.1);  border: 1px solid rgba(22,163,74,0.25);  color: #4ade80; }

    @media (max-width: 640px) {
      .notebook-paper { padding: 28px 14px 36px 60px !important; }
    }
    @media print {
      #bg-canvas, nav, footer, #upload-section, #loading-section, #fullscreen-overlay { display: none !important; }
      body { background: white !important; }
      .glass { background: white !important; box-shadow: none !important; }
    }
  </style>
</head>

<body class="antialiased min-h-screen flex flex-col relative overflow-x-hidden">

<script>
  window.injectedEvaluationData = <%- JSON.stringify(evaluationData || null) %>;
</script>

<!-- Particle canvas -->
<canvas id="bg-canvas" class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none" style="opacity:0.3;"></canvas>
<div class="fixed inset-0 -z-10 pointer-events-none"
    style="background:radial-gradient(ellipse 70% 45% at 50% -10%, rgba(239,68,68,0.07), transparent);"></div>

<!-- ══════════════════════ FULLSCREEN OVERLAY ══════════════════════ -->
<div id="fullscreen-overlay" role="dialog" aria-modal="true" aria-label="Full screen view">
  <!-- Top bar -->
  <div class="fs-topbar">
    <div class="flex items-center gap-3">
      <div class="w-7 h-7 rounded-md flex items-center justify-center text-white font-bold text-sm"
          style="background:linear-gradient(135deg,#6C2BD9,#a855f7);">B</div>
      <span class="text-sm font-bold text-white font-display">Full-screen View</span>
      <span id="fs-page-badge" class="text-xs text-slate-400 font-semibold"></span>
    </div>
    <div class="flex items-center gap-2">
      <!-- Zoom controls -->
      <button class="fs-btn" onclick="fsZoom(1.25)" title="Zoom in"><i data-lucide="zoom-in" class="w-4 h-4"></i></button>
      <span class="fs-zoom-display" id="fs-zoom-label">100%</span>
      <button class="fs-btn" onclick="fsZoom(0.8)"  title="Zoom out"><i data-lucide="zoom-out" class="w-4 h-4"></i></button>
      <button class="fs-btn" onclick="fsZoomReset()" title="Reset zoom"><i data-lucide="maximize-2" class="w-4 h-4"></i></button>
      <!-- Annotation toggles -->
      <div class="w-px h-6 mx-1 bg-white/10"></div>
      <button class="fs-btn" id="fs-toggle-errors" onclick="fstoggleErrors()" title="Toggle error marks"><i data-lucide="x-circle" class="w-4 h-4" style="color:#f87171;"></i></button>
      <button class="fs-btn" id="fs-toggle-marks"  onclick="fstoggleMarks()"  title="Toggle tick marks"><i data-lucide="check-circle" class="w-4 h-4" style="color:#4ade80;"></i></button>
      <div class="w-px h-6 mx-1 bg-white/10"></div>
      <!-- Prev / Next -->
      <button class="fs-btn" id="fs-prev" onclick="fsPrevPage()" title="Previous page"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
      <button class="fs-btn" id="fs-next" onclick="fsNextPage()" title="Next page"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
      <div class="w-px h-6 mx-1 bg-white/10"></div>
      <button class="fs-btn" onclick="closeFullscreen()" title="Close fullscreen (Esc)"><i data-lucide="x" class="w-4 h-4"></i></button>
    </div>
  </div>

  <!-- Main image area -->
  <div class="fs-image-area" id="fs-image-area">
    <div class="fs-zoom-container" id="fs-zoom-container">
      <img id="fs-img" src="" alt="Answer sheet full view" draggable="false">
      <div id="fs-konva-container"></div>
    </div>
  </div>

  <!-- Thumbnail strip (bottom) -->
  <div class="fs-bottombar" id="fs-bottombar"></div>
</div>

<!-- ══════════════════════ NAV ══════════════════════ -->
<nav class="fixed top-0 w-full z-50 glass" style="border-bottom:1px solid rgba(0,0,0,0.05);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 gap-2">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-base"
              style="background:linear-gradient(135deg,#6C2BD9,#a855f7);box-shadow:0 3px 10px rgba(108,43,217,0.4);">B</div>
          <span class="text-xl font-bold font-display tracking-tight text-slate-900 dark:text-white hidden sm:block">
            BOARD <span style="color:#6C2BD9;">Algo</span>
          </span>
        </a>
        <span class="hidden sm:flex items-center gap-1.5 text-sm text-slate-400 dark:text-gray-500">
          <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
          <span class="font-bold" style="color:#EF4444;">Strict Examiner</span>
        </span>
      </div>
      <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
        <button id="theme-toggle"
                class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-slate-500 dark:text-gray-400 transition-colors"
                aria-label="Toggle theme">
          <i data-lucide="sun"  class="hidden dark:block w-4 h-4 sm:w-5 sm:h-5"></i>
          <i data-lucide="moon" class="block dark:hidden w-4 h-4 sm:w-5 sm:h-5"></i>
        </button>
        <a href="/dashboard"
          class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium
                  text-slate-600 dark:text-gray-300 hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
          <i data-lucide="layout-dashboard" class="w-3.5 h-3.5"></i> Dashboard
        </a>
        <a href="/auth/logout" class="logout-btn hidden sm:flex">
          <i data-lucide="log-out" class="w-3.5 h-3.5"></i><span>Logout</span>
        </a>
        <div class="flex items-center gap-2 pl-2 sm:pl-3 border-l border-gray-200 dark:border-gray-800">
          <div class="text-right hidden sm:block">
            <p class="text-sm font-semibold text-slate-900 dark:text-white leading-tight"><%= user.username %></p>
            <%
              let navLabel = 'Free Trial';
              if(user.subscription_status === 'ACTIVE') navLabel = 'Pro Member';
              else if(user.subscription_status === 'EXPIRED' || user.subscription_status === 'CHURNED') navLabel = 'Expired';
            %>
            <p class="text-xs font-medium mt-0.5" style="color:#6C2BD9;"><%= navLabel %></p>
          </div>
          <% if(user.photoURL) { %>
          <div class="avatar-ring flex-shrink-0" style="width:36px;height:36px;">
            <div class="avatar-inner w-full h-full">
              <img src="<%= user.photoURL %>" style="width:100%;height:100%;object-fit:cover;" alt="avatar">
            </div>
          </div>
          <% } else { %>
          <div class="h-9 w-9 rounded-full flex-shrink-0 flex items-center justify-center
                      text-white font-bold text-base font-display"
              style="background:linear-gradient(135deg,rgba(108,43,217,0.8),rgba(168,85,247,0.7));
                      border:2px solid rgba(108,43,217,0.4);">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- ══════════════════════ MAIN ══════════════════════ -->
<main class="flex-grow pt-20 sm:pt-24 pb-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-7 sm:space-y-10">

    <!-- Page Hero -->
    <div class="gsap-entry text-center space-y-3 pt-2">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full"
          style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);">
        <i data-lucide="gavel" class="w-3.5 h-3.5" style="color:#f87171;"></i>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#f87171;">AI-Powered · CBSE Grading</span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white tracking-tight leading-tight">
        Strict Board
        <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#EF4444 10%,#6C2BD9 90%);">
          Evaluator
        </span>
      </h1>
      <p class="text-base sm:text-lg text-slate-500 dark:text-gray-400 max-w-2xl mx-auto">
        Upload your handwritten answer. AI grades it with surgical precision — visual annotations, marks breakdown, and a topper-quality model answer.
      </p>
    </div>

    <!-- Feature tiles -->
    <div class="gsap-entry grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-content" style="background:rgba(239,68,68,0.1);display:flex;justify-content:center;">
          <i data-lucide="shield-check" class="w-4 h-4" style="color:#f87171;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">CBSE Marking</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Official scheme</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-content" style="background:rgba(108,43,217,0.1);display:flex;justify-content:center;">
          <i data-lucide="scan" class="w-4 h-4" style="color:#a78bfa;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">AR Annotations</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Visual marks</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-content" style="background:rgba(22,163,74,0.1);display:flex;justify-content:center;">
          <i data-lucide="sigma" class="w-4 h-4" style="color:#4ade80;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">KaTeX Math</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Perfect rendering</p>
      </div>
      <div class="glass glow-card rounded-xl p-3 sm:p-4 border border-gray-200 dark:border-white/5 text-center">
        <div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-content" style="background:rgba(245,158,11,0.1);display:flex;justify-content:center;">
          <i data-lucide="zap" class="w-4 h-4" style="color:#fbbf24;"></i>
        </div>
        <p class="text-xs font-bold text-slate-700 dark:text-gray-200 font-display">Instant Results</p>
        <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Under 30 sec</p>
      </div>
    </div>

    <!-- ══════════ UPLOAD FORM ══════════ -->
    <div id="upload-section" class="gsap-entry">

      <!-- ★ TIP BANNER (NEW) -->
      <div class="tip-banner mb-5">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
              style="background:rgba(22,163,74,0.15);border:1px solid rgba(22,163,74,0.3);">
            <i data-lucide="lightbulb" class="w-4 h-4" style="color:#4ade80;"></i>
          </div>
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-2 mb-1.5">
              <span class="tip-badge">Pro Tips for Best Results</span>
            </div>
            <ul class="text-sm text-slate-600 dark:text-gray-300 space-y-1 leading-relaxed">
              <li class="flex items-start gap-2">
                <i data-lucide="check-circle-2" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:#4ade80;"></i>
                <span><strong>Fill all fields</strong> (Subject, Max Marks, Class) — this improves accuracy by up to 40%</span>
              </li>
              <li class="flex items-start gap-2">
                <i data-lucide="check-circle-2" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:#4ade80;"></i>
                <span><strong>Upload photos for 1 question only</strong> — multiple pages of the same answer are fine, but don't mix questions</span>
              </li>
              <li class="flex items-start gap-2">
                <i data-lucide="check-circle-2" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:#4ade80;"></i>
                <span><strong>Paste from clipboard</strong> — press <kbd>Ctrl</kbd>+<kbd>V</kbd> anywhere to paste a screenshot directly</span>
              </li>
              <li class="flex items-start gap-2">
                <i data-lucide="check-circle-2" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:#4ade80;"></i>
                <span>Good lighting + flat surface = better handwriting recognition. No PDFs accepted.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <form id="evaluator-form" method="POST" action="/examiner/evaluate" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="screen_width"        id="f-sw">
        <input type="hidden" name="screen_height"       id="f-sh">
        <input type="hidden" name="device_pixel_ratio"  id="f-dpr">
        <input type="hidden" name="device_type"         id="f-dtype">
        <input type="hidden" name="viewport_width"      id="f-vw">
        <input type="hidden" name="viewport_height"     id="f-vh">
        <input type="hidden" name="user_agent"          id="f-ua">
        <input type="hidden" name="image_metadata_json" id="f-imgmeta">
        <input type="hidden" name="timestamp_submit"    id="f-ts">

        <!-- Subject / Marks / Class / Exam Year -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">
              Subject <span style="color:#EF4444;">*</span>
            </label>
            <select name="subject" class="gl-input" required>
              <option value="">Select…</option>
              <option>Physics</option><option>Chemistry</option><option>Mathematics</option>
              <option>Biology</option><option>English</option><option>History</option>
              <option>Geography</option><option>Economics</option><option>Computer Science</option>
              <option>Accountancy</option><option>Business Studies</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">
              Max Marks <span style="color:#EF4444;">*</span>
            </label>
            <input type="number" name="total_marks" min="1" max="100" placeholder="e.g. 5" class="gl-input" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">
              Class <span style="color:#EF4444;">*</span>
            </label>
            <select name="class" class="gl-input" required>
              <option value="">Select…</option>
              <% ['9','10','11','12'].forEach(function(c){ %>
              <option value="<%= c %>" <%= (user.Class === c) ? 'selected' : '' %>>Class <%= c %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">Exam Year</label>
            <select name="exam_year" class="gl-input">
              <option value="">Any</option>
              <% for(let y=2025;y>=2015;y--){ %>
              <option value="<%= y %>"><%= y %></option>
              <% } %>
            </select>
          </div>
        </div>

        <!-- Question text -->
        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-600 dark:text-gray-300 uppercase tracking-wide mb-1.5">
            Question / Topic
            <span class="normal-case font-normal text-slate-400 ml-1">(improves accuracy significantly)</span>
          </label>
          <textarea name="question_text" rows="2"
                    placeholder="e.g. Find the derivative of f(x) = x² · sin(x) using the product rule…"
                    class="gl-input" style="resize:vertical;"></textarea>
        </div>

        <!-- Drop Zone -->
        <div id="drop-zone" class="glass rounded-2xl p-8 sm:p-12 text-center mb-4"
            role="button" tabindex="0" aria-label="Upload answer sheets">
          <div class="upload-icon-wrap">
            <i data-lucide="upload-cloud" class="w-10 h-10" style="color:#6C2BD9;"></i>
          </div>
          <h3 class="text-lg sm:text-xl font-bold font-display text-slate-900 dark:text-white mb-2">
            Drop your answer sheets here
          </h3>
          <p class="text-sm text-slate-400 dark:text-gray-500 mb-2">
            or <span class="font-semibold" style="color:#6C2BD9;">browse to upload</span>
          </p>
          <!-- Paste hint -->
          <div class="flex justify-center mb-5">
            <span class="paste-hint">
              <i data-lucide="clipboard" class="w-3 h-3"></i>
              Press <kbd>Ctrl</kbd>+<kbd>V</kbd> to paste a screenshot directly
            </span>
          </div>
          <!-- Format badges — no PDF -->
          <div class="flex flex-wrap justify-center gap-2 mb-6">
            <span class="fmt-badge"><i data-lucide="camera" class="w-3 h-3" style="color:#6C2BD9;"></i> Camera Photo</span>
