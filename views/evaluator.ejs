   ══════════════════════════════════════════════════════════════════════ */

const SUBMIT_TIMEOUT_MS  = 90_000;  // 90s hard limit (Gemini can be slow)
const SUBMIT_MAX_RETRIES = 2;       // retry twice on network failure
const RETRY_DELAY_MS     = 3_000;

const loadingMessages = [
