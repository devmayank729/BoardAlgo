/* ════════════════════════════════════════════════════════════════════
  RESULT RENDERER
════════════════════════════════════════════════════════════════════ */
function renderResult(data) {
  stopLoadingAnimations();
  document.getElementById('loading-section').style.display = 'none';
  document.getElementById('upload-section').style.display = 'none';

  const rs = document.getElementById('result-section');
  rs.style.display = 'block';

  const { meta, rubric, visual_annotations, perfect_marker_answer } = data;

  // Score ring
  const scored = meta.total_marks_awarded;
  const maxMk  = meta.max_marks;
  document.getElementById('score-main').textContent = `${scored}/${maxMk}`;
  requestAnimationFrame(() => {
    document.getElementById('ring-fill-el').style.strokeDashoffset = 351.9 * (1 - scored / maxMk);
  });

  // Difficulty
  const diffEl = document.getElementById('diff-badge');
  const d = (meta.difficulty || 'Medium').toLowerCase();
  diffEl.textContent = meta.difficulty || 'Medium';
  diffEl.className = 'diff-pill ' + (d === 'easy' ? 'diff-easy' : d === 'hard' ? 'diff-hard' : 'diff-medium');

  // Meta chips
  const chips = document.getElementById('meta-chips');
  const confScore = typeof data.meta?.confidence === 'number' ? data.meta.confidence : null;
  const chipDefs = [
    [`<i data-lucide="book" class="w-3 h-3"></i>`, meta.subject],
    [`<i data-lucide="target" class="w-3 h-3"></i>`, `${scored}/${maxMk} marks`],
  ];
  if (confScore !== null) {
    const confPct = Math.round(confScore * 100);
    const confColor = confPct >= 80 ? '#4ade80' : confPct >= 55 ? '#fbbf24' : '#f87171';
    chipDefs.push([`<i data-lucide="activity" class="w-3 h-3" style="color:${confColor};"></i>`, `AI Confidence: ${confPct}%`]);
  }
  chipDefs.forEach(([ic, txt]) => {
    const c = document.createElement('span');
    c.className = 'meta-chip';
    c.innerHTML = `${ic} ${txt}`;
    chips.appendChild(c);
  });
  lucide.createIcons();

  // Problem statement
  if (meta.problem_statement) {
    const psWrap = document.getElementById('ps-wrapper');
    const psEl   = document.getElementById('problem-statement-banner');
    if (psWrap && psEl) { psEl.textContent = meta.problem_statement; psWrap.style.display = ''; }
  }

  // Summary
  document.getElementById('eval-summary').textContent = meta.evaluation_summary;

  // Rubric bars
  const rubricData = rubric || [
    { label: 'Conceptual Accuracy', scored: scored * 0.6, total: maxMk * 0.6, color: '#a78bfa' },
    { label: 'Step Completeness',   scored: scored * 0.4, total: maxMk * 0.4, color: '#fbbf24' },
  ];
  const rbContainer = document.getElementById('rubric-bars');
  rbContainer.innerHTML = '';
  rubricData.forEach(r => {
    const pct = Math.round((r.scored / r.total) * 100);
    const row = document.createElement('div');
    row.innerHTML = `
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-medium text-slate-600 dark:text-gray-300">${r.label}</span>
        <span class="text-xs font-bold" style="color:${r.color};">${r.scored}/${r.total}</span>
      </div>
      <div class="rbar-track">
        <div class="rbar-fill" data-w="${pct}%" style="width:0%;background:${r.color};"></div>
      </div>`;
    rbContainer.appendChild(row);
  });
  setTimeout(() => {
    rbContainer.querySelectorAll('.rbar-fill').forEach(b => { b.style.width = b.dataset.w; });
  }, 120);

  // Image + annotations
  setupAugmentedCanvas(data.imageUrls, visual_annotations);

  // Topper's steps
  renderSteps(perfect_marker_answer);

  gsap.from('.gsap-r', { y: 28, opacity: 0, stagger: 0.12, duration: 0.7, ease: 'power2.out' });
  lucide.createIcons();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ════════════════════════════════════════════════════════════════════
  SCHEMA VALIDATION
════════════════════════════════════════════════════════════════════ */
const VALID_ANNOTATION_TYPES = new Set(['tick','cross','circle','text','step_mark']);
const CONFIDENCE_THRESHOLD   = 0.40;

function normalisePayload(raw) {
  if (!raw) return { annotations: [] };
  if (!Array.isArray(raw) && Array.isArray(raw.annotations)) return { annotations: raw.annotations };
  if (Array.isArray(raw)) return { annotations: raw };
  if (Array.isArray(raw.visual_annotations)) return { annotations: raw.visual_annotations };
  return { annotations: [] };
}

function validateAnnotations(annotations) {
  const valid = [];
  (annotations || []).forEach((a) => {
    if (!VALID_ANNOTATION_TYPES.has(a.annotation_type)) return;
    if (!Array.isArray(a.box_2d) || a.box_2d.length !== 4 ||
        a.box_2d.some(v => typeof v !== 'number' && isNaN(Number(v)))) return;
    if (typeof a.confidence === 'number' && a.confidence < CONFIDENCE_THRESHOLD) return;
    let [y0, x0, y1, x1] = a.box_2d.map(v => Math.max(0, Math.min(1000, Number(v))));
    if (y0 > y1) [y0, y1] = [y1, y0];
    if (x0 > x1) [x0, x1] = [x1, x0];
    if ((y1 - y0) < 10) y1 = y0 + 10;
    if ((x1 - x0) < 10) x1 = x0 + 10;
    a.box_2d = [y0, x0, y1, x1];
    valid.push(a);
  });
  return valid;
}

/* ════════════════════════════════════════════════════════════════════
  CANVAS SETUP + PAGE NAVIGATION
════════════════════════════════════════════════════════════════════ */
const DEMO_IMAGE_URL = 'https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/PNG_transparency_demonstration_1.png/280px-PNG_transparency_demonstration_1.png';

function setupAugmentedCanvas(imageUrls, rawAnnotations) {
  globalImageUrls   = imageUrls || [];
  const payload     = normalisePayload(rawAnnotations);
  globalAnnotations = validateAnnotations(payload.annotations);
  currentImageIndex = 0;

  // If no page_number on annotations, assign all to page 1
  globalAnnotations.forEach(a => { if (!a.page_number) a.page_number = 1; });

  // Page nav
  const pageNav = document.getElementById('page-nav');
  if (globalImageUrls.length > 1) {
    pageNav.classList.remove('hidden');
    pageNav.classList.add('flex');
  } else {
    pageNav.classList.add('hidden');
    pageNav.classList.remove('flex');
  }

  // Update annotation count badges
  updateAnnoBadges();

  renderCurrentPage(null);
}

function updateAnnoBadges() {
  const errs = currentAnnotations.filter(a => a.color === 'red').length;
  const mrks = currentAnnotations.filter(a => a.color === 'green').length;
  const errEl = document.getElementById('anno-count-errors');
  const mrkEl = document.getElementById('anno-count-marks');
  if (errEl) {
    errEl.innerHTML = `<i data-lucide="x-circle" class="w-3 h-3"></i> ${errs} errors`;
    errEl.classList.toggle('hidden', errs === 0);
  }
  if (mrkEl) {
    mrkEl.innerHTML = `<i data-lucide="check-circle" class="w-3 h-3"></i> ${mrks} marks`;
    mrkEl.classList.toggle('hidden', mrks === 0);
  }
  lucide.createIcons();
}

/* ★ PAGE TURN — with 3D flip animation */
function renderCurrentPage(direction) {
  const wrapper    = document.getElementById('canvas-wrapper');
  const img        = document.getElementById('student-img');
  const prevBtn    = document.getElementById('btn-prev-page');
  const nextBtn    = document.getElementById('btn-next-page');
  const indicator  = document.getElementById('page-indicator');

  if (prevBtn) prevBtn.disabled = currentImageIndex === 0;
  if (nextBtn) nextBtn.disabled = currentImageIndex === globalImageUrls.length - 1;
  if (indicator) indicator.textContent = `Page ${currentImageIndex + 1} / ${globalImageUrls.length}`;

  currentAnnotations = globalAnnotations.filter(a => a.page_number === (currentImageIndex + 1));
  updateAnnoBadges();

  const doRender = () => {
    img.crossOrigin = 'anonymous';
    img.src = globalImageUrls[currentImageIndex] || DEMO_IMAGE_URL;
    img.onload = () => {
      buildKonva();
      // Enter animation
      if (direction === 'right') {
        wrapper.classList.add('flip-enter-right');
      } else if (direction === 'left') {
        wrapper.classList.add('flip-enter-left');
      }
      if (direction) {
        setTimeout(() => {
          wrapper.classList.remove('flip-enter-right', 'flip-enter-left');
        }, 450);
      }
    };
  };

  if (direction) {
    // Exit animation first
    const exitClass = direction === 'right' ? 'flip-exit-left' : 'flip-exit-right';
    wrapper.classList.add(exitClass);
    setTimeout(() => {
      wrapper.classList.remove(exitClass);
      doRender();
    }, 380);
  } else {
    doRender();
  }
}

function prevPage() {
  if (currentImageIndex > 0) {
    currentImageIndex--;
    renderCurrentPage('left');
  }
}

function nextPage() {
  if (currentImageIndex < globalImageUrls.length - 1) {
    currentImageIndex++;
    renderCurrentPage('right');
  }
}

/* Keyboard navigation */
document.addEventListener('keydown', (e) => {
  if (document.getElementById('result-section').style.display === 'none') return;
  if (document.activeElement && ['INPUT','TEXTAREA','SELECT'].includes(document.activeElement.tagName)) return;
  if (e.key === 'ArrowRight') nextPage();
  if (e.key === 'ArrowLeft')  prevPage();
  if (e.key === 'Escape' && document.getElementById('fullscreen-overlay').classList.contains('active')) closeFullscreen();
  if (e.key === 'f' || e.key === 'F') openFullscreen();
});

/* ════════════════════════════════════════════════════════════════════
  KONVA ENGINE — with safe-zone clamping
════════════════════════════════════════════════════════════════════ */
function buildKonva() {
  const img      = document.getElementById('student-img');
  const wrapper  = document.getElementById('canvas-wrapper');
  const konvaDiv = document.getElementById('konva-container');

  const rw = img.offsetWidth  || wrapper.offsetWidth  || 600;
  const rh = img.offsetHeight || Math.round(rw * 1.4);

  if (konvaStage) { konvaStage.destroy(); konvaStage = null; }
  errorGroup = null; markGroup = null;

  konvaDiv.style.width  = rw + 'px';
  konvaDiv.style.height = rh + 'px';

  konvaStage = new Konva.Stage({ container: 'konva-container', width: rw, height: rh });
  konvaLayer = new Konva.Layer();
  errorGroup = new Konva.Group({ name: 'errors' });
  markGroup  = new Konva.Group({ name: 'marks' });
  konvaLayer.add(errorGroup, markGroup);
  konvaStage.add(konvaLayer);

  if (annotationsVisible) drawAnnotations(rw, rh);
}

/* ★ SAFE-ZONE CLAMPING — all annotations stay within visible bounds */
const SAFE_MARGIN_RATIO = 0.035; // 3.5% padding from each edge

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

function drawAnnotations(rw, rh, stage, layer, errGrp, mrkGrp, annotSet) {
  // Support both main canvas and fullscreen canvas
  const useStage  = stage  || konvaStage;
  const useLayer  = layer  || konvaLayer;
  const useErr    = errGrp || errorGroup;
  const useMrk    = mrkGrp || markGroup;
  const useAnnots = annotSet || currentAnnotations;

  if (!useStage || !useLayer) return;
  if (useErr) useErr.destroyChildren();
  if (useMrk) useMrk.destroyChildren();

  const SAFE_X = rw * SAFE_MARGIN_RATIO;
  const SAFE_Y = rh * SAFE_MARGIN_RATIO;

  const sw = (n) => Math.max(1.5, rw * n);
  const fs = (n) => Math.max(10, Math.min(20, rw * n));

  useAnnots.forEach(anno => {
    const [yn, xn, ym, xm] = anno.box_2d;
    const rawPx = (xn / 1000) * rw;
    const rawPy = (yn / 1000) * rh;
    const pw    = ((xm - xn) / 1000) * rw;
    const ph    = ((ym - yn) / 1000) * rh;
    const rawCx = rawPx + pw / 2;
    const rawCy = rawPy + ph / 2;

    const isRed   = anno.color === 'red';
    const isGreen = anno.color === 'green';
    const strokeC = isRed ? 'rgba(239,68,68,0.88)' : isGreen ? 'rgba(22,163,74,0.92)' : 'rgba(108,43,217,0.88)';
    const fillC   = isRed ? 'rgba(239,68,68,0.09)' : isGreen ? 'rgba(22,163,74,0.10)' : 'rgba(108,43,217,0.09)';
    const glowC   = isRed ? '#EF4444' : isGreen ? '#16A34A' : '#6C2BD9';

    const target = isGreen ? useMrk : useErr;

    if (anno.annotation_type === 'tick') {
      const r    = Math.max(14, Math.min(28, Math.min(pw, ph) / 2));
      // ★ SAFE-ZONE: clamp center so circle never clips edge
      const cx   = clamp(rawCx, SAFE_X + r, rw - SAFE_X - r);
      const cy   = clamp(rawCy, SAFE_Y + r, rh - SAFE_Y - r);
      const halo = new Konva.Circle({ x:cx, y:cy, radius:r+4, fill:'rgba(22,163,74,0.12)', stroke:'rgba(22,163,74,0.35)', strokeWidth:1 });
      const bg   = new Konva.Circle({ x:cx, y:cy, radius:r, fill:'rgba(22,163,74,0.82)', shadowColor:'#16A34A', shadowBlur:10, shadowOpacity:0.5 });
      const ts   = r * 0.55;
      const tick = new Konva.Line({ points:[cx-ts*0.6,cy,cx-ts*0.1,cy+ts*0.6,cx+ts*0.7,cy-ts*0.55], stroke:'#ffffff', strokeWidth:sw(0.008)+1.5, lineCap:'round', lineJoin:'round' });
      target.add(halo, bg, tick);
      if (anno.comment) addTooltipBehaviour(bg, anno.comment, cx, cy - r - 8);

    } else if (anno.annotation_type === 'cross') {
      const r    = Math.max(14, Math.min(28, Math.min(pw, ph) / 2));
      const cx   = clamp(rawCx, SAFE_X + r, rw - SAFE_X - r);
      const cy   = clamp(rawCy, SAFE_Y + r, rh - SAFE_Y - r);
      const halo = new Konva.Circle({ x:cx, y:cy, radius:r+4, fill:'rgba(239,68,68,0.1)', stroke:'rgba(239,68,68,0.3)', strokeWidth:1 });
      const bg   = new Konva.Circle({ x:cx, y:cy, radius:r, fill:'rgba(239,68,68,0.8)', shadowColor:'#EF4444', shadowBlur:10, shadowOpacity:0.5 });
      const arm  = r * 0.52;
      const l1   = new Konva.Line({ points:[cx-arm,cy-arm,cx+arm,cy+arm], stroke:'#ffffff', strokeWidth:sw(0.007)+1.5, lineCap:'round' });
      const l2   = new Konva.Line({ points:[cx+arm,cy-arm,cx-arm,cy+arm], stroke:'#ffffff', strokeWidth:sw(0.007)+1.5, lineCap:'round' });
      target.add(halo, bg, l1, l2);
      if (anno.comment) addTooltipBehaviour(bg, anno.comment, cx, cy - r - 8);

    } else if (anno.annotation_type === 'circle') {
      const radiusX = Math.max(8, Math.min(pw / 2, (rw - SAFE_X * 2) / 2));
      const radiusY = Math.max(8, Math.min(ph / 2, (rh - SAFE_Y * 2) / 2));
      const cx = clamp(rawCx, SAFE_X + radiusX, rw - SAFE_X - radiusX);
      const cy = clamp(rawCy, SAFE_Y + radiusY, rh - SAFE_Y - radiusY);
      const ellipse = new Konva.Ellipse({
        x:cx, y:cy, radiusX, radiusY,
        stroke:strokeC, strokeWidth:sw(0.005), dash:[7,4], fill:fillC,
        shadowColor:glowC, shadowBlur:10, shadowOpacity:0.3,
      });
      target.add(ellipse);
      addTooltipBehaviour(ellipse, anno.comment, cx, cy - radiusY - 8);

    } else if (anno.annotation_type === 'text' && anno.comment) {
      const fontSize = fs(0.022);
      const labelW   = Math.min(anno.comment.length * (fontSize * 0.65) + 20, rw * 0.4);
      // ★ SAFE-ZONE: clamp so label never leaves the canvas
      const px  = clamp(rawPx, SAFE_X, rw - SAFE_X - labelW);
      const py  = clamp(rawPy, SAFE_Y, rh - SAFE_Y - 40);
      const label = new Konva.Label({ x:px, y:py });
      label.add(new Konva.Tag({
        fill: isRed ? 'rgba(239,68,68,0.92)' : 'rgba(22,163,74,0.92)',
        cornerRadius:7, shadowColor:glowC, shadowBlur:9, shadowOpacity:0.45,
      }));
      label.add(new Konva.Text({
        text:anno.comment, fontSize, fontFamily:'Poppins, sans-serif', fontStyle:'bold',
        fill:'#ffffff', padding:6,
      }));
      target.add(label);
      const ay1 = py + fontSize + 18;
      const ay2 = clamp(rawPy + ph * 0.85, ay1 + 4, rh - SAFE_Y);
      if (ay2 > ay1) {
        target.add(new Konva.Arrow({
          points:[px+10,ay1,px+10,ay2], stroke:strokeC, fill:strokeC,
          strokeWidth:1.5, pointerLength:7, pointerWidth:6, dash:[4,3],
        }));
      }

    } else if (anno.annotation_type === 'step_mark' && anno.comment) {
      const isDed    = isRed || String(anno.comment).startsWith('-');
      const bgF      = isDed ? 'rgba(239,68,68,0.88)' : 'rgba(22,163,74,0.88)';
      const shd      = isDed ? '#EF4444' : '#16A34A';
      const fontSize = fs(0.030);
      const radius   = Math.max(18, Math.min(36, Math.min(pw, ph) / 2));
      // ★ SAFE-ZONE: step marks often go to margins — clamp hard
      const cx = clamp(rawCx, SAFE_X + radius, rw - SAFE_X - radius);
      const cy = clamp(rawCy, SAFE_Y + radius, rh - SAFE_Y - radius);
      const circle = new Konva.Circle({
        x:cx, y:cy, radius, fill:bgF,
        shadowColor:shd, shadowBlur:14, shadowOpacity:0.55,
        stroke: isDed ? 'rgba(239,68,68,0.4)' : 'rgba(22,163,74,0.4)', strokeWidth:1.5,
      });
      const labelT = new Konva.Text({
        text:anno.comment, fontSize, fontFamily:'Poppins, sans-serif', fontStyle:'bold',
        fill:'#ffffff', align:'center', verticalAlign:'middle',
        width:radius*2, height:radius*2, x:cx-radius, y:cy-radius,
      });
      const rule = new Konva.Line({
        points:[cx-radius-6,cy,cx-radius-30,cy],
        stroke: isDed ? 'rgba(239,68,68,0.35)' : 'rgba(22,163,74,0.35)',
        strokeWidth:1.2, dash:[3,3],
      });
      target.add(rule, circle, labelT);
    }
  });

  if (useErr) useErr.visible(errorsVisible);
  if (useMrk) useMrk.visible(marksVisible);
  useLayer.draw();
}

function addTooltipBehaviour(shape, comment, x, y) {
  if (!comment) return;
  const tooltip = document.getElementById('anno-tooltip');
  if (!tooltip) return;
  shape.on('mouseenter touchstart', () => {
    tooltip.textContent = comment;
    tooltip.style.left  = x + 'px';
    tooltip.style.top   = Math.max(0, y) + 'px';
    tooltip.classList.add('show');
  });
  shape.on('mouseleave touchend', () => tooltip.classList.remove('show'));
}

function toggleAnnotations() {
  annotationsVisible = !annotationsVisible;
  const btn = document.getElementById('btn-toggle-annot');
  if (annotationsVisible) {
    drawAnnotations(konvaStage.width(), konvaStage.height());
    btn.innerHTML = '<i data-lucide="eye" class="w-3.5 h-3.5"></i> All: ON';
  } else {
    if (errorGroup) errorGroup.visible(false);
    if (markGroup)  markGroup.visible(false);
    konvaLayer.draw();
    btn.innerHTML = '<i data-lucide="eye-off" class="w-3.5 h-3.5"></i> All: OFF';
  }
  lucide.createIcons();
}

function toggleErrors() {
  if (!errorGroup) return;
  errorsVisible = !errorsVisible;
  errorGroup.visible(errorsVisible);
  konvaLayer.draw();
  const btn = document.getElementById('btn-toggle-errors');
  btn.innerHTML = `<i data-lucide="x-circle" class="w-3.5 h-3.5" style="color:#f87171;"></i> Errors: ${errorsVisible ? 'ON' : 'OFF'}`;
  btn.style.opacity = errorsVisible ? '1' : '0.5';
  lucide.createIcons();
}

function toggleMarks() {
  if (!markGroup) return;
  marksVisible = !marksVisible;
  markGroup.visible(marksVisible);
  konvaLayer.draw();
  const btn = document.getElementById('btn-toggle-marks');
  btn.innerHTML = `<i data-lucide="check-circle" class="w-3.5 h-3.5" style="color:#4ade80;"></i> Marks: ${marksVisible ? 'ON' : 'OFF'}`;
  btn.style.opacity = marksVisible ? '1' : '0.5';
  lucide.createIcons();
}

function zoomImage(factor) {
  currentZoom = Math.min(4, Math.max(0.5, currentZoom * factor));
  const img = document.getElementById('student-img');
  img.style.transformOrigin = 'top left';
  img.style.transform = `scale(${currentZoom})`;
  document.getElementById('canvas-wrapper').style.overflow = currentZoom > 1 ? 'auto' : 'hidden';
}

function resetZoom() {
  currentZoom = 1;
  document.getElementById('student-img').style.transform = '';
  document.getElementById('canvas-wrapper').style.overflow = 'hidden';
}

const resizeObserver = new ResizeObserver(() => {
  if (konvaStage && document.getElementById('result-section').style.display !== 'none')
    requestAnimationFrame(buildKonva);
});
resizeObserver.observe(document.getElementById('canvas-wrapper'));

window.addEventListener('orientationchange', () => { setTimeout(() => { if (konvaStage) buildKonva(); }, 350); });

/* ════════════════════════════════════════════════════════════════════
  ★ FULLSCREEN MODE
════════════════════════════════════════════════════════════════════ */
function openFullscreen() {
  if (globalImageUrls.length === 0 && !document.getElementById('student-img').src) return;
  fsCurrentIndex = currentImageIndex;
  fsZoomLevel = 1;
  fsTranslate = { x: 0, y: 0 };
  fsErrVis = errorsVisible;
  fsMrkVis = marksVisible;

  buildFsThumbStrip();
  loadFsPage(fsCurrentIndex, null);

  document.getElementById('fullscreen-overlay').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeFullscreen() {
  document.getElementById('fullscreen-overlay').classList.remove('active');
  document.body.style.overflow = '';
  if (fsStage) { fsStage.destroy(); fsStage = null; }
}

function buildFsThumbStrip() {
  const strip = document.getElementById('fs-bottombar');
  strip.innerHTML = '';
  const urls = globalImageUrls.length > 0 ? globalImageUrls : [document.getElementById('student-img').src];
  urls.forEach((url, i) => {
    const img = document.createElement('img');
    img.className = 'fs-thumb' + (i === fsCurrentIndex ? ' active' : '');
    img.src = url || DEMO_IMAGE_URL;
    img.alt = `Page ${i + 1}`;
    img.onclick = () => { fsCurrentIndex = i; loadFsPage(i, null); buildFsThumbStrip(); };
    strip.appendChild(img);
  });
}

function loadFsPage(idx, direction) {
  const mainImg = document.getElementById('fs-img');
  const urls = globalImageUrls.length > 0 ? globalImageUrls : [document.getElementById('student-img').src];
  const url  = urls[idx] || DEMO_IMAGE_URL;

  document.getElementById('fs-page-badge').textContent = `${idx + 1} / ${urls.length}`;
  document.getElementById('fs-prev').style.opacity = idx === 0 ? '0.35' : '1';
  document.getElementById('fs-next').style.opacity = idx === urls.length - 1 ? '0.35' : '1';

  // Update thumb active state
  document.querySelectorAll('.fs-thumb').forEach((t, i) => t.classList.toggle('active', i === idx));

  mainImg.crossOrigin = 'anonymous';
  mainImg.src = url;

  mainImg.onload = () => {
    applyFsZoom();
    buildFsKonva();
  };
}

function buildFsKonva() {
  const img      = document.getElementById('fs-img');
  const konvaDiv = document.getElementById('fs-konva-container');

  if (!img.offsetWidth) return; // Not rendered yet

  const rw = img.offsetWidth;
  const rh = img.offsetHeight;

  if (fsStage) { fsStage.destroy(); fsStage = null; }

  konvaDiv.style.width  = rw + 'px';
  konvaDiv.style.height = rh + 'px';

  fsStage     = new Konva.Stage({ container: 'fs-konva-container', width: rw, height: rh });
  const fsLyr = new Konva.Layer();
  fsErrorGroup = new Konva.Group({ name: 'errors' });
  fsMarkGroup  = new Konva.Group({ name: 'marks' });
  fsLyr.add(fsErrorGroup, fsMarkGroup);
  fsStage.add(fsLyr);

  // Use page annotations
  const pageAnnots = globalAnnotations.filter(a => a.page_number === (fsCurrentIndex + 1));
  drawAnnotations(rw, rh, fsStage, fsLyr, fsErrorGroup, fsMarkGroup, pageAnnots);

  // Apply visibility states
  if (fsErrorGroup) fsErrorGroup.visible(fsErrVis);
  if (fsMarkGroup)  fsMarkGroup.visible(fsMrkVis);
  fsLyr.draw();
}

function applyFsZoom() {
  const container = document.getElementById('fs-zoom-container');
  const label     = document.getElementById('fs-zoom-label');
  container.style.transform = `translate(${fsTranslate.x}px, ${fsTranslate.y}px) scale(${fsZoomLevel})`;
  if (label) label.textContent = Math.round(fsZoomLevel * 100) + '%';
}

function fsZoom(factor) {
  fsZoomLevel = Math.min(5, Math.max(0.3, fsZoomLevel * factor));
  applyFsZoom();
}

function fsZoomReset() {
  fsZoomLevel = 1;
  fsTranslate = { x: 0, y: 0 };
  applyFsZoom();
}

function fsPrevPage() {
  if (fsCurrentIndex > 0) {
    fsCurrentIndex--;
    buildFsThumbStrip();
    loadFsPage(fsCurrentIndex, 'left');
  }
}

function fsNextPage() {
  const urls = globalImageUrls.length > 0 ? globalImageUrls : [document.getElementById('student-img').src];
  if (fsCurrentIndex < urls.length - 1) {
    fsCurrentIndex++;
    buildFsThumbStrip();
    loadFsPage(fsCurrentIndex, 'right');
  }
}

function fstoggleErrors() {
  fsErrVis = !fsErrVis;
  if (fsErrorGroup) {
    const fsLyr = fsStage && fsStage.getLayers()[0];
    if (fsLyr) { fsErrorGroup.visible(fsErrVis); fsLyr.draw(); }
  }
  const btn = document.getElementById('fs-toggle-errors');
  if (btn) btn.style.opacity = fsErrVis ? '1' : '0.4';
}

function fstoggleMarks() {
  fsMrkVis = !fsMrkVis;
  if (fsMarkGroup) {
    const fsLyr = fsStage && fsStage.getLayers()[0];
    if (fsLyr) { fsMarkGroup.visible(fsMrkVis); fsLyr.draw(); }
  }
  const btn = document.getElementById('fs-toggle-marks');
  if (btn) btn.style.opacity = fsMrkVis ? '1' : '0.4';
}

// Mouse wheel zoom in fullscreen
document.getElementById('fs-image-area').addEventListener('wheel', (e) => {
  e.preventDefault();
  const delta = e.deltaY < 0 ? 1.1 : 0.91;
  fsZoom(delta);
  setTimeout(buildFsKonva, 50);
}, { passive: false });

// Drag to pan in fullscreen
const fsArea = document.getElementById('fs-image-area');
fsArea.addEventListener('mousedown', (e) => {
  fsIsDragging = true;
  fsDragStart = { x: e.clientX - fsTranslate.x, y: e.clientY - fsTranslate.y };
  fsArea.style.cursor = 'grabbing';
});
document.addEventListener('mousemove', (e) => {
  if (!fsIsDragging) return;
  fsTranslate = { x: e.clientX - fsDragStart.x, y: e.clientY - fsDragStart.y };
  applyFsZoom();
});
document.addEventListener('mouseup', () => {
  fsIsDragging = false;
  fsArea.style.cursor = 'grab';
});

// Keyboard arrow navigation in fullscreen
document.addEventListener('keydown', (e) => {
  if (!document.getElementById('fullscreen-overlay').classList.contains('active')) return;
  if (e.key === 'ArrowRight') fsNextPage();
  if (e.key === 'ArrowLeft')  fsPrevPage();
  if (e.key === '+' || e.key === '=') { fsZoom(1.2); setTimeout(buildFsKonva, 50); }
  if (e.key === '-') { fsZoom(0.83); setTimeout(buildFsKonva, 50); }
});

/* ════════════════════════════════════════════════════════════════════
  KATEX STEPS RENDERER
════════════════════════════════════════════════════════════════════ */
function renderSteps(steps) {
  const container = document.getElementById('steps-container');
  container.innerHTML = '';
  (steps || []).forEach((s, i) => {
    const card   = document.createElement('div');
    card.className = 'step-card py-5 px-1';
    const header = document.createElement('div');
    header.className = 'flex items-start gap-3 sm:gap-4';
    const numEl  = document.createElement('div');
    numEl.className = 'step-num mt-0.5 flex-shrink-0';
    numEl.textContent = s.step || (i + 1);
    const body   = document.createElement('div');
    body.className = 'flex-1 min-w-0';
    const textEl = document.createElement('p');
    textEl.className = 'text-sm sm:text-base text-slate-700 dark:text-gray-200 leading-relaxed font-medium';
    textEl.textContent = s.text;
    body.appendChild(textEl);
    if (s.latex) {
      const mathBlock = document.createElement('div');
      mathBlock.className = 'katex-block';
      try {
        katex.render(s.latex, mathBlock, { displayMode: true, throwOnError: false, trust: true });
      } catch(_) {
        mathBlock.textContent = s.latex;
        mathBlock.style.fontFamily = 'monospace';
        mathBlock.style.color = '#6C2BD9';
      }
      body.appendChild(mathBlock);
    }
    header.appendChild(numEl);
    header.appendChild(body);
    card.appendChild(header);
    container.appendChild(card);
  });
}

/* ════════════════════════════════════════════════════════════════════
  RESET
════════════════════════════════════════════════════════════════════ */
function resetEvaluator() {
  stopLoadingAnimations();
  if (submitAbortCtrl) { try { submitAbortCtrl.abort('cancelled'); } catch(_){} submitAbortCtrl = null; }
  lastFormData = null;

  fileDT = new DataTransfer();
  fileInput.files = fileDT.files;
  document.getElementById('file-preview-list').innerHTML = '';

  if (konvaStage) { konvaStage.destroy(); konvaStage = null; }
  if (fsStage)    { fsStage.destroy();    fsStage    = null; }
  errorGroup = null; markGroup = null; fsErrorGroup = null; fsMarkGroup = null;
  errorsVisible = true; marksVisible = true; annotationsVisible = true;
  fsErrVis = true; fsMrkVis = true;

  document.getElementById('student-img').src     = '';
  document.getElementById('img-info-bar').innerHTML = '';
  document.getElementById('meta-chips').innerHTML   = '';
  document.getElementById('rubric-bars').innerHTML  = '';
  document.getElementById('steps-container').innerHTML = '';
  document.getElementById('ring-fill-el').style.strokeDashoffset = '351.9';
  document.getElementById('score-main').textContent = '—';
  const psWrap = document.getElementById('ps-wrapper');
  if (psWrap) psWrap.style.display = 'none';

  const up = document.getElementById('upload-section');
  up.style.display = ''; up.style.opacity = '1'; up.style.pointerEvents = '';
  document.getElementById('loading-section').style.display = 'none';
  document.getElementById('result-section').style.display = 'none';
  document.getElementById('fullscreen-overlay').classList.remove('active');
  document.body.style.overflow = '';

  submitBtn.disabled = true;
  document.getElementById('file-count-display').classList.add('hidden');
  document.getElementById('submit-label').innerHTML = `<i data-lucide="gavel" class="w-5 h-5"></i> Submit to Strict Examiner`;

  currentZoom = 1; currentAnnotations = []; globalImageUrls = []; globalAnnotations = [];
  lucide.createIcons();
  gsap.from('.gsap-entry', { y: 20, opacity: 0, stagger: 0.07, duration: 0.55, ease: 'power2.out' });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ════════════════════════════════════════════════════════════════════
  AUTO-TRIGGER on page load (EJS injected data)
════════════════════════════════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded', () => {
  if (window.injectedEvaluationData) {
    document.getElementById('upload-section').style.display = 'none';
    renderResult(window.injectedEvaluationData);
  }
});

/* ════════════════════════════════════════════════════════════════════
  SHARE + DOWNLOAD
════════════════════════════════════════════════════════════════════ */
document.getElementById('btn-download').addEventListener('click', () => { window.print(); });
document.getElementById('btn-share').addEventListener('click', async () => {
  if (navigator.share) {
    try { await navigator.share({ title: 'My BoardAlgo Result', url: window.location.href }); } catch(_) {}
  } else {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('btn-share');
    btn.innerHTML = '<i data-lucide="check" class="w-3.5 h-3.5"></i> Copied!';
    lucide.createIcons();
    setTimeout(() => {
      btn.innerHTML = '<i data-lucide="share-2" class="w-3.5 h-3.5"></i> Share';
      lucide.createIcons();
    }, 2000);
  }
});

/* ════════════════════════════════════════════════════════════════════
  THREE.JS PARTICLE BACKGROUND
════════════════════════════════════════════════════════════════════ */
(function initThree() {
  const canvas   = document.getElementById('bg-canvas');
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true });
  const scene    = new THREE.Scene();
  const camera   = new THREE.PerspectiveCamera(75, innerWidth / innerHeight, 0.1, 1000);
  renderer.setSize(innerWidth, innerHeight);
  renderer.setPixelRatio(Math.min(devicePixelRatio, 1.8));
  const count = window.innerWidth < 640 ? 700 : 1400;
  const pos   = new Float32Array(count * 3);
  for (let i = 0; i < count * 3; i++) pos[i] = (Math.random() - 0.5) * 22;
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  const mat  = new THREE.PointsMaterial({ size: 0.018, color: 0xEF4444, transparent: true, opacity: 0.45 });
  const mesh = new THREE.Points(geo, mat);
  scene.add(mesh);
  camera.position.z = 4;
  let mx = 0, my = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX / innerWidth - 0.5; my = e.clientY / innerHeight - 0.5; });
  document.addEventListener('touchmove', e => {
    if (e.touches[0]) { mx = e.touches[0].clientX / innerWidth - 0.5; my = e.touches[0].clientY / innerHeight - 0.5; }
  }, { passive: true });
  (function animate() {
    requestAnimationFrame(animate);
    mesh.rotation.y += 0.0003 + mx * 0.0014;
    mesh.rotation.x += 0.0002 + my * 0.0008;
    renderer.render(scene, camera);
  })();
  window.addEventListener('resize', () => {
    camera.aspect = innerWidth / innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth, innerHeight);
  });
})();
</script>
