function setStage(n) {
  for (let i = 0; i < 3; i++) {
    const el   = document.getElementById(`lstage-${i}`);
    const icon = document.getElementById(`licon-${i}`);
    if (!el || !icon) continue;
    if (i < n) {
      el.className = 'loader-stage done';
      icon.innerHTML = '<i data-lucide="check" class="w-3 h-3" style="color:#4ade80;"></i>';
    } else if (i === n) {
      el.className = 'loader-stage active';
      icon.innerHTML = '<i data-lucide="loader-2" class="w-3 h-3"></i>';
    } else {
      el.className = 'loader-stage';
      icon.innerHTML = `<span style="font-size:11px;">${i + 1}</span>`;
    }
  }
  const stage = document.querySelectorAll('.loader-stage')[n];
  if (stage) {
    const p = stage.querySelector('p');
    if (p) p.style.color = 'white';
  }
  lucide.createIcons();
}

function animateProgress(target, current = null) {
  const fill = document.getElementById('progress-fill');
  if (!fill) return;
  const from = current !== null ? current : parseFloat(fill.style.width) || 0;
  let start = null;
  function step(ts) {
    if (!start) start = ts;
    const pct = Math.min((ts - start) / 800, 1);
    fill.style.width = (from + (target - from) * pct) + '%';
    if (pct < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

function startLoadingMessages() {
  const el = document.getElementById('loading-status');
  loadingMsgIdx = 0; currentStage = 0;
  if (el) el.textContent = loadingMessages[0];
  setStage(0);
  animateProgress(10, 0);

  loadingInterval = setInterval(() => {
    loadingMsgIdx = (loadingMsgIdx + 1) % loadingMessages.length;
    if (el) {
      el.style.opacity = '0';
      setTimeout(() => {
        if (el) { el.textContent = loadingMessages[loadingMsgIdx]; el.style.opacity = '1'; }
      }, 250);
    }
    // Advance stages
    if (loadingMsgIdx === 2) { setStage(1); animateProgress(45); }
    if (loadingMsgIdx === 5) { setStage(2); animateProgress(78); }
  }, 1800);

  // Fact ticker
  let factIdx = 0;
  factInterval = setInterval(() => {
    factIdx = (factIdx + 1) % examFacts.length;
    const f = document.getElementById('fact-display');
    if (f) {
      f.style.transform = 'translateY(-20px)';
      f.style.opacity = '0';
      setTimeout(() => {
        if (f) { f.textContent = examFacts[factIdx]; f.style.transform = ''; f.style.opacity = '1'; }
      }, 350);
    }
  }, 4000);
}

function stopLoadingAnimations() {
  clearInterval(loadingInterval);
  clearInterval(factInterval);
  clearInterval(progressSim);
  loadingInterval = null; factInterval = null; progressSim = null;
}

