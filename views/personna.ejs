  <!-- ══════ SCRIPTS ══════ -->
  <script>
    lucide.createIcons();

    const TOTAL_STEPS = 7;
    let currentStep = 1;

    // Persona labels for preview
    const PERSONA_MAP = {
      class_level: { 10:'Class 10', 12:'Class 12' },
      language: { english:'English', hinglish:'Hinglish', hindi:'Hindi' },
      dopamine_schema: {
        curiosity_driven:'Curiosity-Driven',
        reward_oriented:'Reward-Oriented',
        thrill_seeker:'Pressure-Activated',
        social_proof:'Socially Motivated',
      },
      cortisol_response: {
        audio_kinesthetic:'Audio Recall',
        spatial_visual:'Visual Recall',
        chunking:'Chunk Recall',
        algorithmic:'Logic Recall',
      },
      von_restorff: {
        gen_z_meme_heavy:'Unhinged Mode',
        desi_drama:'Desi Drama',
        cinematic:'Cinematic',
        grounded:'Grounded',
      },
      memory_decay: {
        serial_position:'Serial Decay',
        jumbled_mess:'Sequence Decay',
        vocab_block:'Vocab Decay',
        wall_of_text:'Block Rejection',
      },
      social_ego: {
        competitive:'Competitive',
        collaborative:'Collaborative',
        self_improver:'Self-Improver',
      },
    };

    const PERSONA_COLOR = {
      class_level:'', language:'blue',
      dopamine_schema:'', cortisol_response:'amber',
      von_restorff:'', memory_decay:'green',
      social_ego:'',
    };

    // Collected answers
    const answers = {};

    // ── Build step dots ────────────────────────────────────────────────
    function buildDots() {
      const container = document.getElementById('step-dots');
      container.innerHTML = '';
      for (let i = 1; i <= TOTAL_STEPS; i++) {
        const d = document.createElement('div');
        d.className = 'step-dot' + (i === currentStep ? ' current' : (i < currentStep ? ' done' : ''));
        container.appendChild(d);
      }
    }

    // ── Update UI for step transition ──────────────────────────────────
    function updateUI(newStep, direction) {
      const steps = document.querySelectorAll('.step-container');
      const oldContainer = steps[currentStep - 1];
      const newContainer = steps[newStep - 1];

      // Exit old
      oldContainer.classList.remove('active');
      oldContainer.style.display = 'none';

      // Enter new
      currentStep = newStep;
      newContainer.style.display = 'block';
      newContainer.style.opacity = '0';
      newContainer.style.transform = direction === 'forward' ? 'translateY(22px) scale(0.99)' : 'translateY(-22px) scale(0.99)';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          newContainer.style.transition = 'opacity 0.42s cubic-bezier(0.34,1.3,0.64,1), transform 0.42s cubic-bezier(0.34,1.3,0.64,1)';
          newContainer.style.opacity = '1';
          newContainer.style.transform = 'translateY(0) scale(1)';
          newContainer.classList.add('active');
        });
      });

      // Progress bar
      document.getElementById('progress-bar').style.width = `${(currentStep / TOTAL_STEPS) * 100}%`;

      // Step counter
      document.getElementById('step-counter').textContent = `${currentStep}/${TOTAL_STEPS}`;

      // Back button
      const btnBack = document.getElementById('btn-back');
      if (currentStep > 1) {
        btnBack.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        btnBack.classList.add('opacity-0', 'pointer-events-none');
      }

      // Dots
      buildDots();

      // Scroll top
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── Advance on radio change ────────────────────────────────────────
    function bindRadioAdvance(stepEl, stepNum) {
      const radios = stepEl.querySelectorAll('input[type="radio"]');
      radios.forEach(radio => {
        radio.addEventListener('change', () => {
          // Store answer
          answers[radio.name] = radio.value;

          // Mark label as selected
          const allLabels = stepEl.querySelectorAll('.opt-label, .class-card, .lang-card');
          allLabels.forEach(l => l.classList.remove('selected'));
          const parentLabel = radio.closest('.opt-label, .class-card, .lang-card');
          if (parentLabel) parentLabel.classList.add('selected');

          // Show XP pop
          showXP();

          // If last step, enable submit and show preview
          if (stepNum === TOTAL_STEPS) {
            document.getElementById('btn-submit').disabled = false;
            updatePersonaPreview();
            return;
          }

          // Advance after brief delay (let user see selected state)
          setTimeout(() => {
            updateUI(currentStep + 1, 'forward');
          }, 350);
        });
      });
    }

    // ── Class cards ────────────────────────────────────────────────────
    function bindClassCards() {
      document.querySelectorAll('.class-card').forEach(card => {
        const radio = card.querySelector('input[type="radio"]');
        card.addEventListener('click', () => {
          document.querySelectorAll('.class-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          radio.checked = true;
          answers[radio.name] = radio.value;
          showXP();
          setTimeout(() => updateUI(2, 'forward'), 350);
        });
      });
    }

    // ── Lang cards ─────────────────────────────────────────────────────
    function bindLangCards() {
      document.querySelectorAll('.lang-card').forEach(card => {
        const radio = card.querySelector('input[type="radio"]');
        card.addEventListener('click', () => {
          document.querySelectorAll('.lang-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          radio.checked = true;
          answers[radio.name] = radio.value;
          showXP();
          setTimeout(() => updateUI(3, 'forward'), 350);
        });
      });
    }

    // ── Persona preview ────────────────────────────────────────────────
    function updatePersonaPreview() {
      const container = document.getElementById('persona-tags');
      const preview = document.getElementById('persona-preview');
      container.innerHTML = '';
      let hasAny = false;
      Object.entries(answers).forEach(([field, value]) => {
        if (!PERSONA_MAP[field] || !PERSONA_MAP[field][value]) return;
        hasAny = true;
        const tag = document.createElement('span');
        const color = PERSONA_COLOR[field] || '';
        tag.className = 'persona-tag' + (color ? ' ' + color : '');
        tag.textContent = PERSONA_MAP[field][value];
        container.appendChild(tag);
      });
      preview.style.display = hasAny ? 'block' : 'none';
    }

    // ── XP pop ────────────────────────────────────────────────────────
    let xpTimer = null;
    function showXP() {
      if (xpTimer) { clearTimeout(xpTimer); document.querySelector('.xp-pop')?.remove(); }
      const pop = document.createElement('div');
      pop.className = 'xp-pop';
      pop.textContent = '+10 XP  · Profile calibrating';
      document.body.appendChild(pop);
      xpTimer = setTimeout(() => {
        pop.style.transition = 'opacity .4s';
        pop.style.opacity = '0';
        setTimeout(() => pop.remove(), 400);
      }, 1800);
    }

    // ── Back button ────────────────────────────────────────────────────
    document.getElementById('btn-back').addEventListener('click', () => {
      if (currentStep > 1) updateUI(currentStep - 1, 'back');
    });

    // ── Form submit validation ─────────────────────────────────────────
    document.getElementById('onboard-form').addEventListener('submit', (e) => {
      const requiredFields = ['class_level', 'language', 'dopamine_schema', 'cortisol_response', 'von_restorff', 'memory_decay', 'social_ego'];
      for (const field of requiredFields) {
        if (!answers[field]) {
          e.preventDefault();
          alert('Please complete all steps before continuing.');
          return;
        }
      }
      // All good — let it submit
    });

    // ── Init ──────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      buildDots();
      bindClassCards();
      bindLangCards();

      const steps = document.querySelectorAll('.step-container');
      steps.forEach((stepEl, idx) => {
        // Steps 3-7 use opt-label, step 2 uses lang-card, step 1 uses class-card
        if (idx >= 2) {
          bindRadioAdvance(stepEl, idx + 1);
        }
      });

      // Re-check if coming back: restore selected states
      // (handled by radio.checked state in re-visits)
    });
  </script>
  <script src="/js/tracking.js" defer></script>
</body>
</html>