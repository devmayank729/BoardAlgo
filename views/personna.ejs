<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BoardAlgo | Neural Calibration</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: {
              black:   '#020617',
              surface: '#0f172a',
              border:  '#1e293b',
              primary: '#6C2BD9',
              accent:  '#16A34A',
            }
          },
          fontFamily: {
            sans:    ['Inter', 'sans-serif'],
            display: ['Poppins', 'sans-serif'],
            mono:    ['Space Mono', 'monospace'],
          }
        }
      }
    }
  </script>

  <style>
    /* ── Base ─────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    body {
      background-color: #020617;
      background-image:
        radial-gradient(ellipse 70% 60% at 50% -10%, rgba(108,43,217,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 110%, rgba(22,163,74,0.07) 0%, transparent 60%);
      color: #f8fafc;
      overflow-x: hidden;
      font-family: 'Inter', sans-serif;
    }

    /* ── Scrollbar ────────────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.3); border-radius: 3px; }

    /* ── Progress bar ─────────────────────────────────────────────────── */
    #progress-bar {
      background: linear-gradient(90deg, #6C2BD9, #a855f7, #16A34A);
      background-size: 200% 100%;
      animation: barShift 3s linear infinite;
      transition: width 0.55s cubic-bezier(0.34, 1.3, 0.64, 1);
    }
    @keyframes barShift { 0%{background-position:0 0}100%{background-position:-200% 0} }

    /* ── Step animation ───────────────────────────────────────────────── */
    .step-container {
      display: none;
      opacity: 0;
      transform: translateY(22px) scale(0.99);
    }
    .step-container.active {
      display: block;
      animation: stepIn 0.42s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
    }
    .step-container.leaving {
      animation: stepOut 0.22s ease forwards;
    }
    @keyframes stepIn  { to { opacity:1; transform:translateY(0) scale(1); } }
    @keyframes stepOut { to { opacity:0; transform:translateY(-16px) scale(0.98); } }

    /* ── Hide native radio ────────────────────────────────────────────── */
    input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }

    /* ── Selection card ───────────────────────────────────────────────── */
    .sel-card {
      display: block; cursor: pointer; position: relative;
      border-radius: 16px; overflow: hidden;
      border: 1.5px solid rgba(255,255,255,0.07);
      background: rgba(15,23,42,0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: border-color .25s, background .25s, transform .2s, box-shadow .25s;
      -webkit-tap-highlight-color: transparent;
    }
    .sel-card:hover {
      border-color: rgba(108,43,217,0.4);
      background: rgba(108,43,217,0.06);
      transform: translateY(-2px);
    }
    .sel-card:active { transform: scale(0.98); }

    /* Selected state */
    input[type="radio"]:checked ~ .sel-inner {
      border-color: rgba(108,43,217,0.65) !important;
      background: rgba(108,43,217,0.14) !important;
      box-shadow: 0 0 0 3px rgba(108,43,217,0.18), 0 10px 30px rgba(108,43,217,0.25) !important;
    }
    /* Trick: use sibling selector via label wrapping */
    .opt-label {
      display: block; cursor: pointer; position: relative;
      border-radius: 16px; overflow: hidden;
      border: 1.5px solid rgba(255,255,255,0.07);
      background: rgba(15,23,42,0.55);
      backdrop-filter: blur(12px);
      transition: border-color .25s, background .25s, transform .2s, box-shadow .25s;
      -webkit-tap-highlight-color: transparent;
    }
    .opt-label:hover {
      border-color: rgba(108,43,217,0.4);
      background: rgba(108,43,217,0.06);
      transform: translateY(-2px);
    }
    .opt-label:active { transform: scale(0.98); }
    .opt-label.selected {
      border-color: rgba(108,43,217,0.65) !important;
      background: rgba(108,43,217,0.14) !important;
      box-shadow: 0 0 0 3px rgba(108,43,217,0.18), 0 10px 30px rgba(108,43,217,0.25) !important;
      transform: translateY(-2px);
    }
    /* Accent overrides for specific steps */
    .opt-label.selected.acc-green {
      border-color: rgba(22,163,74,0.6) !important;
      background: rgba(22,163,74,0.1) !important;
      box-shadow: 0 0 0 3px rgba(22,163,74,0.15), 0 10px 30px rgba(22,163,74,0.2) !important;
    }
    .opt-label.selected.acc-blue {
      border-color: rgba(59,130,246,0.6) !important;
      background: rgba(59,130,246,0.1) !important;
      box-shadow: 0 0 0 3px rgba(59,130,246,0.15), 0 10px 30px rgba(59,130,246,0.2) !important;
    }
    .opt-label.selected.acc-amber {
      border-color: rgba(245,158,11,0.6) !important;
      background: rgba(245,158,11,0.08) !important;
      box-shadow: 0 0 0 3px rgba(245,158,11,0.12), 0 10px 30px rgba(245,158,11,0.15) !important;
    }

    /* Check badge (appears on selected) */
    .check-badge {
      position: absolute; top: 10px; right: 10px;
      width: 22px; height: 22px; border-radius: 50%;
      background: #6C2BD9;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transform: scale(0.5);
      transition: opacity .2s, transform .25s cubic-bezier(0.34,1.56,0.64,1);
      flex-shrink: 0;
    }
    .opt-label.selected .check-badge { opacity: 1; transform: scale(1); }
    .check-badge svg { width: 12px; height: 12px; stroke: #fff; stroke-width: 2.5; fill: none; }

    /* ── Pill tag ─────────────────────────────────────────────────────── */
    .step-tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 12px; border-radius: 99px;
      font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      border: 1px solid rgba(108,43,217,0.3);
      background: rgba(108,43,217,0.1); color: #a78bfa;
      margin-bottom: 16px;
    }

    /* ── Step heading ─────────────────────────────────────────────────── */
    .step-heading {
      font-family: 'Poppins', sans-serif; font-weight: 800;
      font-size: clamp(1.5rem, 4vw, 2.4rem);
      line-height: 1.18; letter-spacing: -0.02em;
      color: #f8fafc; margin-bottom: 8px;
    }
    .step-sub {
      font-size: .88rem; color: #64748b; line-height: 1.6; margin-bottom: 28px;
    }

    /* ── Option content ───────────────────────────────────────────────── */
    .opt-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      transition: background .2s, border-color .2s;
    }
    .opt-label.selected .opt-icon {
      background: rgba(108,43,217,0.2);
      border-color: rgba(108,43,217,0.4);
    }
    .opt-label.selected.acc-green .opt-icon { background:rgba(22,163,74,0.18); border-color:rgba(22,163,74,0.4); }
    .opt-label.selected.acc-blue  .opt-icon { background:rgba(59,130,246,0.18); border-color:rgba(59,130,246,0.4); }
    .opt-label.selected.acc-amber .opt-icon { background:rgba(245,158,11,0.18); border-color:rgba(245,158,11,0.4); }

    .opt-title { font-family:'Poppins',sans-serif; font-weight:700; font-size:.95rem; color:#f1f5f9; line-height:1.3; }
    .opt-desc  { font-size:.78rem; color:#64748b; margin-top:3px; line-height:1.5; }
    .opt-label:hover .opt-title { color:#fff; }
    .opt-label.selected .opt-title { color:#c4b5fd; }
    .opt-label.selected.acc-green .opt-title { color:#86efac; }
    .opt-label.selected.acc-blue  .opt-title { color:#93c5fd; }
    .opt-label.selected.acc-amber .opt-title { color:#fcd34d; }

    /* ── Class level cards (big centered) ────────────────────────────── */
    .class-card {
      display: block; cursor: pointer; position: relative;
      border-radius: 20px; padding: 28px 20px;
      text-align: center;
      border: 1.5px solid rgba(255,255,255,0.07);
      background: rgba(15,23,42,0.55); backdrop-filter: blur(12px);
      transition: all .25s; -webkit-tap-highlight-color: transparent;
    }
    .class-card:hover { border-color:rgba(108,43,217,0.4); background:rgba(108,43,217,0.06); transform:translateY(-3px); }
    .class-card.selected {
      border-color:rgba(108,43,217,0.7) !important;
      background:rgba(108,43,217,0.14) !important;
      box-shadow: 0 0 0 3px rgba(108,43,217,0.2), 0 16px 40px rgba(108,43,217,0.3);
      transform: translateY(-4px);
    }
    .class-num {
      font-family:'Poppins',sans-serif; font-weight:800; font-size:3.5rem; line-height:1;
      background:linear-gradient(135deg,#a78bfa,#6C2BD9); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      margin-bottom:12px;
    }
    .class-card.selected .class-num { background:linear-gradient(135deg,#c4b5fd,#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    .class-label { font-family:'Poppins',sans-serif; font-weight:700; font-size:1rem; color:#e2e8f0; margin-bottom:4px; }
    .class-sub   { font-size:.75rem; color:#475569; font-family:'Space Mono',monospace; }
    .class-check {
      position:absolute; top:12px; right:12px; width:24px; height:24px; border-radius:50%;
      background:#6C2BD9; display:flex; align-items:center; justify-content:center;
      opacity:0; transform:scale(0.4); transition:all .25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .class-card.selected .class-check { opacity:1; transform:scale(1); }

    /* ── Language card ────────────────────────────────────────────────── */
    .lang-card {
      display:block; cursor:pointer; position:relative;
      border-radius:16px; padding:18px 20px;
      border:1.5px solid rgba(255,255,255,0.07);
      background:rgba(15,23,42,0.55); backdrop-filter:blur(12px);
      transition:all .25s; -webkit-tap-highlight-color:transparent;
    }
    .lang-card:hover { border-color:rgba(59,130,246,0.4); background:rgba(59,130,246,0.06); transform:translateY(-2px); }
    .lang-card.selected {
      border-color:rgba(59,130,246,0.65) !important;
      background:rgba(59,130,246,0.12) !important;
      box-shadow:0 0 0 3px rgba(59,130,246,0.15), 0 10px 28px rgba(59,130,246,0.2);
      transform:translateY(-2px);
    }
    .lang-flag { font-size:26px; margin-bottom:8px; display:block; }
    .lang-name { font-family:'Poppins',sans-serif; font-weight:700; font-size:.95rem; color:#e2e8f0; }
    .lang-desc { font-size:.75rem; color:#475569; margin-top:3px; line-height:1.4; }
    .lang-card.selected .lang-name { color:#93c5fd; }
    .lang-check {
      position:absolute; top:10px; right:10px; width:20px; height:20px; border-radius:50%;
      background:#2563eb; display:flex; align-items:center; justify-content:center;
      opacity:0; transform:scale(0.4); transition:all .25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .lang-card.selected .lang-check { opacity:1; transform:scale(1); }

    /* ── Submit button ────────────────────────────────────────────────── */
    .submit-btn {
      background: linear-gradient(135deg, #6C2BD9, #7c3aed);
      box-shadow: 0 6px 24px rgba(108,43,217,0.45);
      transition: all .3s cubic-bezier(0.34,1.3,0.64,1);
      position: relative; overflow: hidden;
    }
    .submit-btn::before {
      content: ''; position: absolute; inset:0;
      background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
    }
    .submit-btn:hover:not(:disabled) { transform: translateY(-3px); box-shadow: 0 10px 32px rgba(108,43,217,0.55); }
    .submit-btn:active:not(:disabled) { transform: scale(0.97); }
    .submit-btn:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ── Back button ─────────────────────────────────────────────────── */
    .back-btn {
      display:flex; align-items:center; gap:6px;
      font-size:.8rem; font-weight:600; color:#475569;
      transition:color .2s; cursor:pointer; border:none; background:none; padding:4px;
    }
    .back-btn:hover { color:#a78bfa; }

    /* ── Step counter dots ────────────────────────────────────────────── */
    .step-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: rgba(255,255,255,0.12);
      transition: all .35s cubic-bezier(0.34,1.3,0.64,1);
    }
    .step-dot.done  { background: rgba(108,43,217,0.6); }
    .step-dot.current { background: #a78bfa; width: 20px; border-radius: 3px; }

    /* ── Persona preview pill ─────────────────────────────────────────── */
    .persona-tag {
      display:inline-flex; align-items:center; gap:5px;
      padding:3px 10px; border-radius:99px;
      font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
      text-transform:uppercase; letter-spacing:.08em;
      background:rgba(108,43,217,0.12); color:#a78bfa;
      border:1px solid rgba(108,43,217,0.25);
      transition:all .3s ease;
    }
    .persona-tag.green { background:rgba(22,163,74,0.1); color:#4ade80; border-color:rgba(22,163,74,0.25); }
    .persona-tag.blue  { background:rgba(59,130,246,0.1); color:#60a5fa; border-color:rgba(59,130,246,0.25); }
    .persona-tag.amber { background:rgba(245,158,11,0.1); color:#fbbf24; border-color:rgba(245,158,11,0.25); }

    /* ── Glow dot ─────────────────────────────────────────────────────── */
    .glow-dot { width:7px; height:7px; border-radius:50%; background:#16A34A; box-shadow:0 0 6px #16A34A; display:inline-block; animation:dp 2s ease-in-out infinite; }
    @keyframes dp { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.8);} }

    /* ── XP Pop ───────────────────────────────────────────────────────── */
    .xp-pop {
      position:fixed; bottom:24px; right:20px; z-index:100;
      background:rgba(108,43,217,0.92); color:#fff; padding:10px 16px;
      border-radius:12px; font-family:'Space Mono',monospace; font-size:12px; font-weight:700;
      border:1px solid rgba(255,255,255,0.15); backdrop-filter:blur(10px);
      box-shadow:0 8px 28px rgba(108,43,217,0.45);
      animation:xpIn .4s cubic-bezier(0.34,1.56,0.64,1) forwards;
    }
    @keyframes xpIn { from{opacity:0;transform:translateY(16px) scale(.9);}to{opacity:1;transform:translateY(0) scale(1);} }

    /* ── Nav glass ─────────────────────────────────────────────────────── */
    nav { background:rgba(2,6,23,0.8); backdrop-filter:blur(16px); }

    /* ── Responsive tweaks ────────────────────────────────────────────── */
    @media (max-width:480px) {
      .step-heading { font-size:1.5rem; }
      .class-num { font-size:2.8rem; }
    }
  </style>
</head>

<body class="min-h-screen flex flex-col">

  <!-- ══════ NAV ══════ -->
  <nav class="fixed top-0 w-full z-50 border-b border-white/5">
    <div class="max-w-2xl mx-auto px-5 h-14 flex items-center justify-between gap-4">
      <button id="btn-back" class="back-btn opacity-0 pointer-events-none" aria-label="Go back">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Back
      </button>
      <div class="flex items-center gap-3">
        <!-- Dot indicator -->
        <div class="flex items-center gap-1.5" id="step-dots"></div>
      </div>
      <div class="text-right min-w-[60px]">
        <span class="font-mono text-[10px] font-bold tracking-widest text-slate-500 uppercase">Phase</span>
        <span id="step-counter" class="font-display font-bold text-sm text-brand-primary ml-1">1/7</span>
      </div>
    </div>
    <!-- Progress bar -->
    <div class="h-0.5 w-full" style="background:rgba(255,255,255,0.05);">
      <div id="progress-bar" class="h-full" style="width:14.28%;"></div>
    </div>
  </nav>

  <!-- ══════ MAIN ══════ -->
  <main class="flex-grow flex items-start justify-center pt-24 pb-16 px-4">
    <form method="POST" action="/api/onboard" id="onboard-form" class="w-full max-w-xl">

      <!-- ═══ STEP 1: Class Level ═══ -->
      <div class="step-container active" data-step="1">
        <div class="mb-8">
          <div class="step-tag"><span class="glow-dot"></span> Step 1 of 7</div>
          <h2 class="step-heading">Which board exam are<br>you preparing for?</h2>
          <p class="step-sub">This sets the language level and complexity of your mnemonics.</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <label class="class-card" data-field="class_level" data-value="10">
            <input type="radio" name="class_level" value="10" required>
            <div class="class-check">
              <svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg>
            </div>
            <div class="class-num">10</div>
            <div class="class-label">Class 10 Boards</div>
            <div class="class-sub">SST · Science · Maths</div>
          </label>
          <label class="class-card" data-field="class_level" data-value="12">
            <input type="radio" name="class_level" value="12">
            <div class="class-check">
              <svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg>
            </div>
            <div class="class-num">12</div>
            <div class="class-label">Class 12 Boards</div>
            <div class="class-sub">PCM · PCB · Commerce</div>
          </label>
        </div>
      </div>

      <!-- ═══ STEP 2: Language ═══ -->
      <div class="step-container" data-step="2">
        <div class="mb-8">
          <div class="step-tag" style="border-color:rgba(59,130,246,0.3);background:rgba(59,130,246,0.1);color:#60a5fa;">
            <span style="width:7px;height:7px;border-radius:50%;background:#60a5fa;box-shadow:0 0 6px #60a5fa;display:inline-block;"></span> Step 2 of 7
          </div>
          <h2 class="step-heading">Which language feels<br>most natural to you?</h2>
          <p class="step-sub">Your mnemonics will be generated in this exact style. Pick the one you actually think in.</p>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <label class="lang-card" data-field="language" data-value="english">
            <input type="radio" name="language" value="english" required>
            <div class="lang-check">
              <svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg>
            </div>
            <span class="lang-flag">🇬🇧</span>
            <div class="lang-name">English</div>
            <div class="lang-desc">Clean, precise, board-exam ready</div>
          </label>
          <label class="lang-card" data-field="language" data-value="hinglish">
            <input type="radio" name="language" value="hinglish">
            <div class="lang-check">
              <svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg>
            </div>
            <span class="lang-flag">🔀</span>
            <div class="lang-name">Hinglish</div>
            <div class="lang-desc">How toppers actually talk to each other</div>
          </label>
          <label class="lang-card" data-field="language" data-value="hindi">
            <input type="radio" name="language" value="hindi">
            <div class="lang-check">
              <svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg>
            </div>
            <span class="lang-flag">🇮🇳</span>
            <div class="lang-name">Hindi</div>
            <div class="lang-desc">Pure Hindi throughout</div>
          </label>
        </div>
      </div>

      <!-- ═══ STEP 3: Attention trigger (DOPAMINE_SCHEMA) ═══ -->
      <!-- Maps to: curiosity_driven, reward_oriented, thrill_seeker, social_proof -->
      <div class="step-container" data-step="3">
        <div class="mb-8">
          <div class="step-tag"><span class="glow-dot"></span> Step 3 of 7</div>
          <h2 class="step-heading">What actually makes<br>your brain switch ON?</h2>
          <p class="step-sub">Not what should — what actually does. Be honest, your mnemonics depend on it.</p>
        </div>
        <div class="grid grid-cols-1 gap-3">
          <label class="opt-label" data-field="dopamine_schema" data-value="curiosity_driven">
            <input type="radio" name="dopamine_schema" value="curiosity_driven" required>
            <div class="check-badge"><svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg></div>
            <div class="p-4 flex items-center gap-4">
              <div class="opt-icon">🧩</div>
              <div>
                <div class="opt-title">When someone says "most students get this wrong"</div>
                <div class="opt-desc">You immediately want to prove you're the exception. Puzzle energy.</div>
              </div>
            </div>
          </label>
          <label class="opt-label" data-field="dopamine_schema" data-value="reward_oriented">
            <input type="radio" name="dopamine_schema" value="reward_oriented">
            <div class="check-badge"><svg viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><polyline points="2,7 5.5,10.5 12,4"/></svg></div>
            <div class="p-4 flex items-center gap-4">
