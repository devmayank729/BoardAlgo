    function recordQuestion(q, mode) {
        const key = q.toLowerCase().trim();
        if (!questionHistory[key]) questionHistory[key] = { count:0, lastMode:mode, lastTs:0 };
        questionHistory[key].count++; questionHistory[key].lastMode = mode; questionHistory[key].lastTs = Date.now();
        saveQuestionHistory(); return questionHistory[key];
    }
    function shouldWarnRepeat(q, mode) {
        const key = q.toLowerCase().trim(); const h = questionHistory[key];
        if (!h || h.count < 1) return false; return h.lastMode === mode;
    }
    function getAlternateMode(mode) { return mode === 'lore' ? 'hack' : 'lore'; }

    // ── Gamification ───────────────────────────────────────────────────────────
    const G = {
        xp:          parseInt(sessionStorage.getItem('ba_xp')   ||'0'),
