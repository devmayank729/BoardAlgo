                </div>
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white tracking-tight mb-3 leading-tight">
                    Never forget a concept.<br class="hidden sm:block">
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Ever again.</span>
                </h1>
                <p class="text-slate-500 dark:text-gray-400 text-sm sm:text-base max-w-lg mx-auto leading-relaxed">
                    Type what you want to memorize. BoardAlgo AI turns it into a trick your brain cannot unsee.
                </p>
            </div>

            <section id="ui-state-idle" class="state-section gsap-entry">
                <form id="mnemonic-form" action="/api/generate-mnemonic" method="POST" autocomplete="off" novalidate>

                    <div class="glass input-shell rounded-2xl overflow-hidden mb-4">
                        <textarea id="brain-dump" name="question"
                            class="w-full min-h-[130px] bg-transparent text-slate-900 dark:text-white p-5 pb-3 font-sans text-base placeholder-slate-400 dark:placeholder-slate-500 leading-relaxed"
