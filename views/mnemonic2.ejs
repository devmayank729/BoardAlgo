                            <p class="text-xs font-medium mt-0.5" style="color:#6C2BD9;"><% if(user.subscription_status==='ACTIVE'){%>Pro Member<%}else{%>Free Trial<%}%></p>
                        </div>
                        <%if(user.photoURL){%>
                        <div class="avatar-ring" style="width:36px;height:36px;"><div class="avatar-inner" style="width:100%;height:100%;"><img src="<%=user.photoURL%>" style="width:100%;height:100%;object-fit:cover;" alt="<%=user.username%>"></div></div>
                        <%}else{%>
