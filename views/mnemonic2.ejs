                        <div id="img-preview-strip">
                            <img id="preview-thumb" src="" alt="Preview" />
                            <div class="flex-1 min-w-0">
                                <p id="preview-filename" class="text-xs font-semibold text-slate-700 dark:text-slate-200 truncate"></p>
                                <p id="preview-filesize" class="text-[11px] text-slate-400 mt-0.5"></p>
                            </div>
                            <button id="btn-remove-img" type="button" class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-slate-400 hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all">
                                <i data-lucide="x" class="w-3.5 h-3.5"></i>
                            </button>
                        </div>
                        <div class="flex flex-wrap items-center justify-between px-4 py-3 border-t border-gray-100 dark:border-white/5 bg-slate-50 dark:bg-black/20 gap-2">
                            <div class="flex items-center gap-2">
                                <button id="btn-camera" type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-500 hover:text-brand-primary hover:border-brand-primary/40 transition-all text-xs font-medium shadow-sm">
                                    <i data-lucide="camera" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">Scan Photo</span>
                                </button>
                                <button id="btn-upload" type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-500 hover:text-brand-primary hover:border-brand-primary/40 transition-all text-xs font-medium shadow-sm">
                                    <i data-lucide="image" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">Upload Image</span>
                                </button>
                                <input id="file-input" name="image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" class="hidden" />
                            </div>
                            <span class="text-xs text-slate-400 dark:text-slate-600 font-medium flex items-center gap-1">
                                <i data-lucide="command" class="w-3 h-3"></i>+Enter to generate
                            </span>
                        </div>
                    </div>

                    <div class="glass rounded-2xl p-5 mb-4">
                        <p class="text-xs font-semibold text-slate-500 dark:text-gray-400 uppercase tracking-widest mb-3">Choose your weapon</p>
                        <div class="grid grid-cols-2 gap-3 mb-5">
                            <button id="btn-lore" type="button" role="radio" aria-checked="true"
                                class="mode-btn flex flex-col items-start p-4 rounded-xl border-2 transition-all duration-300 text-left focus:outline-none"
                                style="border-color:#6C2BD9;background:rgba(108,43,217,0.07);">
                                <div class="flex items-center gap-2 mb-2 w-full">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(108,43,217,0.15);">
                                        <i data-lucide="book-open" class="w-4 h-4" style="color:#a78bfa;"></i>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-bold font-display text-slate-900 dark:text-white text-sm leading-tight">Lore Engine</p>
                                        <span class="badge badge-lore text-[10px]">Story Mode</span>
                                    </div>
                                    <div class="ml-auto w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0 mode-radio" style="border-color:#6C2BD9;">
                                        <div class="w-2 h-2 rounded-full" style="background:#6C2BD9;"></div>
                                    </div>
                                </div>
                                <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed">Cinematic story secretly mapped to your concept.</p>
                            </button>
                            <button id="btn-hack" type="button" role="radio" aria-checked="false"
                                class="mode-btn flex flex-col items-start p-4 rounded-xl border-2 transition-all duration-300 text-left focus:outline-none">
                                <div class="flex items-center gap-2 mb-2 w-full">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(22,163,74,0.1);">
                                        <i data-lucide="zap" class="w-4 h-4" style="color:#4ade80;"></i>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-bold font-display text-slate-900 dark:text-white text-sm leading-tight">Neural Hack</p>
                                        <span class="badge badge-hack text-[10px]">Cheat Code</span>
                                    </div>
                                    <div class="ml-auto w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0 mode-radio">
                                        <div class="w-2 h-2 rounded-full hidden" style="background:#16A34A;"></div>
                                    </div>
                                </div>
                                <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed">Brutal acronym trick. Screenshot and done.</p>
                            </button>
                        </div>

                        <div class="border-t border-gray-100 dark:border-white/5 mb-5"></div>

                        <div class="mb-5">
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                <div>
                                    <p class="text-xs font-semibold text-slate-500 dark:text-gray-400 uppercase tracking-widest mb-0.5">Response Language</p>
                                    <p class="text-[11px] text-slate-400 dark:text-slate-600">AI speaks in your chosen language</p>
                                </div>
                                <div class="lang-track flex-shrink-0">
                                    <button type="button" class="lang-btn active" data-lang="english">🇬🇧 English</button>
                                    <button type="button" class="lang-btn" data-lang="hinglish">🔀 Hinglish</button>
                                    <button type="button" class="lang-btn" data-lang="hindi">🇮🇳 Hindi</button>
                                </div>
                            </div>
                            <div class="mt-2 flex items-center gap-1.5 pl-0.5">
                                <i data-lucide="info" class="w-3 h-3 text-slate-400 flex-shrink-0"></i>
                                <p id="lang-desc-text" class="text-xs text-slate-400 dark:text-slate-500">Full English — precise, clean, board-exam ready.</p>
                            </div>
                        </div>

                        <div class="border-t border-gray-100 dark:border-white/5 mb-5"></div>

                        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
                            <button id="btn-deepscan" type="button" aria-pressed="false"
                                class="deepscan-btn glass flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all focus:outline-none flex-1 sm:flex-none">
                                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 bg-slate-50 dark:bg-white/5">
                                    <i data-lucide="radar" class="w-4 h-4 text-slate-500 dark:text-slate-400" id="deepscan-icon"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-slate-700 dark:text-slate-200 flex items-center gap-2">
                                        Deep Scan
                                        <span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wider" style="background:rgba(22,163,74,0.1);color:#16A34A;border:1px solid rgba(22,163,74,0.2);">Pro</span>
                                    </p>
                                    <p class="text-xs text-slate-400 dark:text-gray-500 leading-snug mt-0.5">Cross-references NCERT. Citation-backed hooks.</p>
                                </div>
                                <div class="w-10 h-6 rounded-full relative flex-shrink-0 border transition-all duration-300" id="deepscan-track" style="background:rgba(0,0,0,0.08);border-color:rgba(0,0,0,0.1);">
                                    <div class="w-4 h-4 rounded-full absolute top-0.5 left-0.5 transition-all duration-300 shadow-sm" id="deepscan-knob" style="background:#94a3b8;"></div>
                                </div>
                            </button>
                            <input type="hidden" name="mode"     id="mode-input"     value="lore" />
                            <input type="hidden" name="deepScan" id="deepscan-input" value="false" />
                            <input type="hidden" name="language" id="language-input" value="english" />
                            <button id="btn-generate" type="submit"
                                class="gen-btn flex-1 sm:flex-none sm:min-w-[180px] px-6 py-3 rounded-xl text-white font-display font-bold text-sm flex items-center justify-center gap-2 focus:outline-none">
                                <i data-lucide="fingerprint" class="w-4 h-4"></i> Generate Hook
                            </button>
                        </div>
                    </div>

                    <div class="gsap-entry flex flex-wrap items-center justify-between gap-3 px-1">
                        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-slate-400 dark:text-slate-600">
                            <span class="flex items-center gap-1"><i data-lucide="book-open" class="w-3 h-3"></i> Lore → chapters</span>
                            <span class="hidden sm:inline">·</span>
                            <span class="flex items-center gap-1"><i data-lucide="zap" class="w-3 h-3"></i> Hack → lists &amp; formulas</span>
                            <span class="hidden sm:inline">·</span>
                            <span class="flex items-center gap-1"><i data-lucide="radar" class="w-3 h-3"></i> Deep → before exams</span>
                        </div>
                        <button type="button" id="btn-reconfig" class="reconfig-btn">
                            <i data-lucide="refresh-cw" class="w-3 h-3"></i> Reconfigure Profile
                        </button>
                    </div>
                </form>
            </section>

            <section id="ui-state-processing"
                class="state-section hidden rounded-2xl border border-gray-200 dark:border-white/8 p-8 md:p-12 flex flex-col items-center"
                aria-live="polite" aria-busy="false" style="min-height:340px;box-shadow:0 4px 24px rgba(108,43,217,0.06);">
                <div class="relative w-20 h-20 mb-7">
                    <div class="ring-outer absolute inset-0 rounded-full border-2"></div>
                    <div class="ring-mid absolute inset-2 rounded-full border-2"></div>
                    <div class="ring-inner absolute inset-4 rounded-full border"></div>
                    <i data-lucide="brain-circuit" class="absolute inset-0 m-auto w-7 h-7 text-brand-primary"></i>
                </div>
                <h2 id="proc-title" class="text-xl font-display font-bold text-slate-900 dark:text-white mb-1 text-center">BoardAlgo AI is thinking...</h2>
                <p id="proc-subtitle" class="text-xs font-medium text-slate-500 mb-6 uppercase tracking-widest text-center">Lore Engine · Narrative Mode</p>
                <div class="w-full max-w-sm bg-gray-200 dark:bg-white/5 rounded-full h-1.5 mb-6 overflow-hidden">
                    <div id="progress-bar" class="h-1.5 rounded-full" style="width:15%;"></div>
                </div>
                <div id="terminal-log" class="w-full max-w-sm font-mono text-xs bg-slate-50 dark:bg-black/40 rounded-xl p-4 border border-slate-200 dark:border-white/5 space-y-2 min-h-[90px]"></div>
                <button id="btn-cancel" class="mt-8 px-5 py-2 rounded-full border border-gray-300 dark:border-gray-700 text-slate-500 hover:text-red-400 hover:border-red-400/50 text-sm font-medium transition-colors focus:outline-none">Cancel</button>
            </section>

            <section id="ui-state-output" class="state-section hidden" aria-live="polite">
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-5">
                    <div class="lg:col-span-1 order-2 lg:order-1" id="source-matrix-container"></div>
                    <div class="lg:col-span-3 order-1 lg:order-2">
                        <div class="glass rounded-t-2xl overflow-hidden border border-gray-200 dark:border-white/8 border-b-0">
                            <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 dark:border-white/5 bg-slate-50 dark:bg-black/20 flex-wrap gap-2">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="glow-dot"></span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-brand-primary font-display">BoardAlgo AI · Result</span>
                                    <span id="output-mode-badge" class="badge badge-lore">Lore Engine</span>
                                    <span id="output-lang-badge" class="badge" style="background:rgba(108,43,217,0.08);color:#6C2BD9;border:1px solid rgba(108,43,217,0.2);">EN</span>
                                    <span id="streak-badge" class="streak-pill hidden"></span>
                                </div>
                                <button id="btn-reset" class="flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-brand-primary transition-colors focus:outline-none">
                                    <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> New Hook
                                </button>
                            </div>
                            <div class="stats-strip" id="stats-strip">
                                <div class="stat-item"><i data-lucide="layers" class="w-3 h-3"></i> Today: <span class="stat-val ml-1" id="stat-locked">0</span></div>
                                <div class="stat-divider"></div>
                                <div class="stat-item"><i data-lucide="zap" class="w-3 h-3"></i> XP: <span class="stat-val ml-1" id="stat-xp-earned">0</span></div>
                                <div class="stat-divider"></div>
                                <div class="stat-item"><i data-lucide="brain-circuit" class="w-3 h-3"></i> Tests: <span class="stat-val ml-1" id="stat-tests">0</span></div>
                            </div>
                        </div>
                        <div id="ai-items-container" class="glass rounded-b-2xl border border-gray-200 dark:border-white/8 border-t-0 p-4 sm:p-6 space-y-5"></div>
                        <div class="flex items-center justify-center gap-2 mt-4 flex-wrap">
                            <button id="btn-copy-output" class="action-bar-btn"><i data-lucide="copy" class="w-3.5 h-3.5"></i> Copy</button>
                            <button id="btn-save-txt"    class="action-bar-btn"><i data-lucide="download" class="w-3.5 h-3.5"></i> Save .txt</button>
                            <button id="btn-bookmark"    class="action-bar-btn"><i data-lucide="bookmark" class="w-3.5 h-3.5"></i> Save to History</button>
                        </div>
                    </div>
                </div>
            </section>

        </div>
    </main>

    <script>
    lucide.createIcons();

    // ── Theme ──────────────────────────────────────────────────────────────────
    const html = document.documentElement;
    (function(){
        const s = localStorage.theme;
        if(s==='dark'||(!s&&window.matchMedia('(prefers-color-scheme:dark)').matches)) html.classList.add('dark');
        else html.classList.remove('dark');
    })();
    document.getElementById('theme-toggle').addEventListener('click',()=>{
        html.classList.toggle('dark');
        localStorage.theme = html.classList.contains('dark')?'dark':'light';
        setMode(currentMode); // re-apply button colors for new theme
        if(typeof updateThreeColors==='function') updateThreeColors();
    });

    // ── DOM refs ───────────────────────────────────────────────────────────────
    const form=document.getElementById('mnemonic-form'),textarea=document.getElementById('brain-dump'),
        fileInput=document.getElementById('file-input'),imgStrip=document.getElementById('img-preview-strip'),
        previewThumb=document.getElementById('preview-thumb'),previewFilename=document.getElementById('preview-filename'),
        previewFilesize=document.getElementById('preview-filesize'),btnRemoveImg=document.getElementById('btn-remove-img'),
        btnUpload=document.getElementById('btn-upload'),btnCamera=document.getElementById('btn-camera'),
        btnLore=document.getElementById('btn-lore'),btnHack=document.getElementById('btn-hack'),
        modeInput=document.getElementById('mode-input'),btnDeepScan=document.getElementById('btn-deepscan'),
        deepScanInput=document.getElementById('deepscan-input'),deepscanTrack=document.getElementById('deepscan-track'),
        deepscanKnob=document.getElementById('deepscan-knob'),deepscanIcon=document.getElementById('deepscan-icon'),
        languageInput=document.getElementById('language-input'),langDescText=document.getElementById('lang-desc-text'),
        outputLangBadge=document.getElementById('output-lang-badge'),btnGenerate=document.getElementById('btn-generate'),
        stateIdle=document.getElementById('ui-state-idle'),stateProc=document.getElementById('ui-state-processing'),
        stateOutput=document.getElementById('ui-state-output'),progressBar=document.getElementById('progress-bar'),
        terminalLog=document.getElementById('terminal-log'),procTitle=document.getElementById('proc-title'),
        procSubtitle=document.getElementById('proc-subtitle'),aiItems=document.getElementById('ai-items-container'),
        sourceMatrix=document.getElementById('source-matrix-container'),outputModeBadge=document.getElementById('output-mode-badge'),
        streakBadge=document.getElementById('streak-badge'),btnCancel=document.getElementById('btn-cancel'),
        btnReset=document.getElementById('btn-reset'),btnCopy=document.getElementById('btn-copy-output'),
        btnSave=document.getElementById('btn-save-txt'),btnReconfig=document.getElementById('btn-reconfig'),
        confirmModal=document.getElementById('confirm-modal'),modalCancelBtn=document.getElementById('modal-cancel-btn'),
        modalConfirmBtn=document.getElementById('modal-confirm-btn');

    // ── App state ──────────────────────────────────────────────────────────────
