    function formatBytes(b){ if(b<1024) return b+' B'; if(b<1048576) return (b/1024).toFixed(1)+' KB'; return (b/1048576).toFixed(1)+' MB'; }
    function mdBold(raw){ if(!raw) return ''; const safe=raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); return safe.replace(/\*\*([^*\n]+?)\*\*/g,'<strong>$1</strong>'); }

    // ════════════════════════════════════════════════════════════════════
    // KATEX — improved rendering with better fallback
    // ════════════════════════════════════════════════════════════════════
    function renderKatexLine(latexStr, containerEl) {
        if (!window.katex) {
            containerEl.className = 'formula-plain-fallback';
            containerEl.textContent = latexStr;
            return;
        }
        // Clean up common patterns
        const cleaned = latexStr.trim();
        try {
            katex.render(cleaned, containerEl, {
                displayMode: true,
                throwOnError: false,
                strict: false,
                trust: true,
                macros: {
                    "\\d": "\\mathrm{d}",
                }
            });
        } catch(e) {
            // Try inline mode
            try {
                katex.render(cleaned, containerEl, { displayMode:false, throwOnError:false, strict:false, trust:true });
            } catch(e2) {
                // Full fallback — styled plain text
                containerEl.className = 'formula-plain-fallback';
                containerEl.textContent = cleaned;
            }
        }
    }

    // Auto-detect and render inline LaTeX in plain text (for content fields)
    function tryRenderInlineLatex(textContent) {
        if (!window.katex || !textContent) return null;
        // If it contains common LaTeX patterns, try to render
        const hasLatex = /\\[a-zA-Z]|[\^_]|\$|\\frac|\\int|\\sum|\\sqrt/.test(textContent);
        if (!hasLatex) return null;
        const el = document.createElement('div');
        el.className = 'latex-line';
        renderKatexLine(textContent, el);
        return el;
    }

    // ── Concept content builder ────────────────────────────────────────────────
    function buildConceptContent(cc){
        if(!cc||!cc.content) return null;
        const ICONS={reaction:'flask-conical',formula:'sigma',table:'table-2',list:'list',statement:'quote',steps:'git-branch'};
        const LABELS={reaction:'The Reaction',formula:'The Formula',table:'The Table',list:'What to Memorize',statement:'The Statement',steps:'The Steps'};
        const box=document.createElement('div'); box.className='concept-box'; box.dataset.type=cc.type||'list';
        const header=document.createElement('div'); header.className='concept-box-header';
        const hl=document.createElement('div'); hl.className='flex items-center gap-2';
        hl.innerHTML=`<i data-lucide="${ICONS[cc.type]||'book-open'}" class="w-3.5 h-3.5"></i><span>${LABELS[cc.type]||'What to Learn'}</span>`;
        header.appendChild(hl);
        const body=document.createElement('div'); body.className='concept-box-body';

        const hasLatex = Array.isArray(cc.latex_content) && cc.latex_content.length > 0;

        if (hasLatex && window.katex) {
            const lw=document.createElement('div'); lw.className='latex-render';
            cc.latex_content.forEach(ls=>{
                const le=document.createElement('div'); le.className='latex-line';
                renderKatexLine(ls, le);
                lw.appendChild(le);
            });
            body.appendChild(lw);

            const tb=document.createElement('button'); tb.className='plain-toggle-btn'; tb.type='button';
            tb.innerHTML=`<i data-lucide="text" class="w-3 h-3"></i> Plain`;
            const pw=document.createElement('div'); pw.className='cc-plain-wrap'; pw.style.display='none';
            cc.content.split('\\n').map(l=>l.trim()).filter(Boolean).forEach(ln=>{
                const p=document.createElement('p'); p.className='cc-plain-line'; p.textContent=ln; pw.appendChild(p);
            });
            body.appendChild(pw);
            let sl=true;
            tb.addEventListener('click',()=>{
                sl=!sl; lw.style.display=sl?'':'none'; pw.style.display=sl?'none':'';
                tb.innerHTML=sl?`<i data-lucide="text" class="w-3 h-3"></i> Plain`:`<i data-lucide="sigma" class="w-3 h-3"></i> LaTeX`;
                lucide.createIcons();
            });
            header.appendChild(tb);

        } else if ((cc.type==='formula' || cc.type==='reaction') && window.katex) {
            // Try to auto-render the content field as LaTeX
            const lw = document.createElement('div'); lw.className = 'latex-render';
            const lines = cc.content.split(/\\n|\n/).map(l=>l.trim()).filter(Boolean);
            lines.forEach(ln => {
                const le = document.createElement('div'); le.className = 'latex-line';
                renderKatexLine(ln, le);
                lw.appendChild(le);
            });
            body.appendChild(lw);

            const tb=document.createElement('button'); tb.className='plain-toggle-btn'; tb.type='button';
            tb.innerHTML=`<i data-lucide="text" class="w-3 h-3"></i> Plain`;
            const pw=document.createElement('div'); pw.className='cc-plain-wrap'; pw.style.display='none';
            lines.forEach(ln=>{ const p=document.createElement('p'); p.className='cc-plain-line'; p.textContent=ln; pw.appendChild(p); });
            body.appendChild(pw);
            let sl=true;
            tb.addEventListener('click',()=>{
                sl=!sl; lw.style.display=sl?'':'none'; pw.style.display=sl?'none':'';
                tb.innerHTML=sl?`<i data-lucide="text" class="w-3 h-3"></i> Plain`:`<i data-lucide="sigma" class="w-3 h-3"></i> LaTeX`;
                lucide.createIcons();
            });
            header.appendChild(tb);

        } else if(cc.type==='list'){
            const ul=document.createElement('div'); ul.className='cc-list';
            cc.content.split('\\n').map(l=>l.trim()).filter(Boolean).forEach((ln,i)=>{
                const it=document.createElement('div'); it.className='cc-item';
                it.innerHTML=`<span class="cc-num">${i+1}</span><span class="cc-text">${ln}</span>`;
                ul.appendChild(it);
            });
            body.appendChild(ul);
        } else if(cc.type==='steps'){
            const sw=document.createElement('div'); sw.className='cc-steps';
            cc.content.split('\\n').map(l=>l.trim()).filter(Boolean).forEach((ln,i)=>{
                const st=document.createElement('div'); st.className='cc-step';
                st.innerHTML=`<span class="cc-step-num">${i+1}</span><span class="cc-step-text">${ln}</span>`;
                sw.appendChild(st);
            });
            body.appendChild(sw);
        } else {
            const pw=document.createElement('div'); pw.className='cc-plain-wrap';
            cc.content.split('\\n').map(l=>l.trim()).filter(Boolean).forEach(ln=>{
                const p=document.createElement('p'); p.className='cc-plain-line'; p.textContent=ln; pw.appendChild(p);
            });
            body.appendChild(pw);
        }
        box.appendChild(header); box.appendChild(body); return box;
    }

    // ── Confetti ───────────────────────────────────────────────────────────────
    function fireConfetti(x,y){ const cv=document.createElement('canvas'); cv.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:200;'; document.body.appendChild(cv); const ctx=cv.getContext('2d'); cv.width=innerWidth; cv.height=innerHeight; const cols=['#6C2BD9','#a78bfa','#16A34A','#4ade80','#f472b6','#fbbf24','#38bdf8']; const cx=x||cv.width/2,cy=y||cv.height/3; const ps=Array.from({length:55},()=>({x:cx,y:cy,r:3+Math.random()*5,color:cols[Math.floor(Math.random()*cols.length)],vx:(Math.random()-.5)*8,vy:-4-Math.random()*6,rot:Math.random()*360,vr:(Math.random()-.5)*14})); let fr; const st=Date.now(); function draw(){ ctx.clearRect(0,0,cv.width,cv.height); const el=Date.now()-st; ps.forEach(p=>{ p.x+=p.vx; p.y+=p.vy; p.rot+=p.vr; p.vy+=0.1; ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot*Math.PI/180); ctx.fillStyle=p.color; ctx.globalAlpha=Math.max(0,1-el/2000); ctx.fillRect(-p.r,-p.r/2,p.r*2,p.r); ctx.restore(); }); if(el<2000) fr=requestAnimationFrame(draw); else{ cancelAnimationFrame(fr); if(cv.parentNode) document.body.removeChild(cv); } } draw(); }

    function showMemoryStrength(cardEl,pct){ const ex=cardEl.querySelector('.memory-strength-wrap'); if(ex) ex.remove(); const w=document.createElement('div'); w.className='memory-strength-wrap'; w.innerHTML=`<span class="ms-label">Memory Strength</span><div class="ms-track"><div class="ms-fill"></div></div><span class="ms-pct">${pct}%</span>`; cardEl.appendChild(w); setTimeout(()=>{ const f=w.querySelector('.ms-fill'); if(f) f.style.width=pct+'%'; },80); }

    // ── FEEDBACK PANEL BUILDER ─────────────────────────────────────────────────
    function buildFeedbackPanel(interactionId, question, mode, cardEl) {
        const panel = document.createElement('div'); panel.className = 'feedback-panel';
        let currentRating=0,currentDisliked=false,submitted=false;
        const bar=document.createElement('div'); bar.className='feedback-bar';
        const lbl=document.createElement('span'); lbl.className='feedback-label'; lbl.textContent='Rate this hook';
        bar.appendChild(lbl);
        const starRow=document.createElement('div'); starRow.className='star-row';
        const stars=[];
        for(let i=1;i<=5;i++){
            const s=document.createElement('button'); s.className='star-btn'; s.type='button'; s.textContent='★';
            s.addEventListener('mouseenter',()=>{ stars.forEach((b,j)=>b.classList.toggle('active',j<i)); });
            s.addEventListener('mouseleave',()=>{ stars.forEach((b,j)=>b.classList.toggle('active',j<currentRating)); });
            s.addEventListener('click',()=>{ currentRating=i; stars.forEach((b,j)=>b.classList.toggle('active',j<i)); openComment(); });
            stars.push(s); starRow.appendChild(s);
        }
        bar.appendChild(starRow);
        const thumbRow=document.createElement('div'); thumbRow.className='thumb-row';
        const likeBtn=document.createElement('button'); likeBtn.className='thumb-btn'; likeBtn.type='button'; likeBtn.innerHTML='<i data-lucide="thumbs-up" class="w-3 h-3"></i>';
        const dislikeBtn=document.createElement('button'); dislikeBtn.className='thumb-btn'; dislikeBtn.type='button'; dislikeBtn.innerHTML='<i data-lucide="thumbs-down" class="w-3 h-3"></i>';
        likeBtn.addEventListener('click',()=>{ likeBtn.classList.toggle('liked'); dislikeBtn.classList.remove('disliked'); currentDisliked=false; submitFeedback(false); gainXP(2,'Feedback given'); });
        dislikeBtn.addEventListener('click',()=>{ dislikeBtn.classList.toggle('disliked'); likeBtn.classList.remove('liked'); currentDisliked=dislikeBtn.classList.contains('disliked'); if(currentDisliked){ openComment(true); showRegenWarning(question,mode,cardEl); } });
        thumbRow.appendChild(likeBtn); thumbRow.appendChild(dislikeBtn); bar.appendChild(thumbRow); panel.appendChild(bar);
        const commentSection=document.createElement('div'); commentSection.className='feedback-comment-section';
        const commentLabel=document.createElement('span'); commentLabel.className='feedback-comment-label'; commentLabel.textContent='Add a comment (optional)'; commentSection.appendChild(commentLabel);
        const ta=document.createElement('textarea'); ta.className='feedback-textarea'; ta.rows=3; ta.maxLength=500; ta.placeholder='e.g. "Mnemonic words are too hard to remember"'; commentSection.appendChild(ta);
        const submitRow=document.createElement('div'); submitRow.className='feedback-submit-row';
        const charCount=document.createElement('span'); charCount.className='feedback-char-count'; charCount.textContent='0 / 500';
        ta.addEventListener('input',()=>{ charCount.textContent=ta.value.length+' / 500'; });
        const submitBtn=document.createElement('button'); submitBtn.className='feedback-submit-btn'; submitBtn.type='button'; submitBtn.textContent='Submit Feedback';
        submitBtn.addEventListener('click',()=>submitFeedback(true));
        submitRow.appendChild(charCount); submitRow.appendChild(submitBtn); commentSection.appendChild(submitRow); panel.appendChild(commentSection);
        const thanksEl=document.createElement('div'); thanksEl.className='feedback-thanks'; thanksEl.style.display='none'; panel.appendChild(thanksEl);
        let commentOpen=false;
        function openComment(forced){ if(commentOpen) return; commentOpen=true; if(forced) commentLabel.textContent='Tell us what was wrong — helps improve the AI'; commentSection.classList.add('open'); }
        async function submitFeedback(withComment){
            if(submitted&&!withComment) return;
            const payload={interaction_id:interactionId,question,mode,rating:currentRating>0?currentRating:null,disliked:currentDisliked,comment:ta.value.trim()};
            try{
                await fetch('/api/feedback/mnemonic',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
                if(withComment||currentDisliked){
                    commentSection.classList.remove('open'); commentOpen=false; thanksEl.style.display='flex';
                    if(currentDisliked){ G.reportCount++; saveG(); if(G.reportCount===1) triggerAchievement('first_report'); if(G.reportCount>=4){ triggerAchievement('four_reports'); thanksEl.innerHTML=`<span>🛡️</span><div><div style="font-family:'Poppins',sans-serif;font-size:.8rem;font-weight:700;color:#4ade80;margin-bottom:3px;">Thank you!</div><div style="font-family:'Space Mono',monospace;font-size:.72rem;color:#64748b;line-height:1.5;">Genuine report verified → <span class="feedback-report-badge">2 Days Premium Free</span></div></div>`; }
                    else{ const rem=4-G.reportCount; thanksEl.innerHTML=`<span>🙏</span><div><div style="font-family:'Poppins',sans-serif;font-size:.78rem;font-weight:700;color:#e2e8f0;margin-bottom:3px;">Thanks!</div><div style="font-family:'Space Mono',monospace;font-size:.7rem;color:#64748b;">${rem} more report${rem!==1?'s':''} = <span class="feedback-report-badge">2 Days Premium</span></div></div>`; }
                    } else{ thanksEl.innerHTML=`<span>⭐</span><div style="font-family:'Space Mono',monospace;font-size:.75rem;color:#64748b;">Thanks! Feedback helps us improve.</div>`; }
                    submitted=true;
                } else{ showToast('Rating saved!',1200); submitted=true; }
            } catch(e){ showToast('Could not save feedback — try again.'); }
        }
        lucide.createIcons();
        return panel;
    }

    // ── REGEN WARNING ──────────────────────────────────────────────────────────
    function showRegenWarning(question, mode, cardEl) {
