        aiItems.insertBefore(warn, aiItems.firstChild);
        warn.querySelector('#regen-yes').addEventListener('click',()=>{ warn.remove(); setMode(altMode); if(!isDeepScan) btnDeepScan.click(); textarea.value=question; form.dispatchEvent(new Event('submit',{bubbles:true,cancelable:true})); });
        warn.querySelector('#regen-no').addEventListener('click',()=>{ warn.style.opacity='0'; warn.style.transition='opacity .3s ease'; setTimeout(()=>warn.remove(),300); });
