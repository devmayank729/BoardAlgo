        /* ── Mnemonic ────────────────────────────────────────────────────── */
        .mnemonic-section-wrap { display:flex; flex-direction:column; gap:0; }
        .mnemonic-hero { border-radius:14px; position:relative; overflow:hidden; padding:18px 20px; }
        .mnemonic-hero[data-mode="lore"] { background:linear-gradient(135deg,rgba(108,43,217,0.07),rgba(230,230,255,0.4)); border:1.5px solid rgba(108,43,217,0.2); }
        .dark .mnemonic-hero[data-mode="lore"] { background:linear-gradient(135deg,rgba(108,43,217,0.12),rgba(5,8,20,0.5)); }
        .mnemonic-hero[data-mode="hack"] { background:linear-gradient(135deg,rgba(22,163,74,0.07),rgba(230,255,240,0.4)); border:1.5px solid rgba(22,163,74,0.2); }
        .dark .mnemonic-hero[data-mode="hack"] { background:linear-gradient(135deg,rgba(22,163,74,0.10),rgba(3,12,6,0.5)); }
        .mnemonic-hero[data-mode="deep"] { background:linear-gradient(135deg,rgba(59,130,246,0.07),rgba(230,240,255,0.4)); border:1.5px solid rgba(59,130,246,0.2); }
        .dark .mnemonic-hero[data-mode="deep"] { background:linear-gradient(135deg,rgba(59,130,246,0.10),rgba(3,6,20,0.5)); }
        .mnemonic-hero::before { content:''; position:absolute; top:0; left:0; bottom:0; width:4px; border-radius:4px 0 0 4px; }
        .mnemonic-hero[data-mode="lore"]::before { background:linear-gradient(180deg,#6C2BD9,#a855f7); }
        .mnemonic-hero[data-mode="hack"]::before { background:linear-gradient(180deg,#16A34A,#4ade80); }
        .mnemonic-hero[data-mode="deep"]::before { background:linear-gradient(180deg,#3b82f6,#60a5fa); }
        .mnemonic-hero::after { content:''; position:absolute; top:-50px; right:-50px; width:180px; height:180px; border-radius:50%; pointer-events:none; opacity:.5; }
        .mnemonic-hero[data-mode="lore"]::after { background:radial-gradient(circle,rgba(108,43,217,0.12),transparent 70%); }
        .mnemonic-hero[data-mode="hack"]::after { background:radial-gradient(circle,rgba(22,163,74,0.10),transparent 70%); }
        .mnemonic-hero[data-mode="deep"]::after { background:radial-gradient(circle,rgba(59,130,246,0.10),transparent 70%); }
        .mnemonic-label-row { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; display:flex; align-items:center; gap:6px; margin-bottom:9px; position:relative; z-index:1; }
        .hook-context-text { font-size:.78rem; font-family:'Inter',sans-serif; color:#64748b; font-style:italic; line-height:1.5; margin-bottom:12px; position:relative; z-index:1; }
        .hook-text { line-height:1.35; position:relative; z-index:1; }
        .hook-text strong { font-weight:900; }
        .mnemonic-hero[data-mode="lore"] .hook-text strong { color:#6C2BD9; }
        .mnemonic-hero[data-mode="hack"] .hook-text strong { color:#16A34A; }
        .mnemonic-hero[data-mode="deep"] .hook-text strong { color:#3b82f6; }
        .dark .mnemonic-hero[data-mode="lore"] .hook-text strong { color:#a78bfa; text-shadow:0 0 18px rgba(167,139,250,0.35); }
        .dark .mnemonic-hero[data-mode="hack"] .hook-text strong { color:#4ade80; text-shadow:0 0 18px rgba(74,222,128,0.3); }
        .dark .mnemonic-hero[data-mode="deep"] .hook-text strong { color:#60a5fa; text-shadow:0 0 18px rgba(96,165,250,0.3); }
        .acronym-badge-row { display:flex; align-items:center; gap:5px; flex-wrap:wrap; margin-bottom:12px; position:relative; z-index:1; }
        .acronym-row-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.6; }
        .acronym-letter-pill { width:30px; height:30px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-family:'Space Mono',monospace; font-size:.8rem; font-weight:700; flex-shrink:0; transition:all .2s; }
        .mnemonic-hero[data-mode="hack"] .acronym-letter-pill { background:rgba(22,163,74,0.12); color:#16A34A; border:1.5px solid rgba(22,163,74,0.25); }
        .mnemonic-hero[data-mode="lore"] .acronym-letter-pill { background:rgba(108,43,217,0.12); color:#6C2BD9; border:1.5px solid rgba(108,43,217,0.25); }
        .mnemonic-hero[data-mode="deep"] .acronym-letter-pill { background:rgba(59,130,246,0.12); color:#2563eb; border:1.5px solid rgba(59,130,246,0.25); }
        .dark .mnemonic-hero[data-mode="hack"] .acronym-letter-pill { color:#4ade80; }
        .dark .mnemonic-hero[data-mode="lore"] .acronym-letter-pill { color:#a78bfa; }
        .dark .mnemonic-hero[data-mode="deep"] .acronym-letter-pill { color:#60a5fa; }
        .word-chips-container { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:10px; position:relative; z-index:1; }
        .word-chip { display:inline-flex; align-items:baseline; gap:1px; padding:7px 12px 7px 8px; border-radius:10px; cursor:pointer; font-family:'Poppins',sans-serif; font-size:.95rem; font-weight:600; transition:transform .18s,box-shadow .18s,background .18s,border-color .18s; position:relative; user-select:none; -webkit-tap-highlight-color:transparent; }
        .mnemonic-hero[data-mode="hack"] .word-chip { background:rgba(22,163,74,0.08); border:1.5px solid rgba(22,163,74,0.2); color:#1e293b; }
        .mnemonic-hero[data-mode="lore"] .word-chip { background:rgba(108,43,217,0.08); border:1.5px solid rgba(108,43,217,0.2); color:#1e293b; }
        .mnemonic-hero[data-mode="deep"] .word-chip { background:rgba(59,130,246,0.08); border:1.5px solid rgba(59,130,246,0.2); color:#1e293b; }
        .dark .mnemonic-hero[data-mode="hack"] .word-chip,
        .dark .mnemonic-hero[data-mode="lore"] .word-chip,
        .dark .mnemonic-hero[data-mode="deep"] .word-chip { color:#f1f5f9; }
        .mnemonic-hero[data-mode="hack"] .word-chip:hover,.mnemonic-hero[data-mode="hack"] .word-chip.chip-active { background:rgba(22,163,74,0.18); border-color:rgba(22,163,74,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(22,163,74,0.2); }
        .mnemonic-hero[data-mode="lore"] .word-chip:hover,.mnemonic-hero[data-mode="lore"] .word-chip.chip-active { background:rgba(108,43,217,0.18); border-color:rgba(108,43,217,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(108,43,217,0.2); }
        .mnemonic-hero[data-mode="deep"] .word-chip:hover,.mnemonic-hero[data-mode="deep"] .word-chip.chip-active { background:rgba(59,130,246,0.18); border-color:rgba(59,130,246,0.4); transform:translateY(-3px); box-shadow:0 6px 14px rgba(59,130,246,0.2); }
        .chip-key-letter { font-size:1.1em; font-weight:800; }
        .mnemonic-hero[data-mode="hack"] .chip-key-letter { color:#16A34A; }
        .mnemonic-hero[data-mode="lore"] .chip-key-letter { color:#6C2BD9; }
        .mnemonic-hero[data-mode="deep"] .chip-key-letter { color:#2563eb; }
        .dark .mnemonic-hero[data-mode="hack"] .chip-key-letter { color:#4ade80; }
        .dark .mnemonic-hero[data-mode="lore"] .chip-key-letter { color:#a78bfa; }
        .dark .mnemonic-hero[data-mode="deep"] .chip-key-letter { color:#60a5fa; }
        .chip-rest-word { font-weight:600; transition:opacity .25s; }
        .word-chip.chip-locked { border-color:rgba(22,163,74,0.5)!important; background:rgba(22,163,74,0.1)!important; }
        .mnemonic-full-sentence { font-size:.8rem; color:rgba(71,85,105,0.65); font-family:'Inter',sans-serif; font-style:italic; margin-bottom:10px; line-height:1.5; position:relative; z-index:1; }
        .dark .mnemonic-full-sentence { color:rgba(148,163,184,0.55); }
        .test-mode-btn { padding:5px 10px; border-radius:8px; border:1px solid rgba(108,43,217,0.22); background:rgba(108,43,217,0.06); color:#6C2BD9; font-size:.68rem; font-weight:700; font-family:'Space Mono',monospace; text-transform:uppercase; letter-spacing:.06em; cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:5px; }
        .dark .test-mode-btn { color:#a78bfa; }
        .test-mode-btn:hover { background:rgba(108,43,217,0.14); border-color:rgba(108,43,217,0.45); }
        .test-mode-btn.active { background:rgba(108,43,217,0.18); border-color:#6C2BD9; color:#6C2BD9; }
        .dark .test-mode-btn.active { color:#c4b5fd; }
        .chip-tooltip { position:absolute; bottom:calc(100% + 10px); left:50%; transform:translateX(-50%); background:#1e293b; color:#f1f5f9; font-size:11px; font-family:'Space Mono',monospace; padding:7px 11px; border-radius:9px; white-space:nowrap; border:1px solid rgba(255,255,255,0.1); z-index:30; pointer-events:none; box-shadow:0 8px 24px rgba(0,0,0,0.45); }
        .chip-tooltip::after { content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%); border:6px solid transparent; border-top-color:#1e293b; }
        .test-score-bar { height:3px; border-radius:2px; background:rgba(0,0,0,0.08); overflow:hidden; margin-top:8px; position:relative; z-index:1; }
        .dark .test-score-bar { background:rgba(255,255,255,0.06); }
        .test-score-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,#16A34A,#4ade80); width:0%; transition:width .4s ease; }
        .test-score-label { font-family:'Space Mono',monospace; font-size:9px; color:#64748b; margin-top:4px; position:relative; z-index:1; display:flex; align-items:center; justify-content:space-between; }

        /* ── Decode ──────────────────────────────────────────────────────── */
        .decode-toggle-btn { width:100%; padding:10px 14px; border-radius:10px; border:1.5px dashed rgba(108,43,217,0.18); background:rgba(108,43,217,0.03); color:#64748b; font-size:.7rem; font-weight:700; font-family:'Space Mono',monospace; text-transform:uppercase; letter-spacing:.09em; display:flex; align-items:center; gap:8px; cursor:pointer; transition:all .25s; margin-top:8px; position:relative; z-index:1; text-align:left; }
        .dark .decode-toggle-btn { border-color:rgba(255,255,255,0.1); background:rgba(0,0,0,0.18); }
        .decode-toggle-btn:hover { border-color:rgba(108,43,217,0.35); color:#6C2BD9; background:rgba(108,43,217,0.06); border-style:solid; }
        .dark .decode-toggle-btn:hover { color:#a78bfa; }
        .decode-toggle-btn[data-open="true"] { border-style:solid; border-color:rgba(108,43,217,0.25); color:#6C2BD9; background:rgba(108,43,217,0.04); }
        .dark .decode-toggle-btn[data-open="true"] { color:#a78bfa; }
        .decode-toggle-hint { margin-left:auto; font-size:9px; opacity:.45; }
        .decode-content-wrapper { overflow:hidden; transition:max-height .45s cubic-bezier(.4,0,.2,1),opacity .3s ease,margin-top .3s ease; max-height:900px; opacity:1; margin-top:10px; }
        .collapsed-decode { max-height:0!important; opacity:0!important; margin-top:0!important; }
        .decode-map-grid { display:flex; flex-direction:column; gap:3px; padding:8px; border-radius:12px; margin-bottom:8px; background:rgba(108,43,217,0.03); border:1px solid rgba(108,43,217,0.08); }
        .dark .decode-map-grid { background:rgba(0,0,0,0.35); border-color:rgba(255,255,255,0.06); }
        .decode-map-row { display:flex; align-items:center; gap:10px; padding:6px 8px; border-radius:8px; transition:background .15s; }
        .decode-map-row:hover { background:rgba(108,43,217,0.05); }
        .dark .decode-map-row:hover { background:rgba(108,43,217,0.1); }
        .decode-letter-badge { width:26px; height:26px; border-radius:7px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-family:'Space Mono',monospace; font-size:.72rem; font-weight:700; }
        .decode-letter-badge[data-mode="hack"] { background:rgba(22,163,74,0.1); color:#15803d; border:1px solid rgba(22,163,74,0.2); }
        .decode-letter-badge[data-mode="lore"] { background:rgba(108,43,217,0.1); color:#6C2BD9; border:1px solid rgba(108,43,217,0.2); }
        .decode-letter-badge[data-mode="deep"] { background:rgba(59,130,246,0.1); color:#2563eb; border:1px solid rgba(59,130,246,0.2); }
        .dark .decode-letter-badge[data-mode="hack"] { color:#4ade80; }
        .dark .decode-letter-badge[data-mode="lore"] { color:#a78bfa; }
        .dark .decode-letter-badge[data-mode="deep"] { color:#60a5fa; }
        .decode-row-text { flex:1; display:flex; align-items:baseline; flex-wrap:wrap; gap:3px; min-width:0; }
        .decode-word-label { font-family:'Poppins',sans-serif; font-weight:700; font-size:.8rem; color:#1e293b; }
        .dark .decode-word-label { color:#e2e8f0; }
        .decode-arrow { font-family:'Space Mono',monospace; font-size:.7rem; color:#94a3b8; flex-shrink:0; }
        .decode-meaning { font-family:'Space Mono',monospace; font-size:.7rem; color:#475569; line-height:1.4; flex:1; }
        .dark .decode-meaning { color:#94a3b8; }
        .decode-full-text { font-family:'Space Mono',monospace; font-size:.7rem; line-height:1.7; padding-top:8px; margin-top:4px; border-top:1px solid rgba(108,43,217,0.07); color:#475569; }
        .dark .decode-full-text { color:#94a3b8; border-top-color:rgba(255,255,255,0.06); }
        .mapping-strip { background:rgba(108,43,217,0.03); border:1px solid rgba(108,43,217,0.08); border-radius:10px; padding:10px 14px; }
        .dark .mapping-strip { background:rgba(0,0,0,0.3); border-color:rgba(255,255,255,0.06); }

        /* ════════════════════════════════════════════════════════════════════
           DND GAME — Complete redesign: engaging, game-like, memorable
        ════════════════════════════════════════════════════════════════════ */
        .dnd-game {
            margin-top:12px;
            border-radius:18px;
            overflow:hidden;
            border:2px solid rgba(108,43,217,0.25);
            background:#f8f7ff;
            box-shadow:0 8px 32px rgba(108,43,217,0.12), 0 2px 8px rgba(0,0,0,0.06);
        }
        .dark .dnd-game {
            background:linear-gradient(160deg,rgba(15,10,35,0.98),rgba(8,10,28,0.95));
            border-color:rgba(108,43,217,0.35);
            box-shadow:0 0 40px rgba(108,43,217,0.15), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        .dnd-game.hidden { display:none; }
        .dnd-game.dnd-complete { border-color:rgba(22,163,74,0.5) !important; }
        .dark .dnd-game.dnd-complete { box-shadow:0 0 40px rgba(22,163,74,0.2), inset 0 1px 0 rgba(255,255,255,0.05); }

        /* Header */
        .dnd-header {
            display:flex; align-items:center; justify-content:space-between;
            padding:12px 16px;
            border-bottom:1.5px solid rgba(108,43,217,0.1);
            background:rgba(108,43,217,0.05);
        }
        .dark .dnd-header { background:rgba(108,43,217,0.1); border-bottom-color:rgba(108,43,217,0.18); }
        .dnd-header-left { display:flex; align-items:center; gap:12px; }
        .dnd-title {
            font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
            text-transform:uppercase; letter-spacing:.12em; color:#6C2BD9; display:flex; align-items:center; gap:6px;
        }
        .dark .dnd-title { color:#a78bfa; }
        .dnd-title-dot { width:6px; height:6px; border-radius:50%; background:#6C2BD9; animation:dotpulse 1.5s ease-in-out infinite; }
        .dark .dnd-title-dot { background:#a78bfa; }
        .dnd-score-wrap { display:flex; align-items:center; gap:8px; }
        .dnd-score-text { font-family:'Space Mono',monospace; font-size:11px; color:#64748b; }
        .dark .dnd-score-text { color:#64748b; }
        .dnd-score-cur { color:#6C2BD9; font-weight:700; font-size:14px; }
        .dark .dnd-score-cur { color:#a78bfa; }
        .dnd-score-total { color:#94a3b8; font-size:11px; }

        /* Progress mini-bar in header */
        .dnd-progress-track {
            width:80px; height:4px; border-radius:2px;
            background:rgba(108,43,217,0.1);
            overflow:hidden;
        }
        .dark .dnd-progress-track { background:rgba(255,255,255,0.06); }
        .dnd-progress-fill {
            height:100%; border-radius:2px; width:0%;
            background:linear-gradient(90deg,#6C2BD9,#a855f7);
            transition:width .4s cubic-bezier(.34,1.3,.64,1);
        }

        .dnd-exit-btn {
            display:flex; align-items:center; gap:4px; padding:5px 10px; border-radius:8px;
            font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em;
            border:1.5px solid rgba(239,68,68,0.2); background:rgba(239,68,68,0.05); color:#ef4444; cursor:pointer; transition:all .2s;
        }
        .dnd-exit-btn:hover { background:rgba(239,68,68,0.12); border-color:rgba(239,68,68,0.4); }

        /* Instruction */
        .dnd-instr {
            font-family:'Space Mono',monospace; font-size:10px; color:#64748b;
            text-align:center; padding:10px 16px 6px; letter-spacing:.05em;
        }
        .dark .dnd-instr { color:#475569; }

        /* Drop zones row */
        .dnd-drop-zones {
            display:flex; flex-wrap:wrap; gap:8px;
            padding:14px 16px 10px; justify-content:center; min-height:80px;
        }

        /* Individual drop zone — bigger, cleaner, with letter ABOVE */
        .dnd-zone {
            display:flex; flex-direction:column; align-items:center; justify-content:center;
            gap:4px; min-width:72px; min-height:72px; padding:6px 8px;
            border-radius:14px;
            border:2px dashed rgba(108,43,217,0.2);
            background:rgba(108,43,217,0.03);
            transition:border-color .2s,background .2s,transform .15s,box-shadow .2s;
            cursor:pointer; position:relative; flex-shrink:0;
        }
        .dark .dnd-zone {
            background:rgba(108,43,217,0.05);
            border-color:rgba(108,43,217,0.25);
        }
        /* Zone letter label (always visible) */
        .dnd-zone-letter-label {
            font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
            text-transform:uppercase; letter-spacing:.06em;
            color:#6C2BD9; opacity:.5;
        }
        .dark .dnd-zone-letter-label { color:#a78bfa; opacity:.6; }
        /* Zone placeholder */
        .dnd-zone-placeholder {
            width:44px; height:44px; border-radius:10px;
            border:2px dashed rgba(108,43,217,0.15);
            display:flex; align-items:center; justify-content:center;
        }
        .dark .dnd-zone-placeholder { border-color:rgba(108,43,217,0.2); }
        .dnd-zone-placeholder-letter {
            font-family:'Poppins',monospace; font-size:1rem; font-weight:700;
            color:rgba(108,43,217,0.3);
        }
        .dark .dnd-zone-placeholder-letter { color:rgba(167,139,250,0.3); }

        /* Hover state */
        .dnd-zone.dnd-zone-hover {
            border-style:solid; transform:scale(1.05);
            border-color:#a78bfa; background:rgba(108,43,217,0.1);
            box-shadow:0 0 20px rgba(108,43,217,0.2);
        }
        .dark .dnd-zone.dnd-zone-hover { border-color:#a78bfa; background:rgba(108,43,217,0.15); }

        /* Correct state */
        .dnd-zone.dnd-zone-correct {
            border-style:solid; border-color:rgba(22,163,74,0.5);
            background:rgba(22,163,74,0.06); cursor:default;
        }
        .dark .dnd-zone.dnd-zone-correct { background:rgba(22,163,74,0.1); }

        /* Wrong shake */
        .dnd-zone.dnd-zone-wrong { animation:zoneShake .4s ease; border-color:#ef4444 !important; }
        @keyframes zoneShake { 0%,100%{transform:translateX(0);}20%{transform:translateX(-6px);}40%{transform:translateX(6px);}60%{transform:translateX(-4px);}80%{transform:translateX(4px);} }

        .dnd-zone.dnd-zone-hint { animation:zoneHint .4s ease; }
        @keyframes zoneHint { 0%,100%{transform:scale(1);}50%{transform:scale(1.08);} }

        /* Filled zone chip */
        .dnd-zone-filled {
            display:flex; flex-direction:column; align-items:center; justify-content:center;
            gap:2px; padding:6px 8px; border-radius:10px; text-align:center; width:100%;
            animation:chipPlaceIn .35s cubic-bezier(.34,1.56,.64,1);
        }
        @keyframes chipPlaceIn { from{transform:scale(0.7) translateY(-8px);opacity:0;}to{transform:scale(1) translateY(0);opacity:1;} }
        .dnd-zone-filled-lore { background:rgba(108,43,217,0.15); border:1.5px solid rgba(108,43,217,0.3); }
        .dark .dnd-zone-filled-lore { background:rgba(108,43,217,0.25); }
        .dnd-zone-filled-hack { background:rgba(22,163,74,0.15); border:1.5px solid rgba(22,163,74,0.3); }
        .dark .dnd-zone-filled-hack { background:rgba(22,163,74,0.2); }
        .dnd-zone-filled-deep { background:rgba(59,130,246,0.15); border:1.5px solid rgba(59,130,246,0.3); }
        .dark .dnd-zone-filled-deep { background:rgba(59,130,246,0.2); }
        .dnd-zone-filled .dnd-chip-key-display {
            font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
            text-transform:uppercase; letter-spacing:.06em;
        }
        .dnd-zone-filled-lore .dnd-chip-key-display { color:#6C2BD9; }
        .dark .dnd-zone-filled-lore .dnd-chip-key-display { color:#a78bfa; }
        .dnd-zone-filled-hack .dnd-chip-key-display { color:#16A34A; }
        .dark .dnd-zone-filled-hack .dnd-chip-key-display { color:#4ade80; }
        .dnd-zone-filled-deep .dnd-chip-key-display { color:#2563eb; }
        .dark .dnd-zone-filled-deep .dnd-chip-key-display { color:#60a5fa; }
        .dnd-zone-filled .dnd-filled-word {
            font-family:'Poppins',sans-serif; font-size:.7rem; font-weight:700; color:#1e293b;
            white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:100%;
        }
        .dark .dnd-zone-filled .dnd-filled-word { color:#e2e8f0; }
        .dnd-check-icon { font-size:10px; }

        /* Separator */
        .dnd-separator {
            height:1.5px; margin:0 16px;
            background:linear-gradient(90deg,transparent,rgba(108,43,217,0.15),transparent);
        }
        .dark .dnd-separator { background:linear-gradient(90deg,transparent,rgba(108,43,217,0.2),transparent); }

        /* Chip bank */
        .dnd-chip-bank-label {
            font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
            text-transform:uppercase; letter-spacing:.1em; color:#94a3b8;
            text-align:center; padding:8px 16px 0; display:flex; align-items:center;
            justify-content:center; gap:6px;
        }
        .dnd-chip-bank {
            display:flex; flex-wrap:wrap; gap:8px;
            padding:10px 16px 16px; justify-content:center; min-height:60px;
        }

        /* Bank chips — bigger and more visual */
        .dnd-bank-chip {
            display:inline-flex; flex-direction:column; align-items:center; justify-content:center;
            gap:2px; padding:10px 14px; border-radius:12px; cursor:grab;
            font-family:'Poppins',sans-serif; font-weight:600;
            transition:transform .18s,box-shadow .18s,opacity .2s,background .15s,border-color .15s;
            user-select:none; -webkit-tap-highlight-color:transparent; touch-action:none;
            min-width:64px; text-align:center; position:relative; overflow:hidden;
        }
        .dnd-bank-chip::after {
            content:''; position:absolute; inset:0; border-radius:inherit;
            background:linear-gradient(135deg,rgba(255,255,255,0.12),transparent);
            pointer-events:none;
        }
        /* Mode-specific bank chip styles */
        .dnd-bank-chip[data-mode="lore"] {
            background:rgba(108,43,217,0.1); border:1.5px solid rgba(108,43,217,0.25);
            box-shadow:0 2px 8px rgba(108,43,217,0.1);
        }
        .dark .dnd-bank-chip[data-mode="lore"] { background:rgba(108,43,217,0.15); }
        .dnd-bank-chip[data-mode="hack"] {
            background:rgba(22,163,74,0.1); border:1.5px solid rgba(22,163,74,0.25);
            box-shadow:0 2px 8px rgba(22,163,74,0.08);
        }
        .dark .dnd-bank-chip[data-mode="hack"] { background:rgba(22,163,74,0.12); }
        .dnd-bank-chip[data-mode="deep"] {
            background:rgba(59,130,246,0.1); border:1.5px solid rgba(59,130,246,0.25);
            box-shadow:0 2px 8px rgba(59,130,246,0.08);
        }
        .dark .dnd-bank-chip[data-mode="deep"] { background:rgba(59,130,246,0.12); }

        .dnd-bank-chip:hover:not(.dnd-bank-placed) {
            transform:translateY(-4px) scale(1.04);
            box-shadow:0 8px 20px rgba(108,43,217,0.25);
        }
        .dnd-bank-chip[data-mode="hack"]:hover:not(.dnd-bank-placed) { box-shadow:0 8px 20px rgba(22,163,74,0.2); }
        .dnd-bank-chip[data-mode="deep"]:hover:not(.dnd-bank-placed) { box-shadow:0 8px 20px rgba(59,130,246,0.2); }

        .dnd-bank-chip.dnd-dragging { opacity:.35; cursor:grabbing; transform:scale(.92); }
        .dnd-bank-chip.dnd-bank-placed { opacity:.2; cursor:not-allowed; pointer-events:none; transform:scale(.95); }

        /* Selected state */
        .dnd-bank-chip.dnd-selected[data-mode="lore"] {
            border-color:#6C2BD9; background:rgba(108,43,217,0.2);
            box-shadow:0 0 0 3px rgba(108,43,217,0.2),0 8px 20px rgba(108,43,217,0.3);
            transform:translateY(-4px) scale(1.04);
        }
        .dark .dnd-bank-chip.dnd-selected[data-mode="lore"] { border-color:#a78bfa; }
        .dnd-bank-chip.dnd-selected[data-mode="hack"] {
            border-color:#16A34A; background:rgba(22,163,74,0.2);
            box-shadow:0 0 0 3px rgba(22,163,74,0.2),0 8px 20px rgba(22,163,74,0.25);
            transform:translateY(-4px) scale(1.04);
        }
        .dark .dnd-bank-chip.dnd-selected[data-mode="hack"] { border-color:#4ade80; }
        .dnd-bank-chip.dnd-selected[data-mode="deep"] {
            border-color:#2563eb; background:rgba(59,130,246,0.2);
            box-shadow:0 0 0 3px rgba(59,130,246,0.2),0 8px 20px rgba(59,130,246,0.25);
            transform:translateY(-4px) scale(1.04);
        }

        /* Chip key letter */
        .dnd-chip-key {
            font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
            text-transform:uppercase; letter-spacing:.06em;
        }
        .dnd-bank-chip[data-mode="lore"] .dnd-chip-key { color:#6C2BD9; }
        .dark .dnd-bank-chip[data-mode="lore"] .dnd-chip-key { color:#a78bfa; }
        .dnd-bank-chip[data-mode="hack"] .dnd-chip-key { color:#16A34A; }
        .dark .dnd-bank-chip[data-mode="hack"] .dnd-chip-key { color:#4ade80; }
        .dnd-bank-chip[data-mode="deep"] .dnd-chip-key { color:#2563eb; }
        .dark .dnd-bank-chip[data-mode="deep"] .dnd-chip-key { color:#60a5fa; }

        /* Chip word */
        .dnd-chip-word { font-family:'Poppins',sans-serif; font-size:.85rem; font-weight:700; color:#1e293b; }
        .dark .dnd-chip-word { color:#e2e8f0; }

        /* Touch clone */
        .dnd-touch-clone {
            position:fixed; z-index:9999; pointer-events:none;
            transform:scale(1.1) rotate(-3deg);
            box-shadow:0 16px 40px rgba(0,0,0,0.35); opacity:.92;
            font-family:'Poppins',sans-serif; font-size:.95rem; font-weight:600;
            padding:10px 14px; border-radius:12px;
            display:inline-flex; flex-direction:column; align-items:center; gap:2px;
            background:rgba(108,43,217,0.9); color:#e2e8f0; border:2px solid #a78bfa;
        }

        /* Complete message */
        .dnd-complete-msg {
            display:flex; align-items:center; justify-content:center; gap:10px;
            padding:14px 16px; font-family:'Poppins',sans-serif; font-size:.88rem; font-weight:700;
            color:#16A34A; border-top:2px solid rgba(22,163,74,0.2);
            background:linear-gradient(135deg,rgba(22,163,74,0.06),rgba(74,222,128,0.04));
            animation:termReveal .4s ease;
        }
        .dark .dnd-complete-msg { color:#4ade80; }

        /* Mode-specific drop zone colors */
        [data-mode="hack"] .dnd-zone { border-color:rgba(22,163,74,0.2); background:rgba(22,163,74,0.03); }
        .dark [data-mode="hack"] .dnd-zone { background:rgba(22,163,74,0.04); }
        [data-mode="hack"] .dnd-zone-letter-label { color:#16A34A; }
        .dark [data-mode="hack"] .dnd-zone-letter-label { color:#4ade80; }
        [data-mode="hack"] .dnd-zone.dnd-zone-hover { border-color:#4ade80; background:rgba(22,163,74,0.1); box-shadow:0 0 20px rgba(22,163,74,0.18); }
        [data-mode="hack"] .dnd-progress-fill { background:linear-gradient(90deg,#16A34A,#4ade80); }
        [data-mode="hack"] .dnd-score-cur { color:#16A34A; }
        .dark [data-mode="hack"] .dnd-score-cur { color:#4ade80; }
        [data-mode="hack"] .dnd-title { color:#16A34A; }
        .dark [data-mode="hack"] .dnd-title { color:#4ade80; }
        [data-mode="hack"] .dnd-title-dot { background:#16A34A; }
        .dark [data-mode="hack"] .dnd-title-dot { background:#4ade80; }
        [data-mode="hack"] .dnd-header { background:rgba(22,163,74,0.05); border-bottom-color:rgba(22,163,74,0.12); }
        .dark [data-mode="hack"] .dnd-header { background:rgba(22,163,74,0.08); }
        [data-mode="hack"] .dnd-zone-placeholder-letter { color:rgba(22,163,74,0.3); }
        [data-mode="hack"] .dnd-zone-placeholder { border-color:rgba(22,163,74,0.15); }
        [data-mode="hack"] .dnd-separator { background:linear-gradient(90deg,transparent,rgba(22,163,74,0.15),transparent); }
        .dark [data-mode="hack"] .dnd-separator { background:linear-gradient(90deg,transparent,rgba(22,163,74,0.2),transparent); }
        .dark .dnd-game[data-mode="hack"] { border-color:rgba(22,163,74,0.35); box-shadow:0 0 40px rgba(22,163,74,0.1), inset 0 1px 0 rgba(255,255,255,0.04); }

        [data-mode="deep"] .dnd-zone { border-color:rgba(59,130,246,0.2); background:rgba(59,130,246,0.03); }
        .dark [data-mode="deep"] .dnd-zone { background:rgba(59,130,246,0.04); }
        [data-mode="deep"] .dnd-zone-letter-label { color:#2563eb; }
        .dark [data-mode="deep"] .dnd-zone-letter-label { color:#60a5fa; }
        [data-mode="deep"] .dnd-zone.dnd-zone-hover { border-color:#60a5fa; background:rgba(59,130,246,0.1); box-shadow:0 0 20px rgba(59,130,246,0.18); }
        [data-mode="deep"] .dnd-progress-fill { background:linear-gradient(90deg,#2563eb,#60a5fa); }
        [data-mode="deep"] .dnd-score-cur { color:#2563eb; }
        .dark [data-mode="deep"] .dnd-score-cur { color:#60a5fa; }
        [data-mode="deep"] .dnd-title { color:#2563eb; }
        .dark [data-mode="deep"] .dnd-title { color:#60a5fa; }

        /* FEEDBACK PANEL ────────────────────────────────────────────────── */
        .feedback-panel { margin-top:10px; border-radius:12px; border:1px solid rgba(108,43,217,0.1); background:rgba(248,250,252,0.7); overflow:hidden; transition:all .3s ease; }
        .dark .feedback-panel { background:rgba(15,23,42,0.4); border-color:rgba(255,255,255,0.06); }
        .feedback-bar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:8px 14px; }
        .feedback-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#64748b; white-space:nowrap; }
        .dark .feedback-label { color:#475569; }
        .star-row { display:flex; gap:3px; align-items:center; }
        .star-btn { background:none; border:none; cursor:pointer; padding:2px; font-size:18px; line-height:1; transition:transform .15s; color:#cbd5e1; }
        .dark .star-btn { color:#334155; }
        .star-btn:hover, .star-btn.active { color:#f59e0b; transform:scale(1.2); }
        .star-btn.dimmed { color:#cbd5e1; }
        .dark .star-btn.dimmed { color:#334155; }
        .thumb-row { display:flex; gap:6px; margin-left:auto; }
        .thumb-btn { display:inline-flex; align-items:center; gap:4px; padding:5px 11px; border-radius:8px; cursor:pointer; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; border:1px solid rgba(108,43,217,0.1); background:rgba(108,43,217,0.04); color:#64748b; transition:all .2s; }
        .dark .thumb-btn { border-color:rgba(255,255,255,0.08); background:rgba(255,255,255,0.04); color:#94a3b8; }
        .thumb-btn:hover { border-color:rgba(108,43,217,0.3); color:#6C2BD9; }
        .thumb-btn.liked { background:rgba(22,163,74,0.1); border-color:rgba(22,163,74,0.3); color:#16A34A; }
        .dark .thumb-btn.liked { color:#4ade80; }
        .thumb-btn.disliked { background:rgba(239,68,68,0.08); border-color:rgba(239,68,68,0.3); color:#ef4444; }
        .feedback-comment-section { padding:0 14px; max-height:0; overflow:hidden; transition:max-height .35s cubic-bezier(.4,0,.2,1),padding .35s ease,opacity .3s ease; opacity:0; }
        .feedback-comment-section.open { max-height:220px; padding:10px 14px 14px; opacity:1; }
        .feedback-comment-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#64748b; margin-bottom:6px; display:block; }
        .dark .feedback-comment-label { color:#475569; }
        .feedback-textarea { width:100%; background:rgba(255,255,255,0.8); border:1.5px solid rgba(108,43,217,0.1); border-radius:9px; padding:8px 12px; font-family:'Space Mono',monospace; font-size:.75rem; color:#1e293b; outline:none; resize:none; line-height:1.5; transition:border-color .2s,box-shadow .2s; }
        .dark .feedback-textarea { background:rgba(0,0,0,0.25); border-color:rgba(255,255,255,0.1); color:#e2e8f0; }
        .feedback-textarea:focus { border-color:#6C2BD9; box-shadow:0 0 0 3px rgba(108,43,217,0.1); }
        .feedback-submit-row { display:flex; align-items:center; justify-content:space-between; margin-top:8px; gap:8px; flex-wrap:wrap; }
        .feedback-char-count { font-family:'Space Mono',monospace; font-size:9px; color:#94a3b8; }
        .feedback-submit-btn { padding:6px 14px; border-radius:8px; cursor:pointer; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; background:linear-gradient(135deg,#6C2BD9,#7c3aed); color:#fff; border:none; box-shadow:0 3px 10px rgba(108,43,217,0.3); transition:all .2s; }
        .feedback-submit-btn:hover { opacity:.88; transform:translateY(-1px); }
        .feedback-submit-btn:disabled { opacity:.5; cursor:not-allowed; transform:none; }
        .feedback-thanks { padding:10px 14px 12px; font-family:'Space Mono',monospace; font-size:.75rem; color:#16A34A; display:flex; align-items:center; gap:8px; }
        .dark .feedback-thanks { color:#4ade80; }
        .feedback-report-badge { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:99px; font-size:9px; font-weight:700; background:rgba(245,158,11,0.1); color:#d97706; border:1px solid rgba(245,158,11,0.2); font-family:'Space Mono',monospace; text-transform:uppercase; letter-spacing:.04em; }
        .dark .feedback-report-badge { color:#f59e0b; }

        /* ── Auto-regen warning ───────────────────────────────────────────── */
        .regen-warning { border-radius:12px; padding:12px 16px; margin-bottom:16px; border:1.5px solid rgba(245,158,11,0.3); background:rgba(245,158,11,0.06); display:flex; align-items:flex-start; gap:10px; animation:termReveal .4s ease; }
        .dark .regen-warning { background:rgba(245,158,11,0.08); }
        .regen-warning-icon { font-size:18px; flex-shrink:0; margin-top:1px; }
        .regen-warning-text { flex:1; min-width:0; }
        .regen-warning-title { font-family:'Poppins',sans-serif; font-size:.82rem; font-weight:700; color:#d97706; margin-bottom:4px; }
        .dark .regen-warning-title { color:#fbbf24; }
        .regen-warning-body { font-family:'Space Mono',monospace; font-size:.72rem; color:#64748b; line-height:1.5; }
        .regen-warning-btns { display:flex; gap:6px; margin-top:8px; flex-wrap:wrap; }
        .regen-btn-yes { padding:5px 12px; border-radius:7px; cursor:pointer; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; background:#d97706; color:#fff; border:none; transition:all .2s; }
        .regen-btn-yes:hover { background:#b45309; }
        .regen-btn-no { padding:5px 12px; border-radius:7px; cursor:pointer; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; background:rgba(108,43,217,0.06); color:#64748b; border:1px solid rgba(108,43,217,0.1); transition:all .2s; }
        .dark .regen-btn-no { background:rgba(255,255,255,0.06); border-color:rgba(255,255,255,0.1); color:#94a3b8; }
        .regen-btn-no:hover { border-color:rgba(108,43,217,0.3); color:#6C2BD9; }

        /* ── Source card ─────────────────────────────────────────────────── */
        .source-card { border-left:3px solid #6C2BD9; border-radius:12px; transition:transform .25s,box-shadow .25s; }
        .source-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(108,43,217,0.12); }

        /* ── Toast ───────────────────────────────────────────────────────── */
        .toast { position:fixed; left:50%; transform:translateX(-50%); bottom:24px; background:rgba(15,23,42,0.95); color:#f1f5f9; padding:10px 18px; border-radius:10px; font-size:13px; z-index:500; border:1px solid rgba(255,255,255,0.1); backdrop-filter:blur(10px); animation:termReveal .3s ease forwards; font-family:'Inter',sans-serif; white-space:nowrap; }

        /* ── Confirm modal ───────────────────────────────────────────────── */
        #confirm-modal { position:fixed; inset:0; z-index:300; background:rgba(0,0,0,0.55); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; padding:1rem; }
        #confirm-modal.open { display:flex; }
        #confirm-modal-box { background:#fff; border-radius:20px; padding:2rem; max-width:380px; width:100%; box-shadow:0 24px 60px rgba(0,0,0,0.2); border:1px solid rgba(108,43,217,0.1); animation:termReveal .3s ease; }
        .dark #confirm-modal-box { background:#0f172a; border-color:rgba(255,255,255,0.08); }

        /* ── Image preview ───────────────────────────────────────────────── */
        #img-preview-strip { display:none; align-items:center; gap:10px; padding:8px 16px; border-top:1px solid rgba(108,43,217,0.08); background:rgba(108,43,217,0.02); }
        .dark #img-preview-strip { border-top-color:rgba(255,255,255,0.05); background:rgba(108,43,217,0.05); }
        #img-preview-strip.visible { display:flex; }
        #preview-thumb { width:48px; height:48px; object-fit:cover; border-radius:8px; border:2px solid rgba(108,43,217,0.3); flex-shrink:0; }

        /* ── State transitions ───────────────────────────────────────────── */
        .state-section { transition:opacity .3s ease; }
        .gsap-entry { opacity:0; transform:translateY(16px); }

        /* ── Action bar ──────────────────────────────────────────────────── */
        .action-bar-btn { display:flex; align-items:center; gap:6px; padding:8px 14px; border-radius:10px; border:1.5px solid rgba(108,43,217,0.12); background:#ffffff; color:#6C2BD9; font-size:.8rem; font-weight:600; font-family:'Inter',sans-serif; transition:all .25s; cursor:pointer; box-shadow:0 1px 4px rgba(108,43,217,0.06); }
        .dark .action-bar-btn { background:rgba(15,23,42,0.7); border-color:rgba(255,255,255,0.08); color:#94a3b8; }
        .action-bar-btn:hover { border-color:rgba(108,43,217,0.4); color:#6C2BD9; transform:translateY(-1px); box-shadow:0 4px 12px rgba(108,43,217,0.15); }

        /* ── Definition text ─────────────────────────────────────────────── */
        .def-text { font-size:.88rem; color:#475569; line-height:1.7; border-bottom:1px solid rgba(108,43,217,0.07); padding-bottom:14px; margin-bottom:16px; }
        .dark .def-text { color:#94a3b8; border-bottom-color:rgba(255,255,255,0.06); }

        /* ── Tip banner ──────────────────────────────────────────────────── */
        .tip-banner { display:flex; align-items:center; gap:8px; padding:8px 14px; border-radius:10px; margin-top:12px; background:rgba(108,43,217,0.06); border:1px solid rgba(108,43,217,0.12); font-size:.72rem; color:#64748b; font-family:'Inter',sans-serif; }
        .dark .tip-banner { background:rgba(108,43,217,0.07); }

        /* ── Chip pop ────────────────────────────────────────────────────── */
        @keyframes chipPop { 0%{transform:scale(1.18) translateY(-3px);}60%{transform:scale(.96) translateY(0);}100%{transform:scale(1) translateY(0);} }
        .chip-pop { animation:chipPop .3s ease; }

        /* ── Output header light ──────────────────────────────────────────── */
        html:not(.dark) .glass.rounded-t-2xl { background:#ffffff; border-color:rgba(108,43,217,0.1); }
        html:not(.dark) #ui-state-output .glass { box-shadow:0 2px 16px rgba(108,43,217,0.06); }

        /* ── Nav light ────────────────────────────────────────────────────── */
        html:not(.dark) nav.glass { background:rgba(255,255,255,0.95); border-bottom:1px solid rgba(108,43,217,0.08) !important; box-shadow:0 1px 20px rgba(108,43,217,0.06); }

        /* ── Responsive ──────────────────────────────────────────────────── */
        @media (max-width:380px) { .grid.grid-cols-2 { grid-template-columns:1fr; } }
        @media (max-width:480px) {
            .word-chip { padding:6px 10px 6px 7px; font-size:.88rem; border-radius:9px; }
            .mnemonic-hero { padding:14px; }
            .concept-box-body { padding:10px 12px; }
            .result-card { border-radius:16px; padding:14px !important; }
            .dnd-zone { min-width:58px; min-height:62px; border-radius:12px; }
            .dnd-drop-zones { gap:6px; padding:10px 12px; }
            .dnd-bank-chip { padding:8px 10px; min-width:52px; }
            .dnd-chip-bank { gap:6px; padding:8px 12px 14px; }
        }
        @media (max-width:360px) {
            #btn-camera span, #btn-upload span { display:none; }
