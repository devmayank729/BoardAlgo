        @media (max-width:1023px) {
            #source-matrix-container { display:flex; flex-wrap:nowrap; overflow-x:auto; gap:10px; padding-bottom:4px; -webkit-overflow-scrolling:touch; }
            #source-matrix-container .source-card { min-width:180px; flex-shrink:0; margin-bottom:0 !important; }
        }
    </style>
</head>

<body class="antialiased min-h-screen flex flex-col relative">

