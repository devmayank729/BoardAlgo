    // ════════════════════════════════════════════════════════════════════
    // MNEMONIC SECTION BUILDER
    // ════════════════════════════════════════════════════════════════════
    function buildMnemonicSection(json, heroMode, labelColor, labelIcon, defaultLabel, cardEl) {
        const wrap = document.createElement('div'); wrap.className = 'mnemonic-section-wrap';
        const hero = document.createElement('div'); hero.className = 'mnemonic-hero'; hero.dataset.mode = heroMode;
        wrap.appendChild(hero);
        const hl=document.createElement('div'); hl.className='mnemonic-label-row'; hl.style.color=labelColor;
        hl.innerHTML=`<i data-lucide="${labelIcon}" class="w-3 h-3"></i> ${json.hook_label||defaultLabel}`;
        hero.appendChild(hl);
        if(json.hook_context){ const ctx=document.createElement('p'); ctx.className='hook-context-text'; ctx.textContent=json.hook_context; hero.appendChild(ctx); }
        const hasChips=Array.isArray(json.word_chips)&&json.word_chips.length>0;

        if(hasChips){
            if(json.acronym_key){
                const ar=document.createElement('div'); ar.className='acronym-badge-row';
                const al=document.createElement('span'); al.className='acronym-row-label'; al.style.color=labelColor; al.textContent='Key →';
                ar.appendChild(al);
                [...json.acronym_key].forEach(l=>{ const p=document.createElement('span'); p.className='acronym-letter-pill'; p.textContent=l; ar.appendChild(p); });
                hero.appendChild(ar);
            }
            const chipsContainer=document.createElement('div'); chipsContainer.className='word-chips-container';
            let revealedCount=0; const totalChips=json.word_chips.length;
            const scoreBarWrap=document.createElement('div');
            scoreBarWrap.innerHTML=`<div class="test-score-bar"><div class="test-score-fill"></div></div><div class="test-score-label" style="display:none;"><span>Tap each word to reveal</span><span class="test-score-pct">0 / ${totalChips}</span></div>`;

            json.word_chips.forEach((cd,idx)=>{
                const chip=document.createElement('div'); chip.className='word-chip';
                chip.innerHTML=`<span class="chip-key-letter">${cd.letter||'?'}</span><span class="chip-rest-word">${cd.rest||''}</span>`;
                chip.style.opacity='0'; chip.style.transform='translateY(10px)';
                setTimeout(()=>{ chip.style.transition='opacity .3s ease,transform .3s ease'; chip.style.opacity='1'; chip.style.transform='translateY(0)'; },60+idx*40);
                chip.addEventListener('click',()=>{
                    if(chipsContainer.classList.contains('test-mode')){
                        if(!chip.classList.contains('chip-revealed')){ chip.classList.add('chip-revealed','chip-pop'); setTimeout(()=>chip.classList.remove('chip-pop'),300); revealedCount++; const pct=Math.round(revealedCount/totalChips*100); const f=scoreBarWrap.querySelector('.test-score-fill'); if(f) f.style.width=pct+'%'; const pl=scoreBarWrap.querySelector('.test-score-pct'); if(pl) pl.textContent=`${revealedCount} / ${totalChips}`; if(revealedCount===totalChips){ G.tests++; saveG(); updateStatStrip(); gainXP(25,'Test passed'); triggerAchievement('first_test'); if(G.tests>=5) triggerAchievement('five_tests'); triggerAchievement('perfect_test'); setTimeout(()=>{ const r=chip.getBoundingClientRect(); fireConfetti(r.left,r.top); showToast('Memory locked! +25 XP',2800); showMemoryStrength(cardEl,100); chipsContainer.querySelectorAll('.word-chip').forEach(c=>c.classList.add('chip-locked')); },200); } }
                    } else {
                        chipsContainer.querySelectorAll('.chip-tooltip').forEach(t=>t.remove()); chipsContainer.querySelectorAll('.word-chip.chip-active').forEach(c=>c.classList.remove('chip-active'));
                        if(!chip.classList.contains('chip-active')){ const mt=(cd.maps_to&&cd.maps_to.trim())?cd.maps_to:`${cd.letter} — see decode`; const tt=document.createElement('div'); tt.className='chip-tooltip'; tt.innerHTML=`<span style="font-weight:700;color:${labelColor};">${cd.letter}</span>&nbsp;→&nbsp;${mt}`; chip.appendChild(tt); chip.classList.add('chip-active'); setTimeout(()=>{ tt.remove(); chip.classList.remove('chip-active'); },3500); }
                    }
                });
                chipsContainer.appendChild(chip);
            });
            hero.appendChild(chipsContainer);
            if(json.hook_text){ const s=document.createElement('p'); s.className='mnemonic-full-sentence'; s.textContent=json.hook_text; hero.appendChild(s); }

            const testRow=document.createElement('div'); testRow.style.cssText='display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:4px;position:relative;z-index:1;';
            const testBtn=document.createElement('button'); testBtn.className='test-mode-btn'; testBtn.type='button'; testBtn.innerHTML=`<i data-lucide="brain-circuit" class="w-3 h-3"></i> Test Me`;
            const tiphint=document.createElement('span'); tiphint.style.cssText='font-family:Space Mono,monospace;font-size:9px;color:#94a3b8;letter-spacing:.04em;'; tiphint.textContent='tap any word · reveal mapping';
            testRow.appendChild(testBtn); testRow.appendChild(tiphint); hero.appendChild(testRow); hero.appendChild(scoreBarWrap);

            // ════════════════════════════════════════════════════════════════════
            // DND GAME — Redesigned
            // ════════════════════════════════════════════════════════════════════
            const dndGame = document.createElement('div');
            dndGame.className = 'dnd-game hidden';
            dndGame.dataset.mode = heroMode;

            // Header
            const dndHeader = document.createElement('div'); dndHeader.className = 'dnd-header';
            const dndHeaderLeft = document.createElement('div'); dndHeaderLeft.className = 'dnd-header-left';
            const dndTitleEl = document.createElement('div'); dndTitleEl.className = 'dnd-title';
            dndTitleEl.innerHTML = `<span class="dnd-title-dot"></span> MEMORY TEST`;
            const dndScoreWrap = document.createElement('div'); dndScoreWrap.className = 'dnd-score-wrap';
            dndScoreWrap.innerHTML = `<div class="dnd-progress-track"><div class="dnd-progress-fill"></div></div><span class="dnd-score-text"><span class="dnd-score-cur">0</span><span class="dnd-score-total"> / ${totalChips}</span></span>`;
            dndHeaderLeft.appendChild(dndTitleEl); dndHeaderLeft.appendChild(dndScoreWrap);
            const dndExitBtn = document.createElement('button'); dndExitBtn.className = 'dnd-exit-btn'; dndExitBtn.type = 'button';
            dndExitBtn.innerHTML = `<i data-lucide="x" style="width:11px;height:11px;"></i> Exit`;
            dndHeader.appendChild(dndHeaderLeft); dndHeader.appendChild(dndExitBtn); dndGame.appendChild(dndHeader);

            // Instruction
            const dndInstr = document.createElement('p'); dndInstr.className = 'dnd-instr';
            dndInstr.textContent = window.innerWidth < 640 ? 'Tap a word chip, then tap its letter slot' : 'Drag each word chip to its matching letter slot';
            dndGame.appendChild(dndInstr);

            // Drop zones
            const dropZonesRow = document.createElement('div'); dropZonesRow.className = 'dnd-drop-zones';
            const dropZones = [];
            json.word_chips.forEach((cd, idx) => {
                const z = document.createElement('div'); z.className = 'dnd-zone'; z.dataset.idx = idx; z.dataset.mode = heroMode;
                // Letter label above zone
                const zLetterLabel = document.createElement('div'); zLetterLabel.className = 'dnd-zone-letter-label'; zLetterLabel.textContent = cd.letter || '?';
                // Placeholder box
                const zPlaceholder = document.createElement('div'); zPlaceholder.className = 'dnd-zone-placeholder';
                const zPlaceholderLetter = document.createElement('span'); zPlaceholderLetter.className = 'dnd-zone-placeholder-letter'; zPlaceholderLetter.textContent = cd.letter || '?';
                zPlaceholder.appendChild(zPlaceholderLetter);
                z.appendChild(zLetterLabel); z.appendChild(zPlaceholder);
                dropZonesRow.appendChild(z); dropZones.push(z);
            });
            dndGame.appendChild(dropZonesRow);

            // Separator
            const sep = document.createElement('div'); sep.className = 'dnd-separator'; dndGame.appendChild(sep);

            // Bank label
            const bankLabel = document.createElement('div'); bankLabel.className = 'dnd-chip-bank-label';
            bankLabel.innerHTML = `<i data-lucide="hand" style="width:11px;height:11px;opacity:.5;"></i> WORD BANK — drag to match`;
            dndGame.appendChild(bankLabel);

            // Chip bank
            const chipBank = document.createElement('div'); chipBank.className = 'dnd-chip-bank';
            const shuffled = [...Array(totalChips).keys()].sort(() => Math.random() - .5);
            const bankChips = [];
            shuffled.forEach(idx => {
                const cd = json.word_chips[idx];
                const bc = document.createElement('div');
                bc.className = 'dnd-bank-chip'; bc.dataset.idx = idx; bc.dataset.mode = heroMode; bc.draggable = true;
                // Key letter label + full word
                bc.innerHTML = `<span class="dnd-chip-key">${cd.letter || '?'}</span><span class="dnd-chip-word">${(cd.letter||'') + (cd.rest||'')}</span>`;
                chipBank.appendChild(bc); bankChips[idx] = bc;
            });
            dndGame.appendChild(chipBank);

            let dndCorrect = 0, selectedBankChip = null;
            const progressFill = dndGame.querySelector('.dnd-progress-fill');

            function updateDndProgress() {
                if (progressFill) progressFill.style.width = Math.round((dndCorrect / totalChips) * 100) + '%';
                const scoreEl = dndGame.querySelector('.dnd-score-cur'); if (scoreEl) scoreEl.textContent = dndCorrect;
            }

            function placedCorrect(zone, bc) {
                const idx = parseInt(bc.dataset.idx); const cd = json.word_chips[idx];
                zone.innerHTML = '';
                zone.classList.add('dnd-zone-correct');
                const fi = document.createElement('div'); fi.className = `dnd-zone-filled dnd-zone-filled-${heroMode}`;
                const keySpan = document.createElement('span'); keySpan.className = 'dnd-chip-key-display'; keySpan.textContent = cd.letter || '';
                const wordSpan = document.createElement('span'); wordSpan.className = 'dnd-filled-word'; wordSpan.textContent = (cd.letter||'')+(cd.rest||'');
                const checkSpan = document.createElement('span'); checkSpan.className = 'dnd-check-icon'; checkSpan.textContent = '✓';
                fi.appendChild(keySpan); fi.appendChild(wordSpan); fi.appendChild(checkSpan);
                zone.appendChild(fi);
                bc.classList.add('dnd-bank-placed'); bc.draggable = false;
                dndCorrect++; selectedBankChip = null;
                document.querySelectorAll('.dnd-bank-chip.dnd-selected').forEach(c => c.classList.remove('dnd-selected'));
                updateDndProgress();

                if (dndCorrect === totalChips) {
                    setTimeout(() => {
                        G.tests++; saveG(); updateStatStrip(); gainXP(25, 'Test passed');
                        triggerAchievement('first_test'); if (G.tests >= 5) triggerAchievement('five_tests'); triggerAchievement('perfect_test');
                        const r = dndGame.getBoundingClientRect(); fireConfetti(r.left + r.width / 2, r.top + r.height / 2);
                        showToast('🎯 Perfect recall! +25 XP', 2800); showMemoryStrength(cardEl, 100);
                        dndGame.classList.add('dnd-complete');
                        const cm = document.createElement('div'); cm.className = 'dnd-complete-msg';
                        cm.innerHTML = `<span>🎯</span><strong>Perfect recall!</strong><span style="opacity:.7;">All ${totalChips} words mapped correctly.</span>`;
                        dndGame.appendChild(cm);
                    }, 300);
                }
            }

            function placedWrong(z) {
                z.classList.add('dnd-zone-wrong'); setTimeout(() => z.classList.remove('dnd-zone-wrong'), 600);
                // Brief red flash
                z.style.borderColor = '#ef4444';
                setTimeout(() => { z.style.borderColor = ''; }, 700);
            }

            function tryPlace(z, bc) {
                if (!bc || bc.classList.contains('dnd-bank-placed')) return;
                if (z.classList.contains('dnd-zone-correct')) return;
                parseInt(z.dataset.idx) === parseInt(bc.dataset.idx) ? placedCorrect(z, bc) : placedWrong(z);
            }

            // Drag events
            let draggedChip = null;
            chipBank.addEventListener('dragstart', e => {
                const c = e.target.closest('.dnd-bank-chip'); if (!c || c.classList.contains('dnd-bank-placed')) { e.preventDefault(); return; }
                draggedChip = c; c.classList.add('dnd-dragging'); e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', c.dataset.idx);
            });
            chipBank.addEventListener('dragend', e => { e.target.classList.remove('dnd-dragging'); draggedChip = null; });
            dropZonesRow.addEventListener('dragover', e => { e.preventDefault(); const z = e.target.closest('.dnd-zone'); if (z && !z.classList.contains('dnd-zone-correct')) z.classList.add('dnd-zone-hover'); });
            dropZonesRow.addEventListener('dragleave', e => { const z = e.target.closest('.dnd-zone'); if (z) z.classList.remove('dnd-zone-hover'); });
            dropZonesRow.addEventListener('drop', e => { e.preventDefault(); const z = e.target.closest('.dnd-zone'); if (!z) return; z.classList.remove('dnd-zone-hover'); tryPlace(z, bankChips[parseInt(e.dataTransfer.getData('text/plain'))]); });

            // Click-to-place
            chipBank.addEventListener('click', e => {
                const c = e.target.closest('.dnd-bank-chip'); if (!c || c.classList.contains('dnd-bank-placed')) return;
                if (selectedBankChip === c) { c.classList.remove('dnd-selected'); selectedBankChip = null; }
                else { document.querySelectorAll('.dnd-bank-chip.dnd-selected').forEach(b => b.classList.remove('dnd-selected')); c.classList.add('dnd-selected'); selectedBankChip = c; }
            });
            dropZonesRow.addEventListener('click', e => {
                const z = e.target.closest('.dnd-zone'); if (!z || z.classList.contains('dnd-zone-correct')) return;
                if (!selectedBankChip) { z.classList.add('dnd-zone-hint'); setTimeout(() => z.classList.remove('dnd-zone-hint'), 500); return; }
                tryPlace(z, selectedBankChip);
            });

            // Touch drag
            let touchDragChip = null, touchClone = null;
            chipBank.addEventListener('touchstart', e => {
                const c = e.target.closest('.dnd-bank-chip'); if (!c || c.classList.contains('dnd-bank-placed')) return;
                touchDragChip = c; c.classList.add('dnd-dragging');
                touchClone = document.createElement('div'); touchClone.className = 'dnd-touch-clone';
                touchClone.innerHTML = c.innerHTML;
                document.body.appendChild(touchClone);
                const t = e.touches[0]; touchClone.style.left = t.clientX - 50 + 'px'; touchClone.style.top = t.clientY - 28 + 'px';
            }, { passive: true });
            document.addEventListener('touchmove', e => {
                if (!touchClone) return;
                const t = e.touches[0]; touchClone.style.left = t.clientX - 50 + 'px'; touchClone.style.top = t.clientY - 28 + 'px';
                touchClone.style.display = 'none'; const el = document.elementFromPoint(t.clientX, t.clientY); touchClone.style.display = '';
                const z = el && el.closest('.dnd-zone'); document.querySelectorAll('.dnd-zone.dnd-zone-hover').forEach(dz => dz.classList.remove('dnd-zone-hover'));
                if (z && !z.classList.contains('dnd-zone-correct')) z.classList.add('dnd-zone-hover');
            }, { passive: true });
            document.addEventListener('touchend', e => {
                if (!touchDragChip || !touchClone) return; touchClone.remove(); touchClone = null; touchDragChip.classList.remove('dnd-dragging');
                const t = e.changedTouches[0]; const el = document.elementFromPoint(t.clientX, t.clientY); const z = el && el.closest('.dnd-zone');
                document.querySelectorAll('.dnd-zone.dnd-zone-hover').forEach(dz => dz.classList.remove('dnd-zone-hover'));
                if (z) tryPlace(z, touchDragChip); touchDragChip = null;
            }, { passive: true });

            testBtn.addEventListener('click', () => {
                const activating = !dndGame.classList.contains('dnd-active');
                if (activating) {
                    chipsContainer.style.display = 'none'; const fs = hero.querySelector('.mnemonic-full-sentence'); if (fs) fs.style.display = 'none'; const ab = hero.querySelector('.acronym-badge-row'); if (ab) ab.style.display = 'none'; scoreBarWrap.style.display = 'none'; tiphint.style.display = 'none';
                    dndGame.classList.remove('hidden'); dndGame.classList.add('dnd-active');
                    testBtn.innerHTML = `<i data-lucide="eye" class="w-3 h-3"></i> Show Mnemonic`; testBtn.classList.add('active');
                    lucide.createIcons();
                } else {
                    chipsContainer.style.display = ''; const fs = hero.querySelector('.mnemonic-full-sentence'); if (fs) fs.style.display = ''; const ab = hero.querySelector('.acronym-badge-row'); if (ab) ab.style.display = ''; scoreBarWrap.style.display = ''; tiphint.style.display = '';
                    dndGame.classList.remove('dnd-active'); dndGame.classList.add('hidden');
                    testBtn.innerHTML = `<i data-lucide="brain-circuit" class="w-3 h-3"></i> Test Me`; testBtn.classList.remove('active');
                    lucide.createIcons();
                }
            });
            dndExitBtn.addEventListener('click', () => testBtn.click());
            wrap._dndGame = dndGame;
            lucide.createIcons();

        } else {
            const ht = document.createElement('p');
            ht.className = 'hook-text text-xl md:text-2xl font-display font-bold text-slate-900 dark:text-white leading-snug mb-4';
            ht.innerHTML = mdBold(json.hook_text || '');
            hero.appendChild(ht);
        }

        // Decode section
        const subtext = (json.hook_subtext || '').trim();
        if (hasChips || subtext.length > 0) {
            const dc = document.createElement('div'); dc.className = 'decode-content-wrapper collapsed-decode';
            if (hasChips) {
                const mg = document.createElement('div'); mg.className = 'decode-map-grid';
                json.word_chips.forEach(cd => {
                    const row = document.createElement('div'); row.className = 'decode-map-row';
                    const badge = document.createElement('div'); badge.className = 'decode-letter-badge'; badge.dataset.mode = heroMode; badge.textContent = cd.letter || '?';
                    const tp = document.createElement('div'); tp.className = 'decode-row-text';
                    const wl = document.createElement('span'); wl.className = 'decode-word-label'; wl.textContent = (cd.letter || '') + (cd.rest || '');
                    const ar = document.createElement('span'); ar.className = 'decode-arrow'; ar.textContent = ' → ';
                    const mn = document.createElement('span'); mn.className = 'decode-meaning'; mn.textContent = (cd.maps_to && cd.maps_to.trim()) ? cd.maps_to : `${cd.letter} — tap chip above`;
                    tp.appendChild(wl); tp.appendChild(ar); tp.appendChild(mn); row.appendChild(badge); row.appendChild(tp); mg.appendChild(row);
                });
                dc.appendChild(mg);
                const fn = document.createElement('p'); fn.className = 'decode-full-text';
                fn.innerHTML = subtext ? mdBold(subtext) : json.word_chips.map(c => `[${c.letter}]${c.rest} = ${c.maps_to || c.letter}`).join('  ·  ');
                dc.appendChild(fn);
            } else {
                const mw = document.createElement('div'); mw.className = 'mapping-strip';
                const ml = document.createElement('p'); ml.style.cssText = `font-family:'Space Mono',monospace;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:${labelColor};display:flex;align-items:center;gap:5px;margin-bottom:8px;`;
                ml.innerHTML = `<i data-lucide="arrow-right" class="w-3 h-3"></i> How it maps`;
                const st = document.createElement('p'); st.style.cssText = 'font-family:Space Mono,monospace;font-size:.75rem;line-height:1.7;color:#475569;';
                st.innerHTML = mdBold(subtext); mw.appendChild(ml); mw.appendChild(st); dc.appendChild(mw);
            }
            const dt = document.createElement('button'); dt.className = 'decode-toggle-btn'; dt.type = 'button'; dt.dataset.open = 'false';
            dt.innerHTML = `<i data-lucide="lock" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Unlock the Decode</span><span class="decode-toggle-hint">tap to reveal →</span>`;
            wrap.appendChild(dt); wrap.appendChild(dc);
            dt.addEventListener('click', () => {
                const open = dt.dataset.open === 'true';
                if (!open) { dc.classList.remove('collapsed-decode'); dt.dataset.open = 'true'; dt.innerHTML = `<i data-lucide="lock-open" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Hide Decode</span>`; }
                else { dc.classList.add('collapsed-decode'); dt.dataset.open = 'false'; dt.innerHTML = `<i data-lucide="lock" class="w-3.5 h-3.5" style="flex-shrink:0;"></i><span>Unlock the Decode</span><span class="decode-toggle-hint">tap to reveal →</span>`; }
                lucide.createIcons();
            });
        }
        return wrap;
    }

    // ── Mode selection ─────────────────────────────────────────────────────────
    function setMode(mode){
        currentMode=mode; modeInput.value=mode;
        const isDark = html.classList.contains('dark');
        // Unselected colors differ per theme — dark needs visible borders/backgrounds
        const unselBorder = isDark ? 'rgba(255,255,255,0.09)' : 'rgba(0,0,0,0.08)';
        const unselBg     = isDark ? 'rgba(255,255,255,0.04)' : '#fafbff';
        const unselRadio  = isDark ? 'rgba(255,255,255,0.2)'  : 'rgba(0,0,0,0.2)';

        btnLore.style.borderColor = mode==='lore' ? '#6C2BD9'  : unselBorder;
        btnLore.style.background  = mode==='lore' ? 'rgba(108,43,217,0.1)' : unselBg;
        btnHack.style.borderColor = mode==='hack' ? '#16A34A'  : unselBorder;
        btnHack.style.background  = mode==='hack' ? 'rgba(22,163,74,0.08)' : unselBg;

        const ld=btnLore.querySelector('.mode-radio div'),hd=btnHack.querySelector('.mode-radio div');
        btnLore.querySelector('.mode-radio').style.borderColor = mode==='lore' ? '#6C2BD9' : unselRadio;
        btnHack.querySelector('.mode-radio').style.borderColor = mode==='hack' ? '#16A34A' : unselRadio;
        if(ld) ld.classList.toggle('hidden',mode!=='lore');
        if(hd) hd.classList.toggle('hidden',mode!=='hack');
        btnLore.setAttribute('aria-checked',mode==='lore');
        btnHack.setAttribute('aria-checked',mode==='hack');
        btnGenerate.style.background  = mode==='hack' ? 'linear-gradient(135deg,#16A34A,#15803d)' : 'linear-gradient(135deg,#6C2BD9,#7c3aed)';
        btnGenerate.style.boxShadow   = mode==='hack' ? '0 4px 20px rgba(22,163,74,0.4)' : '0 4px 20px rgba(108,43,217,0.4)';
    }
    btnLore.addEventListener('click',()=>setMode('lore'));
    btnHack.addEventListener('click',()=>setMode('hack'));
    setMode('lore');

    // ── Deep scan ──────────────────────────────────────────────────────────────
    btnDeepScan.addEventListener('click',()=>{
        isDeepScan=!isDeepScan; deepScanInput.value=isDeepScan?'true':'false'; btnDeepScan.setAttribute('aria-pressed',isDeepScan);
        if(isDeepScan){ btnDeepScan.classList.add('active'); deepscanTrack.style.background='#16A34A'; deepscanTrack.style.borderColor='#16A34A'; deepscanKnob.style.left='20px'; deepscanKnob.style.background='#fff'; deepscanIcon.style.color='#4ade80'; }
        else { btnDeepScan.classList.remove('active'); deepscanTrack.style.background='rgba(0,0,0,0.08)'; deepscanTrack.style.borderColor='rgba(0,0,0,0.1)'; deepscanKnob.style.left='2px'; deepscanKnob.style.background='#94a3b8'; deepscanIcon.style.color=''; }
    });

    // ── Language ───────────────────────────────────────────────────────────────
    const LANG_META={english:{badge:'🇬🇧 EN',desc:'Full English — precise, clean, board-exam ready.'},hinglish:{badge:'🔀 HE',desc:'Hindi + English mix — the way toppers actually talk.'},hindi:{badge:'🇮🇳 HI',desc:'Pure Hindi — best if you memorize in Hindi.'}};
    document.querySelectorAll('.lang-btn').forEach(btn=>{ btn.addEventListener('click',()=>{ document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); currentLanguage=btn.dataset.lang; languageInput.value=currentLanguage; langDescText.textContent=LANG_META[currentLanguage].desc; }); });

    // ── Image upload & Paste handler ───────────────────────────────────────────
    btnUpload.addEventListener('click',()=>fileInput.click()); btnCamera.addEventListener('click',()=>showToast('📷 Camera capture coming soon'));
    function loadImageFile(file){ if(!file) return; if(file.size>5*1024*1024){ showToast('❌ Image too large — max 5MB'); fileInput.value=''; return; } const r=new FileReader(); r.onload=e=>{ imageBase64=e.target.result; previewThumb.src=imageBase64; previewFilename.textContent=file.name; previewFilesize.textContent=formatBytes(file.size); imgStrip.classList.add('visible'); btnUpload.style.borderColor='#6C2BD9'; btnUpload.style.color='#6C2BD9'; }; r.readAsDataURL(file); }
    fileInput.addEventListener('change',()=>loadImageFile(fileInput.files&&fileInput.files[0]));
    function clearImage(){ imageBase64=null; fileInput.value=''; previewThumb.src=''; previewFilename.textContent=''; previewFilesize.textContent=''; imgStrip.classList.remove('visible'); btnUpload.style.borderColor=''; btnUpload.style.color=''; }
    btnRemoveImg.addEventListener('click',clearImage);
    
    window.addEventListener('paste',e=>{ 
        if(!e.clipboardData) return; 
        for(const it of e.clipboardData.items){ 
            if(it.type&&it.type.startsWith('image/')){ 
                e.preventDefault(); 
                const blob=it.getAsFile(); 
                if(!blob) continue; 
                if(blob.size>5*1024*1024){ showToast('❌ Too large — max 5MB'); return; } 
                const file = new File([blob], "Screenshot-pasted.png", { type: blob.type });
                const dt=new DataTransfer(); 
                dt.items.add(file); 
                fileInput.files=dt.files; 
                loadImageFile(file); 
                return; 
            } 
        } 
    });
    
    textarea.addEventListener('input',function(){ this.style.height='auto'; this.style.height=Math.max(130,this.scrollHeight)+'px'; });

    // ── Processing terminal ────────────────────────────────────────────────────
    const TERMINAL={
        lore:[{t:'> Reading your concept...',c:'#94a3b8',d:0},{t:'> Mapping to your learning profile...',c:'#a78bfa',d:700},{t:'> Constructing narrative arc...',c:'#94a3b8',d:1500},{t:'> Planting memory anchors...',c:'#a78bfa',d:2600},{t:'> Finalizing lore sequence...',c:'#94a3b8',d:4000}],
        hack:[{t:'> Extracting concept signal...',c:'#94a3b8',d:0},{t:'> Compressing to minimum viable mnemonic...',c:'#4ade80',d:500},{t:'> Building letter chips...',c:'#94a3b8',d:1200},{t:'> Neural hack ready. Encoding...',c:'#4ade80',d:2000}],
        deep:[{t:'> Deep Scan activated...',c:'#60a5fa',d:0},{t:'> Cross-referencing NCERT index...',c:'#94a3b8',d:700},{t:'> Pulling chapter references...',c:'#60a5fa',d:1600},{t:'> Validating accuracy...',c:'#94a3b8',d:2800},{t:'> Building citation-backed hook...',c:'#60a5fa',d:4200}],
    };
    let termTimers=[];
    function runTerminal(lines){ terminalLog.innerHTML=''; termTimers.forEach(clearTimeout); termTimers=[]; lines.forEach(({t,c,d})=>{ const tid=setTimeout(()=>{ const el=document.createElement('div'); el.className='terminal-line'; el.style.color=c; el.textContent=t; terminalLog.appendChild(el); terminalLog.scrollTop=terminalLog.scrollHeight; },d); termTimers.push(tid); }); }
    function startProgress(fast){ clearInterval(progTimer); let p=15; progTimer=setInterval(()=>{ if(p<78){ p+=Math.random()*(fast?10:5); if(p>78)p=78; progressBar.style.width=Math.floor(p)+'%'; } },fast?280:480); }
    function stopProgress(){ clearInterval(progTimer); progTimer=null; }

    // ── Render output ──────────────────────────────────────────────────────────
    function renderOutput(rawData, mode, deepScan, language, interactionId) {
        const items=Array.isArray(rawData)?rawData:[rawData]; if(!items.length) return;
        if(deepScan){ outputModeBadge.textContent='Deep Scan'; outputModeBadge.className='badge badge-deep'; }
        else if(mode==='hack'){ outputModeBadge.textContent='Neural Hack'; outputModeBadge.className='badge badge-hack'; }
        else { outputModeBadge.textContent='Lore Engine'; outputModeBadge.className='badge badge-lore'; }
        outputLangBadge.textContent=(LANG_META[language]||LANG_META.english).badge;
        const heroMode=deepScan?'deep':mode;
        const titleColor=deepScan?'#2563eb':(mode==='hack'?'#16A34A':'#6C2BD9');
        const labelColor=deepScan?'#60a5fa':(mode==='hack'?'#4ade80':'#a78bfa');
        const labelIcon=deepScan?'scan-search':(mode==='hack'?'zap':'book-open');
        const defaultLabel=deepScan?'Deep Scan Result:':(mode==='lore'?'Lore Engine Narrative:':'Neural Hack Mnemonic:');
        aiItems.innerHTML='';
        let currentQuestion = textarea.value.trim();
        if (!currentQuestion && window.__INJECTED_RESULT__) {
            currentQuestion = window.__INJECTED_RESULT__.user_query_text || '(unknown)';
        } else if (!currentQuestion) {
            currentQuestion = '(unknown)';
        }
        items.forEach((json,idx)=>{
            const card=document.createElement('div'); card.className='result-card p-4 sm:p-6';
            card.style.cssText=`opacity:0;transform:translateY(14px);transition:opacity .45s ease ${idx*0.12}s,transform .45s cubic-bezier(0.34,1.3,0.64,1) ${idx*0.12}s;`;
            if(items.length>1){ const ph=document.createElement('div'); ph.style.cssText='display:flex;align-items:center;margin-bottom:12px;'; const pl=document.createElement('div'); pl.className='part-label'; pl.innerHTML=`<i data-lucide="layers" class="w-3 h-3"></i> Part ${idx+1} of ${items.length}`; ph.appendChild(pl); card.appendChild(ph); }
            const te=document.createElement('div'); te.className='text-base sm:text-lg font-display font-bold mb-3'; te.style.color=titleColor; te.textContent=json.title||'Result'; card.appendChild(te);
            if(json.definition){ const def=document.createElement('p'); def.className='def-text'; def.textContent=json.definition; card.appendChild(def); }
            const cc=json.concept_content||json.learn_box; const ccEl=buildConceptContent(cc); if(ccEl) card.appendChild(ccEl);
            if(json.hook_text){ const mnWrap=buildMnemonicSection(json,heroMode,labelColor,labelIcon,defaultLabel,card); card.appendChild(mnWrap); if(mnWrap._dndGame) mnWrap.appendChild(mnWrap._dndGame); }
            if(idx===0&&Array.isArray(json.word_chips)&&json.word_chips.length>0){ const tip=document.createElement('div'); tip.className='tip-banner'; tip.innerHTML=`<i data-lucide="lightbulb" class="w-3.5 h-3.5 flex-shrink-0" style="color:#a78bfa;"></i> Tap any word chip for its mapping. Hit <strong style="color:#6C2BD9;">Test Me</strong> to earn +25 XP.`; card.appendChild(tip); }
            if(interactionId){ const fp=buildFeedbackPanel(interactionId,currentQuestion,mode,card); card.appendChild(fp); }
            aiItems.appendChild(card);
            requestAnimationFrame(()=>requestAnimationFrame(()=>{ card.style.opacity='1'; card.style.transform='translateY(0)'; }));
        });
        lucide.createIcons();
        G.locked++; saveG(); updateStatStrip(); gainXP(15,'Hook generated');
        if(G.locked===1) triggerAchievement('first_hook'); if(G.locked===5) triggerAchievement('five_hooks'); if(deepScan) triggerAchievement('deep_scan');
        setTimeout(()=>fireConfetti(),350);
        const allSources=items.flatMap(j=>j.source_matrix||[]);
        if(allSources.length){
            let h=`<div class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-gray-500 flex items-center gap-2 mb-3 px-1" style="font-family:'Space Mono',monospace;"><i data-lucide="database" class="w-3 h-3"></i> NCERT References</div>`;
            allSources.forEach((s,i)=>{ const ac=i%2===0?'#6C2BD9':'#16A34A'; const ic=s.icon_type==='file'?'file-text':'book-open'; h+=`<div class="source-card glass p-3 mb-3" style="border-left-color:${ac};"><div class="flex items-start justify-between gap-2 mb-2"><p class="text-xs font-semibold text-slate-800 dark:text-slate-200 leading-tight">${s.title||'Source'}</p><span class="text-[10px] font-bold whitespace-nowrap px-1.5 py-0.5 rounded flex-shrink-0" style="color:${ac};background:rgba(108,43,217,0.08);border:1px solid rgba(108,43,217,0.15);">${s.match_percentage||''}</span></div><div class="flex items-center gap-1.5 text-slate-400"><i data-lucide="${ic}" class="w-3.5 h-3.5"></i><span class="text-[11px]">${ic==='file-text'?'Board Paper':'NCERT Chapter'}</span></div></div>`; });
            sourceMatrix.innerHTML=h; lucide.createIcons();
        } else { sourceMatrix.innerHTML=''; }
    }

    // ── Form submit ────────────────────────────────────────────────────────────
    form.addEventListener('submit',async(ev)=>{
        ev.preventDefault(); const q=textarea.value.trim(); if(!q){ showToast('Please type what you want to memorize'); return; }
        if(shouldWarnRepeat(q,currentMode)){
            const altMode=getAlternateMode(currentMode); const altLabel=altMode==='hack'?'Neural Hack':'Lore Engine';
            const warn=document.createElement('div'); warn.className='regen-warning';
            warn.innerHTML=`<div class="regen-warning-icon">🔄</div><div class="regen-warning-text"><div class="regen-warning-title">You tried this before with ${currentMode==='lore'?'Lore Engine':'Neural Hack'}!</div><div class="regen-warning-body">Same mode = same result. Switch to <strong>${altLabel}</strong> for a fresh perspective?</div><div class="regen-warning-btns"><button class="regen-btn-yes" id="repeat-yes">Switch to ${altLabel} →</button><button class="regen-btn-no" id="repeat-no">Keep same mode</button></div></div>`;
            switchState(stateIdle,stateOutput); aiItems.innerHTML=''; sourceMatrix.innerHTML=''; aiItems.appendChild(warn);
            await new Promise(resolve=>{ warn.querySelector('#repeat-yes').addEventListener('click',()=>{ setMode(altMode); warn.remove(); resolve('alt'); }); warn.querySelector('#repeat-no').addEventListener('click',()=>{ warn.remove(); resolve('same'); }); });
            if(stateOutput.contains(aiItems)&&!aiItems.children.length) switchState(stateOutput,stateIdle);
        }
        const isFast=currentMode==='hack'&&!isDeepScan; const lines=isDeepScan?TERMINAL.deep:(currentMode==='hack'?TERMINAL.hack:TERMINAL.lore);
        procTitle.textContent=isDeepScan?'Running Deep Scan...':(currentMode==='hack'?'Hacking your concept...':'Crafting your lore...');
        procSubtitle.textContent=isDeepScan?'Deep Scan · NCERT Cross-Reference':(currentMode==='hack'?'Neural Hack · Compression Mode':'Lore Engine · Narrative Mode');
        runTerminal(lines); progressBar.style.width='15%'; startProgress(isFast);
        stateProc.setAttribute('aria-busy','true'); switchState(stateIdle,stateProc);
        const payload={question:q,mode:currentMode,deepScan:isDeepScan,language:currentLanguage,image:imageBase64};
        ctrl=new AbortController();
        try{
            const res=await fetch(form.action,{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(payload),signal:ctrl.signal});
            progressBar.style.width='88%';
            if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.error||`Server error ${res.status}`); }
            const json=await res.json(); stopProgress(); progressBar.style.width='100%';
            recordQuestion(q,currentMode); lastInteractionId=json._id||null;
            renderOutput(json.initial_ai_response||json,currentMode,isDeepScan,currentLanguage,lastInteractionId);
            stateProc.setAttribute('aria-busy','false'); switchState(stateProc,stateOutput);
        } catch(err){
            stopProgress(); progressBar.style.width='0%'; stateProc.setAttribute('aria-busy','false'); switchState(stateProc,stateIdle);
            if(err.name==='AbortError') showToast('Cancelled.'); else { showToast('❌ '+(err.message||'Something went wrong.')); console.error(err); }
        } finally { ctrl=null; termTimers.forEach(clearTimeout); termTimers=[]; }
    });

    btnCancel.addEventListener('click',()=>{ if(ctrl) ctrl.abort(); stateProc.setAttribute('aria-busy','false'); switchState(stateProc,stateIdle); stopProgress(); progressBar.style.width='0%'; });
    btnReset.addEventListener('click',()=>{ form.reset(); clearImage(); aiItems.innerHTML=''; sourceMatrix.innerHTML=''; progressBar.style.width='0%'; switchState(stateOutput,stateIdle); setMode('lore'); textarea.focus(); });
    btnCopy.addEventListener('click',()=>{ const txt=aiItems.innerText||''; if(!txt) return showToast('Nothing to copy yet'); navigator.clipboard.writeText(txt).then(()=>showToast('✓ Copied to clipboard')); });
    btnSave.addEventListener('click',()=>{ const txt=aiItems.innerText||''; if(!txt) return showToast('Nothing to save yet'); const blob=new Blob([txt],{type:'text/plain'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='boardalgo-mnemonic.txt'; a.click(); });
    document.getElementById('btn-bookmark').addEventListener('click',()=>showToast('📌 Bookmark feature coming soon'));
    textarea.addEventListener('keydown',e=>{ if((e.ctrlKey||e.metaKey)&&e.key==='Enter') btnGenerate.click(); });

    // ── Reconfig modal ─────────────────────────────────────────────────────────
    btnReconfig.addEventListener('click',()=>{ confirmModal.classList.add('open'); document.body.style.overflow='hidden'; });
    function closeConfirmModal(){ confirmModal.classList.remove('open'); document.body.style.overflow=''; }
    modalCancelBtn.addEventListener('click',closeConfirmModal);
    confirmModal.addEventListener('click',e=>{ if(e.target===confirmModal) closeConfirmModal(); });
    modalConfirmBtn.addEventListener('click',async()=>{ modalConfirmBtn.textContent='Resetting...'; modalConfirmBtn.disabled=true; try{ await fetch('/api/user/reset-behaviour',{method:'POST',credentials:'include'}); window.location.href='/dashboard'; }catch(e){ showToast('❌ Reset failed. Try again.'); modalConfirmBtn.textContent='Yes, Reset It'; modalConfirmBtn.disabled=false; closeConfirmModal(); } });

    gsap.to('.gsap-entry',{y:0,opacity:1,stagger:.1,duration:.55,ease:'power2.out',delay:.05});

    // ── Three.js background ────────────────────────────────────────────────────
    let threeParticles,threeRenderer;
    function updateThreeColors(){ if(!threeParticles) return; threeParticles.material.color.set(html.classList.contains('dark')?0x6C2BD9:0x6C2BD9); threeParticles.material.opacity=html.classList.contains('dark')?.6:.12; }
    (function(){
        const canvas=document.getElementById('bg-canvas'); threeRenderer=new THREE.WebGLRenderer({canvas,alpha:true}); const scene=new THREE.Scene(),camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,1000); threeRenderer.setSize(innerWidth,innerHeight); threeRenderer.setPixelRatio(Math.min(devicePixelRatio,2));
        const count=1500,pos=new Float32Array(count*3); for(let i=0;i<count*3;i++) pos[i]=(Math.random()-.5)*20;
        const geo=new THREE.BufferGeometry(); geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
        const mat=new THREE.PointsMaterial({size:.025,color:0x6C2BD9,transparent:true,opacity:.4});
        threeParticles=new THREE.Points(geo,mat); scene.add(threeParticles); camera.position.z=4;
        let mx=0,my=0;
        document.addEventListener('mousemove',e=>{ mx=e.clientX/innerWidth-.5; my=e.clientY/innerHeight-.5; });
        document.addEventListener('touchmove',e=>{ if(e.touches.length){ mx=e.touches[0].clientX/innerWidth-.5; my=e.touches[0].clientY/innerHeight-.5; } },{passive:true});
        (function animate(){ requestAnimationFrame(animate); threeParticles.rotation.y+=.0005+mx*.002; threeParticles.rotation.x+=.0002+my*.001; threeRenderer.render(scene,camera); })();
        window.addEventListener('resize',()=>{ camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix(); threeRenderer.setSize(innerWidth,innerHeight); });
        updateThreeColors();
    })();

    // ── Injected result loader (history) ──────────────────────────────────────
    (function(){
        if(!window.__INJECTED_RESULT__) return;
        const saved=window.__INJECTED_RESULT__; const raw=saved.initial_ai_response||saved; const mode=saved.generation_mode||'lore'; const deep=saved.deep_scan_enabled||false; const lang=saved.language||'english';
        currentMode=mode; isDeepScan=deep; currentLanguage=lang; setMode(mode); if(deep) btnDeepScan.click();
        document.querySelectorAll('.lang-btn').forEach(b=>{ b.classList.toggle('active',b.dataset.lang===lang); });
        languageInput.value=lang; langDescText.textContent=(LANG_META[lang]||LANG_META.english).desc;
        renderOutput(raw,mode,deep,lang,saved._id||null); switchState(stateIdle,stateOutput);
    })();
    </script>
    <script src="/js/tracking.js" defer></script>
</body>
</html>