    const XP_LEVELS=[0,50,130,250,420,650,950,1350,1900,2600,3500];
    function getLevel(xp){ let l=1; for(let i=1;i<XP_LEVELS.length;i++){ if(xp>=XP_LEVELS[i]) l=i+1; else break; } return Math.min(l,XP_LEVELS.length); }
    function getLevelXP(xp){ const l=getLevel(xp),base=XP_LEVELS[l-1],next=XP_LEVELS[l]||XP_LEVELS[XP_LEVELS.length-1]+1000; return {base,next,pct:Math.round((xp-base)/(next-base)*100)}; }
    function saveG(){ sessionStorage.setItem('ba_xp',G.xp); sessionStorage.setItem('ba_locked',G.locked); sessionStorage.setItem('ba_tests',G.tests); sessionStorage.setItem('ba_ach',JSON.stringify(G.achievements)); localStorage.setItem('ba_streak',G.streak); localStorage.setItem('ba_lastday',G.lastDay); localStorage.setItem('ba_reports',G.reportCount); }
