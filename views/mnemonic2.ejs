    function showAchievement(icon,title,sub){ const el=document.createElement('div'); el.className='achievement-banner'; el.innerHTML=`<div class="achieve-icon">${icon}</div><div><div class="achieve-title">${title}</div><div class="achieve-sub">ACHIEVEMENT UNLOCKED · ${sub.toUpperCase()}</div></div>`; document.body.appendChild(el); setTimeout(()=>{ el.style.transition='opacity .5s ease,transform .5s ease'; el.style.opacity='0'; el.style.transform='translateX(30px)'; setTimeout(()=>el.remove(),500); },3500); }

    // Streak
    (function(){
