    <main class="flex-grow pt-20 pb-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6">

            <div class="gsap-entry text-center pt-8 pb-6">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-4 text-xs font-semibold" style="background:rgba(108,43,217,0.08);border:1px solid rgba(108,43,217,0.2);color:#6C2BD9;">
