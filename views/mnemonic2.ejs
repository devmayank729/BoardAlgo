<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BoardAlgo | Memory Synthesizer</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/mhchem.min.js"></script>

    <script>
        window.__INJECTED_RESULT__ = <%- typeof savedSolution !== "undefined" ? JSON.stringify(savedSolution) : "null" %>;
    </script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { brand: { black:'#020617', surface:'#0f172a', border:'#1e293b', primary:'#6C2BD9', accent:'#16A34A' } },
                    fontFamily: { sans:['Inter','sans-serif'], display:['Poppins','sans-serif'], mono:['Space Mono','monospace'] }
                }
            }
        }
    </script>

    <style>
        /* ── Reset ───────────────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; }

        /* ════════════════════════════════════════════════════════════════════
           LIGHT MODE — Complete overhaul
        ════════════════════════════════════════════════════════════════════ */
        body {
            background-color: #f0f4ff;
            background-image:
                radial-gradient(ellipse 70% 50% at 20% 10%, rgba(108,43,217,0.06) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 90%, rgba(22,163,74,0.05) 0%, transparent 60%);
            color: #0f172a;
            transition: background-color .3s, color .3s;
            overflow-x: hidden;
        }
        .dark body {
            background-color: #020617;
            background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(108,43,217,0.12), transparent);
            color: #f8fafc;
        }

        /* ── Glass — light mode is now a real card ────────────────────────── */
        .glass {
            background: #ffffff;
            border: 1px solid rgba(108,43,217,0.1);
            box-shadow: 0 2px 16px rgba(108,43,217,0.06), 0 1px 4px rgba(0,0,0,0.04);
            transition: all .3s ease;
        }
        .dark .glass {
            background: rgba(15,23,42,0.72);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            box-shadow: none;
        }

        /* ── Scrollbar ───────────────────────────────────────────────────── */
        ::-webkit-scrollbar { width:6px; height:6px; }
        ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background:rgba(108,43,217,0.25); border-radius:3px; }

        /* ── Glow dot ────────────────────────────────────────────────────── */
        .glow-dot { width:7px; height:7px; border-radius:50%; background:#16A34A; box-shadow:0 0 6px #16A34A; display:inline-block; animation:dotpulse 2s ease-in-out infinite; flex-shrink:0; }
        @keyframes dotpulse { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:.55;transform:scale(.82);} }

        /* ── Avatar ring ─────────────────────────────────────────────────── */
        .avatar-ring { background:conic-gradient(#6C2BD9 0%,#a78bfa 45%,#16A34A 70%,#6C2BD9 100%); border-radius:50%; padding:2px; display:inline-flex; flex-shrink:0; }
        .avatar-inner { border-radius:50%; overflow:hidden; display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:700; }

        /* ── Nav buttons ─────────────────────────────────────────────────── */
        .logout-btn { display:flex; align-items:center; gap:6px; padding:7px 13px; border-radius:9px; border:1px solid rgba(239,68,68,0.28); background:rgba(239,68,68,0.07); color:#f87171; font-size:.8rem; font-weight:500; text-decoration:none; font-family:'Inter',sans-serif; transition:all .2s; }
        .logout-btn:hover { background:rgba(239,68,68,0.15); border-color:rgba(239,68,68,0.45); }
        .reconfig-btn { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:8px; font-size:.75rem; font-weight:600; border:1px solid rgba(239,68,68,0.22); background:rgba(239,68,68,0.05); color:#f87171; cursor:pointer; font-family:'Inter',sans-serif; transition:all .2s; }
        .reconfig-btn:hover { background:rgba(239,68,68,0.12); border-color:rgba(239,68,68,0.4); }

        /* ── Input ───────────────────────────────────────────────────────── */
        #brain-dump { outline:none; resize:none; caret-color:#6C2BD9; line-height:1.6; }
        .input-shell { border: 1.5px solid rgba(108,43,217,0.15) !important; }
        .input-shell:focus-within { border-color:rgba(108,43,217,0.5)!important; box-shadow:0 0 0 3px rgba(108,43,217,0.1),0 0 30px rgba(108,43,217,0.08); }
        html:not(.dark) #brain-dump { color: #1e293b; }
        html:not(.dark) #brain-dump::placeholder { color: #94a3b8; }

        /* ── Mode buttons ─────────────────────────────────────────────────── */
        /* Light: explicit white-ish background so buttons never go transparent */
        html:not(.dark) .mode-btn { background: #fafbff; }
        /* Dark: glass card — must be explicit or browser renders native white button */
        .dark .mode-btn {
            background: rgba(255,255,255,0.04) !important;
            border-color: rgba(255,255,255,0.09) !important;
        }
        /* Mode radio circle default — JS overrides on selection */
        .mode-btn .mode-radio { border-color: rgba(0,0,0,0.2); }
        .dark .mode-btn .mode-radio { border-color: rgba(255,255,255,0.22); }

        /* ── Deep scan btn ───────────────────────────────────────────────── */
        .deepscan-btn { border:1.5px solid rgba(108,43,217,0.12); transition:all .3s ease; }
        .dark .deepscan-btn { border-color:rgba(255,255,255,0.1); }
        .deepscan-btn.active { border-color:#16A34A!important; background:rgba(22,163,74,0.08)!important; box-shadow:0 0 20px rgba(22,163,74,0.2); }

        /* ── Lang pill ───────────────────────────────────────────────────── */
        .lang-track { display:flex; background:rgba(108,43,217,0.05); border:1.5px solid rgba(108,43,217,0.1); border-radius:10px; padding:3px; gap:2px; }
        .dark .lang-track { background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.08); }
        .lang-btn { flex:1; padding:6px 8px; border-radius:7px; border:none; cursor:pointer; font-family:'Inter',sans-serif; font-size:.72rem; font-weight:600; transition:all .25s; white-space:nowrap; background:transparent; color:#64748b; }
        .dark .lang-btn { color:#94a3b8; }
        .lang-btn.active { background:#6C2BD9; color:#fff; box-shadow:0 2px 10px rgba(108,43,217,0.4); }
        .lang-btn:not(.active):hover { background:rgba(108,43,217,0.08); color:#6C2BD9; }

        /* ── Generate button ─────────────────────────────────────────────── */
        .gen-btn { background:linear-gradient(135deg,#6C2BD9,#7c3aed); box-shadow:0 4px 20px rgba(108,43,217,0.4); transition:all .3s cubic-bezier(.34,1.56,.64,1); position:relative; overflow:hidden; }
        .gen-btn::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,0.15),transparent); border-radius:inherit; }
        .gen-btn:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(108,43,217,0.55); }
        .gen-btn:active { transform:scale(.97); }

        /* ── Processing rings ────────────────────────────────────────────── */
        #ui-state-processing { background:#ffffff; }
        .dark #ui-state-processing { background:rgba(2,6,23,0.92); backdrop-filter:blur(20px); }
        .ring-outer { border:2px solid rgba(108,43,217,0.15); animation:spin 8s linear infinite; }
        .ring-mid   { border:2px solid transparent; border-top-color:#6C2BD9; animation:spin 1.1s linear infinite; }
        .ring-inner { border:1px solid rgba(108,43,217,0.3); border-top-color:rgba(108,43,217,0.6); animation:spin .7s linear infinite reverse; }
        @keyframes spin { to { transform:rotate(360deg); } }

        /* ── Terminal ────────────────────────────────────────────────────── */
        .terminal-line { opacity:0; transform:translateY(6px); animation:termReveal .35s ease forwards; }
        @keyframes termReveal { to { opacity:1; transform:translateY(0); } }

        /* ── Progress bar ────────────────────────────────────────────────── */
        #progress-bar { transition:width .5s ease; background:linear-gradient(90deg,#6C2BD9,#a855f7,#16A34A); background-size:200% 100%; animation:barShift 2s linear infinite; }
        @keyframes barShift { 0%{background-position:0 0;}100%{background-position:-200% 0;} }

        /* ── XP Bar ──────────────────────────────────────────────────────── */
        .xp-bar-wrap { display:flex; align-items:center; gap:7px; padding:4px 10px; border-radius:8px; background:rgba(108,43,217,0.06); border:1px solid rgba(108,43,217,0.14); }
        .xp-bar-track { width:60px; height:4px; border-radius:2px; background:rgba(108,43,217,0.15); overflow:hidden; }
        .xp-bar-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,#6C2BD9,#a855f7); transition:width .6s cubic-bezier(.34,1.3,.64,1); }
        .xp-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; color:#a78bfa; letter-spacing:.06em; white-space:nowrap; }
        .level-badge { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; padding:2px 6px; border-radius:4px; letter-spacing:.04em; background:rgba(108,43,217,0.14); color:#a78bfa; border:1px solid rgba(108,43,217,0.25); }

        /* ── Stats strip ─────────────────────────────────────────────────── */
        .stats-strip { display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:8px 16px; border-bottom:1px solid rgba(108,43,217,0.07); background:rgba(108,43,217,0.02); }
        .dark .stats-strip { background:rgba(0,0,0,0.2); border-bottom-color:rgba(255,255,255,0.04); }
        .stat-item { display:flex; align-items:center; gap:4px; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; color:#64748b; letter-spacing:.04em; }
        .dark .stat-item { color:#475569; }
        .stat-item .stat-val { color:#6C2BD9; }
        .dark .stat-item .stat-val { color:#a78bfa; }
        .stat-divider { width:1px; height:12px; background:rgba(108,43,217,0.1); flex-shrink:0; }
        .dark .stat-divider { background:rgba(255,255,255,0.07); }

        /* ── XP pop + Achievement ────────────────────────────────────────── */
        .xp-gain-pop { position:fixed; right:20px; bottom:80px; z-index:600; display:flex; align-items:center; gap:8px; padding:10px 16px; border-radius:12px; background:rgba(108,43,217,0.92); color:#fff; font-family:'Space Mono',monospace; font-size:12px; font-weight:700; box-shadow:0 8px 30px rgba(108,43,217,0.45); border:1px solid rgba(255,255,255,0.15); animation:xpPopIn .4s cubic-bezier(.34,1.56,.64,1) forwards; backdrop-filter:blur(10px); }
        @keyframes xpPopIn { from{opacity:0;transform:translateY(16px) scale(.9);}to{opacity:1;transform:translateY(0) scale(1);} }
        .achievement-banner { position:fixed; top:72px; right:16px; z-index:600; display:flex; align-items:center; gap:10px; padding:12px 16px; border-radius:14px; max-width:300px; background:rgba(15,23,42,0.96); border:1px solid rgba(108,43,217,0.3); box-shadow:0 12px 40px rgba(0,0,0,0.4); animation:achieveIn .45s cubic-bezier(.34,1.3,.64,1) forwards; backdrop-filter:blur(14px); }
        @keyframes achieveIn { from{opacity:0;transform:translateX(30px);}to{opacity:1;transform:translateX(0);} }
        .achieve-icon { width:36px; height:36px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:18px; background:rgba(108,43,217,0.15); border:1px solid rgba(108,43,217,0.25); }
        .achieve-title { font-family:'Poppins',sans-serif; font-size:.78rem; font-weight:700; color:#e2e8f0; margin-bottom:2px; }
        .achieve-sub   { font-family:'Space Mono',monospace; font-size:9px; color:#64748b; letter-spacing:.04em; }

        /* ── Memory strength ─────────────────────────────────────────────── */
        .memory-strength-wrap { display:flex; align-items:center; gap:10px; padding:10px 14px; border-radius:10px; margin-top:12px; background:rgba(22,163,74,0.05); border:1px solid rgba(22,163,74,0.15); }
        .ms-label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#16A34A; white-space:nowrap; }
        .ms-track { flex:1; height:5px; border-radius:3px; background:rgba(22,163,74,0.15); overflow:hidden; }
        .ms-fill  { height:100%; border-radius:3px; background:linear-gradient(90deg,#16A34A,#4ade80); width:0%; transition:width 1.2s cubic-bezier(.34,1.3,.64,1); }
        .ms-pct   { font-family:'Space Mono',monospace; font-size:10px; font-weight:700; color:#16A34A; white-space:nowrap; }

        /* ── Badges ──────────────────────────────────────────────────────── */
        .badge { display:inline-flex; align-items:center; gap:3px; padding:2px 8px; border-radius:99px; font-size:.68rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; }
        .badge-lore { background:rgba(108,43,217,0.12); color:#7c3aed; border:1px solid rgba(108,43,217,0.25); }
        .dark .badge-lore { color:#a78bfa; }
        .badge-hack { background:rgba(22,163,74,0.1);  color:#16a34a; border:1px solid rgba(22,163,74,0.2); }
        .dark .badge-hack { color:#4ade80; }
        .badge-deep { background:rgba(59,130,246,0.1); color:#2563eb; border:1px solid rgba(59,130,246,0.2); }
        .dark .badge-deep { color:#60a5fa; }
        .streak-pill { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:99px; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; letter-spacing:.04em; background:rgba(251,191,36,0.1); color:#d97706; border:1px solid rgba(251,191,36,0.2); }
        .dark .streak-pill { color:#f59e0b; }

        /* ── Result card ─────────────────────────────────────────────────── */
        .result-card { border:1px solid rgba(108,43,217,0.12); border-radius:20px; transition:border-color .3s,box-shadow .3s; position:relative; overflow:hidden; background:#ffffff; box-shadow:0 4px 24px rgba(108,43,217,0.07), 0 1px 6px rgba(0,0,0,0.04); }
        .dark .result-card { background:rgba(15,23,42,0.7); box-shadow:none; }
        .result-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,transparent,rgba(108,43,217,0.5),rgba(22,163,74,0.3),transparent); }
        .result-card:hover { border-color:rgba(108,43,217,0.3); box-shadow:0 12px 40px rgba(108,43,217,0.12); }
        .dark .result-card:hover { box-shadow:0 12px 40px rgba(108,43,217,0.1); }
        .part-label { font-family:'Space Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:#7c3aed; display:flex; align-items:center; gap:6px; }
        .dark .part-label { color:#a78bfa; }

        /* ════════════════════════════════════════════════════════════════════
           CONCEPT BOX — improved light mode
        ════════════════════════════════════════════════════════════════════ */
        .concept-box { border-radius:14px; overflow:hidden; margin-bottom:20px; border:1px solid rgba(108,43,217,0.1); background:#fafbff; }
        .dark .concept-box { background:rgba(8,10,22,0.6); border-color:rgba(255,255,255,0.07); }
        .concept-box-header { display:flex; align-items:center; justify-content:space-between; padding:9px 14px; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.09em; border-bottom:1px solid rgba(108,43,217,0.08); }
        .dark .concept-box-header { border-bottom-color:rgba(255,255,255,0.06); }
        .concept-box[data-type="formula"] .concept-box-header,
        .concept-box[data-type="table"] .concept-box-header { color:#2563eb; background:rgba(59,130,246,0.06); border-bottom-color:rgba(59,130,246,0.12); }
        .dark .concept-box[data-type="formula"] .concept-box-header,
        .dark .concept-box[data-type="table"] .concept-box-header { color:#60a5fa; background:rgba(59,130,246,0.08); }
        .concept-box[data-type="reaction"] .concept-box-header,
        .concept-box[data-type="steps"] .concept-box-header { color:#15803d; background:rgba(22,163,74,0.06); border-bottom-color:rgba(22,163,74,0.12); }
        .dark .concept-box[data-type="reaction"] .concept-box-header,
        .dark .concept-box[data-type="steps"] .concept-box-header { color:#4ade80; background:rgba(22,163,74,0.08); }
        .concept-box[data-type="list"] .concept-box-header,
        .concept-box[data-type="statement"] .concept-box-header { color:#6C2BD9; background:rgba(108,43,217,0.06); border-bottom-color:rgba(108,43,217,0.12); }
        .dark .concept-box[data-type="list"] .concept-box-header,
        .dark .concept-box[data-type="statement"] .concept-box-header { color:#a78bfa; background:rgba(108,43,217,0.08); }
        .concept-box-body { padding:14px 16px; }

        /* ════════════════════════════════════════════════════════════════════
           LATEX — FIX: proper rendering, proper styling
        ════════════════════════════════════════════════════════════════════ */
        .latex-render { display:flex; flex-direction:column; gap:6px; }
        .latex-line {
            padding:10px 12px;
            overflow-x:auto;
            border-bottom:1px solid rgba(0,0,0,0.04);
            -webkit-overflow-scrolling:touch;
            border-radius:8px;
            background:rgba(59,130,246,0.03);
        }
        .latex-line:last-child { border-bottom:none; }
        .dark .latex-line { border-bottom-color:rgba(255,255,255,0.04); background:rgba(59,130,246,0.06); }
        .latex-render .katex { font-size:1.1rem!important; }
        .latex-render .katex-display { margin:0; overflow-x:auto; overflow-y:hidden; }

        /* Light mode KaTeX — dark text */
        html:not(.dark) .latex-render .katex { color: #1e293b !important; }
        html:not(.dark) .latex-render .katex .mord,
        html:not(.dark) .latex-render .katex .mop,
        html:not(.dark) .latex-render .katex .mrel,
        html:not(.dark) .latex-render .katex .mopen,
        html:not(.dark) .latex-render .katex .mclose,
        html:not(.dark) .latex-render .katex .mpunct,
        html:not(.dark) .latex-render .katex .minner,
        html:not(.dark) .latex-render .katex span { color:#1e293b !important; }
        html:not(.dark) .latex-render .katex .frac-line { background:#1e293b !important; }
        html:not(.dark) .latex-render .katex svg path { fill:#1e293b !important; }
        html:not(.dark) .latex-render .katex .rule { background:#1e293b !important; }

        /* Dark mode KaTeX — light text */
        .dark .latex-render .katex { color:#e2e8f0 !important; }
        .dark .latex-render .katex .mord,
        .dark .latex-render .katex .mop,
        .dark .latex-render .katex .mrel,
        .dark .latex-render .katex .mopen,
        .dark .latex-render .katex .mclose,
        .dark .latex-render .katex .mpunct,
        .dark .latex-render .katex .minner,
        .dark .latex-render .katex span { color:#e2e8f0 !important; }
        .dark .latex-render .katex .frac-line { background:#e2e8f0 !important; }
        .dark .latex-render .katex svg path { fill:#e2e8f0 !important; }
        .dark .latex-render .katex .rule { background:#e2e8f0 !important; }

        /* Formula fallback plain text — better styled */
        .formula-plain-fallback {
            font-family: 'Space Mono', monospace;
            font-size: .92rem;
            line-height: 1.8;
            color: #1e293b;
            padding: 10px 14px;
            background: rgba(59,130,246,0.04);
            border-radius: 8px;
            border-left: 3px solid #3b82f6;
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .dark .formula-plain-fallback { color:#e2e8f0; background:rgba(59,130,246,0.08); }

        .plain-toggle-btn { display:inline-flex; align-items:center; gap:5px; padding:3px 9px; border-radius:7px; cursor:pointer; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; border:none; background:rgba(108,43,217,0.06); color:#6C2BD9; transition:all .2s; }
        .dark .plain-toggle-btn { background:rgba(255,255,255,0.06); color:#94a3b8; }
        .plain-toggle-btn:hover { background:rgba(108,43,217,0.12); color:#6C2BD9; }
        .cc-list { display:flex; flex-direction:column; gap:3px; }
        .cc-item { display:flex; align-items:center; gap:10px; padding:5px 8px; border-radius:7px; transition:background .15s; }
        .cc-item:hover { background:rgba(108,43,217,0.05); }
        .dark .cc-item:hover { background:rgba(108,43,217,0.1); }
        .cc-num { width:20px; height:20px; border-radius:6px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-family:'Space Mono',monospace; font-size:9px; font-weight:700; background:rgba(108,43,217,0.1); color:#6C2BD9; }
        .dark .cc-num { background:rgba(108,43,217,0.18); color:#a78bfa; }
        .cc-text { font-family:'Space Mono',monospace; font-size:.78rem; color:#1e293b; line-height:1.5; }
        .dark .cc-text { color:#e2e8f0; }
        .cc-steps { display:flex; flex-direction:column; gap:5px; }
