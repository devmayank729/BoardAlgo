<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | BOARD Algo</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            black: '#020617', 
                            surface: '#0f172a',
                            border: '#1e293b',
                            primary: '#6366f1',
                            accent: '#8b5cf6',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            color: #f8fafc;
        }
        
        .glass-input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
        }
        .glass-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

        .mesh-bg {
            background-color: #020617;
            background-image: radial-gradient(at 100% 100%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 0% 0%, hsla(225,39%,30%,1) 0, transparent 50%);
        }
    </style>
</head>
<body class="h-screen w-full flex overflow-hidden mesh-bg">

<script src="https://accounts.google.com/gsi/client" async defer></script>  

    <div class="hidden lg:flex w-1/2 relative items-center justify-center p-12">
        <div class="absolute inset-0 bg-brand-surface/30 backdrop-blur-sm"></div>
        
        <div class="relative z-10 max-w-lg">
            <a href="/" class="flex items-center gap-3 mb-12">
                <img src="logo.png" alt="XCEED" class="h-8 w-auto object-contain hidden" onerror="this.style.display='none'">
                <span class="text-3xl font-display font-bold tracking-tight text-white">BOARD <span class="text-brand-primary">Algo</span></span>
            </a>

            <h1 class="text-5xl font-display font-bold leading-tight mb-6 text-white">
                Welcome Back, <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Future Topper.</span>
            </h1>
            <p class="text-lg text-slate-400 mb-8 leading-relaxed">
                Your personalized question bank is ready. Let's get that score up.
            </p>

            <div class="w-full h-48 border border-brand-primary/30 rounded-2xl bg-gradient-to-b from-brand-primary/10 to-transparent flex items-center justify-center relative overflow-hidden">
                 <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
                 <div class="text-center z-10">
                     <div class="text-xs font-mono text-brand-primary mb-2 animate-pulse">SYSTEM STATUS</div>
                     <div class="text-2xl font-bold text-white">Online</div>
                 </div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 relative z-20 bg-brand-black/80 backdrop-blur-xl border-l border-white/5">
        <div class="w-full max-w-md space-y-8">
            
            <div class="lg:hidden text-center mb-8">
                <span class="text-2xl font-display font-bold tracking-tight text-white">BOARD <span class="text-brand-primary">Algo</span></span>
            </div>

            <div class="text-center lg:text-left">
                <h2 class="text-3xl font-display font-bold text-white">Log in</h2>
                <p class="text-slate-400 mt-2 text-sm">Enter your credentials to access the dashboard.</p>
            </div>

            <button id="custom-google-btn" class="w-full flex items-center justify-center gap-3 bg-white text-brand-black font-bold py-3 px-4 rounded-xl hover:bg-slate-200 transition-colors">
                <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.17c-.22-.66-.35-1.36-.35-2.17s.13-1.51.35-2.17V7.01H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.99l3.66-2.82z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.01l3.66 2.82c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Continue with Google
            </button>

            <div class="relative">
                <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-white/10"></span></div>
                <div class="relative flex justify-center text-xs uppercase"><span class="bg-brand-black px-2 text-slate-500">Or log in with email</span></div>
            </div>
            
            <% if (locals.message) { %>
                <% 
                    let msgColor = locals.color || 'green'; 
                    let borderColor = msgColor === 'red' ? 'border-red-500/30' : 'border-green-500/30';
                    let bgColor = msgColor === 'red' ? 'bg-red-500/10' : 'bg-green-500/10';
                    let textColor = msgColor === 'red' ? 'text-red-400' : 'text-green-400';
                    let iconType = msgColor === 'red' ? 'alert-circle' : 'check-circle-2';
                %>
                <div id="dynamic-message" class="p-4 rounded-xl border <%= borderColor %> <%= bgColor %> flex items-start gap-3 transition-all">
                    <i data-lucide="<%= iconType %>" class="w-5 h-5 <%= textColor %> shrink-0 mt-0.5"></i>
                    <p class="text-sm <%= textColor %> font-medium leading-relaxed">
                        <%= message %>
                    </p>
                </div>
            <% } %>

            <form class="space-y-5" method="post" action="/loginsubmit">
                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Email</label>
                    <input type="email" placeholder="student@example.com" name="email" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600">
                </div>

                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Password</label>
                        <a href="/forgot/password" class="text-xs text-brand-primary hover:text-white transition-colors">Forgot password?</a>
                    </div>
                    <input type="password" name="password" placeholder="••••••••" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600">
                </div>

                <button type="submit" class="w-full bg-brand-primary hover:bg-indigo-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all transform hover:-translate-y-0.5">
                    Log In
                </button>
            </form>

            <p class="text-center text-sm text-slate-500">
                Don't have an account? 
                <a href="/signup" class="text-brand-primary font-bold hover:text-white transition-colors">Sign Up</a>
            </p>
        </div>
    </div>
    

<script>
  window.onload = function () {
    // Initialize the Google Client to ONLY ask for basic profile info
    const client = google.accounts.oauth2.initTokenClient({
        
      client_id: '142684388060-j6ttjg7iru88tq3nalg7lc0uo0j0e323.apps.googleusercontent.com', 

      scope: 'email profile', // This guarantees NO access to Drive/Gmail
      callback: (response) => {
        if (response.access_token) {
          // Send this secure proof to your backend
          verifyUserWithBackend(response.access_token);
        }
      },
    });

    document.getElementById('custom-google-btn').addEventListener('click', () => {
      client.requestAccessToken();
    });
  };

  async function verifyUserWithBackend(token) {
    try {
      const res = await fetch('http://localhost:3000/api/auth/google', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: token })
      });
      
      const data = await res.json();
        if (data.success) 
        {
        window.location = data.redirect;
        }
    } 
    catch (error) {
      console.error("Login failed:", error);
    }
  }
</script>

    <script>
        lucide.createIcons();
    </script>

    <script src="/js/tracking.js" defer></script>
</body>
</html>