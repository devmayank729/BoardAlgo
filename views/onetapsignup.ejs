<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Setup | BOARD Algo</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            black: '#020617', 
                            surface: '#0f172a',
                            border: '#1e293b',
                            primary: '#6C2BD9', /* XCEEDJS Brand Purple */
                            accent: '#16A34A',  /* XCEEDJS Action Green */
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            color: #f8fafc;
        }
        
        /* Glass Navbar */
        .glass-nav {
            background: rgba(2, 6, 23, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Glass Input Fields */
        .glass-input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
        }
        .glass-input:focus {
            border-color: #6C2BD9;
            box-shadow: 0 0 0 4px rgba(108, 43, 217, 0.15);
            outline: none;
        }
        
        /* Abstract Background Mesh */
        .mesh-bg {
            background-color: #020617;
            background-image: radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 50% 0%, hsla(225,39%,30%,1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(339,49%,30%,1) 0, transparent 50%);
            background-attachment: fixed;
        }

        /* Custom Webkit Scrollbar for the left section */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent; 
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1); 
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(108, 43, 217, 0.5); 
        }
    </style>
</head>
<body class="min-h-screen w-full flex flex-col lg:flex-row mesh-bg pt-20">

    <nav class="fixed top-0 w-full z-50 glass-nav transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 h-20 flex justify-between items-center">
            
            <a href="/" class="flex items-center gap-2 sm:gap-3 group">
                <img id="nav-logo-img" src="logo.png" alt="BOARD Algo" class="h-6 sm:h-8 w-auto object-contain hidden">
                <span id="nav-logo-text" class="text-xl sm:text-2xl font-display font-bold tracking-tight text-white group-hover:text-brand-primary transition-colors">
                    BOARD <span class="text-brand-primary">Algo</span>
                </span>
            </a>

            <div class="hidden lg:flex items-center space-x-8 text-sm font-medium text-slate-400">
                <a href="/" class="hover:text-white transition-colors">Back to Home</a>
                <a href="mailto:Xceedjs@gmail.com" class="hover:text-white transition-colors">Support</a>
            </div>

            <div class="flex items-center gap-3 sm:gap-4">
                <span class="text-xs sm:text-sm text-slate-400 hidden sm:block">Already a member?</span>
                <a href="/login" class="px-4 py-2 sm:px-5 sm:py-2 rounded-lg border border-white/10 hover:bg-white/5 text-white font-semibold text-xs sm:text-sm transition-all whitespace-nowrap">
                    Log In
                </a>
            </div>
        </div>
    </nav>

    <div class="w-full lg:w-1/2 relative flex flex-col items-center justify-center p-6 sm:p-12 lg:sticky lg:top-20 lg:h-[calc(100vh-80px)] overflow-y-auto z-10">
        <div class="absolute inset-0 bg-brand-surface/30 backdrop-blur-sm rounded-b-3xl lg:rounded-b-none lg:rounded-tr-3xl"></div>
        
        <div class="relative z-10 max-w-lg w-full flex-grow flex flex-col justify-center py-10 lg:py-0">
            <h1 class="text-4xl lg:text-5xl font-display font-bold leading-tight mb-4 lg:mb-6 text-transparent bg-clip-text bg-gradient-to-r from-white to-brand-primary/60">
                Almost Done.
            </h1>
            <p class="text-base lg:text-lg text-slate-400 mb-8 leading-relaxed">
                Here you go, very little is remaining! Your Google account is connected securely. We just need to know your class and contact details to calibrate your dashboard.
            </p>

            <div class="relative mt-4 mb-8 lg:mb-0 hidden sm:block">
                <div class="relative h-48 lg:h-64 w-full bg-gradient-to-tr from-brand-primary to-brand-accent rounded-3xl opacity-20 animate-float blur-2xl"></div>
                <div class="absolute bottom-4 lg:bottom-12 left-0 lg:left-0 p-5 lg:p-6 glass-input rounded-2xl border-l-4 border-brand-primary animate-float w-full max-w-[280px]" style="animation-delay: 1s;">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="h-2 w-2 rounded-full bg-brand-accent animate-pulse"></div>
                        <span class="text-[10px] lg:text-xs font-mono text-brand-primary">SYSTEM READY</span>
                    </div>
                    <div class="text-xs lg:text-sm font-bold text-white leading-snug">"Awaiting class parameters..."</div>
                </div>
            </div>
        </div>

        <div class="relative z-10 w-full max-w-lg text-xs text-slate-500 hidden lg:flex flex-wrap gap-4 pt-8 border-t border-white/10 mt-auto">
            <span>Support: Xceedjs@gmail.com</span>
            <span>WA: +91 90243 91398</span>
            <a href="https://xceedjs.com" target="_blank" class="hover:text-brand-primary transition-colors">By XCEEDJS</a>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 md:p-16 relative z-20 bg-brand-black/90 lg:bg-brand-black/80 lg:backdrop-blur-xl border-t lg:border-t-0 lg:border-l border-white/5 min-h-[calc(100vh-80px)]">
        <div class="w-full max-w-md space-y-6 py-10">
            
            <div class="text-center lg:text-left mb-2">
                <h2 class="text-3xl font-display font-bold text-white">Final Step</h2>
                <p class="text-slate-400 mt-2 text-sm">Complete your profile to unlock your 7-day trial dashboard.</p>
            </div>

            <% if (locals.message && locals.color) { %>
                <% 
                   let borderColor = color === 'red' ? 'border-red-500/30' : 'border-green-500/30';
                   let bgColor = color === 'red' ? 'bg-red-500/10' : 'bg-green-500/10';
                   let textColor = color === 'red' ? 'text-red-400' : 'text-green-400';
                   let iconType = color === 'red' ? 'alert-circle' : 'check-circle-2';
                %>
                <div id="dynamic-message" class="p-4 rounded-xl border <%= borderColor %> <%= bgColor %> flex items-start gap-3 transition-all">
                    <i data-lucide="<%= iconType %>" class="w-5 h-5 <%= textColor %> shrink-0 mt-0.5"></i>
                    <p class="text-sm <%= textColor %> font-medium leading-relaxed">
                        <%= message %>
                    </p>
                </div>
            <% } %>

            <form class="space-y-6" id="complete-profile-form" method="POST" action="/api/auth/google/submit-details">
                
                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Your Class <span class="text-brand-primary">*</span></label>
                    <select name="Class" required class="w-full p-3.5 rounded-lg glass-input text-white focus:text-white transition-all cursor-pointer">
                        <option value="" disabled selected class="bg-[#0f172a] text-slate-400">Select Class</option>
                        <option value="10th" class="bg-[#0f172a] text-white">10th</option>
                        <option value="12th" class="bg-[#0f172a] text-white">12th</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Your Phone Number <span class="text-brand-primary">*</span></label>
                    <div class="relative flex items-center">
                        <span class="absolute left-4 text-white font-bold tracking-wide z-10 pointer-events-none">+91</span>
                        <input type="tel" name="phone_number" placeholder="99999 99999" required pattern="[0-9\s]{10,11}" class="w-full pl-14 p-3.5 rounded-lg glass-input text-white placeholder-slate-600 transition-all">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Referral Code</label>
                    <input type="text" name="referral_code" placeholder="Optional" class="w-full p-3.5 rounded-lg glass-input text-white placeholder-slate-600 focus:text-white transition-all">
                </div>

                <div class="space-y-4 pt-2">
                    <div class="flex items-start gap-3 p-4 rounded-xl border border-white/5 bg-white/5 transition-all hover:bg-white/10">
                        <div class="flex items-center h-5 mt-0.5">
                            <input id="report-consent" type="checkbox" class="w-4 h-4 rounded border-gray-600 text-brand-primary focus:ring-brand-primary bg-gray-700 cursor-pointer">
                        </div>
                        <div class="ml-1 text-sm">
                            <label for="report-consent" class="font-medium text-white select-none cursor-pointer flex items-center gap-2">
                                Enable Parent Reports
                                <i data-lucide="shield-check" class="w-4 h-4 text-brand-accent"></i>
                            </label>
                            <p class="text-slate-400 text-xs mt-1.5 leading-relaxed">We promise no spam. We will only send your weekly progress report to your parent.</p>
                        </div>
                    </div>

                    <div id="parent-field-container" class="opacity-50 pointer-events-none h-0 overflow-hidden transition-all duration-300 ease-in-out">
                        <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Parent's Phone Number (Optional)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-white font-bold tracking-wide z-10 pointer-events-none">+91</span>
                            <input type="tel" name="parent_phone_number" id="parent-phone" placeholder="98765 43210" pattern="[0-9\s]{10,11}" class="w-full pl-14 p-3.5 rounded-lg glass-input text-white placeholder-slate-600 transition-all">
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-brand-primary hover:bg-[#5A24B5] text-white font-bold py-4 px-4 rounded-xl shadow-[0_0_20px_rgba(108,43,217,0.4)] transition-all transform hover:-translate-y-0.5 mt-4">
                    Start Learning
                </button>
            </form>

            <div class="flex lg:hidden flex-col items-center gap-2 text-xs text-slate-500 pt-8 border-t border-white/10">
                <span>Support: Xceedjs@gmail.com</span>
                <span>WA: +91 90243 91398</span>
                <a href="https://xceedjs.com" target="_blank" class="hover:text-brand-primary transition-colors">By XCEEDJS</a>
            </div>
        </div>
    </div>

    <script>
        // Initialize Icons
        lucide.createIcons();

        // Logo Handling
        const logoImg = document.getElementById('nav-logo-img');
        const logoText = document.getElementById('nav-logo-text');
        logoImg.onload = function() { logoImg.classList.remove('hidden'); logoText.classList.add('hidden'); };
        logoImg.onerror = function() { logoImg.classList.add('hidden'); logoText.classList.remove('hidden'); };

        // Parent Phone Toggle
        const checkbox = document.getElementById('report-consent');
        const parentContainer = document.getElementById('parent-field-container');
        const parentInput = document.getElementById('parent-phone');

        checkbox.addEventListener('change', (e) => {
            if (e.target.checked) {
                parentContainer.classList.remove('opacity-50', 'pointer-events-none', 'h-0');
                parentContainer.classList.add('h-20', 'mt-4'); 
                parentInput.focus();
            } else {
                parentContainer.classList.add('opacity-50', 'pointer-events-none', 'h-0');
                parentContainer.classList.remove('h-20', 'mt-4');
                parentInput.value = ""; 
            }
        });
    </script>
</body>
</html>