<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | BOARD Algo</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            black: '#020617', 
                            surface: '#0f172a',
                            border: '#1e293b',
                            primary: '#6366f1',
                            accent: '#8b5cf6',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            color: #f8fafc;
        }
        
        .glass-input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
        }
        .glass-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

        .mesh-bg {
            background-color: #020617;
            background-image: radial-gradient(at 100% 100%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 0% 0%, hsla(225,39%,30%,1) 0, transparent 50%);
        }
    </style>
</head>
<body class="h-screen w-full flex overflow-hidden mesh-bg">

    <div class="hidden lg:flex w-1/2 relative items-center justify-center p-12">
        <div class="absolute inset-0 bg-brand-surface/30 backdrop-blur-sm"></div>
        
        <div class="relative z-10 max-w-lg">
            <a href="/" class="flex items-center gap-3 mb-12 group">
                <img src="logo.png" alt="Logo" class="h-8 w-auto object-contain hidden" onerror="this.style.display='none'">
                <span class="text-3xl font-display font-bold tracking-tight text-white group-hover:text-brand-primary transition-colors">BOARD <span class="text-brand-primary">Algo</span></span>
            </a>

            <h1 class="text-5xl font-display font-bold leading-tight mb-6 text-white">
                Forgot your <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Password?</span>
            </h1>
            <p class="text-lg text-slate-400 mb-8 leading-relaxed">
                Don't worry, it happens to the best of us. Let's get you back into your dashboard.
            </p>

            <div class="w-full h-48 border border-brand-primary/30 rounded-2xl bg-gradient-to-b from-brand-primary/10 to-transparent flex flex-col items-center justify-center relative overflow-hidden animate-float">
                 <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
                 <div class="text-center z-10">
                     <i data-lucide="shield-question" class="w-12 h-12 text-brand-primary mx-auto mb-3 opacity-80"></i>
                     <div class="text-sm font-mono text-slate-300">SECURE RECOVERY INITIATED</div>
                 </div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 relative z-20 bg-brand-black/80 backdrop-blur-xl border-l border-white/5">
        <div class="w-full max-w-md space-y-8">
            
            <div class="lg:hidden text-center mb-8">
                <span class="text-2xl font-display font-bold tracking-tight text-white">BOARD <span class="text-brand-primary">Algo</span></span>
            </div>

            <div class="text-center lg:text-left">
                <h2 class="text-3xl font-display font-bold text-white mb-2">Reset Password</h2>
                <p class="text-slate-400 text-sm leading-relaxed">
                    Enter the email address associated with your account and we'll send you a secure link to reset your password.
                </p>
            </div>

            <% if (locals.message) { %>
                <% 
                    let msgColor = locals.color || 'green'; 
                    let borderColor = msgColor === 'red' ? 'border-red-500/30' : 'border-green-500/30';
                    let bgColor = msgColor === 'red' ? 'bg-red-500/10' : 'bg-green-500/10';
                    let textColor = msgColor === 'red' ? 'text-red-400' : 'text-green-400';
                    let iconType = msgColor === 'red' ? 'alert-circle' : 'mail-check';
                %>
                <div id="dynamic-message" class="p-4 rounded-xl border <%= borderColor %> <%= bgColor %> flex items-start gap-3 transition-all">
                    <i data-lucide="<%= iconType %>" class="w-5 h-5 <%= textColor %> shrink-0 mt-0.5"></i>
                    <p class="text-sm <%= textColor %> font-medium leading-relaxed">
                        <%= message %>
                    </p>
                </div>
            <% } %>

            <form class="space-y-6" method="POST" action="/api/auth/forgot-password">
                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Email Address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <i data-lucide="mail" class="w-5 h-5 text-slate-500"></i>
                        </div>
                        <input type="email" name="email" required placeholder="student@example.com" class="w-full pl-11 p-3.5 rounded-lg glass-input text-white placeholder-slate-600 focus:text-white transition-all">
                    </div>
                </div>

                <button type="submit" class="w-full bg-brand-primary hover:bg-indigo-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all transform hover:-translate-y-0.5 flex items-center justify-center gap-2">
                    Send Reset Link
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </form>

            <div class="text-center pt-4 border-t border-white/10">
                <a href="/login" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors group">
                    <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
                    Back to Log In
                </a>
            </div>
            
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>