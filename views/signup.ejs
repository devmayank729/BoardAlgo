<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join BOARD Algo | Future of Boards</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            black: '#020617', 
                            surface: '#0f172a',
                            border: '#1e293b',
                            primary: '#6366f1',
                            accent: '#8b5cf6',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            color: #f8fafc;
        }
        
        /* Glass Navbar */
        .glass-nav {
            background: rgba(2, 6, 23, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Glass Input Fields */
        .glass-input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
        }
        .glass-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }
        
        /* Validation States */
        .valid-input { border-color: #10b981 !important; }
        .invalid-input { border-color: #ef4444 !important; }

        /* Abstract Background Mesh */
        .mesh-bg {
            background-color: #020617;
            background-image: radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 50% 0%, hsla(225,39%,30%,1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(339,49%,30%,1) 0, transparent 50%);
            background-attachment: fixed;
        }
    </style>
</head>
<body class="min-h-screen w-full flex flex-col lg:flex-row mesh-bg pt-20">

    <nav class="fixed top-0 w-full z-50 glass-nav transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
            
            <a href="/" class="flex items-center gap-3 group">
                <img id="nav-logo-img" src="logo.png" alt="BOARD Algo" class="h-8 w-auto object-contain hidden">
                <span id="nav-logo-text" class="text-2xl font-display font-bold tracking-tight text-white group-hover:text-brand-primary transition-colors">
                    BOARD <span class="text-brand-primary">Algo</span>
                </span>
            </a>

            <div class="hidden lg:flex items-center space-x-8 text-sm font-medium text-slate-400">
                <a href="/" class="hover:text-white transition-colors">Back to Home</a>
                <a href="#" class="hover:text-white transition-colors">Support</a>
            </div>

            <div class="flex items-center gap-4">
                <span class="text-sm text-slate-400 hidden sm:block">Already a member?</span>
                <a href="/login" class="px-5 py-2 rounded-lg border border-white/10 hover:bg-white/5 text-white font-semibold text-sm transition-all">
                    Log In
                </a>
            </div>
        </div>
    </nav>

    <div class="hidden lg:flex w-1/2 relative items-center justify-center p-12 sticky top-20 h-[calc(100vh-80px)]">
        <div class="absolute inset-0 bg-brand-surface/30 backdrop-blur-sm rounded-tr-3xl"></div>
        
        <div class="relative z-10 max-w-lg">
            <h1 class="text-5xl font-display font-bold leading-tight mb-6 text-transparent bg-clip-text bg-gradient-to-r from-white to-brand-primary/50">
                Join the Top 1%.
            </h1>
            <p class="text-lg text-slate-400 mb-8 leading-relaxed">
                Stop guessing what will come in the exam. Use AI to predict your paper and secure that 99%.
            </p>

            <div class="relative h-64 w-full bg-gradient-to-tr from-brand-primary to-brand-accent rounded-3xl opacity-20 animate-float blur-2xl"></div>
            <div class="absolute bottom-20 left-12 p-6 glass-input rounded-2xl border-l-4 border-brand-primary animate-float" style="animation-delay: 1s;">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-2 w-2 rounded-full bg-green-400"></div>
                    <span class="text-xs font-mono text-brand-primary">AI PREDICTION</span>
                </div>
                <div class="text-sm font-bold text-white">"Probability of Thermodynamics: 89%"</div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 md:p-16 relative z-20 bg-brand-black/80 backdrop-blur-xl border-l border-white/5 min-h-[calc(100vh-80px)]">
        <div class="w-full max-w-md space-y-8 py-10">
            
            <div class="text-center lg:text-left">
                <h2 class="text-3xl font-display font-bold text-white">Create Account</h2>
                <p class="text-slate-400 mt-2 text-sm">Start your 7-day free trial. No credit card required.</p>
            </div>

            <button class="w-full flex items-center justify-center gap-3 bg-white text-brand-black font-bold py-3 px-4 rounded-xl hover:bg-slate-200 transition-colors">
                <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.17c-.22-.66-.35-1.36-.35-2.17s.13-1.51.35-2.17V7.01H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.99l3.66-2.82z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.01l3.66 2.82c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Sign up with Google
            </button>

            <div class="relative">
                <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-white/10"></span></div>
                <div class="relative flex justify-center text-xs uppercase"><span class="bg-brand-black px-2 text-slate-500">Or continue with email</span></div>
            </div>

            <form class="space-y-5" id="signup-form" method="post" action="/signupsubmit" onsubmit="return attemptSignup(event)">
                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Full Name</label>
                    <input type="text" name="username" placeholder="Arjun Sharma" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600 focus:text-white">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Email Address</label>
                    <input type="email" name="email" placeholder="student@example.com" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Password</label>
                    <div class="relative">
                        <input type="password" name="password" id="password" placeholder="Min 6 chars + 1 special (@#$%)" class="w-full p-3 pr-12 rounded-lg glass-input text-white placeholder-slate-600 focus:text-white" oninput="validatePassword()">
                        <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white transition-colors focus:outline-none">
                            <i data-lucide="eye" id="eye-icon" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <p id="password-hint" class="text-xs text-slate-500 mt-1 transition-colors">
                        Requirement: 6+ characters and at least 1 special character.
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Your Phone</label>
                        <input type="tel" name="phone_number" placeholder="99999 99999" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600">
                    </div>
                    
                    <div id="parent-field-container" class="opacity-50 pointer-events-none transition-all duration-300">
                        <label class="block text-xs font-bold text-slate-400 mb-1 uppercase tracking-wider">Parent's Phone</label>
                        <input type="tel" name="parent_phone_number" id="parent-phone" placeholder="Optional" class="w-full p-3 rounded-lg glass-input text-white placeholder-slate-600">
                    </div>
                </div>

                <div class="flex items-start gap-3 p-4 rounded-xl border border-white/5 bg-white/5">
                    <div class="flex items-center h-5">
                        <input id="report-consent" type="checkbox" class="w-4 h-4 rounded border-gray-600 text-brand-primary focus:ring-brand-primary bg-gray-700">
                    </div>
                    <div class="ml-1 text-sm">
                        <label for="report-consent" class="font-medium text-white select-none cursor-pointer">Enable Parent Reports</label>
                        <p class="text-slate-400 text-xs mt-1">We promise no spam. We will only send your weekly progress report to your parent. Untick to disable.</p>
                    </div>
                </div>

                <button type="submit" id="submit-btn" class="w-full bg-brand-primary hover:bg-indigo-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all transform hover:-translate-y-0.5">
                    Create Account
                </button>
            </form>
        </div>
    </div>

    <script>
        // 1. Initialize Icons
        lucide.createIcons();

        // 2. Logo Handling
        const logoImg = document.getElementById('nav-logo-img');
        const logoText = document.getElementById('nav-logo-text');
        logoImg.onload = function() { logoImg.classList.remove('hidden'); logoText.classList.add('hidden'); };
        logoImg.onerror = function() { logoImg.classList.add('hidden'); logoText.classList.remove('hidden'); };

        // 3. Parent Phone Toggle
        const checkbox = document.getElementById('report-consent');
        const parentContainer = document.getElementById('parent-field-container');
        const parentInput = document.getElementById('parent-phone');

        checkbox.addEventListener('change', (e) => {
            if (e.target.checked) {
                parentContainer.classList.remove('opacity-50', 'pointer-events-none');
                parentInput.required = true;
                parentInput.placeholder = "98765 43210";
                parentInput.focus();
            } else {
                parentContainer.classList.add('opacity-50', 'pointer-events-none');
                parentInput.required = false;
                parentInput.value = "";
                parentInput.placeholder = "Optional";
            }
        });

        // 4. Password Toggle
        const passwordInput = document.getElementById('password');
        const eyeIcon = document.getElementById('eye-icon');
        
        function togglePassword() {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.setAttribute('data-lucide', 'eye-off');
            } else {
                passwordInput.type = 'password';
                eyeIcon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons(); // Refresh icon
        }

        // 5. Password Validation
        const passwordHint = document.getElementById('password-hint');
        let isPasswordValid = false;

        function validatePassword() {
            const value = passwordInput.value;
            // Regex: At least 6 characters AND at least one special character
            const regex = /^(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]).{6,}$/;

            if (regex.test(value)) {
                passwordInput.classList.remove('invalid-input');
                passwordInput.classList.add('valid-input');
                passwordHint.style.color = '#10b981'; // Green
                passwordHint.innerText = "Strong password selected.";
                isPasswordValid = true;
            } else {
                passwordInput.classList.remove('valid-input');
                if (value.length > 0) passwordInput.classList.add('invalid-input');
                passwordHint.style.color = '#ef4444'; // Red
                passwordHint.innerText = "Must be 6+ chars with 1 special character (@, #, $, etc.)";
                isPasswordValid = false;
            }
        }

        // 6. Submit Handling
function attemptSignup(event) {
    if (!isPasswordValid) {
        event.preventDefault(); // Stop form
        passwordInput.classList.add('invalid-input');
        passwordInput.focus();
        passwordHint.style.color = '#ef4444';
        alert("Please meet password requirements.");
        return false;
    }
    return true; // Allow submission
}

    </script>

    <script src="/js/tracking.js" defer></script>
    
</body>
</html>