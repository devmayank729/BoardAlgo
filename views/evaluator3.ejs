  const win=window.open('','_blank');
  if (!win) { alert('Please allow pop-ups from this site to download the PDF.'); return; }
  win.document.write(printHtml);
  win.document.close();
  // Data URLs are already loaded — short delay for KaTeX CSS to load
  setTimeout(()=>{ try { win.print(); } catch(_){} }, 700);
}

/* ══════════════════════════════════════════════════════════════════
   13. RESET
══════════════════════════════════════════════════════════════════ */
function resetEvaluator() {
  clearInterval(loadingInterval);
  if (submitAbortCtrl) { try { submitAbortCtrl.abort('cancelled'); } catch(_){} submitAbortCtrl=null; }
  lastFormData=null; lastEvaluationData=null;
  cropQueue=[]; closeCropModal();

  fileDT=new DataTransfer();
  fileInput.files=fileDT.files; cameraInput.value='';
  document.getElementById('file-preview-list').innerHTML='';

  if(konvaStage){konvaStage.destroy();konvaStage=null;}
  errorGroup=null;markGroup=null;errorsVisible=true;marksVisible=true;annotationsVisible=true;

  document.getElementById('student-img').src='';
  document.getElementById('img-info-bar').innerHTML='';
  document.getElementById('meta-chips').innerHTML='';
  document.getElementById('rubric-bars').innerHTML='';
  document.getElementById('steps-container').innerHTML='';
  document.getElementById('ring-fill-el').style.strokeDashoffset='351.9';
  document.getElementById('score-main').textContent='—';
  const psWrap=document.getElementById('ps-wrapper');
  if(psWrap)psWrap.style.display='none';

  const up=document.getElementById('upload-section');
  up.style.display='';up.style.opacity='1';up.style.pointerEvents='';
  document.getElementById('loading-section').classList.add('hidden');
  document.getElementById('result-section').style.display='none';

  submitBtn.disabled=true;
  document.getElementById('submit-label').innerHTML=`<i data-lucide="gavel" class="w-5 h-5"></i> Submit to Strict Examiner`;

  currentZoom=1;currentAnnotations=[];globalImageUrls=[];globalAnnotations=[];
  lucide.createIcons();
  gsap.from('.gsap-entry',{y:20,opacity:0,stagger:0.07,duration:0.55,ease:'power2.out'});
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ══════════════════════════════════════════════════════════════════
   14. ACTION BUTTONS
