}

async function submitWithRetry(formData, attempt=1) {
  submitAbortCtrl = new AbortController();
  const tid = setTimeout(() => submitAbortCtrl.abort('timeout'), SUBMIT_TIMEOUT_MS);
  try {
    const resp = await fetch('/examiner/evaluate', { method:'POST', body:formData, signal:submitAbortCtrl.signal });
    clearTimeout(tid);
    if (!resp.ok) {
      if (resp.status===429) { showErrorState('Rate limit reached','Too many evaluations. Please wait and try again.',true); return; }
      if (resp.status>=500)  throw new Error(`Server error ${resp.status}`);
      showErrorState(`Request failed (${resp.status})`,'The server rejected the request. Check your inputs.',false); return;
    }
    let json;
    try { json = await resp.json(); } catch(_) { throw new Error('Invalid JSON from server'); }
    if (json && json.meta) renderResult(json);
    else showErrorState('Unexpected response format','Server returned unrecognised data. Please try again.',true);
  } catch(err) {
    clearTimeout(tid);
    if (err.name!=='AbortError' && err.message!=='cancelled' && attempt<=SUBMIT_MAX_RETRIES) {
      document.getElementById('loading-status').textContent=`Retrying (attempt ${attempt+1}/${SUBMIT_MAX_RETRIES+1})…`;
      await new Promise(r=>setTimeout(r,RETRY_DELAY_MS));
      return submitWithRetry(formData, attempt+1);
    }
    if (err.name==='AbortError'||String(err.message).includes('timeout'))
      showErrorState('Request timed out',`Gemini took longer than ${SUBMIT_TIMEOUT_MS/1000}s. Please try again.`,true);
    else
      showErrorState('Network error',`Could not reach the server: ${err.message}`,true);
  }
}

