/* ══════════════════════════════════════════════════════════════════
   11. STEPS RENDERER — Topper's Notebook
   ─────────────────────────────────────────────────────────────────
   Uses renderLatexBlock (KaTeX display mode) for math blocks,
   and renderMathSafe for step text (handles mixed text+inline math).
══════════════════════════════════════════════════════════════════ */
function renderSteps(steps) {
  const container = document.getElementById('steps-container');
  container.innerHTML = '';
  (steps||[]).forEach((s,i) => {
    const card=document.createElement('div');
    card.className='step-card py-5 px-1';
    const header=document.createElement('div');
    header.className='flex items-start gap-3 sm:gap-4';
    const numEl=document.createElement('div');
    numEl.className='step-num mt-0.5 flex-shrink-0';
    numEl.textContent=s.step||(i+1);
    const body=document.createElement('div');
    body.className='flex-1 min-w-0';

    // Text — may contain inline LaTeX like $f(x)$
    const textEl=document.createElement('p');
    textEl.className='text-sm sm:text-base text-slate-700 dark:text-gray-200 leading-relaxed font-medium';
    renderMathSafe(textEl, s.text);
    body.appendChild(textEl);

    // LaTeX block — pure LaTeX, display mode
    if (s.latex) {
      const mathBlock=document.createElement('div');
      mathBlock.className='katex-block';
      renderLatexBlock(mathBlock, s.latex);
      body.appendChild(mathBlock);
    }

    header.appendChild(numEl);
    header.appendChild(body);
    card.appendChild(header);
    container.appendChild(card);
  });
}

/* ══════════════════════════════════════════════════════════════════
   12. PDF GENERATION
   ─────────────────────────────────────────────────────────────────
   Key fix: annotations are drawn onto a canvas at NATURAL image
   resolution using coordsToPixels(box_2d, naturalWidth, naturalHeight).
   This is the SAME formula used by Konva at rendered resolution.
   Result: pixel-perfect annotation placement in the PDF.
══════════════════════════════════════════════════════════════════ */

/**
 * drawAnnotations2DCanvas — mirrors drawAnnotations() but uses
 * Canvas 2D API at NATURAL image resolution for PDF compositing.
 * Uses coordsToPixels for identical coordinate mapping.
 */
function drawAnnotations2DCanvas(ctx, annos, W, H) {
  if (!annos||!annos.length) return;
  const sw = n => Math.max(1.5, W*n);
  const fs = n => Math.max(W*0.012, W*n);

  annos.forEach(anno => {
    const {px,py,pw,ph,cx,cy} = coordsToPixels(anno.box_2d, W, H);

    const isRed   = anno.color==='red';
    const isGreen = anno.color==='green';
    const strokeC = isRed?'rgba(239,68,68,0.88)':isGreen?'rgba(22,163,74,0.92)':'rgba(108,43,217,0.88)';
    const fillC   = isRed?'rgba(239,68,68,0.09)':isGreen?'rgba(22,163,74,0.10)':'rgba(108,43,217,0.09)';

    ctx.save();

    if (anno.annotation_type==='tick') {
      const r=Math.max(W*0.014,Math.min(W*0.028,Math.min(pw,ph)/2));
      // Halo
      ctx.beginPath(); ctx.arc(cx,cy,r+W*0.004,0,Math.PI*2);
      ctx.fillStyle='rgba(22,163,74,0.18)'; ctx.fill();
      // Circle bg
      ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
      ctx.fillStyle='rgba(22,163,74,0.85)';
      ctx.shadowColor='#16A34A'; ctx.shadowBlur=W*0.01; ctx.fill(); ctx.shadowBlur=0;
      // Tick
      const ts=r*0.55;
      ctx.beginPath();
      ctx.moveTo(cx-ts*0.6,cy); ctx.lineTo(cx-ts*0.1,cy+ts*0.6); ctx.lineTo(cx+ts*0.7,cy-ts*0.55);
      ctx.strokeStyle='#fff'; ctx.lineWidth=sw(0.008)+W*0.001;
      ctx.lineCap='round'; ctx.lineJoin='round'; ctx.stroke();

    } else if (anno.annotation_type==='cross') {
      const r=Math.max(W*0.014,Math.min(W*0.028,Math.min(pw,ph)/2));
      ctx.beginPath(); ctx.arc(cx,cy,r+W*0.004,0,Math.PI*2);
      ctx.fillStyle='rgba(239,68,68,0.15)'; ctx.fill();
      ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
      ctx.fillStyle='rgba(239,68,68,0.85)';
      ctx.shadowColor='#EF4444'; ctx.shadowBlur=W*0.01; ctx.fill(); ctx.shadowBlur=0;
      const arm=r*0.52;
      ctx.strokeStyle='#fff'; ctx.lineWidth=sw(0.007)+W*0.001; ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(cx-arm,cy-arm); ctx.lineTo(cx+arm,cy+arm); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(cx+arm,cy-arm); ctx.lineTo(cx-arm,cy+arm); ctx.stroke();

    } else if (anno.annotation_type==='circle') {
      ctx.beginPath();
      ctx.ellipse(cx,cy,Math.max(W*0.008,pw/2),Math.max(W*0.008,ph/2),0,0,Math.PI*2);
      ctx.fillStyle=fillC; ctx.fill();
      ctx.strokeStyle=strokeC; ctx.lineWidth=sw(0.005);
      ctx.setLineDash([W*0.007,W*0.004]); ctx.stroke(); ctx.setLineDash([]);

    } else if (anno.annotation_type==='text' && anno.comment) {
      const fSize=fs(0.022);
      ctx.font=`bold ${fSize}px 'Poppins',sans-serif`;
      const tw=ctx.measureText(anno.comment).width+fSize;
      const th=fSize*1.8;
      const br=fSize*0.35;
      ctx.fillStyle=isRed?'rgba(239,68,68,0.92)':'rgba(22,163,74,0.92)';
      ctx.shadowColor=isRed?'#EF4444':'#16A34A'; ctx.shadowBlur=W*0.009;
      ctx.beginPath();
      ctx.moveTo(px+br,py); ctx.lineTo(px+tw-br,py); ctx.arcTo(px+tw,py,px+tw,py+br,br);
      ctx.lineTo(px+tw,py+th-br); ctx.arcTo(px+tw,py+th,px+tw-br,py+th,br);
      ctx.lineTo(px+br,py+th); ctx.arcTo(px,py+th,px,py+th-br,br);
      ctx.lineTo(px,py+br); ctx.arcTo(px,py,px+br,py,br); ctx.closePath();
      ctx.fill(); ctx.shadowBlur=0;
      ctx.fillStyle='#fff'; ctx.textBaseline='middle';
      ctx.fillText(anno.comment,px+fSize*0.4,py+th/2);

    } else if (anno.annotation_type==='step_mark' && anno.comment) {
      const isDed=isRed||String(anno.comment).startsWith('-');
      const radius=Math.max(W*0.018,Math.min(W*0.036,Math.min(pw,ph)/2));
      const fSize=fs(0.030);
      const bgF=isDed?'rgba(239,68,68,0.88)':'rgba(22,163,74,0.88)';
      const shd=isDed?'#EF4444':'#16A34A';
      // Dashed rule line
      ctx.strokeStyle=isDed?'rgba(239,68,68,0.35)':'rgba(22,163,74,0.35)';
      ctx.lineWidth=W*0.0012; ctx.setLineDash([W*0.003,W*0.003]);
      ctx.beginPath(); ctx.moveTo(cx-radius-W*0.006,cy); ctx.lineTo(cx-radius-W*0.03,cy); ctx.stroke();
      ctx.setLineDash([]);
      // Circle
      ctx.beginPath(); ctx.arc(cx,cy,radius,0,Math.PI*2);
      ctx.fillStyle=bgF; ctx.shadowColor=shd; ctx.shadowBlur=W*0.014;
      ctx.fill(); ctx.shadowBlur=0;
      // Label
      ctx.font=`bold ${fSize}px 'Poppins',sans-serif`;
      ctx.fillStyle='#fff'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(anno.comment,cx,cy);
    }

    ctx.restore();
  });
}

/**
 * buildCompositeImage — loads image at natural size, draws annotations
 * using coordsToPixels at naturalWidth/naturalHeight for precise placement.
 */
function buildCompositeImage(imageUrl, pageIndex) {
  return new Promise(resolve => {
    const img=new Image();
    img.crossOrigin='anonymous';
    img.onload=()=>{
      const W=img.naturalWidth, H=img.naturalHeight;
      const canvas=document.createElement('canvas');
      canvas.width=W; canvas.height=H;
      const ctx=canvas.getContext('2d');
      ctx.drawImage(img,0,0,W,H);
      const total=globalImageUrls.length;
      const annos=globalAnnotations.filter(a=>total<=1?true:a.page_number===(pageIndex+1));
      drawAnnotations2DCanvas(ctx,annos,W,H);
      try { resolve(canvas.toDataURL('image/jpeg',0.92)); }
      catch(e) { console.warn('[BoardAlgo PDF] CORS prevented composite for page',pageIndex+1); resolve(imageUrl); }
    };
    img.onerror=()=>resolve(imageUrl);
    img.src=imageUrl;
    // Handle already-cached images
    if(img.complete&&img.naturalWidth) img.onload();
  });
}

async function generatePDF() {
  const data = lastEvaluationData;
  if (!data) { window.print(); return; }

  const meta   = data.meta||{};
  const urls   = globalImageUrls||[];
  const today  = new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});

  // Build all composites (await sequentially to avoid memory spikes on mobile)
  const compositeUrls=[];
  for (let i=0;i<Math.max(1,urls.length);i++) {
    compositeUrls.push(urls[i] ? await buildCompositeImage(urls[i],i) : null);
  }

  const imagesSection = compositeUrls.some(u=>u)
    ? compositeUrls.map((url,i)=>url?`
        <div class="page-block">
          <p class="page-label">Answer Sheet${compositeUrls.length>1?` — Page ${i+1} of ${compositeUrls.length}`:''}</p>
          <img src="${url}" class="answer-img">
        </div>`:'').join('')
    : '<p style="color:#94a3b8;font-style:italic;padding:16px 0;">No answer sheet image available.</p>';

  // Steps with KaTeX rendered to HTML strings
  const stepsSection=(data.perfect_marker_answer||[]).map((s,i)=>`
    <div class="step-row">
      <div class="step-circle">${s.step||(i+1)}</div>
      <div class="step-body">
        <p class="step-text">${(s.text||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>
        ${s.latex?`<div class="step-math">${latexToHTMLString(s.latex,true)}</div>`:''}
      </div>
    </div>`).join('');

  // Rubric
  const rubricRows=(data.rubric||[]).map(r=>{
    const pct=Math.min(100,Math.round((r.scored/r.total)*100));
    return `<div class="rubric-row">
      <div class="rubric-header"><span>${r.label}</span><span style="color:${r.color};font-weight:700;">${r.scored}/${r.total}</span></div>
      <div class="rubric-track"><div class="rubric-bar" style="width:${pct}%;background:${r.color};"></div></div>
    </div>`;
  }).join('');

  const scored  = meta.total_marks_awarded??'—';
  const maxMk   = meta.max_marks??'—';
  const subject = meta.subject||'';
  const diff    = meta.difficulty||'—';
  const summary = (meta.evaluation_summary||'—').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  // Problem statement rendered via latexToHTMLString if it contains LaTeX
  const questionHtml = (()=>{
    const q=meta.problem_statement||'';
    if (!q) return '';
    if (/\$|\\[[(]/.test(q)) {
      // Has LaTeX — render inline
      try { return katex.renderToString(q,{displayMode:false,throwOnError:false,trust:true}); }
      catch(e) {}
    }
    return q.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  })();

  const printHtml=`<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>BoardAlgo Evaluation Report</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1e293b;background:#fff;font-size:13px;}
    .header{background:linear-gradient(135deg,#6C2BD9 0%,#7c3aed 50%,#dc2626 100%);color:#fff;padding:20px 28px;display:flex;justify-content:space-between;align-items:flex-start;gap:16px;}
    .header-left h1{font-size:20px;font-weight:800;letter-spacing:-0.02em;}
    .header-left .question{font-size:12px;opacity:0.9;margin-top:5px;max-width:480px;}
    .score-box{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);border-radius:12px;padding:10px 20px;text-align:center;flex-shrink:0;}
    .score-box .marks{font-size:28px;font-weight:900;line-height:1;}
    .score-box .sub{font-size:10px;opacity:0.8;text-transform:uppercase;letter-spacing:0.05em;margin-top:2px;}
    .body{padding:22px 28px;}
    .chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
    .chip{font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;background:#f5f0ff;border:1px solid #ddd6fe;color:#6C2BD9;}
    .section-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6C2BD9;border-bottom:2px solid #e9d5ff;padding-bottom:4px;margin:20px 0 10px;}
    .summary-box{background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:12px 14px;font-size:12.5px;color:#475569;line-height:1.55;}
