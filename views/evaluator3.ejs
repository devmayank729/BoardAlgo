      { step:2, text:"Differentiate each part individually:", latex:"\\frac{d}{dx}(x^2) = 2x \\qquad \\text{and} \\qquad \\frac{d}{dx}(\\sin x) = \\cos x" },
      { step:3, text:"Substitute back into the product rule formula:", latex:"f'(x) = (2x)(\\sin x) + (x^2)(\\cos x)" },
      { step:4, text:"Simplify to the final answer:", latex:"\\boxed{f'(x) = 2x\\sin(x) + x^2\\cos(x)}" }
    ]
  };
}

/* ══════════════════════════════════════════════════════════════════
   1. BOOTSTRAP — theme + icons + GSAP
══════════════════════════════════════════════════════════════════ */
lucide.createIcons();

const html = document.documentElement;
(function applyTheme() {
  const s = localStorage.theme;
  if (s === 'dark' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches))
    html.classList.add('dark');
  else html.classList.remove('dark');
})();
document.getElementById('theme-toggle').addEventListener('click', () => {
  html.classList.toggle('dark');
  localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
});
gsap.from('.gsap-entry', { y:24, opacity:0, stagger:0.08, duration:0.7, ease:'power2.out' });

/* ══════════════════════════════════════════════════════════════════
   2. MOBILE DETECTION + UI SETUP
══════════════════════════════════════════════════════════════════ */
const IS_MOBILE = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) ||
                  (navigator.maxTouchPoints > 1 && window.innerWidth < 1024);

if (IS_MOBILE) {
  document.getElementById('desktop-upload-hint').style.display = 'none';
  document.getElementById('mobile-action-btns').style.display  = 'flex';
  lucide.createIcons();
}

/* ══════════════════════════════════════════════════════════════════
   3. DEVICE METADATA CAPTURE
══════════════════════════════════════════════════════════════════ */
function captureDeviceMetadata() {
  const ua = navigator.userAgent;
  let dtype = 'desktop';
  if (/Mobi|Android|iPhone|iPad|iPod/i.test(ua)) dtype = 'mobile';
  else if (/Tablet|iPad/i.test(ua)) dtype = 'tablet';
  document.getElementById('f-sw').value    = screen.width;
  document.getElementById('f-sh').value    = screen.height;
  document.getElementById('f-dpr').value   = window.devicePixelRatio || 1;
  document.getElementById('f-dtype').value = dtype;
  document.getElementById('f-vw').value    = window.innerWidth;
  document.getElementById('f-vh').value    = window.innerHeight;
  document.getElementById('f-ua').value    = ua;
  document.getElementById('f-ts').value    = new Date().toISOString();
}

/* ══════════════════════════════════════════════════════════════════
   4. FILE MANAGEMENT
══════════════════════════════════════════════════════════════════ */
const dropZone    = document.getElementById('drop-zone');
const fileInput   = document.getElementById('file-input');
const cameraInput = document.getElementById('camera-input');
const previewList = document.getElementById('file-preview-list');
const submitBtn   = document.getElementById('submit-btn');
let fileDT        = new DataTransfer();

function refreshSubmit() { submitBtn.disabled = fileDT.files.length === 0; }

function formatBytes(b) {
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(2) + ' MB';
}

function buildImageMeta() {
  const arr = Array.from(fileDT.files).map(f => ({
    name:f.name, size:f.size, sizeHuman:formatBytes(f.size), type:f.type, lastModified:f.lastModified
  }));
  document.getElementById('f-imgmeta').value = JSON.stringify(arr);
}

function addSingleFile(file) {
  if (fileDT.files.length >= 10) return;
  if (file.size > 20*1024*1024) { alert(`"${file.name}" exceeds 20 MB.`); return; }
  if (Array.from(fileDT.files).some(x => x.name===file.name && x.size===file.size)) return;
  fileDT.items.add(file);
  renderChip(file);
  fileInput.files = fileDT.files;
  buildImageMeta();
  refreshSubmit();
}

function addFiles(files) {
  const arr = Array.from(files);
  arr.filter(f => !f.type.startsWith('image/')).forEach(addSingleFile);
  const imgs = arr.filter(f => f.type.startsWith('image/'));
  if (imgs.length) enqueueCrop(imgs);
}

function renderChip(file) {
  const chip = document.createElement('div');
  chip.className = 'file-chip';
  const isPdf = file.type === 'application/pdf';
  chip.innerHTML = `
    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      ${isPdf
        ? '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>'
        : '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>'}
    </svg>
    <span class="file-chip-name">${file.name}</span>
    <span class="text-[10px] text-purple-300/70">${formatBytes(file.size)}</span>
    <span class="chip-remove" title="Remove">✕</span>`;
  chip.querySelector('.chip-remove').addEventListener('click', e => {
    e.stopPropagation();
    const ndt = new DataTransfer();
    Array.from(fileDT.files).forEach(x => { if (!(x.name===file.name && x.size===file.size)) ndt.items.add(x); });
    fileDT = ndt;
    fileInput.files = fileDT.files;
    buildImageMeta();
    chip.remove();
    refreshSubmit();
  });
  previewList.appendChild(chip);
}

dropZone.addEventListener('click', e => {
  if (e.target.closest('.chip-remove') || e.target.closest('.file-chip')) return;
  if (e.target.closest('#mobile-action-btns')) return;
  if (IS_MOBILE) return;
  fileInput.click();
});
dropZone.addEventListener('keydown', e => { if ((e.key==='Enter'||e.key===' ') && !IS_MOBILE) fileInput.click(); });
document.getElementById('btn-take-photo').addEventListener('click', e => { e.stopPropagation(); cameraInput.value=''; cameraInput.click(); });
document.getElementById('btn-upload-gallery').addEventListener('click', e => { e.stopPropagation(); fileInput.value=''; fileInput.click(); });
fileInput.addEventListener('change',   () => { if (fileInput.files.length)   addFiles(fileInput.files); });
cameraInput.addEventListener('change', () => { if (cameraInput.files.length) addFiles(cameraInput.files); });
['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.add('drag-over'); }));
['dragleave','dragend','drop'].forEach(ev => dropZone.addEventListener(ev, () => dropZone.classList.remove('drag-over')));
dropZone.addEventListener('drop', e => { e.preventDefault(); addFiles(e.dataTransfer.files); });

/* ══════════════════════════════════════════════════════════════════
   5. CROP MODAL ENGINE
══════════════════════════════════════════════════════════════════ */
function enqueueCrop(files) {
  const wasEmpty = cropQueue.length === 0;
  cropQueue.push(...files);
  if (wasEmpty) { cropQueueTotal = cropQueue.length; openCropFor(cropQueue[0]); }
  else cropQueueTotal += files.length;
  updateCropCounter();
}

function openCropFor(file) {
  CS.file = file;
  const blobUrl = URL.createObjectURL(file);
  const img = new Image();
  img.onerror = () => { URL.revokeObjectURL(blobUrl); cropSkip(); };
  img.onload  = () => {
    URL.revokeObjectURL(blobUrl);
    CS.img = img;
    const maxW = Math.min(480, window.innerWidth - 60);
    const ar   = img.naturalHeight / img.naturalWidth;
    const cW   = maxW;
    const cH   = Math.min(Math.round(cW * ar), 430);
    const cc   = document.getElementById('crop-canvas');
    cc.width   = cW; cc.height = cH;
    let iX, iY, iW, iH;
    if (img.naturalWidth/img.naturalHeight > cW/cH) {
      iW=cW; iH=Math.round(cW/img.naturalWidth*img.naturalHeight); iX=0; iY=Math.round((cH-iH)/2);
    } else {
      iH=cH; iW=Math.round(cH/img.naturalHeight*img.naturalWidth); iY=0; iX=Math.round((cW-iW)/2);
    }
    CS.imgX=iX; CS.imgY=iY; CS.imgW=iW; CS.imgH=iH;
    CS.box = { x:iX, y:iY, w:iW, h:iH };
    updateCropCounter(); drawCrop();
    document.getElementById('crop-modal').classList.add('open');
    lucide.createIcons();
  };
  img.src = blobUrl;
}

function updateCropCounter() {
  const idx = cropQueueTotal - cropQueue.length + 1;
  document.getElementById('crop-counter').textContent = cropQueueTotal > 1 ? `Photo ${idx} of ${cropQueueTotal}` : '';
}

function drawCrop() {
  const cc  = document.getElementById('crop-canvas');
  const ctx = cc.getContext('2d');
  const { img, imgX, imgY, imgW, imgH, box } = CS;
  ctx.clearRect(0,0,cc.width,cc.height);
  ctx.fillStyle = '#080e1e'; ctx.fillRect(0,0,cc.width,cc.height);
  ctx.globalAlpha = 0.3; ctx.drawImage(img,imgX,imgY,imgW,imgH); ctx.globalAlpha = 1;
  ctx.save();
  ctx.beginPath(); ctx.rect(box.x,box.y,box.w,box.h); ctx.clip();
  ctx.drawImage(img,imgX,imgY,imgW,imgH);
  ctx.restore();
  ctx.strokeStyle='#a78bfa'; ctx.lineWidth=1.5; ctx.setLineDash([]);
  ctx.strokeRect(box.x,box.y,box.w,box.h);
  ctx.strokeStyle='rgba(167,139,250,0.2)'; ctx.lineWidth=0.75; ctx.setLineDash([4,4]);
  ctx.beginPath();
  [1/3,2/3].forEach(t => {
    ctx.moveTo(box.x+box.w*t,box.y); ctx.lineTo(box.x+box.w*t,box.y+box.h);
    ctx.moveTo(box.x,box.y+box.h*t); ctx.lineTo(box.x+box.w,box.y+box.h*t);
  });
  ctx.stroke(); ctx.setLineDash([]);
  [[box.x,box.y],[box.x+box.w,box.y],[box.x,box.y+box.h],[box.x+box.w,box.y+box.h]].forEach(([hx,hy]) => {
    ctx.beginPath(); ctx.arc(hx,hy,7,0,Math.PI*2);
    ctx.fillStyle='#6C2BD9'; ctx.fill();
    ctx.strokeStyle='#ffffff'; ctx.lineWidth=1.5; ctx.stroke();
  });
}

function cropCanvasPos(e) {
  const cc   = document.getElementById('crop-canvas');
  const rect = cc.getBoundingClientRect();
  const sx   = cc.width/rect.width, sy = cc.height/rect.height;
  const src  = e.touches ? e.touches[0] : e;
  return { x:(src.clientX-rect.left)*sx, y:(src.clientY-rect.top)*sy };
}
function hitHandle(mx,my) {
  const { box } = CS; const R=14;
  const h={ tl:[box.x,box.y], tr:[box.x+box.w,box.y], bl:[box.x,box.y+box.h], br:[box.x+box.w,box.y+box.h] };
  for (const [k,[hx,hy]] of Object.entries(h)) { if (Math.hypot(mx-hx,my-hy)<R) return k; }
  return null;
}
function hitInside(mx,my) { const {box}=CS; return mx>box.x&&mx<box.x+box.w&&my>box.y&&my<box.y+box.h; }

const cropCanvas = document.getElementById('crop-canvas');
function onCropStart(e) {
  e.preventDefault();
  const {x,y}=cropCanvasPos(e);
  const hit=hitHandle(x,y)||(hitInside(x,y)?'move':null);
  if(!hit) return;
  CS.dragging=hit; CS.dragStartX=x; CS.dragStartY=y; CS.boxAtDragStart={...CS.box};
  if(e.type==='pointerdown') cropCanvas.setPointerCapture(e.pointerId);
}
function onCropMove(e) {
  if(!CS.dragging) return; e.preventDefault();
  const {x,y}=cropCanvasPos(e);
  const dx=x-CS.dragStartX, dy=y-CS.dragStartY;
  const S=CS.boxAtDragStart, {imgX,imgY,imgW,imgH}=CS;
  const MIN=30; let b={...S};
  if (CS.dragging==='move') {
    b.x=Math.max(imgX,Math.min(imgX+imgW-b.w,b.x+dx));
    b.y=Math.max(imgY,Math.min(imgY+imgH-b.h,b.y+dy));
  } else if (CS.dragging==='br') {
    b.w=Math.max(MIN,Math.min(imgX+imgW-b.x,b.w+dx));
    b.h=Math.max(MIN,Math.min(imgY+imgH-b.y,b.h+dy));
  } else if (CS.dragging==='bl') {
    const nx=Math.max(imgX,Math.min(b.x+b.w-MIN,b.x+dx)); b.w=b.x+b.w-nx; b.x=nx;
    b.h=Math.max(MIN,Math.min(imgY+imgH-b.y,b.h+dy));
  } else if (CS.dragging==='tr') {
    b.w=Math.max(MIN,Math.min(imgX+imgW-b.x,b.w+dx));
    const ny=Math.max(imgY,Math.min(b.y+b.h-MIN,b.y+dy)); b.h=b.y+b.h-ny; b.y=ny;
  } else if (CS.dragging==='tl') {
    const nx=Math.max(imgX,Math.min(b.x+b.w-MIN,b.x+dx)); b.w=b.x+b.w-nx; b.x=nx;
    const ny=Math.max(imgY,Math.min(b.y+b.h-MIN,b.y+dy)); b.h=b.y+b.h-ny; b.y=ny;
  }
  CS.box=b; drawCrop();
}
function onCropEnd() { CS.dragging=null; }
cropCanvas.addEventListener('pointerdown', onCropStart);
cropCanvas.addEventListener('pointermove', onCropMove);
cropCanvas.addEventListener('pointerup',   onCropEnd);
cropCanvas.addEventListener('pointercancel', onCropEnd);
cropCanvas.addEventListener('touchstart', onCropStart, {passive:false});
cropCanvas.addEventListener('touchmove',  onCropMove,  {passive:false});
cropCanvas.addEventListener('touchend',   onCropEnd);

function cropApply() {
  const {img,box,imgX,imgY,imgW,imgH,file}=CS;
  const scaleX=img.naturalWidth/imgW, scaleY=img.naturalHeight/imgH;
  const srcX=Math.max(0,(box.x-imgX)*scaleX);
  const srcY=Math.max(0,(box.y-imgY)*scaleY);
  const srcW=Math.min(img.naturalWidth-srcX,  box.w*scaleX);
  const srcH=Math.min(img.naturalHeight-srcY, box.h*scaleY);
  const off=document.createElement('canvas');
  off.width=Math.round(srcW); off.height=Math.round(srcH);
  off.getContext('2d').drawImage(img,srcX,srcY,srcW,srcH,0,0,off.width,off.height);
  off.toBlob(blob => {
    const fname=file.name.replace(/\.[^.]+$/,'')+'_cropped.jpg';
    addSingleFile(blob ? new File([blob],fname,{type:'image/jpeg'}) : file);
    cropNext();
  }, 'image/jpeg', 0.92);
}
function cropSkip()      { addSingleFile(CS.file); cropNext(); }
function cropCancelAll() { cropQueue=[]; closeCropModal(); }
function cropNext()      { cropQueue.shift(); if (cropQueue.length>0) openCropFor(cropQueue[0]); else closeCropModal(); }
function closeCropModal(){ document.getElementById('crop-modal').classList.remove('open'); CS.dragging=null; }
document.getElementById('crop-apply-btn').addEventListener('click',  cropApply);
document.getElementById('crop-skip-btn').addEventListener('click',   cropSkip);
document.getElementById('crop-cancel-btn').addEventListener('click', cropCancelAll);
document.getElementById('crop-backdrop').addEventListener('click',   cropCancelAll);
document.addEventListener('keydown', e => {
  if (e.key==='Escape' && document.getElementById('crop-modal').classList.contains('open')) cropCancelAll();
});

