    [`<i data-lucide="book" class="w-3 h-3"></i>`, meta.subject],
    [`<i data-lucide="target" class="w-3 h-3"></i>`, `${scored}/${maxMk} marks`],
  ];
  if (conf!==null) {
    const pct=Math.round(conf*100);
    const cc=pct>=80?'#4ade80':pct>=55?'#fbbf24':'#f87171';
    chipDefs.push([`<i data-lucide="activity" class="w-3 h-3" style="color:${cc};"></i>`,`AI Confidence: ${pct}%`]);
  }
  chipDefs.forEach(([ic,txt]) => {
    const c=document.createElement('span'); c.className='meta-chip'; c.innerHTML=`${ic} ${txt}`; chips.appendChild(c);
  });
  lucide.createIcons();

  /* Problem statement — use renderMathSafe for mixed text+LaTeX */
  if (meta.problem_statement) {
    const psWrap = document.getElementById('ps-wrapper');
    const psEl   = document.getElementById('problem-statement-banner');
    if (psWrap && psEl) {
      renderMathSafe(psEl, meta.problem_statement);
      psWrap.style.display = '';
    }
  }

  /* Summary */
  document.getElementById('eval-summary').textContent = meta.evaluation_summary;

  /* Rubric bars */
  const rubricData = rubric || [
    { label:'Conceptual Accuracy', scored:scored*0.6, total:maxMk*0.6, color:'#a78bfa' },
    { label:'Step Completeness',   scored:scored*0.4, total:maxMk*0.4, color:'#fbbf24' },
  ];
  const rbc = document.getElementById('rubric-bars');
  rbc.innerHTML = '';
  rubricData.forEach(r => {
    const pct = Math.min(100, Math.round((r.scored/r.total)*100));
    const row = document.createElement('div');
    row.innerHTML = `
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-medium text-slate-600 dark:text-gray-300">${r.label}</span>
        <span class="text-xs font-bold" style="color:${r.color};">${r.scored}/${r.total}</span>
      </div>
      <div class="rbar-track">
        <div class="rbar-fill" data-w="${pct}%" style="width:0%;background:${r.color};"></div>
      </div>`;
    rbc.appendChild(row);
  });
  setTimeout(() => rbc.querySelectorAll('.rbar-fill').forEach(b => { b.style.width=b.dataset.w; }), 120);

  setupAugmentedCanvas(data.imageUrls, visual_annotations);
  renderSteps(perfect_marker_answer);

  gsap.from('.gsap-r', { y:28, opacity:0, stagger:0.12, duration:0.7, ease:'power2.out' });
  lucide.createIcons();
  window.scrollTo({ top:0, behavior:'smooth' });
}

/* ══════════════════════════════════════════════════════════════════
   9. ANNOTATION SCHEMA VALIDATION
══════════════════════════════════════════════════════════════════ */
function normalisePayload(raw) {
  if (!raw) return { version:SCHEMA_VERSION, annotations:[] };
  if (!Array.isArray(raw) && Array.isArray(raw.annotations))
    return { version:raw.version||SCHEMA_VERSION, annotations:raw.annotations };
  if (Array.isArray(raw))
    return { version:SCHEMA_VERSION, annotations:raw };
  if (Array.isArray(raw.visual_annotations))
    return { version:raw.version||SCHEMA_VERSION, annotations:raw.visual_annotations };
  return { version:SCHEMA_VERSION, annotations:[] };
}

function validateAnnotations(annotations) {
  const valid=[]; const skipped=[];
  (annotations||[]).forEach((a,idx) => {
    if (!VALID_ANNO_TYPES.has(a.annotation_type)) { skipped.push({idx,reason:`unknown type "${a.annotation_type}"`}); return; }
    if (!Array.isArray(a.box_2d)||a.box_2d.length!==4||a.box_2d.some(v=>typeof v!=='number'&&isNaN(Number(v))))
      { skipped.push({idx,reason:'invalid box_2d'}); return; }
    if (typeof a.confidence==='number'&&a.confidence<CONFIDENCE_THRESHOLD)
      { skipped.push({idx,reason:`confidence ${a.confidence} below threshold`}); return; }
    let [y0,x0,y1,x1]=a.box_2d.map(v=>Math.max(0,Math.min(1000,Number(v))));
    if (y0>y1) [y0,y1]=[y1,y0];
    if (x0>x1) [x0,x1]=[x1,x0];
    if ((y1-y0)<10) y1=y0+10;
    if ((x1-x0)<10) x1=x0+10;
    a.box_2d=[y0,x0,y1,x1];
    valid.push(a);
  });
  if (skipped.length) console.warn('[BoardAlgo] Skipped annotations:', skipped);
  return valid;
}

/* ══════════════════════════════════════════════════════════════════
   10. KONVA ANNOTATION ENGINE
   ─────────────────────────────────────────────────────────────────
   ALL coordinate math uses the same 0-1000 grid → rendered pixel
   mapping. PDF uses identical mapping at natural image resolution.
══════════════════════════════════════════════════════════════════ */
function setupAugmentedCanvas(imageUrls, rawAnnotations) {
  globalImageUrls   = imageUrls || [];
  const payload     = normalisePayload(rawAnnotations);
  globalAnnotations = validateAnnotations(payload.annotations);
  currentImageIndex = 0;

  const pageNav = document.getElementById('page-nav');
  if (globalImageUrls.length > 1) pageNav.classList.remove('hidden');
  else pageNav.classList.add('hidden');
  lucide.createIcons();

  renderCurrentPage();
}

function renderCurrentPage() {
  const img = document.getElementById('student-img');
  document.getElementById('page-indicator').textContent =
    `Page ${currentImageIndex+1} / ${Math.max(1,globalImageUrls.length)}`;

  // For single-page docs, show all annotations (no page_number filter needed)
  currentAnnotations = globalAnnotations.filter(a =>
    globalImageUrls.length <= 1 ? true : a.page_number === (currentImageIndex+1)
  );

  img.crossOrigin = 'anonymous';
  img.src = globalImageUrls[currentImageIndex] || DEMO_IMAGE_URL;
  img.onload = () => buildKonva();
}

function prevPage() { if (currentImageIndex>0) { currentImageIndex--; renderCurrentPage(); } }
function nextPage() { if (currentImageIndex<globalImageUrls.length-1) { currentImageIndex++; renderCurrentPage(); } }

function buildKonva() {
  const img      = document.getElementById('student-img');
  const wrapper  = document.getElementById('canvas-wrapper');
  const konvaDiv = document.getElementById('konva-container');

  const rw = img.offsetWidth  || wrapper.offsetWidth  || 600;
  const rh = img.offsetHeight || Math.round(rw*1.4);

  if (konvaStage) { konvaStage.destroy(); konvaStage=null; }
  errorGroup=null; markGroup=null;

  konvaDiv.style.width  = rw+'px';
  konvaDiv.style.height = rh+'px';

  konvaStage = new Konva.Stage({ container:'konva-container', width:rw, height:rh });
  konvaLayer = new Konva.Layer();
  errorGroup = new Konva.Group({ name:'errors' });
  markGroup  = new Konva.Group({ name:'marks'  });
  konvaLayer.add(errorGroup, markGroup);
  konvaStage.add(konvaLayer);

  if (annotationsVisible) drawAnnotations(rw, rh);
}

/**
 * coordsToPixels — converts a 0-1000 box_2d to pixel coords.
 * This exact function is mirrored in drawAnnotations2DCanvas.
 */
function coordsToPixels(box_2d, W, H) {
  const [yn,xn,ym,xm] = box_2d;
  return {
    px: (xn/1000)*W,
    py: (yn/1000)*H,
    pw: ((xm-xn)/1000)*W,
    ph: ((ym-yn)/1000)*H,
    cx: ((xn+xm)/2000)*W,
    cy: ((yn+ym)/2000)*H,
  };
}

function drawAnnotations(rw, rh) {
  if (errorGroup) errorGroup.destroyChildren();
  if (markGroup)  markGroup.destroyChildren();

  const sw = n => Math.max(1.5, rw*n);
  const fs = n => Math.max(10, Math.min(20, rw*n));

  currentAnnotations.forEach(anno => {
    const {px,py,pw,ph,cx,cy} = coordsToPixels(anno.box_2d, rw, rh);

    const isRed   = anno.color==='red';
    const isGreen = anno.color==='green';
    const strokeC = isRed?'rgba(239,68,68,0.88)':isGreen?'rgba(22,163,74,0.92)':'rgba(108,43,217,0.88)';
    const fillC   = isRed?'rgba(239,68,68,0.09)':isGreen?'rgba(22,163,74,0.10)':'rgba(108,43,217,0.09)';
    const glowC   = isRed?'#EF4444':isGreen?'#16A34A':'#6C2BD9';
    const target  = isGreen ? markGroup : errorGroup;

    if (anno.annotation_type==='tick') {
      const r=Math.max(14,Math.min(28,Math.min(pw,ph)/2));
      const halo=new Konva.Circle({x:cx,y:cy,radius:r+4,fill:'rgba(22,163,74,0.12)',stroke:'rgba(22,163,74,0.35)',strokeWidth:1});
      const bg  =new Konva.Circle({x:cx,y:cy,radius:r,fill:'rgba(22,163,74,0.82)',shadowColor:'#16A34A',shadowBlur:10,shadowOpacity:0.5});
      const ts  =r*0.55;
      const tick=new Konva.Line({points:[cx-ts*0.6,cy,cx-ts*0.1,cy+ts*0.6,cx+ts*0.7,cy-ts*0.55],
        stroke:'#ffffff',strokeWidth:sw(0.008)+1.5,lineCap:'round',lineJoin:'round'});
      target.add(halo,bg,tick);
      if(anno.comment) addTooltipBehaviour(bg,anno.comment,cx,py);

    } else if (anno.annotation_type==='cross') {
      const r=Math.max(14,Math.min(28,Math.min(pw,ph)/2));
      const halo=new Konva.Circle({x:cx,y:cy,radius:r+4,fill:'rgba(239,68,68,0.1)',stroke:'rgba(239,68,68,0.3)',strokeWidth:1});
      const bg  =new Konva.Circle({x:cx,y:cy,radius:r,fill:'rgba(239,68,68,0.8)',shadowColor:'#EF4444',shadowBlur:10,shadowOpacity:0.5});
      const arm=r*0.52;
      const l1=new Konva.Line({points:[cx-arm,cy-arm,cx+arm,cy+arm],stroke:'#ffffff',strokeWidth:sw(0.007)+1.5,lineCap:'round'});
      const l2=new Konva.Line({points:[cx+arm,cy-arm,cx-arm,cy+arm],stroke:'#ffffff',strokeWidth:sw(0.007)+1.5,lineCap:'round'});
      target.add(halo,bg,l1,l2);
      if(anno.comment) addTooltipBehaviour(bg,anno.comment,cx,py);

    } else if (anno.annotation_type==='circle') {
      const ellipse=new Konva.Ellipse({x:cx,y:cy,
        radiusX:Math.max(8,pw/2),radiusY:Math.max(8,ph/2),
        stroke:strokeC,strokeWidth:sw(0.005),dash:[7,4],fill:fillC,
        shadowColor:glowC,shadowBlur:10,shadowOpacity:0.3});
      target.add(ellipse);
      addTooltipBehaviour(ellipse,anno.comment,cx,py);

    } else if (anno.annotation_type==='text' && anno.comment) {
      const label=new Konva.Label({x:px,y:py});
      label.add(new Konva.Tag({fill:isRed?'rgba(239,68,68,0.92)':'rgba(22,163,74,0.92)',
        cornerRadius:7,shadowColor:glowC,shadowBlur:9,shadowOpacity:0.45}));
      label.add(new Konva.Text({text:anno.comment,fontSize:fs(0.022),
        fontFamily:'Poppins, sans-serif',fontStyle:'bold',fill:'#ffffff',padding:6}));
      target.add(label);
      if (ph>4) {
        const ay1=py+fs(0.022)+18, ay2=py+ph*0.85;
        if (ay2>ay1) target.add(new Konva.Arrow({points:[px+10,ay1,px+10,ay2],
          stroke:strokeC,fill:strokeC,strokeWidth:1.5,pointerLength:7,pointerWidth:6,dash:[4,3]}));
      }

    } else if (anno.annotation_type==='step_mark' && anno.comment) {
      const isDed=isRed||String(anno.comment).startsWith('-');
      const bgF=isDed?'rgba(239,68,68,0.88)':'rgba(22,163,74,0.88)';
      const shd=isDed?'#EF4444':'#16A34A';
      const fontSize=fs(0.030);
      const radius=Math.max(18,Math.min(36,Math.min(pw,ph)/2));
      const circle=new Konva.Circle({x:cx,y:cy,radius,fill:bgF,
        shadowColor:shd,shadowBlur:14,shadowOpacity:0.55,
        stroke:isDed?'rgba(239,68,68,0.4)':'rgba(22,163,74,0.4)',strokeWidth:1.5});
      const label=new Konva.Text({text:anno.comment,fontSize,
        fontFamily:'Poppins, sans-serif',fontStyle:'bold',fill:'#ffffff',
        align:'center',verticalAlign:'middle',width:radius*2,height:radius*2,x:cx-radius,y:cy-radius});
      const rule=new Konva.Line({points:[cx-radius-6,cy,cx-radius-30,cy],
        stroke:isDed?'rgba(239,68,68,0.35)':'rgba(22,163,74,0.35)',strokeWidth:1.2,dash:[3,3]});
      target.add(rule,circle,label);
    }
  });

  if (errorGroup) errorGroup.visible(errorsVisible);
  if (markGroup)  markGroup.visible(marksVisible);
  konvaLayer.draw();
}

function addTooltipBehaviour(shape, comment, x, y) {
  if (!comment) return;
  const tooltip = document.getElementById('anno-tooltip');
  shape.on('mouseenter touchstart', () => {
    tooltip.textContent=comment; tooltip.style.left=x+'px'; tooltip.style.top=(y-32)+'px';
    tooltip.classList.add('show');
  });
  shape.on('mouseleave touchend', () => tooltip.classList.remove('show'));
}

function toggleAnnotations() {
  annotationsVisible=!annotationsVisible;
  const btn=document.getElementById('btn-toggle-annot');
  if (annotationsVisible) { drawAnnotations(konvaStage.width(),konvaStage.height()); btn.innerHTML='<i data-lucide="eye" class="w-3.5 h-3.5"></i> All: ON'; }
  else { if(errorGroup)errorGroup.visible(false); if(markGroup)markGroup.visible(false); konvaLayer.draw(); btn.innerHTML='<i data-lucide="eye-off" class="w-3.5 h-3.5"></i> All: OFF'; }
  lucide.createIcons();
}
function toggleErrors() {
  if (!errorGroup||!konvaStage) return;
  errorsVisible=!errorsVisible; errorGroup.visible(errorsVisible); konvaLayer.draw();
  const btn=document.getElementById('btn-toggle-errors');
  btn.innerHTML=`<i data-lucide="x-circle" class="w-3.5 h-3.5" style="color:#f87171;"></i> Errors: ${errorsVisible?'ON':'OFF'}`;
  btn.style.opacity=errorsVisible?'1':'0.5'; lucide.createIcons();
}
function toggleMarks() {
  if (!markGroup||!konvaStage) return;
  marksVisible=!marksVisible; markGroup.visible(marksVisible); konvaLayer.draw();
  const btn=document.getElementById('btn-toggle-marks');
  btn.innerHTML=`<i data-lucide="check-circle" class="w-3.5 h-3.5" style="color:#4ade80;"></i> Marks: ${marksVisible?'ON':'OFF'}`;
  btn.style.opacity=marksVisible?'1':'0.5'; lucide.createIcons();
}
function zoomImage(factor) {
  currentZoom=Math.min(4,Math.max(0.5,currentZoom*factor));
  const img=document.getElementById('student-img');
  img.style.transformOrigin='top left';
  img.style.transform=`scale(${currentZoom})`;
  document.getElementById('canvas-wrapper').style.overflow=currentZoom>1?'auto':'hidden';
}
function resetZoom() {
  currentZoom=1;
  document.getElementById('student-img').style.transform='';
  document.getElementById('canvas-wrapper').style.overflow='hidden';
}

const resizeObserver=new ResizeObserver(()=>{
  if(konvaStage&&document.getElementById('result-section').style.display!=='none')
    requestAnimationFrame(buildKonva);
