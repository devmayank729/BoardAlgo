/* ══════════════════════════════════════════════════════════════════
   7. KATEX HELPERS
   ─────────────────────────────────────────────────────────────────
   renderMathInElement is the ONLY reliable way to handle mixed
   text + LaTeX. We use KaTeX auto-render for all displayed content.
══════════════════════════════════════════════════════════════════ */
const KATEX_OPTS = {
  delimiters: [
    { left: '$$', right: '$$', display: true  },
    { left: '$',  right: '$',  display: false },
    { left: '\\[', right: '\\]', display: true  },
    { left: '\\(', right: '\\)', display: false },
  ],
  throwOnError: false,
  trust: true,
  strict: false,
};

/**
 * renderMathSafe — sets text content and runs auto-render.
 * Handles both plain text and strings with LaTeX delimiters.
 * This is the single correct way to render math in this app.
 */
function renderMathSafe(el, text) {
  if (!text) { el.innerHTML = ''; return; }
  // Escape HTML entities in raw text before inserting
  const escaped = text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    // But undo escaping for LaTeX delimiters ($ \[ etc stay as-is)
    .replace(/\\\$/g,'\\$');
  el.innerHTML = escaped;
  // Run KaTeX auto-render over the element
  if (typeof renderMathInElement === 'function') {
    renderMathInElement(el, KATEX_OPTS);
  }
}

/**
 * renderLatexBlock — renders a pure LaTeX string in display mode.
 * Used for .katex-block divs in steps.
 */
function renderLatexBlock(el, latex) {
  if (!latex) return;
  try {
    katex.render(latex, el, { displayMode:true, throwOnError:false, trust:true, strict:false });
  } catch(err) {
    el.textContent = latex;
    el.style.fontFamily = 'monospace';
    el.style.color = '#6C2BD9';
  }
}

/**
 * latexToHTMLString — for embedding rendered KaTeX in PDF HTML.
 */
function latexToHTMLString(latex, display=true) {
  if (!latex) return '';
  try {
    return katex.renderToString(latex, { displayMode:display, throwOnError:false, trust:true, strict:false });
  } catch(e) {
    return `<code style="color:#6C2BD9;font-family:'Courier New',monospace;font-size:12px;">${latex}</code>`;
  }
}

/* ══════════════════════════════════════════════════════════════════
   8. RESULT RENDERER
══════════════════════════════════════════════════════════════════ */
function renderResult(data) {
