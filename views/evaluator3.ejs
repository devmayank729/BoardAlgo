      { annotation_type:"step_mark", color:"green", box_2d:[170,840,230,960], comment:"+2" },
      { annotation_type:"circle",    color:"red",   box_2d:[430,180,510,420], comment:"Sign error here" },
      { annotation_type:"text",      color:"red",   box_2d:[360,60,420,200],  comment:"Sign Error! −0.5" },
      { annotation_type:"step_mark", color:"red",   box_2d:[430,840,490,960], comment:"-½" },
