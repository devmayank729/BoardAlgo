document.getElementById('btn-download').addEventListener('click', async () => {
  const btn=document.getElementById('btn-download');
  const orig=btn.innerHTML;
  btn.innerHTML='<svg class="animate-spin w-3.5 h-3.5 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Preparing…';
  btn.disabled=true;
  await generatePDF();
  btn.innerHTML=orig; btn.disabled=false; lucide.createIcons();
});

document.getElementById('btn-share').addEventListener('click', async () => {
  if (navigator.share) {
    try { await navigator.share({title:'My BoardAlgo Result',url:window.location.href}); } catch(_){}
  } else {
    await navigator.clipboard.writeText(window.location.href);
    const btn=document.getElementById('btn-share');
    btn.innerHTML='<i data-lucide="check" class="w-3.5 h-3.5"></i> Copied!';
    lucide.createIcons();
    setTimeout(()=>{ btn.innerHTML='<i data-lucide="share-2" class="w-3.5 h-3.5"></i> Share'; lucide.createIcons(); },2000);
  }
});

